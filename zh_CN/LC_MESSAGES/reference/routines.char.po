msgid "String operations"
msgstr ""

#: ../../../reference/routines.char.rst:8
msgid ""
"The `numpy.char` module provides a set of vectorized string operations for "
"arrays of type `numpy.str_` or `numpy.bytes_`. For example"
msgstr ""

#: ../../../reference/routines.char.rst:16
msgid "The methods in this module are based on the methods in :py:mod:`String`"
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ":py:obj:`add <numpy.char.add>`\\ \\(x1\\, x2\\)"
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ""
"Return element-wise string concatenation for two arrays of str or unicode."
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ":py:obj:`multiply <numpy.char.multiply>`\\ \\(a\\, i\\)"
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid "Return (a * i), that is string multiple concatenation, element-wise."
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ":py:obj:`mod <numpy.char.mod>`\\ \\(a\\, values\\)"
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ""
"Return (a % i), that is pre-Python 2.6 string formatting (interpolation), "
"element-wise for a pair of array_likes of str or unicode."
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ":py:obj:`capitalize <numpy.char.capitalize>`\\ \\(a\\)"
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ""
"Return a copy of `a` with only the first character of each element "
"capitalized."
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ""
":py:obj:`center <numpy.char.center>`\\ \\(a\\, width\\[\\, fillchar\\]\\)"
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ""
"Return a copy of `a` with its elements centered in a string of length "
"`width`."
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ""
":py:obj:`decode <numpy.char.decode>`\\ \\(a\\[\\, encoding\\, errors\\]\\)"
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid "Calls ``bytes.decode`` element-wise."
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ""
":py:obj:`encode <numpy.char.encode>`\\ \\(a\\[\\, encoding\\, errors\\]\\)"
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid "Calls `str.encode` element-wise."
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ":py:obj:`expandtabs <numpy.char.expandtabs>`\\ \\(a\\[\\, tabsize\\]\\)"
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ""
"Return a copy of each string element where all tab characters are replaced "
"by one or more spaces."
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ":py:obj:`join <numpy.char.join>`\\ \\(sep\\, seq\\)"
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ""
"Return a string which is the concatenation of the strings in the sequence "
"`seq`."
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ":py:obj:`ljust <numpy.char.ljust>`\\ \\(a\\, width\\[\\, fillchar\\]\\)"
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ""
"Return an array with the elements of `a` left-justified in a string of "
"length `width`."
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ":py:obj:`lower <numpy.char.lower>`\\ \\(a\\)"
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid "Return an array with the elements converted to lowercase."
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ":py:obj:`lstrip <numpy.char.lstrip>`\\ \\(a\\[\\, chars\\]\\)"
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ""
"For each element in `a`, return a copy with the leading characters removed."
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ":py:obj:`partition <numpy.char.partition>`\\ \\(a\\, sep\\)"
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid "Partition each element in `a` around `sep`."
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ""
":py:obj:`replace <numpy.char.replace>`\\ \\(a\\, old\\, new\\[\\, count\\]\\)"
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ""
"For each element in `a`, return a copy of the string with all occurrences of "
"substring `old` replaced by `new`."
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ":py:obj:`rjust <numpy.char.rjust>`\\ \\(a\\, width\\[\\, fillchar\\]\\)"
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ""
"Return an array with the elements of `a` right-justified in a string of "
"length `width`."
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ":py:obj:`rpartition <numpy.char.rpartition>`\\ \\(a\\, sep\\)"
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid "Partition (split) each element around the right-most separator."
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ":py:obj:`rsplit <numpy.char.rsplit>`\\ \\(a\\[\\, sep\\, maxsplit\\]\\)"
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ""
"For each element in `a`, return a list of the words in the string, using "
"`sep` as the delimiter string."
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ":py:obj:`rstrip <numpy.char.rstrip>`\\ \\(a\\[\\, chars\\]\\)"
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ""
"For each element in `a`, return a copy with the trailing characters removed."
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ":py:obj:`split <numpy.char.split>`\\ \\(a\\[\\, sep\\, maxsplit\\]\\)"
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ""
":py:obj:`splitlines <numpy.char.splitlines>`\\ \\(a\\[\\, keepends\\]\\)"
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ""
"For each element in `a`, return a list of the lines in the element, breaking "
"at line boundaries."
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ":py:obj:`strip <numpy.char.strip>`\\ \\(a\\[\\, chars\\]\\)"
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ""
"For each element in `a`, return a copy with the leading and trailing "
"characters removed."
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ":py:obj:`swapcase <numpy.char.swapcase>`\\ \\(a\\)"
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ""
"Return element-wise a copy of the string with uppercase characters converted "
"to lowercase and vice versa."
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ":py:obj:`title <numpy.char.title>`\\ \\(a\\)"
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid "Return element-wise title cased version of string or unicode."
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ""
":py:obj:`translate <numpy.char.translate>`\\ \\(a\\, table\\[\\, "
"deletechars\\]\\)"
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ""
"For each element in `a`, return a copy of the string where all characters "
"occurring in the optional argument `deletechars` are removed, and the "
"remaining characters have been mapped through the given translation table."
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ":py:obj:`upper <numpy.char.upper>`\\ \\(a\\)"
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid "Return an array with the elements converted to uppercase."
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid ":py:obj:`zfill <numpy.char.zfill>`\\ \\(a\\, width\\)"
msgstr ""

#: ../../../reference/routines.char.rst:50:<autosummary>:1
msgid "Return the numeric string left-filled with zeros"
msgstr ""

#: ../../../reference/routines.char.rst:52
msgid "Comparison"
msgstr ""

#: ../../../reference/routines.char.rst:54
msgid ""
"Unlike the standard numpy comparison operators, the ones in the `char` "
"module strip trailing whitespace characters before performing the comparison."
msgstr ""

#: ../../../reference/routines.char.rst:68:<autosummary>:1
msgid ":py:obj:`equal <numpy.char.equal>`\\ \\(x1\\, x2\\)"
msgstr ""

#: ../../../reference/routines.char.rst:68:<autosummary>:1
msgid "Return (x1 == x2) element-wise."
msgstr ""

#: ../../../reference/routines.char.rst:68:<autosummary>:1
msgid ":py:obj:`not_equal <numpy.char.not_equal>`\\ \\(x1\\, x2\\)"
msgstr ""

#: ../../../reference/routines.char.rst:68:<autosummary>:1
msgid "Return (x1 != x2) element-wise."
msgstr ""

#: ../../../reference/routines.char.rst:68:<autosummary>:1
msgid ":py:obj:`greater_equal <numpy.char.greater_equal>`\\ \\(x1\\, x2\\)"
msgstr ""

#: ../../../reference/routines.char.rst:68:<autosummary>:1
msgid "Return (x1 >= x2) element-wise."
msgstr ""

#: ../../../reference/routines.char.rst:68:<autosummary>:1
msgid ":py:obj:`less_equal <numpy.char.less_equal>`\\ \\(x1\\, x2\\)"
msgstr ""

#: ../../../reference/routines.char.rst:68:<autosummary>:1
msgid "Return (x1 <= x2) element-wise."
msgstr ""

#: ../../../reference/routines.char.rst:68:<autosummary>:1
msgid ":py:obj:`greater <numpy.char.greater>`\\ \\(x1\\, x2\\)"
msgstr ""

#: ../../../reference/routines.char.rst:68:<autosummary>:1
msgid "Return (x1 > x2) element-wise."
msgstr ""

#: ../../../reference/routines.char.rst:68:<autosummary>:1
msgid ":py:obj:`less <numpy.char.less>`\\ \\(x1\\, x2\\)"
msgstr ""

#: ../../../reference/routines.char.rst:68:<autosummary>:1
msgid "Return (x1 < x2) element-wise."
msgstr ""

#: ../../../reference/routines.char.rst:68:<autosummary>:1
msgid ""
":py:obj:`compare_chararrays <numpy.char.compare_chararrays>`\\ \\(a1\\, "
"a2\\, cmp\\, rstrip\\)"
msgstr ""

#: ../../../reference/routines.char.rst:68:<autosummary>:1
msgid ""
"Performs element-wise comparison of two string arrays using the comparison "
"operator specified by `cmp_op`."
msgstr ""

#: ../../../reference/routines.char.rst:70
msgid "String information"
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ""
":py:obj:`count <numpy.char.count>`\\ \\(a\\, sub\\[\\, start\\, end\\]\\)"
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ""
"Returns an array with the number of non-overlapping occurrences of substring "
"`sub` in the range [`start`, `end`]."
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ""
":py:obj:`endswith <numpy.char.endswith>`\\ \\(a\\, suffix\\[\\, start\\, "
"end\\]\\)"
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ""
"Returns a boolean array which is `True` where the string element in `a` ends "
"with `suffix`, otherwise `False`."
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ":py:obj:`find <numpy.char.find>`\\ \\(a\\, sub\\[\\, start\\, end\\]\\)"
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ""
"For each element, return the lowest index in the string where substring "
"`sub` is found."
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ""
":py:obj:`index <numpy.char.index>`\\ \\(a\\, sub\\[\\, start\\, end\\]\\)"
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid "Like `find`, but raises `ValueError` when the substring is not found."
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ":py:obj:`isalpha <numpy.char.isalpha>`\\ \\(a\\)"
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ""
"Returns true for each element if all characters in the string are alphabetic "
"and there is at least one character, false otherwise."
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ":py:obj:`isalnum <numpy.char.isalnum>`\\ \\(a\\)"
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ""
"Returns true for each element if all characters in the string are "
"alphanumeric and there is at least one character, false otherwise."
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ":py:obj:`isdecimal <numpy.char.isdecimal>`\\ \\(a\\)"
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ""
"For each element, return True if there are only decimal characters in the "
"element."
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ":py:obj:`isdigit <numpy.char.isdigit>`\\ \\(a\\)"
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ""
"Returns true for each element if all characters in the string are digits and "
"there is at least one character, false otherwise."
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ":py:obj:`islower <numpy.char.islower>`\\ \\(a\\)"
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ""
"Returns true for each element if all cased characters in the string are "
"lowercase and there is at least one cased character, false otherwise."
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ":py:obj:`isnumeric <numpy.char.isnumeric>`\\ \\(a\\)"
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ""
"For each element, return True if there are only numeric characters in the "
"element."
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ":py:obj:`isspace <numpy.char.isspace>`\\ \\(a\\)"
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ""
"Returns true for each element if there are only whitespace characters in the "
"string and there is at least one character, false otherwise."
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ":py:obj:`istitle <numpy.char.istitle>`\\ \\(a\\)"
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ""
"Returns true for each element if the element is a titlecased string and "
"there is at least one character, false otherwise."
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ":py:obj:`isupper <numpy.char.isupper>`\\ \\(a\\)"
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ""
"Return true for each element if all cased characters in the string are "
"uppercase and there is at least one character, false otherwise."
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ""
":py:obj:`rfind <numpy.char.rfind>`\\ \\(a\\, sub\\[\\, start\\, end\\]\\)"
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ""
"For each element in `a`, return the highest index in the string where "
"substring `sub` is found, such that `sub` is contained within [`start`, "
"`end`]."
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ""
":py:obj:`rindex <numpy.char.rindex>`\\ \\(a\\, sub\\[\\, start\\, end\\]\\)"
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ""
"Like `rfind`, but raises `ValueError` when the substring `sub` is not found."
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ""
":py:obj:`startswith <numpy.char.startswith>`\\ \\(a\\, prefix\\[\\, start\\, "
"end\\]\\)"
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ""
"Returns a boolean array which is `True` where the string element in `a` "
"starts with `prefix`, otherwise `False`."
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid ":py:obj:`str_len <numpy.char.str_len>`\\ \\(a\\)"
msgstr ""

#: ../../../reference/routines.char.rst:92:<autosummary>:1
msgid "Return len(a) element-wise."
msgstr ""

