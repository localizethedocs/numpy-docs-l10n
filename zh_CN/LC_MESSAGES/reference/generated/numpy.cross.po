msgid "numpy.cross"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.cross:2
msgid "Return the cross product of two (arrays of) vectors."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.cross:4
msgid ""
"The cross product of `a` and `b` in :math:`R^3` is a vector perpendicular to "
"both `a` and `b`.  If `a` and `b` are arrays of vectors, the vectors are "
"defined by the last axis of `a` and `b` by default, and these axes must have "
"3 dimensions."
msgstr ""

