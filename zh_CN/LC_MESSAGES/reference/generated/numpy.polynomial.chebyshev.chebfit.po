#: ../../../reference/generated/numpy.polynomial.chebyshev.chebfit.rst:4
msgid "numpy.polynomial.chebyshev.chebfit"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/chebyshev.py:docstring
#: of numpy.polynomial.chebyshev.chebfit:2
msgid "Least squares fit of Chebyshev series to data."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/chebyshev.py:docstring
#: of numpy.polynomial.chebyshev.chebfit:4
msgid ""
"Return the coefficients of a Chebyshev series of degree `deg` that is the "
"least squares fit to the data values `y` given at points `x`. If `y` is 1-D "
"the returned coefficients will also be 1-D. If `y` is 2-D multiple fits are "
"done, one for each column of `y`, and the resulting coefficients are stored "
"in the corresponding columns of a 2-D return. The fitted polynomial(s) are "
"in the form"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/chebyshev.py:docstring
#: of numpy.polynomial.chebyshev.chebfit:11
msgid ""
"p(x) = c_0 + c_1 * T_1(x) + ... + c_n * T_n(x),\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/chebyshev.py:docstring
#: of numpy.polynomial.chebyshev.chebfit:13
msgid "where `n` is `deg`."
msgstr ""

