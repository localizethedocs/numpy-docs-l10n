#: of numpy.polynomial.chebyshev.chebfit:23
msgid "**y**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/chebyshev.py:docstring
#: of numpy.polynomial.chebyshev.chebfit:-1
msgid "array_like, shape (M,) or (M, K)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/chebyshev.py:docstring
#: of numpy.polynomial.chebyshev.chebfit:21
msgid ""
"y-coordinates of the sample points. Several data sets of sample points "
"sharing the same x-coordinates can be fitted at once by passing in a 2D-"
"array that contains one dataset per column."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/chebyshev.py:docstring
#: of numpy.polynomial.chebyshev.chebfit:29
msgid "**deg**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/chebyshev.py:docstring
#: of numpy.polynomial.chebyshev.chebfit:-1
msgid "int or 1-D array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/chebyshev.py:docstring
#: of numpy.polynomial.chebyshev.chebfit:26
msgid ""
"Degree(s) of the fitting polynomials. If `deg` is a single integer, all "
"terms up to and including the `deg`'th term are included in the fit. For "
"NumPy versions >= 1.11.0 a list of integers specifying the degrees of the "
"terms to include may be used instead."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/chebyshev.py:docstring
#: of numpy.polynomial.chebyshev.chebfit:35
msgid "**rcond**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/chebyshev.py:docstring
#: of numpy.polynomial.chebyshev.chebfit:-1
msgid "float, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/chebyshev.py:docstring
#: of numpy.polynomial.chebyshev.chebfit:32
msgid ""
"Relative condition number of the fit. Singular values smaller than this "
"relative to the largest singular value will be ignored. The default value is "
"``len(x)*eps``, where eps is the relative precision of the float type, about "
"2e-16 in most cases."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/chebyshev.py:docstring
#: of numpy.polynomial.chebyshev.chebfit:40
msgid "**full**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/chebyshev.py:docstring
#: of numpy.polynomial.chebyshev.chebfit:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/chebyshev.py:docstring
#: of numpy.polynomial.chebyshev.chebfit:38
msgid ""
"Switch determining nature of return value. When it is False (the default) "
"just the coefficients are returned, when True diagnostic information from "
"the singular value decomposition is also returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/chebyshev.py:docstring
#: of numpy.polynomial.chebyshev.chebfit:49
msgid "**w** : array_like, shape (`M`,), optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/chebyshev.py:docstring
#: of numpy.polynomial.chebyshev.chebfit:-1
msgid "array_like, shape ("
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/chebyshev.py:docstring
#: of numpy.polynomial.chebyshev.chebfit:43
msgid ""
"Weights. If not None, the weight ``w[i]`` applies to the unsquared residual "
"``y[i] - y_hat[i]`` at ``x[i]``. Ideally the weights are chosen so that the "
"errors of the products ``w[i]*y[i]`` all have the same variance.  When using "
"inverse-variance weighting, use ``w[i] = 1/sigma(y[i])``.  The default value "
"is None."
msgstr ""

