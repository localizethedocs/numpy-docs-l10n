#: of numpy.polynomial.chebyshev.chebfit:-1
msgid "ndarray, shape (M,) or (M, K)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/chebyshev.py:docstring
#: of numpy.polynomial.chebyshev.chebfit:54
msgid ""
"Chebyshev coefficients ordered from low to high. If `y` was 2-D, the "
