#: ../../../reference/generated/numpy.fmod.rst:4
msgid "numpy.fmod"
msgstr ""

#: ../../../../docstring of numpy.fmod:2
msgid "Returns the element-wise remainder of division."
msgstr ""

#: ../../../../docstring of numpy.fmod:4
msgid ""
"This is the NumPy implementation of the C library function fmod, the "
"remainder has the same sign as the dividend `x1`. It is equivalent to the "
"Matlab(TM) ``rem`` function and should not be confused with the Python "
"modulus operator ``x1 % x2``."
msgstr ""

#: ../../../../docstring of numpy.fmod:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.fmod:12
msgid "**x1**"
msgstr ""

#: ../../../../docstring of numpy.fmod:-1
msgid "array_like"
msgstr ""

#: ../../../../docstring of numpy.fmod:12
msgid "Dividend."
msgstr ""

#: ../../../../docstring of numpy.fmod:17
msgid "**x2**"
msgstr ""

#: ../../../../docstring of numpy.fmod:15
msgid ""
"Divisor. If ``x1.shape != x2.shape``, they must be broadcastable to a common "
"shape (which becomes the shape of the output)."
msgstr ""

#: ../../../../docstring of numpy.fmod:23
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.fmod:-1
msgid "ndarray, None, or tuple of ndarray and None, optional"
msgstr ""

#: ../../../../docstring of numpy.fmod:20
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or None, a freshly-"
"allocated array is returned. A tuple (possible only as a keyword argument) "
"must have length equal to the number of outputs."
msgstr ""

#: ../../../../docstring of numpy.fmod:31
msgid "**where**"
msgstr ""

#: ../../../../docstring of numpy.fmod:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../docstring of numpy.fmod:26
msgid ""
"This condition is broadcast over the input. At locations where the condition "
"is True, the `out` array will be set to the ufunc result. Elsewhere, the "
"`out` array will retain its original value. Note that if an uninitialized "
"`out` array is created via the default ``out=None``, locations within it "
"where the condition is False will remain uninitialized."
msgstr ""

#: ../../../../docstring of numpy.fmod:35
msgid "**\\*\\*kwargs**"
msgstr ""

#: ../../../../docstring of numpy.fmod:34
msgid ""
"For other keyword-only arguments, see the :ref:`ufunc docs <ufuncs.kwargs>`."
msgstr ""

#: ../../../../docstring of numpy.fmod:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.fmod:47
msgid "**y**"
msgstr ""

#: ../../../../docstring of numpy.fmod:40
msgid ""
"The remainder of the division of `x1` by `x2`. This is a scalar if both `x1` "
"and `x2` are scalars."
msgstr ""

#: ../../../../docstring of numpy.fmod:52
msgid ":obj:`remainder`"
msgstr ""

#: ../../../../docstring of numpy.fmod:53
msgid "Equivalent to the Python ``%`` operator."
msgstr ""

#: ../../../../docstring of numpy.fmod:54
msgid ":obj:`divide`"
msgstr ""

#: ../../../../docstring of numpy.fmod:58
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.fmod:59
msgid ""
"The result of the modulo operation for negative dividend and divisors is "
"bound by conventions. For `fmod`, the sign of result is the sign of the "
"dividend, while for `remainder` the sign of the result is the sign of the "
"divisor. The `fmod` function is equivalent to the Matlab(TM) ``rem`` "
"function."
msgstr ""

