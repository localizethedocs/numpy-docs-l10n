msgid "numpy.tril"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.tril:2
msgid "Lower triangle of an array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.tril:4
msgid ""
"Return a copy of an array with elements above the `k`-th diagonal zeroed. "
"For arrays with ``ndim`` exceeding 2, `tril` will apply to the final two "
"axes."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.tril:0
msgid "Parameters"
msgstr ""

