#: ../../../reference/generated/numpy.ma.fromfunction.rst:4
msgid "numpy.ma.fromfunction"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.fromfunction:2
msgid "Construct an array by executing a function over each coordinate."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.fromfunction:4
msgid ""
"The resulting array therefore has a value ``fn(x, y, z)`` at coordinate "
"``(x, y, z)``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.fromfunction:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.fromfunction:14
msgid "**function**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.fromfunction:-1
msgid "callable"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.fromfunction:10
msgid ""
"The function is called with N parameters, where N is the rank of `shape`.  "
"Each parameter represents the coordinates of the array varying along a "
"specific axis.  For example, if `shape` were ``(2, 2)``, then the parameters "
"would be ``array([[0, 0], [1, 1]])`` and ``array([[0, 1], [0, 1]])``"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.fromfunction:18
msgid "**shape**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.fromfunction:-1
msgid "(N,) tuple of ints"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.fromfunction:17
msgid ""
"Shape of the output array, which also determines the shape of the coordinate "
"arrays passed to `function`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.fromfunction:22
msgid "**dtype**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.fromfunction:-1
msgid "data-type, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.fromfunction:21
msgid ""
"Data-type of the coordinate arrays passed to `function`. By default, `dtype` "
"is float."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.fromfunction:33
msgid "**like**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.fromfunction:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.fromfunction:25
msgid ""
"Reference object to allow the creation of arrays which are not NumPy arrays. "
"If an array-like passed in as ``like`` supports the ``__array_function__`` "
"protocol, the result will be defined by it. In this case, it ensures the "
"creation of an array object compatible with that passed in via this argument."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.fromfunction:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.fromfunction:47
msgid "fromfunction: MaskedArray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.fromfunction:38
msgid ""
"The result of the call to `function` is passed back directly. Therefore the "
"shape of `fromfunction` is completely determined by `function`.  If "
"`function` returns a scalar value, the shape of `fromfunction` would not "
"match the `shape` parameter."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.fromfunction:52
msgid ":obj:`indices`, :obj:`meshgrid`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.fromfunction:56
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.fromfunction:57
msgid "Keywords other than `dtype` and `like` are passed to `function`."
msgstr ""

