#: ../../../reference/generated/numpy.heaviside.rst:4
msgid "numpy.heaviside"
msgstr ""

#: ../../../../docstring of numpy.heaviside:2
msgid "Compute the Heaviside step function."
msgstr ""

#: ../../../../docstring of numpy.heaviside:4
msgid "The Heaviside step function is defined as::"
msgstr ""

#: ../../../../docstring of numpy.heaviside:6
msgid ""
"                      0   if x1 < 0\n"
"heaviside(x1, x2) =  x2   if x1 == 0\n"
"                      1   if x1 > 0"
msgstr ""

#: ../../../../docstring of numpy.heaviside:10
msgid ""
"where `x2` is often taken to be 0.5, but 0 and 1 are also sometimes used."
msgstr ""

#: ../../../../docstring of numpy.heaviside:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.heaviside:15
msgid "**x1**"
msgstr ""

#: ../../../../docstring of numpy.heaviside:-1
msgid "array_like"
msgstr ""

#: ../../../../docstring of numpy.heaviside:15
msgid "Input values."
msgstr ""

#: ../../../../docstring of numpy.heaviside:20
msgid "**x2**"
msgstr ""

#: ../../../../docstring of numpy.heaviside:18
msgid ""
"The value of the function when x1 is 0. If ``x1.shape != x2.shape``, they "
"must be broadcastable to a common shape (which becomes the shape of the "
"output)."
msgstr ""

#: ../../../../docstring of numpy.heaviside:26 numpy.heaviside:51
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.heaviside:-1
msgid "ndarray, None, or tuple of ndarray and None, optional"
msgstr ""

#: ../../../../docstring of numpy.heaviside:23
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or None, a freshly-"
"allocated array is returned. A tuple (possible only as a keyword argument) "
"must have length equal to the number of outputs."
msgstr ""

#: ../../../../docstring of numpy.heaviside:34
msgid "**where**"
msgstr ""

#: ../../../../docstring of numpy.heaviside:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../docstring of numpy.heaviside:29
msgid ""
"This condition is broadcast over the input. At locations where the condition "
"is True, the `out` array will be set to the ufunc result. Elsewhere, the "
"`out` array will retain its original value. Note that if an uninitialized "
"`out` array is created via the default ``out=None``, locations within it "
"where the condition is False will remain uninitialized."
msgstr ""

#: ../../../../docstring of numpy.heaviside:38
msgid "**\\*\\*kwargs**"
msgstr ""

#: ../../../../docstring of numpy.heaviside:37
msgid ""
"For other keyword-only arguments, see the :ref:`ufunc docs <ufuncs.kwargs>`."
msgstr ""

#: ../../../../docstring of numpy.heaviside:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.heaviside:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.heaviside:43
msgid ""
"The output array, element-wise Heaviside step function of `x1`. This is a "
"scalar if both `x1` and `x2` are scalars."
msgstr ""

