#: of numpy.loadtxt:131
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.loadtxt:132
msgid ""
"This function aims to be a fast reader for simply formatted files.  The "
"`genfromtxt` function provides more sophisticated handling of, e.g., lines "
"with missing values."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.loadtxt:136
msgid ""
"Each row in the input text file must have the same number of values to be "
"able to read all values. If all rows do not have same number of values, a "
"subset of up to n columns (where n is the least number of values present in "
"all rows) can be read by specifying the columns via `usecols`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.loadtxt:141
msgid ""
"The strings produced by the Python float.hex method can be used as input for "
"floats."
msgstr ""

