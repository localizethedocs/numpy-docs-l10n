msgid "Determine if two arrays share memory."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.shares_memory:6
msgid ""
"This function can be exponentially slow for some inputs, unless `max_work` "
"is set to zero or a positive integer. If in doubt, use `numpy."
"may_share_memory` instead."
msgstr ""

