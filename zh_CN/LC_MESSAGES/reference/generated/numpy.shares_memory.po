msgid ""
"Effort to spend on solving the overlap problem (maximum number of candidate "
"solutions to consider). The following special values are recognized:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.shares_memory:22
msgid "max_work=-1 (default)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.shares_memory:21
msgid ""
"The problem is solved exactly. In this case, the function returns True only "
"if there is an element shared between the arrays. Finding the exact solution "
"may take extremely long in some cases."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.shares_memory:28
msgid "max_work=0"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.shares_memory:25
msgid ""
"Only the memory bounds of a and b are checked. This is equivalent to using "
"``may_share_memory()``."
msgstr ""

