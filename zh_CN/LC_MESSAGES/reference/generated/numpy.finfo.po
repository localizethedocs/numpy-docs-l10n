msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.finfo:42
msgid ""
"The smallest positive power of the base (2) that causes overflow. "
"Corresponds to the C standard MAX_EXP."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.finfo:46
msgid "**min**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.finfo:46
msgid "The smallest representable number, typically ``-max``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.finfo:51
msgid "**minexp**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.finfo:49
msgid ""
"The most negative power of the base (2) consistent with there being no "
"leading 0's in the mantissa. Corresponds to the C standard MIN_EXP - 1."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.finfo:54
msgid "**negep**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.finfo:54
msgid "The exponent that yields `epsneg`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.finfo:57
msgid "**nexp**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.finfo:57
msgid "The number of bits in the exponent including its sign and bias."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.finfo:61
msgid "**nmant**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.finfo:60
msgid ""
"The number of explicit bits in the mantissa (excluding the implicit leading "
"bit for normalized numbers)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.finfo:65
msgid "**precision**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.finfo:64
msgid ""
"The approximate number of decimal digits to which this kind of float is "
"precise."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.finfo:69
msgid "**resolution**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.finfo:68
msgid ""
"The approximate decimal resolution of this type, i.e., ``10**-precision``."
msgstr ""

