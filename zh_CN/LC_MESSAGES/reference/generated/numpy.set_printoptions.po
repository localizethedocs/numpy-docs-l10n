msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:10
msgid ""
"Number of digits of precision for floating point output (default 8). May be "
"None if `floatmode` is not `fixed`, to print as many digits as necessary to "
"uniquely specify the value."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:17
msgid "**threshold**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:15
msgid ""
"Total number of array elements which trigger summarization rather than full "
"repr (default 1000). To always use the full repr without summarization, pass "
"`sys.maxsize`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:21
msgid "**edgeitems**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:20
msgid ""
"Number of array items in summary at beginning and end of each dimension "
"(default 3)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:25
msgid "**linewidth**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:24
msgid ""
"The number of characters per line for the purpose of inserting line breaks "
"(default 75)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:32
msgid "**suppress**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:28
msgid ""
"If True, always print floating point numbers using fixed point notation, in "
"which case numbers equal to zero in the current precision will print as "
"zero.  If False, then scientific notation is used when absolute value of the "
"smallest number is < 1e-4 or the ratio of the maximum absolute value to the "
"minimum is > 1e3. The default is False."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:35
msgid "**nanstr**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:-1
msgid "str, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:35
msgid "String representation of floating point not-a-number (default nan)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:38
msgid "**infstr**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:38
msgid "String representation of floating point infinity (default inf)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:48
msgid "**sign**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:-1
msgid "string, either '-', '+', or ' ', optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:41
msgid ""
"Controls printing of the sign of floating-point types. If '+', always print "
"the sign of positive values. If ' ', always prints a space (whitespace "
"character) in the sign position of positive values.  If '-', omit the sign "
"character of positive values. (default '-')"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:46
msgid ""
"The sign parameter can now be an integer type, previously types were "
"floating-point types."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:74
msgid "**formatter**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:-1
msgid "dict of callables, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:51
msgid ""
"If not None, the keys should indicate the type(s) that the respective "
"formatting function applies to.  Callables should return a string. Types "
"that are not specified (by their corresponding keys) are handled by the "
"default formatters.  Individual types for which a formatter can be set are:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:57
msgid "'bool'"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:58
msgid "'int'"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:59
msgid "'timedelta' : a `numpy.timedelta64`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:60
msgid "'datetime' : a `numpy.datetime64`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:61
msgid "'float'"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:62
msgid "'longfloat' : 128-bit floats"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:63
msgid "'complexfloat'"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:64
msgid "'longcomplexfloat' : composed of two 128-bit floats"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:65
msgid "'numpystr' : types `numpy.bytes_` and `numpy.str_`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:66
msgid "'object' : `np.object_` arrays"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:68
msgid "Other keys that can be used to set a group of types at once are:"
msgstr ""

