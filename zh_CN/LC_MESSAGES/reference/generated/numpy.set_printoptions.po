msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:73
msgid "'complex_kind' : sets 'complexfloat' and 'longcomplexfloat'"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:74
msgid "'str_kind' : sets 'numpystr'"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:94
msgid "**floatmode**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:77
msgid ""
"Controls the interpretation of the `precision` option for floating-point "
"types. Can take the following values (default maxprec_equal):"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:82
msgid "'fixed': Always print exactly `precision` fractional digits,"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:82
msgid ""
"even if this would print more or fewer digits than necessary to specify the "
"value uniquely."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:86
msgid "'unique': Print the minimum number of fractional digits necessary"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:85
msgid ""
"to represent each value uniquely. Different elements may have a different "
"number of digits. The value of the `precision` option is ignored."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:89
msgid "'maxprec': Print at most `precision` fractional digits, but if"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:89
msgid ""
"an element can be uniquely represented with fewer digits only print it with "
"that many."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:94
msgid "'maxprec_equal': Print at most `precision` fractional digits,"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:92
msgid ""
"but if every element in the array can be uniquely represented with an equal "
"number of fewer digits, use that many digits for all elements."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:124
msgid "**legacy** : string or `False`, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:-1
msgid "string or"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:97
msgid ""
"If set to the string ``'1.13'`` enables 1.13 legacy printing mode. This "
"approximates numpy 1.13 print output by including a space in the sign "
"position of floats and different behavior for 0d arrays. This also enables "
"1.21 legacy printing mode (described below)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:102
msgid ""
"If set to the string ``'1.21'`` enables 1.21 legacy printing mode. This "
"approximates numpy 1.21 print output of complex structured dtypes by not "
"inserting spaces after commas that separate fields and after colons."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:107
msgid ""
"If set to ``'1.25'`` approximates printing of 1.25 which mainly means that "
"numeric scalars are printed without their type information, e.g. as ``3.0`` "
"rather than ``np.float64(3.0)``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:111
msgid ""
"If set to ``'2.1'``, shape information is not given when arrays are "
"summarized (i.e., multiple elements replaced with ``...``)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:114
msgid ""
"If set to ``'2.2'``, the transition to use scientific notation for printing "
"``np.float16`` and ``np.float32`` types may happen later or not at all for "
"larger values."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:118
msgid "If set to `False`, disables legacy mode."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:120
msgid ""
"Unrecognized strings will be ignored with a warning for forward "
"compatibility."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:137
msgid "**override_repr: callable, optional**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:127
msgid ""
"If set a passed function will be used for generating arrays' repr. Other "
"options will be ignored."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:142
msgid ":obj:`get_printoptions`, :obj:`printoptions`, :obj:`array2string`"
msgstr ""

