#: ../../../reference/generated/numpy.ma.polyfit.rst:4
msgid "numpy.ma.polyfit"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:2
msgid "Least squares polynomial fit."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:5
msgid ""
"This forms part of the old polynomial API. Since version 1.4, the new "
"polynomial API defined in `numpy.polynomial` is preferred. A summary of the "
"differences can be found in the :doc:`transition guide </reference/routines."
"polynomials>`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:10
msgid ""
"Fit a polynomial ``p[0] * x**deg + ... + p[deg]`` of degree `deg` to points "
"`(x, y)`. Returns a vector of coefficients `p` that minimises the squared "
"error in the order `deg`, `deg-1`, ... `0`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:14
msgid ""
"The `Polynomial.fit <numpy.polynomial.polynomial.Polynomial.fit>` class "
"method is recommended for new code as it is more stable numerically. See the "
"documentation of the method for more information."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:21
msgid "**x**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:-1
msgid "array_like, shape (M,)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:21
msgid "x-coordinates of the M sample points ``(x[i], y[i])``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:26
msgid "**y**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:-1
msgid "array_like, shape (M,) or (M, K)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:24
msgid ""
"y-coordinates of the sample points. Several data sets of sample points "
"sharing the same x-coordinates can be fitted at once by passing in a 2D-"
"array that contains one dataset per column."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:29
msgid "**deg**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:-1
msgid "int"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:29
msgid "Degree of the fitting polynomial"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:35
msgid "**rcond**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:-1
msgid "float, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:32
msgid ""
"Relative condition number of the fit. Singular values smaller than this "
"relative to the largest singular value will be ignored. The default value is "
"len(x)*eps, where eps is the relative precision of the float type, about "
"2e-16 in most cases."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:40
msgid "**full**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:38
msgid ""
"Switch determining nature of return value. When it is False (the default) "
"just the coefficients are returned, when True diagnostic information from "
"the singular value decomposition is also returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:47
msgid "**w**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:-1
msgid "array_like, shape (M,), optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:43
msgid ""
"Weights. If not None, the weight ``w[i]`` applies to the unsquared residual "
"``y[i] - y_hat[i]`` at ``x[i]``. Ideally the weights are chosen so that the "
"errors of the products ``w[i]*y[i]`` all have the same variance.  When using "
"inverse-variance weighting, use ``w[i] = 1/sigma(y[i])``.  The default value "
"is None."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:59
msgid "**cov**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:-1
msgid "bool or str, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:50
msgid ""
"If given and not `False`, return not just the estimate but also its "
"covariance matrix. By default, the covariance are scaled by chi2/dof, where "
"dof = M - (deg + 1), i.e., the weights are presumed to be unreliable except "
"in a relative sense and everything is scaled such that the reduced chi2 is "
"unity. This scaling is omitted if ``cov='unscaled'``, as is relevant for the "
"case that the weights are w = 1/sigma, with sigma known to be a reliable "
"estimate of the uncertainty."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:65
msgid "**p**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:-1
msgid "ndarray, shape (deg + 1,) or (deg + 1, K)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:64
msgid ""
"Polynomial coefficients, highest power first.  If `y` was 2-D, the "
"coefficients for `k`-th data set are in ``p[:,k]``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:77
msgid "residuals, rank, singular_values, rcond"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:68
msgid "These values are only returned if ``full == True``"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:70
msgid "residuals -- sum of squared residuals of the least squares fit"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:71
msgid "rank -- the effective rank of the scaled Vandermonde coefficient matrix"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:73
msgid ""
"singular_values -- singular values of the scaled Vandermonde coefficient "
"matrix"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:75
msgid "rcond -- value of `rcond`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:77
msgid "For more details, see `numpy.linalg.lstsq`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:88
msgid "**V**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:-1
msgid "ndarray, shape (deg + 1, deg + 1) or (deg + 1, deg + 1, K)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:80
msgid ""
"Present only if ``full == False`` and ``cov == True``.  The covariance "
"matrix of the polynomial coefficient estimates.  The diagonal of this matrix "
"are the variance estimates for each coefficient.  If y is a 2-D array, then "
"the covariance matrix for the `k`-th data set are in ``V[:,:,k]``"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:0
msgid "Warns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:100
msgid "RankWarning"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.polyfit:93
msgid ""
"The rank of the coefficient matrix in the least-squares fit is deficient. "
"The warning is only raised if ``full == False``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
