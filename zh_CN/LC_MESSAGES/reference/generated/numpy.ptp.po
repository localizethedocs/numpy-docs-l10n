#: ../../../reference/generated/numpy.ptp.rst:4
msgid "numpy.ptp"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ptp:2
msgid "Range of values (maximum - minimum) along an axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ptp:4
msgid "The name of the function comes from the acronym for 'peak to peak'."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ptp:7
msgid ""
"`ptp` preserves the data type of the array. This means the return value for "
"an input of signed integers with n bits (e.g. `np.int8`, `np.int16`, etc) is "
"also a signed integer with n bits.  In that case, peak-to-peak values "
"greater than ``2**(n-1)-1`` will be returned as negative values. An example "
"with a work-around is shown below."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ptp:0
msgid "Parameters"
msgstr ""

