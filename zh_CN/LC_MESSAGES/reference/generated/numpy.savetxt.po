msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:10
msgid "**fname**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:-1
msgid "filename or file handle"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:8
msgid ""
"If the filename ends in ``.gz``, the file is automatically saved in "
"compressed gzip format.  `loadtxt` understands gzipped files transparently."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:13
msgid "**X**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:-1
msgid "1D or 2D array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:13
msgid "Data to be saved to a text file."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:27
msgid "**fmt**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:-1
msgid "str or sequence of strs, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:16
msgid ""
"A single format (%10.5f), a sequence of formats, or a multi-format string, e."
"g. 'Iteration %d -- %10.5f', in which case `delimiter` is ignored. For "
"complex `X`, the legal options for `fmt` are:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:21
msgid ""
"a single specifier, `fmt='%.4e'`, resulting in numbers formatted like `' (%s+"
"%sj)' % (fmt, fmt)`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:23
msgid ""
"a full string specifying every real and imaginary part, e.g. `' %.4e %+.4ej "
"%.4e %+.4ej %.4e %+.4ej'` for 3 columns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:25
msgid ""
"a list of specifiers, one per column - in this case, the real and imaginary "
"part must have separate specifiers, e.g. `['%.3e + %.3ej', '(%.15e%"
"+.15ej)']` for 2 columns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:30
msgid "**delimiter**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:-1
msgid "str, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:30
msgid "String or character separating columns."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:35
msgid "**newline**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:33
msgid "String or character separating lines.  Default is universal newline."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:40
msgid "**header**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:38
msgid "String that will be written at the beginning of the file."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:45
msgid "**footer**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:43
msgid "String that will be written at the end of the file."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:52
msgid "**comments**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:48
msgid ""
"String that will be prepended to the ``header`` and ``footer`` strings, to "
"mark them as comments. Default: '# ',  as expected by e.g. ``numpy.loadtxt``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:67
msgid "**encoding**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:-1
msgid "{None, str}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:55
msgid ""
"Encoding used to encode the outputfile. Does not apply to output streams. If "
"the encoding is something other than 'bytes' or 'latin1' you will not be "
"able to load the file in NumPy versions < 1.14. Default is 'latin1'."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:72
msgid ":obj:`save`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:73
msgid "Save an array to a binary file in NumPy ``.npy`` format"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:74
msgid ":obj:`savez`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:75
msgid "Save several arrays into an uncompressed ``.npz`` archive"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:76
msgid ":obj:`savez_compressed`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:77
msgid "Save several arrays into a compressed ``.npz`` archive"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:81
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:82
msgid ""
"Further explanation of the `fmt` parameter (``%[flag]width[."
"precision]specifier``):"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:90
msgid "flags:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:86
msgid "``-`` : left justify"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:88
msgid "``+`` : Forces to precede result with + or -."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:90
msgid "``0`` : Left pad the number with zeros instead of space (see width)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:94
msgid "width:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:93
msgid ""
"Minimum number of characters to be printed. The value is not truncated if it "
"has more characters."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:102
msgid "precision:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:97
msgid "For integer specifiers (eg. ``d,i,o,x``), the minimum number of digits."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:99
msgid ""
"For ``e, E`` and ``f`` specifiers, the number of digits to print after the "
"decimal point."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:101
msgid "For ``g`` and ``G``, the maximum number of significant digits."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:102
msgid "For ``s``, the maximum number of characters."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:121
msgid "specifiers:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:105
msgid "``c`` : character"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:107
msgid "``d`` or ``i`` : signed decimal integer"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:109
msgid "``e`` or ``E`` : scientific notation with ``e`` or ``E``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:111
msgid "``f`` : decimal floating point"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:113
msgid "``g,G`` : use the shorter of ``e,E`` or ``f``"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:115
msgid "``o`` : signed octal"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:117
msgid "``s`` : string of characters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:119
msgid "``u`` : unsigned decimal integer"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:121
msgid "``x,X`` : unsigned hexadecimal integer"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:123
msgid ""
"This explanation of ``fmt`` is not complete, for an exhaustive specification "
"see [R672d4d5b6143-1]_."
msgstr ""

