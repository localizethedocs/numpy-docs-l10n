#: ../../../reference/generated/numpy.from_dlpack.rst:4
msgid "numpy.from\\_dlpack"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.from_dlpack:2
msgid ""
"Create a NumPy array from an object implementing the ``__dlpack__`` "
"protocol. Generally, the returned NumPy array is a view of the input object. "
"See [Re9eadf7a166b-1]_ and [Re9eadf7a166b-2]_ for more details."
msgstr ""

