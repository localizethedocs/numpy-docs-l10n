msgid "device, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.from_dlpack:14
msgid ""
"Device on which to place the created array. Default: ``None``. Must be "
"``\"cpu\"`` if passed which may allow importing an array that is not already "
"CPU available."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.from_dlpack:25
msgid "**copy**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.from_dlpack:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.from_dlpack:19
msgid ""
"Boolean indicating whether or not to copy the input. If ``True``, the copy "
"will be made. If ``False``, the function will never copy, and will raise "
"``BufferError`` in case a copy is deemed necessary. Passing it requests a "
"copy from the exporter who may or may not implement the capability. If "
"``None``, the function will reuse the existing memory buffer if possible and "
"copy otherwise. Default: ``None``."
msgstr ""

