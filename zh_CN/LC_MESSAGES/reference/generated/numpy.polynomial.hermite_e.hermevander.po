#: ../../../reference/generated/numpy.polynomial.hermite_e.hermevander.rst:4
msgid "numpy.polynomial.hermite\\_e.hermevander"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/hermite_e.py:docstring
#: of numpy.polynomial.hermite_e.hermevander:2
msgid "Pseudo-Vandermonde matrix of given degree."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/hermite_e.py:docstring
#: of numpy.polynomial.hermite_e.hermevander:4
msgid ""
"Returns the pseudo-Vandermonde matrix of degree `deg` and sample points `x`. "
"The pseudo-Vandermonde matrix is defined by"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/hermite_e.py:docstring
#: of numpy.polynomial.hermite_e.hermevander:7
msgid ""
"V[..., i] = He_i(x),\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/hermite_e.py:docstring
#: of numpy.polynomial.hermite_e.hermevander:9
msgid ""
"where `0 <= i <= deg`. The leading indices of `V` index the elements of `x` "
"and the last index is the degree of the HermiteE polynomial."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/hermite_e.py:docstring
#: of numpy.polynomial.hermite_e.hermevander:12
msgid ""
"If `c` is a 1-D array of coefficients of length `n + 1` and `V` is the array "
"``V = hermevander(x, n)``, then ``np.dot(V, c)`` and ``hermeval(x, c)`` are "
"the same up to roundoff. This equivalence is useful both for least squares "
"fitting and for the evaluation of a large number of HermiteE series of the "
"same degree and sample points."
msgstr ""

