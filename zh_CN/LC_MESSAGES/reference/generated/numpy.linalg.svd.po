#: ../../../reference/generated/numpy.linalg.svd.rst:4
msgid "numpy.linalg.svd"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.svd:2
msgid "Singular Value Decomposition."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.svd:4
msgid ""
"When `a` is a 2D array, and ``full_matrices=False``, then it is factorized "
"as ``u @ np.diag(s) @ vh = (u * s) @ vh``, where `u` and the Hermitian "
"transpose of `vh` are 2D arrays with orthonormal columns and `s` is a 1D "
"array of `a`'s singular values. When `a` is higher-dimensional, SVD is "
"applied in stacked mode as explained below."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.svd:0
msgid "Parameters"
msgstr ""

