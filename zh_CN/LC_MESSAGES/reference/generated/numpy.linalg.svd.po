#: of numpy.linalg.svd:14
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.svd:-1
msgid "(..., M, N) array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.svd:14
msgid "A real or complex array with ``a.ndim >= 2``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.svd:20
msgid "**full_matrices**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.svd:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.svd:17
msgid ""
"If True (default), `u` and `vh` have the shapes ``(..., M, M)`` and ``(..., "
"N, N)``, respectively.  Otherwise, the shapes are ``(..., M, K)`` and "
"``(..., K, N)``, respectively, where ``K = min(M, N)``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.svd:24
msgid "**compute_uv**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.svd:23
msgid ""
"Whether or not to compute `u` and `vh` in addition to `s`.  True by default."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.svd:31
msgid "**hermitian**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.svd:27
msgid ""
"If True, `a` is assumed to be Hermitian (symmetric if real-valued), enabling "
"a more efficient method for finding singular values. Defaults to False."
msgstr ""

