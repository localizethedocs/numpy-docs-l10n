#: ../../../reference/generated/numpy.mgrid.rst:4
msgid "numpy.mgrid"
msgstr ""

#: ../../../../docstring of numpy.mgrid:2
msgid "An instance which returns a dense multi-dimensional \"meshgrid\"."
msgstr ""

#: ../../../../docstring of numpy.mgrid:4
msgid ""
"An instance which returns a dense (or fleshed out) mesh-grid when indexed, "
"so that each returned argument has the same shape. The dimensions and number "
"of the output arrays are equal to the number of indexing dimensions.  If the "
"step length is not a complex number, then the stop is not inclusive."
msgstr ""

#: ../../../../docstring of numpy.mgrid:10
msgid ""
"However, if the step length is a **complex number** (e.g. 5j), then the "
"integer part of its magnitude is interpreted as specifying the number of "
"points to create between the start and stop values, where the stop value "
"**is inclusive**."
msgstr ""

