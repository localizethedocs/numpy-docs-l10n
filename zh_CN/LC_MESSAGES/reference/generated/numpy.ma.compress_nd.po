msgid "Suppress slices from multiple dimensions which contain masked values."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.compress_nd:0
msgid "Parameters"
msgstr ""

