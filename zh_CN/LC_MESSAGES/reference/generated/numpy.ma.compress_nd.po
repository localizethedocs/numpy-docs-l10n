msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.compress_nd:-1
msgid "array_like, MaskedArray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.compress_nd:8
msgid ""
"The array to operate on. If not a MaskedArray instance (or if no array "
"elements are masked), `x` is interpreted as a MaskedArray with `mask` set to "
"`nomask`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.compress_nd:19
msgid "**axis**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.compress_nd:-1
msgid "tuple of ints or int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.compress_nd:13
msgid ""
"Which dimensions to suppress slices from can be configured with this "
"parameter. - If axis is a tuple of ints, those are the axes to suppress "
"slices from. - If axis is an int, then that is the only axis to suppress "
"slices from. - If axis is None, all axis are selected."
msgstr ""

