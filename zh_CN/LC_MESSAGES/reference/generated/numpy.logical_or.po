#: ../../../reference/generated/numpy.logical_or.rst:4
msgid "numpy.logical\\_or"
msgstr ""

#: ../../../../docstring of numpy.logical_or:2
msgid "Compute the truth value of x1 OR x2 element-wise."
msgstr ""

#: ../../../../docstring of numpy.logical_or:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.logical_or:10
msgid "**x1, x2**"
msgstr ""

#: ../../../../docstring of numpy.logical_or:-1
msgid "array_like"
msgstr ""

#: ../../../../docstring of numpy.logical_or:8
msgid ""
"Logical OR is applied to the elements of `x1` and `x2`. If ``x1.shape != x2."
"shape``, they must be broadcastable to a common shape (which becomes the "
"shape of the output)."
msgstr ""

#: ../../../../docstring of numpy.logical_or:16
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.logical_or:-1
msgid "ndarray, None, or tuple of ndarray and None, optional"
msgstr ""

#: ../../../../docstring of numpy.logical_or:13
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or None, a freshly-"
"allocated array is returned. A tuple (possible only as a keyword argument) "
"must have length equal to the number of outputs."
msgstr ""

#: ../../../../docstring of numpy.logical_or:24
msgid "**where**"
msgstr ""

#: ../../../../docstring of numpy.logical_or:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../docstring of numpy.logical_or:19
msgid ""
"This condition is broadcast over the input. At locations where the condition "
"is True, the `out` array will be set to the ufunc result. Elsewhere, the "
"`out` array will retain its original value. Note that if an uninitialized "
"`out` array is created via the default ``out=None``, locations within it "
"where the condition is False will remain uninitialized."
msgstr ""

#: ../../../../docstring of numpy.logical_or:28
msgid "**\\*\\*kwargs**"
msgstr ""

#: ../../../../docstring of numpy.logical_or:27
msgid ""
"For other keyword-only arguments, see the :ref:`ufunc docs <ufuncs.kwargs>`."
msgstr ""

#: ../../../../docstring of numpy.logical_or:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.logical_or:41
msgid "**y**"
msgstr ""

#: ../../../../docstring of numpy.logical_or:-1
msgid "ndarray or bool"
msgstr ""

#: ../../../../docstring of numpy.logical_or:33
msgid ""
"Boolean result of the logical OR operation applied to the elements of `x1` "
"and `x2`; the shape is determined by broadcasting. This is a scalar if both "
"`x1` and `x2` are scalars."
msgstr ""

#: ../../../../docstring of numpy.logical_or:46
msgid ":obj:`logical_and`, :obj:`logical_not`, :obj:`logical_xor`"
msgstr ""

#: ../../../../docstring of numpy.logical_or:48
msgid ":obj:`bitwise_or`"
msgstr ""

#: ../../../../docstring of numpy.logical_or:54
msgid "Examples"
msgstr ""

#: ../../../../docstring of numpy.logical_or:64
msgid ""
"The ``|`` operator can be used as a shorthand for ``np.logical_or`` on "
"boolean ndarrays."
msgstr ""
