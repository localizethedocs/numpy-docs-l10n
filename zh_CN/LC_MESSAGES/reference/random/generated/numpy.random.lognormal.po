msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.lognormal:52
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.lognormal:53
msgid ""
"A variable `x` has a log-normal distribution if `log(x)` is normally "
"distributed.  The probability density function for the log-normal "
"distribution is:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.lognormal:57
msgid ""
"p(x) = \\frac{1}{\\sigma x \\sqrt{2\\pi}}\n"
"e^{(-\\frac{(ln(x)-\\mu)^2}{2\\sigma^2})}\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.lognormal:60
msgid ""
"where :math:`\\mu` is the mean and :math:`\\sigma` is the standard deviation "
"of the normally distributed logarithm of the variable. A log-normal "
"distribution results if a random variable is the *product* of a large number "
"of independent, identically-distributed variables in the same way that a "
"normal distribution results if the variable is the *sum* of a large number "
"of independent, identically-distributed variables."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.lognormal:69
msgid "References"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.lognormal:70
msgid ""
"Limpert, E., Stahel, W. A., and Abbt, M., \"Log-normal Distributions across "
"the Sciences: Keys and Clues,\" BioScience, Vol. 51, No. 5, May, 2001. "
"https://stat.ethz.ch/~stahel/lognormal/bioscience.pdf"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.lognormal:74
msgid ""
"Reiss, R.D. and Thomas, M., \"Statistical Analysis of Extreme Values,\" "
"Basel: Birkhauser Verlag, 2001, pp. 31-32."
msgstr ""

