#: ../../../reference/random/generated/numpy.random.randn.rst:4
msgid "numpy.random.randn"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.randn:2
msgid "Return a sample (or samples) from the \"standard normal\" distribution."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.randn:5
msgid ""
"This is a convenience function for users porting code from Matlab, and wraps "
"`standard_normal`. That function takes a tuple to specify the size of the "
"output, which is consistent with other NumPy functions like `numpy.zeros` "
"and `numpy.ones`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.randn:11
msgid ""
"New code should use the `~numpy.random.Generator.standard_normal` method of "
"a `~numpy.random.Generator` instance instead; please see the :ref:`random-"
"quick-start`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.randn:16
msgid ""
"If positive int_like arguments are provided, `randn` generates an array of "
"shape ``(d0, d1, ..., dn)``, filled with random floats sampled from a "
"univariate \"normal\" (Gaussian) distribution of mean 0 and variance 1. A "
"single float randomly sampled from the distribution is returned if no "
"argument is provided."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.randn:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.randn:26
msgid "**d0, d1, ..., dn**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.randn:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.randn:25
msgid ""
"The dimensions of the returned array, must be non-negative. If no argument "
"is given a single Python float is returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.randn:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.randn:39
msgid "**Z**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.randn:-1
msgid "ndarray or float"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.randn:31
msgid ""
"A ``(d0, d1, ..., dn)``-shaped array of floating-point samples from the "
"standard normal distribution, or a single such float if no parameters were "
"supplied."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.randn:44
msgid ":obj:`standard_normal`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.randn:45
msgid "Similar, but takes a tuple as its argument."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.randn:46
msgid ":obj:`normal`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.randn:47
msgid "Also accepts mu and sigma arguments."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.randn:48
msgid ":obj:`random.Generator.standard_normal`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.randn:49
msgid "which should be used for new code."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.randn:53
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.randn:54
msgid ""
"For random samples from the normal distribution with mean ``mu`` and "
"standard deviation ``sigma``, use::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.randn:57
msgid "sigma * np.random.randn(...) + mu"
msgstr ""

