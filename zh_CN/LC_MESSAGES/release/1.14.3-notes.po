#: ../../../release/1.14.3-notes.rst:3
msgid "NumPy 1.14.3 Release Notes"
msgstr ""

#: ../../../release/1.14.3-notes.rst:5
msgid ""
"This is a bugfix release for a few bugs reported following the 1.14.2 "
"release:"
msgstr ""

#: ../../../release/1.14.3-notes.rst:7
msgid "np.lib.recfunctions.fromrecords accepts a list-of-lists, until 1.15"
msgstr ""

#: ../../../release/1.14.3-notes.rst:8
msgid "In python2, float types use the new print style when printing to a file"
msgstr ""

#: ../../../release/1.14.3-notes.rst:9
msgid "style arg in \"legacy\" print mode now works for 0d arrays"
msgstr ""

#: ../../../release/1.14.3-notes.rst:11
msgid ""
"The Python versions supported in this release are 2.7 and 3.4 - 3.6. The "
"Python 3.6 wheels available from PIP are built with Python 3.6.2 and should "
"be compatible with all previous versions of Python 3.6. The source releases "
"were cythonized with Cython 0.28.2."
msgstr ""

