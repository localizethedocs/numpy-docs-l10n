#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.power:2
msgid ""
"Draws samples in [0, 1] from a power distribution with positive exponent a - "
"1."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.power:5
msgid "Also known as the power function distribution."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.power:8
msgid ""
"New code should use the `~numpy.random.Generator.power` method of a `~numpy."
"random.Generator` instance instead; please see the :ref:`random-quick-start`."
msgstr ""

