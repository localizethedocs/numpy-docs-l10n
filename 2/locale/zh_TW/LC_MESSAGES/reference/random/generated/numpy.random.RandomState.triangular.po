msgid "which should be used for new code."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.triangular:53
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.triangular:54
msgid "The probability density function for the triangular distribution is"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.triangular:56
msgid ""
"P(x;l, m, r) = \\begin{cases}\n"
"\\frac{2(x-l)}{(r-l)(m-l)}& \\text{for $l \\leq x \\leq m$},\\\\\n"
"\\frac{2(r-x)}{(r-l)(r-m)}& \\text{for $m \\leq x \\leq r$},\\\\\n"
"0& \\text{otherwise}.\n"
"\\end{cases}\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.triangular:62
msgid ""
"The triangular distribution is often used in ill-defined problems where the "
"underlying distribution is not known, but some knowledge of the limits and "
"mode exists. Often it is used in simulations."
msgstr ""

