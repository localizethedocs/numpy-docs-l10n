#: ../../../reference/random/generated/numpy.random.hypergeometric.rst:4
msgid "numpy.random.hypergeometric"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.hypergeometric:2
msgid "Draw samples from a Hypergeometric distribution."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.hypergeometric:4
msgid ""
"Samples are drawn from a hypergeometric distribution with specified "
"parameters, `ngood` (ways to make a good selection), `nbad` (ways to make a "
"bad selection), and `nsample` (number of items sampled, which is less than "
"or equal to the sum ``ngood + nbad``)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.hypergeometric:10
msgid ""
"New code should use the `~numpy.random.Generator.hypergeometric` method of a "
"`~numpy.random.Generator` instance instead; please see the :ref:`random-"
"quick-start`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.hypergeometric:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.hypergeometric:18
msgid "**ngood**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.hypergeometric:-1
msgid "int or array_like of ints"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.hypergeometric:18
msgid "Number of ways to make a good selection.  Must be nonnegative."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.hypergeometric:21
msgid "**nbad**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.hypergeometric:21
msgid "Number of ways to make a bad selection.  Must be nonnegative."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.hypergeometric:25
msgid "**nsample**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.hypergeometric:24
msgid ""
"Number of items sampled.  Must be at least 1 and at most ``ngood + nbad``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.hypergeometric:32
msgid "**size**"
msgstr "**size**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.hypergeometric:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.hypergeometric:28
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn.  If size is ``None`` (default), a single value is "
"returned if `ngood`, `nbad`, and `nsample` are all scalars.  Otherwise, ``np."
"broadcast(ngood, nbad, nsample).size`` samples are drawn."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.hypergeometric:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.hypergeometric:45
msgid "**out**"
msgstr "**out**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.hypergeometric:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.hypergeometric:37
msgid ""
"Drawn samples from the parameterized hypergeometric distribution. Each "
"sample is the number of good items within a randomly selected subset of size "
"`nsample` taken from a set of `ngood` good items and `nbad` bad items."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.hypergeometric:50
msgid ":obj:`scipy.stats.hypergeom`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.hypergeometric:51
msgid ""
"probability density function, distribution or cumulative density function, "
"etc."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.hypergeometric:52
msgid ":obj:`random.Generator.hypergeometric`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.hypergeometric:53
msgid "which should be used for new code."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.hypergeometric:57
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.hypergeometric:58
msgid ""
"The probability mass function (PMF) for the Hypergeometric distribution is"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.hypergeometric:60
msgid ""
"P(x) = \\frac{\\binom{g}{x}\\binom{b}{n-x}}{\\binom{g+b}{n}},\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.hypergeometric:62
msgid "where :math:`0 \\le x \\le n` and :math:`n-b \\le x \\le g`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.hypergeometric:64
msgid ""
"for P(x) the probability of ``x`` good results in the drawn sample, g = "
"`ngood`, b = `nbad`, and n = `nsample`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.hypergeometric:67
msgid ""
"Consider an urn with black and white marbles in it, `ngood` of them are "
"black and `nbad` are white. If you draw `nsample` balls without replacement, "
"then the hypergeometric distribution describes the distribution of black "
"balls in the drawn sample."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.hypergeometric:72
msgid ""
"Note that this distribution is very similar to the binomial distribution, "
"except that in this case, samples are drawn without replacement, whereas in "
"the Binomial case samples are drawn with replacement (or the sample space is "
"infinite). As the sample space becomes large, this distribution approaches "
"the binomial."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.hypergeometric:79
msgid "References"
msgstr ""

