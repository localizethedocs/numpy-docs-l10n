#: ../../../reference/random/generated/numpy.random.RandomState.exponential.rst:4
msgid "numpy.random.RandomState.exponential"
msgstr ""

#: ../../../reference/random/generated/numpy.random.RandomState.exponential.rst:8
msgid "method"
msgstr "方法"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.exponential:2
msgid "Draw samples from an exponential distribution."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.exponential:4
msgid "Its probability density function is"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.exponential:6
msgid ""
"f(x; \\frac{1}{\\beta}) = \\frac{1}{\\beta} \\exp(-\\frac{x}{\\beta}),\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.exponential:8
msgid ""
"for ``x > 0`` and 0 elsewhere. :math:`\\beta` is the scale parameter, which "
"is the inverse of the rate parameter :math:`\\lambda = 1/\\beta`. The rate "
"parameter is an alternative, widely used parameterization of the exponential "
"distribution [Rcfd3e98ffb09-3]_."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.exponential:13
msgid ""
"The exponential distribution is a continuous analogue of the geometric "
"distribution.  It describes many common situations, such as the size of "
"raindrops measured over many rainstorms [Rcfd3e98ffb09-1]_, or the time "
"between page requests to Wikipedia [Rcfd3e98ffb09-2]_."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.exponential:19
msgid ""
"New code should use the `~numpy.random.Generator.exponential` method of a "
"`~numpy.random.Generator` instance instead; please see the :ref:`random-"
"quick-start`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.exponential:0
msgid "Parameters"
msgstr "參數"

