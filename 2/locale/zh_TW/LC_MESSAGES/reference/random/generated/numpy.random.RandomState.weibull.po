msgstr "**a**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.weibull:-1
msgid "float or array_like of floats"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.weibull:22
msgid "Shape parameter of the distribution.  Must be nonnegative."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.weibull:30
msgid "**size**"
msgstr "**size**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
