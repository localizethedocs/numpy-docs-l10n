#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.weibull:2
msgid "Draw samples from a Weibull distribution."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.weibull:4
msgid ""
"Draw samples from a 1-parameter Weibull distribution with the given shape "
"parameter `a`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.weibull:7
msgid ""
"X = (-ln(U))^{1/a}\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.weibull:9
msgid "Here, U is drawn from the uniform distribution over (0,1]."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.weibull:11
msgid ""
"The more common 2-parameter Weibull, including a scale parameter :math:"
"`\\lambda` is just :math:`X = \\lambda(-ln(U))^{1/a}`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.weibull:15
msgid ""
"New code should use the `~numpy.random.Generator.weibull` method of a "
"`~numpy.random.Generator` instance instead; please see the :ref:`random-"
"quick-start`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.weibull:0
msgid "Parameters"
msgstr "參數"

