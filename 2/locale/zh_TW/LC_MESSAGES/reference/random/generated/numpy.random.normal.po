msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.normal:75
msgid ""
"P. R. Peebles Jr., \"Central Limit Theorem\" in \"Probability, Random "
"Variables and Random Signal Principles\", 4th ed., 2001, pp. 51, 51, 125."
msgstr ""

