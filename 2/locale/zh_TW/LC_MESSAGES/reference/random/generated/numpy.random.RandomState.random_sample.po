#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.random_sample:4
msgid ""
"Results are from the \"continuous uniform\" distribution over the stated "
"interval.  To sample :math:`Unif[a, b), b > a` multiply the output of "
"`random_sample` by `(b-a)` and add `a`::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.random_sample:8
msgid "(b - a) * random_sample() + a"
msgstr ""

