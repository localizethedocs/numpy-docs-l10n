#: ../../../reference/generated/numpy.bitwise_xor.rst:4
msgid "numpy.bitwise\\_xor"
msgstr ""

#: ../../../../docstring of numpy.bitwise_xor:2
msgid "Compute the bit-wise XOR of two arrays element-wise."
msgstr ""

#: ../../../../docstring of numpy.bitwise_xor:4
msgid ""
"Computes the bit-wise XOR of the underlying binary representation of the "
"integers in the input arrays. This ufunc implements the C/Python operator "
"``^``."
msgstr ""

#: ../../../../docstring of numpy.bitwise_xor:0
msgid "Parameters"
msgstr "參數"

#: ../../../../docstring of numpy.bitwise_xor:13
msgid "**x1, x2**"
msgstr ""

#: ../../../../docstring of numpy.bitwise_xor:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../docstring of numpy.bitwise_xor:11
msgid ""
"Only integer and boolean types are handled. If ``x1.shape != x2.shape``, "
"they must be broadcastable to a common shape (which becomes the shape of the "
"output)."
msgstr ""

#: ../../../../docstring of numpy.bitwise_xor:19 numpy.bitwise_xor:43
msgid "**out**"
msgstr "**out**"

#: ../../../../docstring of numpy.bitwise_xor:-1
msgid "ndarray, None, or tuple of ndarray and None, optional"
msgstr ""

#: ../../../../docstring of numpy.bitwise_xor:16
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or None, a freshly-"
"allocated array is returned. A tuple (possible only as a keyword argument) "
"must have length equal to the number of outputs."
msgstr ""

#: ../../../../docstring of numpy.bitwise_xor:27
msgid "**where**"
msgstr "**where**"

#: ../../../../docstring of numpy.bitwise_xor:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../docstring of numpy.bitwise_xor:22
msgid ""
"This condition is broadcast over the input. At locations where the condition "
"is True, the `out` array will be set to the ufunc result. Elsewhere, the "
"`out` array will retain its original value. Note that if an uninitialized "
"`out` array is created via the default ``out=None``, locations within it "
"where the condition is False will remain uninitialized."
msgstr ""

#: ../../../../docstring of numpy.bitwise_xor:31
msgid "**\\*\\*kwargs**"
msgstr "**\\*\\*kwargs**"

#: ../../../../docstring of numpy.bitwise_xor:30
msgid ""
"For other keyword-only arguments, see the :ref:`ufunc docs <ufuncs.kwargs>`."
msgstr ""

#: ../../../../docstring of numpy.bitwise_xor:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../docstring of numpy.bitwise_xor:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.bitwise_xor:36
msgid "Result. This is a scalar if both `x1` and `x2` are scalars."
msgstr ""

#: ../../../../docstring of numpy.bitwise_xor:48
msgid ":obj:`logical_xor`"
msgstr ":obj:`logical_xor`"

#: ../../../../docstring of numpy.bitwise_xor:50
msgid ":obj:`bitwise_and`"
msgstr ":obj:`bitwise_and`"

#: ../../../../docstring of numpy.bitwise_xor:52
msgid ":obj:`bitwise_or`"
msgstr ":obj:`bitwise_or`"

#: ../../../../docstring of numpy.bitwise_xor:54
msgid ":obj:`binary_repr`"
msgstr ":obj:`binary_repr`"

#: ../../../../docstring of numpy.bitwise_xor:55
msgid "Return the binary representation of the input number as a string."
msgstr ""

#: ../../../../docstring of numpy.bitwise_xor:61
msgid "Examples"
msgstr "範例"

#: ../../../../docstring of numpy.bitwise_xor:68
msgid ""
"The number 13 is represented by ``00001101``. Likewise, 17 is represented by "
"``00010001``.  The bit-wise XOR of 13 and 17 is therefore ``00011100``, or "
"28:"
msgstr ""

#: ../../../../docstring of numpy.bitwise_xor:87
msgid ""
"The ``^`` operator can be used as a shorthand for ``np.bitwise_xor`` on "
"ndarrays."
msgstr ""

