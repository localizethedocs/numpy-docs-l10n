msgid "**x**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagfit:-1
msgid "array_like, shape (M,)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagfit:18
msgid "x-coordinates of the M sample points ``(x[i], y[i])``."
msgstr ""

