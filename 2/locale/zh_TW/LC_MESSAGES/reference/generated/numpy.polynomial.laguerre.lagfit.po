#: of numpy.polynomial.laguerre.lagfit:-1
msgid "ndarray, shape (M,) or (M, K)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagfit:52
msgid ""
"Laguerre coefficients ordered from low to high. If `y` was 2-D, the "
