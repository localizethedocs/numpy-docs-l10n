#: ../../../reference/generated/numpy.polynomial.laguerre.lagfit.rst:4
msgid "numpy.polynomial.laguerre.lagfit"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagfit:2
msgid "Least squares fit of Laguerre series to data."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagfit:4
msgid ""
"Return the coefficients of a Laguerre series of degree `deg` that is the "
"least squares fit to the data values `y` given at points `x`. If `y` is 1-D "
"the returned coefficients will also be 1-D. If `y` is 2-D multiple fits are "
"done, one for each column of `y`, and the resulting coefficients are stored "
"in the corresponding columns of a 2-D return. The fitted polynomial(s) are "
"in the form"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagfit:11
msgid ""
"p(x) = c_0 + c_1 * L_1(x) + ... + c_n * L_n(x),\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagfit:13
msgid "where ``n`` is `deg`."
msgstr ""

