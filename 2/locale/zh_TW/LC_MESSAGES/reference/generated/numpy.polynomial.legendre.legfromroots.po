#: ../../../reference/generated/numpy.polynomial.legendre.legfromroots.rst:4
msgid "numpy.polynomial.legendre.legfromroots"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfromroots:2
msgid "Generate a Legendre series with given roots."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfromroots:4
msgid "The function returns the coefficients of the polynomial"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfromroots:6
msgid ""
"p(x) = (x - r_0) * (x - r_1) * ... * (x - r_n),\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfromroots:8
msgid ""
"in Legendre form, where the :math:`r_n` are the roots specified in `roots`. "
"If a zero has multiplicity n, then it must appear in `roots` n times. For "
"instance, if 2 is a root of multiplicity three and 3 is a root of "
"multiplicity 2, then `roots` looks something like [2, 2, 2, 3, 3]. The roots "
"can appear in any order."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfromroots:14
msgid "If the returned coefficients are `c`, then"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfromroots:16
msgid ""
"p(x) = c_0 + c_1 * L_1(x) + ... +  c_n * L_n(x)\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfromroots:18
msgid ""
"The coefficient of the last term is not generally 1 for monic polynomials in "
"Legendre form."
msgstr ""

