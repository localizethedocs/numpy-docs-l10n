#: ../../../reference/generated/numpy.nditer.rst:2
msgid "numpy.nditer"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:2
msgid ""
"Efficient multi-dimensional iterator object to iterate over arrays. To get "
"started using this object, see the :ref:`introductory guide to array "
"iteration <arrays.nditer>`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:10
msgid "**op**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:-1
msgid "ndarray or sequence of array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:10
msgid "The array(s) to iterate over."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:41
msgid "**flags**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:-1
msgid "sequence of str, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:13
msgid "Flags to control the behavior of the iterator."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:15
msgid "``buffered`` enables buffering when required."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:16
msgid "``c_index`` causes a C-order index to be tracked."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:17
msgid "``f_index`` causes a Fortran-order index to be tracked."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:18
msgid ""
"``multi_index`` causes a multi-index, or a tuple of indices with one per "
"iteration dimension, to be tracked."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:20
msgid ""
"``common_dtype`` causes all the operands to be converted to a common data "
"type, with copying or buffering as necessary."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:22
msgid ""
"``copy_if_overlap`` causes the iterator to determine if read operands have "
"overlap with write operands, and make temporary copies as necessary to avoid "
"overlap. False positives (needless copying) are possible in some cases."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:26
msgid ""
"``delay_bufalloc`` delays allocation of the buffers until a reset() call is "
"made. Allows ``allocate`` operands to be initialized before their values are "
"copied into the buffers."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:29
msgid ""
"``external_loop`` causes the ``values`` given to be one-dimensional arrays "
"with multiple values instead of zero-dimensional arrays."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:32
msgid ""
"``grow_inner`` allows the ``value`` array sizes to be made larger than the "
"buffer size when both ``buffered`` and ``external_loop`` is used."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:35
msgid ""
"``ranged`` allows the iterator to be restricted to a sub-range of the "
"iterindex values."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:37
msgid ""
"``refs_ok`` enables iteration of reference types, such as object arrays."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:39
msgid ""
"``reduce_ok`` enables iteration of ``readwrite`` operands which are "
"broadcasted, also known as reduction operands."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:41
msgid "``zerosize_ok`` allows `itersize` to be zero."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:68
msgid "**op_flags**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:-1
msgid "list of list of str, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:44
msgid ""
"This is a list of flags for each operand. At minimum, one of ``readonly``, "
"``readwrite``, or ``writeonly`` must be specified."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:47
msgid "``readonly`` indicates the operand will only be read from."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:48
msgid "``readwrite`` indicates the operand will be read from and written to."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:49
msgid "``writeonly`` indicates the operand will only be written to."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:50
msgid "``no_broadcast`` prevents the operand from being broadcasted."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:51
msgid "``contig`` forces the operand data to be contiguous."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:52
msgid "``aligned`` forces the operand data to be aligned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:53
msgid "``nbo`` forces the operand data to be in native byte order."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:54
msgid "``copy`` allows a temporary read-only copy if required."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:55
msgid "``updateifcopy`` allows a temporary read-write copy if required."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:56
msgid ""
"``allocate`` causes the array to be allocated if it is None in the ``op`` "
"parameter."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:58
msgid "``no_subtype`` prevents an ``allocate`` operand from using a subtype."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:59
msgid ""
"``arraymask`` indicates that this operand is the mask to use for selecting "
"elements when writing to operands with the 'writemasked' flag set. The "
"iterator does not enforce this, but when writing from a buffer back to the "
"array, it only copies those elements indicated by this mask."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:64
msgid ""
"``writemasked`` indicates that only elements where the chosen ``arraymask`` "
"operand is True will be written to."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:66
msgid ""
"``overlap_assume_elementwise`` can be used to mark operands that are "
"accessed only in the iterator order, to allow less conservative copying when "
"``copy_if_overlap`` is present."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:72
msgid "**op_dtypes**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:-1
msgid "dtype or tuple of dtype(s), optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:71
msgid ""
"The required data type(s) of the operands. If copying or buffering is "
"enabled, the data will be converted to/from their original types."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:81
msgid "**order**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:-1
msgid "{'C', 'F', 'A', 'K'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:75
msgid ""
"Controls the iteration order. 'C' means C order, 'F' means Fortran order, "
"'A' means 'F' order if all the arrays are Fortran contiguous, 'C' order "
"otherwise, and 'K' means as close to the order the array elements appear in "
"memory as possible. This also affects the element memory order of "
"``allocate`` operands, as they are allocated to be compatible with iteration "
"order. Default is 'K'."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:93
msgid "**casting**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:-1
msgid "{'no', 'equiv', 'safe', 'same_kind', 'unsafe'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:84
msgid ""
"Controls what kind of data casting may occur when making a copy or "
"buffering.  Setting this to 'unsafe' is not recommended, as it can adversely "
"affect accumulations."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:88
msgid "'no' means the data types should not be cast at all."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:89
msgid "'equiv' means only byte-order changes are allowed."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:90
msgid "'safe' means only casts which can preserve values are allowed."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:91
msgid ""
"'same_kind' means only safe casts or casts within a kind, like float64 to "
"float32, are allowed."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:93
msgid "'unsafe' means any data conversions may be done."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:100
msgid "**op_axes**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:-1
msgid "list of list of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:96
msgid ""
"If provided, is a list of ints or None for each operands. The list of axes "
"for an operand is a mapping from the dimensions of the iterator to the "
"dimensions of the operand. A value of -1 can be placed for entries, causing "
"that dimension to be treated as `newaxis`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:106
msgid "**itershape**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:-1
msgid "tuple of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:103
msgid ""
"The desired shape of the iterator. This allows ``allocate`` operands with a "
"dimension mapped by op_axes not corresponding to a dimension of a different "
"operand to get a value not equal to 1 for that dimension."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:118
msgid "**buffersize**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:109
msgid ""
"When buffering is enabled, controls the size of the temporary buffers. Set "
"to 0 for the default value."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:121
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:122
msgid ""
"`nditer` supersedes `flatiter`.  The iterator implementation behind `nditer` "
"is also exposed by the NumPy C API."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:125
msgid ""
"The Python exposure supplies two iteration interfaces, one which follows the "
"Python iterator protocol, and another which mirrors the C-style do-while "
"pattern.  The native Python approach is better in most cases, but if you "
"need the coordinates or index of an iterator, use the C-style pattern."
msgstr ""

