msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:248
msgid "**has_delayed_bufalloc**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:247
msgid ""
"If True, the iterator was created with the ``delay_bufalloc`` flag, and no "
"reset() function was called on it yet."
