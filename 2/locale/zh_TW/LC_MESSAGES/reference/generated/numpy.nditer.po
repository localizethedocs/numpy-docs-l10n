msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:251
msgid ""
"If True, the iterator was created with either the ``c_index`` or the "
"``f_index`` flag, and the property `index` can be used to retrieve it."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:257
msgid "**has_multi_index**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:256
msgid ""
"If True, the iterator was created with the ``multi_index`` flag, and the "
"property `multi_index` can be used to retrieve it."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:262
msgid "**index**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:260
msgid ""
"When the ``c_index`` or ``f_index`` flag was used, this property provides "
"access to the index. Raises a ValueError if accessed and ``has_index`` is "
"False."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:266
msgid "**iterationneedsapi**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nditer:265
msgid ""
"Whether iteration requires access to the Python API, for example if one of "
"the operands is an object array."
msgstr ""

