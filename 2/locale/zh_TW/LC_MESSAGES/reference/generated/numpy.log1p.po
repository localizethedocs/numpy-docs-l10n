msgstr ""

#: ../../../../docstring of numpy.log1p:2
msgid "Return the natural logarithm of one plus the input array, element-wise."
msgstr ""

#: ../../../../docstring of numpy.log1p:4
msgid "Calculates ``log(1 + x)``."
msgstr ""

