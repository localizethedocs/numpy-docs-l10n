msgid "References"
msgstr ""

#: ../../../../docstring of numpy.log1p:68
msgid ""
"M. Abramowitz and I.A. Stegun, \"Handbook of Mathematical Functions\", 10th "
"printing, 1964, pp. 67. https://personal.math.ubc.ca/~cbm/aands/page_67.htm"
msgstr ""

