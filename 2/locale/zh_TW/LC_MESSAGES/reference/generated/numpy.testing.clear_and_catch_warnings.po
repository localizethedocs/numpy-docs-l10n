#: ../../../reference/generated/numpy.testing.clear_and_catch_warnings.rst:2
msgid "numpy.testing.clear\\_and\\_catch\\_warnings"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.clear_and_catch_warnings:2
msgid "Context manager that resets warning registry for catching warnings"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.clear_and_catch_warnings:4
msgid ""
"Warnings can be slippery, because, whenever a warning is triggered, Python "
"adds a ``__warningregistry__`` member to the *calling* module.  This makes "
"it impossible to retrigger the warning in this module, whatever you put in "
"the warnings filters.  This context manager accepts a sequence of `modules` "
"as a keyword argument to its constructor and:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.clear_and_catch_warnings:10
msgid ""
"stores and removes any ``__warningregistry__`` entries in given `modules` on "
"entry;"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.clear_and_catch_warnings:12
msgid "resets ``__warningregistry__`` to its previous state on exit."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.clear_and_catch_warnings:14
msgid ""
"This makes it possible to trigger any warning afresh inside the context "
"manager without disturbing the state of warnings outside."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.clear_and_catch_warnings:17
msgid ""
"For compatibility with Python, please consider all arguments to be keyword-"
"only."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.clear_and_catch_warnings:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.clear_and_catch_warnings:27
msgid "**record**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.clear_and_catch_warnings:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.clear_and_catch_warnings:23
msgid ""
"Specifies whether warnings should be captured by a custom implementation of "
"``warnings.showwarning()`` and be appended to a list returned by the context "
"manager. Otherwise None is returned by the context manager. The objects "
"appended to the list are arguments whose attributes mirror the arguments to "
"``showwarning()``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.clear_and_catch_warnings:42
msgid "**modules**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.clear_and_catch_warnings:-1
msgid "sequence, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.clear_and_catch_warnings:30
msgid ""
"Sequence of modules for which to reset warnings registry on entry and "
"restore on exit. To work correctly, all 'ignore' filters should filter by "
"one of these modules."
msgstr ""

