#: of numpy.percentile:54
msgid ""
"This argument was previously called \"interpolation\" and only offered the "
"\"linear\" default and last four options."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.percentile:61
msgid "**keepdims**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.percentile:59
msgid ""
"If this is set to True, the axes which are reduced are left in the result as "
"dimensions with size one. With this option, the result will broadcast "
"correctly against the original array `a`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.percentile:73
msgid "**weights**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.percentile:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.percentile:64
msgid ""
"An array of weights associated with the values in `a`. Each value in `a` "
"contributes to the percentile according to its associated weight. The "
"weights array can either be 1-D (in which case its length must be the size "
"of `a` along the given axis) or of the same shape as `a`. If `weights=None`, "
"then all data in `a` are assumed to have a weight equal to one. Only "
"`method=\"inverted_cdf\"` supports weights. See the notes for more details."
msgstr ""

