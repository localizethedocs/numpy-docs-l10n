#: ../../../reference/generated/numpy.stack.rst:4
msgid "numpy.stack"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.stack:2
msgid "Join a sequence of arrays along a new axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.stack:4
msgid ""
"The ``axis`` parameter specifies the index of the new axis in the dimensions "
"of the result. For example, if ``axis=0`` it will be the first dimension and "
"if ``axis=-1`` it will be the last dimension."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.stack:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.stack:13
msgid "**arrays**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.stack:-1
msgid "sequence of ndarrays"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.stack:11
msgid ""
"Each array must have the same shape. In the case of a single ndarray "
"array_like input, it will be treated as a sequence of arrays; i.e., each "
"element along the zeroth axis is treated as a separate array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.stack:16
msgid "**axis**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.stack:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.stack:16
msgid "The axis in the result array along which the input arrays are stacked."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.stack:21
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.stack:-1
msgid "ndarray, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.stack:19
msgid ""
"If provided, the destination to place the result. The shape must be correct, "
"matching that of what stack would have returned if no out argument were "
"specified."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.stack:27
msgid "**dtype**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.stack:-1
msgid "str or dtype"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.stack:24
msgid ""
"If provided, the destination array will have this dtype. Cannot be provided "
"together with `out`."
msgstr ""

