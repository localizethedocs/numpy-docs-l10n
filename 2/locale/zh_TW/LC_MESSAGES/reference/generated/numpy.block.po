#: of numpy.block:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.block:25
msgid "**arrays**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.block:-1
msgid "nested list of array_like or scalars (but not tuples)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.block:20
msgid ""
"If passed a single ndarray or scalar (a nested list of depth 0), this is "
"returned unmodified (and not copied)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.block:23
msgid ""
"Elements shapes must match along the appropriate axes (without "
"broadcasting), but leading 1s will be prepended to the shape as necessary to "
"make the dimensions match."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
