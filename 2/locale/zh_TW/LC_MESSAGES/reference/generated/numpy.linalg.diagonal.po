#: of numpy.linalg.diagonal:-1
msgid "(...,min(N,M)) ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.diagonal:27
msgid ""
"An array containing the diagonals and whose shape is determined by removing "
"the last two dimensions and appending a dimension equal to the size of the "
"resulting diagonals. The returned array must have the same data type as "
"``x``."
msgstr ""

