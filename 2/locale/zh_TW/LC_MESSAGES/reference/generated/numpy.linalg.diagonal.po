msgid ""
"Offset specifying the off-diagonal relative to the main diagonal, where::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.diagonal:18
msgid ""
"* offset = 0: the main diagonal.\n"
"* offset > 0: off-diagonal above the main diagonal.\n"
"* offset < 0: off-diagonal below the main diagonal."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.diagonal:0
msgid "Returns"
msgstr "回傳值"

