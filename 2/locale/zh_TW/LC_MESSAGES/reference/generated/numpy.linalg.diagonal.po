msgid "numpy.linalg.diagonal"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.diagonal:2
msgid "Returns specified diagonals of a matrix (or a stack of matrices) ``x``."
msgstr "傳回矩陣（或矩陣堆疊）「`x``的指定對角線。"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.diagonal:4
msgid ""
"This function is Array API compatible, contrary to :py:func:`numpy."
"diagonal`, the matrix is assumed to be defined by the last two dimensions."
msgstr ""

