#: ../../../reference/generated/numpy.lib.format.open_memmap.rst:4
msgid "numpy.lib.format.open\\_memmap"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:2
msgid "Open a .npy file as a memory-mapped array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:4
msgid "This may be used to read an existing file or create a new one."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:10
msgid "**filename**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:-1
msgid "str or path-like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:9
msgid "The name of the file on disk.  This may *not* be a file-like object."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:15
msgid "**mode**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:-1
msgid "str, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:13
msgid ""
"The mode in which to open the file; the default is 'r+'.  In addition to the "
"standard file modes, 'c' is also accepted to mean \"copy on write.\"  See "
"`memmap` for the available mode strings."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:20
msgid "**dtype**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:-1
msgid "data-type, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:18
msgid ""
"The data type of the array if we are creating a new file in \"write\" mode, "
"if not, `dtype` is ignored.  The default value is None, which results in a "
"data-type of `float64`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:25
msgid "**shape**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:-1
msgid "tuple of int"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:23
msgid ""
"The shape of the array if we are creating a new file in \"write\" mode, in "
"which case this parameter is required.  Otherwise, this parameter is ignored "
"and is thus optional."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:30
msgid "**fortran_order**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:28
msgid ""
"Whether the array should be Fortran-contiguous (True) or C-contiguous "
"(False, the default) if we are creating a new file in \"write\" mode."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:35
msgid "**version**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:-1
msgid "tuple of int (major, minor) or None"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:33
msgid ""
"If the mode is a \"write\" mode, then this is the version of the file format "
"used to create the file.  None means use the oldest supported version that "
"is able to store the data.  Default: None"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:40
msgid "**max_header_size**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:38
msgid ""
"Maximum allowed size of the header.  Large headers may not be safe to load "
"securely and thus require explicitly passing a larger value. See :py:func:"
"`ast.literal_eval()` for details."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:48
msgid "**marray**"
msgstr ""

