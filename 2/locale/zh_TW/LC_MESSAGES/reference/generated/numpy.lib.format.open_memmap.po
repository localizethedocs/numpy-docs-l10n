#: of numpy.lib.format.open_memmap:-1
msgid "memmap"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:45
msgid "The memory-mapped array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:0
msgid "Raises"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:53
msgid "ValueError"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:53
msgid "If the data or the mode is invalid."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:58
msgid "OSError"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.open_memmap:56
msgid "If the file is not found or cannot be opened correctly."
msgstr ""

