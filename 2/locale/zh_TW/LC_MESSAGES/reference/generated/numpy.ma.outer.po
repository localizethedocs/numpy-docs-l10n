#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.outer:2
msgid "Compute the outer product of two vectors."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.outer:4
msgid ""
"Given two vectors `a` and `b` of length ``M`` and ``N``, respectively, the "
"outer product [R863504129d6e-1]_ is::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.outer:7
msgid ""
"[[a_0*b_0  a_0*b_1 ... a_0*b_{N-1} ]\n"
" [a_1*b_0    .\n"
" [ ...          .\n"
" [a_{M-1}*b_0            a_{M-1}*b_{N-1} ]]"
msgstr ""

