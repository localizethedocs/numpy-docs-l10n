#: ../../../reference/generated/numpy.ma.var.rst:4
msgid "numpy.ma.var"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:2
msgid "Compute the variance along the specified axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:4
msgid ""
"Returns the variance of the array elements, a measure of the spread of a "
"distribution.  The variance is computed for the flattened array by default, "
"otherwise over the specified axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:12
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:11
msgid ""
"Array containing numbers whose variance is desired.  If `a` is not an array, "
"a conversion is attempted."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:18
msgid "**axis**"
msgstr "**axis**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:-1
msgid "None or int or tuple of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:15
msgid ""
"Axis or axes along which the variance is computed.  The default is to "
"compute the variance of the flattened array. If this is a tuple of ints, a "
"variance is performed over multiple axes, instead of a single axis or all "
"the axes as before."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:23
msgid "**dtype**"
msgstr "**dtype**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:-1
msgid "data-type, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:21
msgid ""
"Type to use in computing the variance.  For arrays of integer type the "
"default is `float64`; for arrays of float types it is the same as the array "
"type."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:28
msgid "**out**"
msgstr "**out**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:-1
msgid "ndarray, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:26
msgid ""
"Alternate output array in which to place the result.  It must have the same "
"shape as the expected output, but the type is cast if necessary."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:33
msgid "**ddof**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:-1
msgid "{int, float}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:31
msgid ""
"\"Delta Degrees of Freedom\": the divisor used in the calculation is ``N - "
"ddof``, where ``N`` represents the number of elements. By default `ddof` is "
"zero. See notes for details about use of `ddof`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:44
msgid "**keepdims**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:36
msgid ""
"If this is set to True, the axes which are reduced are left in the result as "
"dimensions with size one. With this option, the result will broadcast "
"correctly against the input array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:40
msgid ""
"If the default value is passed, then `keepdims` will not be passed through "
"to the `var` method of sub-classes of `ndarray`, however any non-default "
"value will be.  If the sub-class' method does not implement `keepdims` any "
"exceptions will be raised."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:50
msgid "**where**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:-1
msgid "array_like of bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:47
msgid ""
"Elements to include in the variance. See `~numpy.ufunc.reduce` for details."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:58
msgid "**mean**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:-1
msgid "array like, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:53
msgid ""
"Provide the mean to prevent its recalculation. The mean should have a shape "
"as if it was calculated with ``keepdims=True``. The axis for the calculation "
"of the mean should be the same as used in the call to this var function."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:64
msgid "**correction**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:61
msgid ""
"Array API compatible name for the ``ddof`` parameter. Only one of them can "
"be provided at the same time."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:76
msgid "**variance**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:-1
msgid "ndarray, see dtype parameter above"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:69
msgid ""
"If ``out=None``, returns a new array containing the variance; otherwise, a "
"reference to the output array is returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:81
msgid ":obj:`std`, :obj:`mean`, :obj:`nanmean`, :obj:`nanstd`, :obj:`nanvar`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:83
msgid ":ref:`ufuncs-output-type`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:87
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:88
msgid ""
"There are several common variants of the array variance calculation. "
"Assuming the input `a` is a one-dimensional NumPy array and ``mean`` is "
"either provided as an argument or computed as ``a.mean()``, NumPy computes "
"the variance of an array as::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:93
msgid ""
"N = len(a)\n"
"d2 = abs(a - mean)**2  # abs is for complex `a`\n"
"var = d2.sum() / (N - ddof)  # note use of `ddof`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:97
msgid ""
"Different values of the argument `ddof` are useful in different contexts. "
"NumPy's default ``ddof=0`` corresponds with the expression:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:100
msgid "\\frac{\\sum_i{|a_i - \\bar{a}|^2 }}{N}"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:104
msgid ""
"which is sometimes called the \"population variance\" in the field of "
"statistics because it applies the definition of variance to `a` as if `a` "
"were a complete population of possible observations."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:108
msgid "Many other libraries define the variance of an array differently, e.g.:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:110
msgid "\\frac{\\sum_i{|a_i - \\bar{a}|^2}}{N - 1}"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:114
msgid ""
"In statistics, the resulting quantity is sometimes called the \"sample "
"variance\" because if `a` is a random sample from a larger population, this "
"calculation provides an unbiased estimate of the variance of the "
"population.  The use of :math:`N-1` in the denominator is often called "
"\"Bessel's correction\" because it corrects for bias (toward lower values) "
"in the variance estimate introduced when the sample mean of `a` is used in "
"place of the true mean of the population. For this quantity, use ``ddof=1``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:123
msgid ""
"Note that for complex numbers, the absolute value is taken before squaring, "
"so that the result is always real and nonnegative."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.var:126
msgid ""
"For floating-point input, the variance is computed using the same precision "
"the input has.  Depending on the input data, this can cause the results to "
"be inaccurate, especially for `float32` (see example below).  Specifying a "
"higher-accuracy accumulator using the ``dtype`` keyword can alleviate this "
"issue."
msgstr ""

