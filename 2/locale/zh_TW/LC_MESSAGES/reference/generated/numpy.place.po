#: ../../../reference/generated/numpy.place.rst:4
msgid "numpy.place"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.place:2
msgid "Change elements of an array based on conditional and input values."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.place:4
msgid ""
"Similar to ``np.copyto(arr, vals, where=mask)``, the difference is that "
"`place` uses the first N elements of `vals`, where N is the number of True "
"values in `mask`, while `copyto` uses the elements where `mask` is True."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.place:9
msgid "Note that `extract` does the exact opposite of `place`."
msgstr ""

