msgid "numpy.array"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:2
msgid "Create an array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:11
msgid "**object**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:8
msgid ""
"An array, any object exposing the array interface, an object whose "
"``__array__`` method returns an array, or any (nested) sequence. If object "
"is a scalar, a 0-dimensional array containing object is returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:16
msgid "**dtype**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:-1
msgid "data-type, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:14
msgid ""
"The desired data-type for the array. If not given, NumPy will try to use a "
"default ``dtype`` that can represent the values (by applying promotion rules "
"when necessary.)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:26
msgid "**copy**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:19
msgid ""
"If ``True`` (default), then the array data is copied. If ``None``, a copy "
"will only be made if ``__array__`` returns a copy, if obj is a nested "
"sequence, or if a copy is needed to satisfy any of the other requirements "
"(``dtype``, ``order``, etc.). Note that any copy of the data is shallow, i."
"e., for arrays with object dtype, the new array will point to the same "
"objects. See Examples for `ndarray.copy`. For ``False`` it raises a "
"``ValueError`` if a copy cannot be avoided. Default: ``True``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:45
msgid "**order**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:-1
msgid "{'K', 'A', 'C', 'F'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:29
msgid ""
"Specify the memory layout of the array. If object is not an array, the newly "
"created array will be in C order (row major) unless 'F' is specified, in "
"which case it will be in Fortran order (column major). If object is an array "
"the following holds."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:35
msgid "order"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:35
msgid "no copy"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:35
msgid "copy=True"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:37
msgid "'K'"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:37 numpy.array:38
msgid "unchanged"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:37
msgid "F & C order preserved, otherwise most similar order"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:38
msgid "'A'"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:38
msgid "F order if input is F and not C, otherwise C order"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:39
msgid "'C'"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:39
msgid "C order"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:40
msgid "'F'"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:40
msgid "F order"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:43
msgid ""
"When ``copy=None`` and a copy is made for other reasons, the result is the "
"same as if ``copy=True``, with some exceptions for 'A', see the Notes "
"section. The default order is 'K'."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:49
msgid "**subok**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:48
msgid ""
"If True, then sub-classes will be passed-through, otherwise the returned "
"array will be forced to be a base-class array (default)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:54
msgid "**ndmin**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:52
msgid ""
"Specifies the minimum number of dimensions that the resulting array should "
"have.  Ones will be prepended to the shape as needed to meet this "
"requirement."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:65
msgid "**ndmax**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:57
msgid ""
"Specifies the maximum number of dimensions to create when inferring shape "
"from nested sequences. By default (ndmax=0), NumPy recurses through all "
"nesting levels (up to the compile-time constant ``NPY_MAXDIMS``). Setting "
"``ndmax`` stops recursion at the specified depth, preserving deeper nested "
"structures as objects instead of promoting them to higher-dimensional "
"arrays. In this case, ``dtype=object`` is required."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:74
msgid "**like**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array:68
msgid ""
"Reference object to allow the creation of arrays which are not NumPy arrays. "
"If an array-like passed in as ``like`` supports the ``__array_function__`` "
"protocol, the result will be defined by it. In this case, it ensures the "
"creation of an array object compatible with that passed in via this argument."
msgstr ""

