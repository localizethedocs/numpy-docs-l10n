#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfft2:29
msgid ""
"The axes over which to compute the inverse fft. Default: ``(-2, -1)``, the "
"last two axes."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfft2:34
msgid ""
"If `s` is specified, the corresponding `axes` to be transformed must not be "
"``None``."
msgstr ""

