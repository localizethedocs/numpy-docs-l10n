#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.outer:2
msgid "Apply the ufunc `op` to all pairs (a, b) with a in `A` and b in `B`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.outer:4
msgid ""
"Let ``M = A.ndim``, ``N = B.ndim``. Then the result, `C`, of ``op.outer(A, "
"B)`` is an array of dimension M + N such that:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.outer:7
msgid ""
"C[i_0, ..., i_{M-1}, j_0, ..., j_{N-1}] =\n"
"op(A[i_0, ..., i_{M-1}], B[j_0, ..., j_{N-1}])\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.outer:10
msgid "For `A` and `B` one-dimensional, this is equivalent to::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.outer:12
msgid ""
"r = empty(len(A),len(B))\n"
"for i in range(len(A)):\n"
"    for j in range(len(B)):\n"
"        r[i,j] = op(A[i], B[j])  # op = ufunc in question"
msgstr ""

