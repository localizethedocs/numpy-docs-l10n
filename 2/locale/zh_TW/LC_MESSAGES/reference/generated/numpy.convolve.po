#: ../../../reference/generated/numpy.convolve.rst:4
msgid "numpy.convolve"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.convolve:2
msgid ""
"Returns the discrete, linear convolution of two one-dimensional sequences."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.convolve:4
msgid ""
"The convolution operator is often seen in signal processing, where it models "
"the effect of a linear time-invariant system on a signal "
"[R95849f33d2b1-1]_.  In probability theory, the sum of two independent "
"random variables is distributed according to the convolution of their "
"individual distributions."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.convolve:10
msgid "If `v` is longer than `a`, the arrays are swapped before computation."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.convolve:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.convolve:15
msgid "**a**"
msgstr "**a**"

