#: of numpy.convolve:57
msgid ":obj:`polymul`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.convolve:58
msgid ""
"Polynomial multiplication. Same output as convolve, but also accepts poly1d "
"objects as input."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.convolve:62
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.convolve:63
msgid "The discrete convolution operation is defined as"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.convolve:65
msgid ""
"(a * v)_n = \\sum_{m = -\\infty}^{\\infty} a_m v_{n - m}\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.convolve:67
msgid ""
"It can be shown that a convolution :math:`x(t) * y(t)` in time/space is "
"equivalent to the multiplication :math:`X(f) Y(f)` in the Fourier domain, "
"after appropriate padding (padding is necessary to prevent circular "
"convolution).  Since multiplication is more efficient (faster) than "
"convolution, the function `scipy.signal.fftconvolve` exploits the FFT to "
"calculate the convolution of large data-sets."
msgstr ""

