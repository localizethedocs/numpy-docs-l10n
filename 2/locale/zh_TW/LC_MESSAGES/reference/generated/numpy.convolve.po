#: of numpy.convolve:-1
msgid "(N,) array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.convolve:15
msgid "First one-dimensional input array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.convolve:18
msgid "**v**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.convolve:-1
msgid "(M,) array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.convolve:18
msgid "Second one-dimensional input array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.convolve:37
msgid "**mode**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.convolve:-1
msgid "{'full', 'valid', 'same'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.convolve:25
msgid "'full':"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.convolve:22
msgid ""
"By default, mode is 'full'.  This returns the convolution at each point of "
"overlap, with an output shape of (N+M-1,). At the end-points of the "
"convolution, the signals do not overlap completely, and boundary effects may "
"be seen."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.convolve:29
msgid "'same':"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.convolve:28
msgid ""
"Mode 'same' returns output of length ``max(M, N)``.  Boundary effects are "
"still visible."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.convolve:37
msgid "'valid':"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.convolve:32
msgid ""
"Mode 'valid' returns output of length ``max(M, N) - min(M, N) + 1``.  The "
"convolution product is only given for points where the signals overlap "
"completely.  Values outside the signal boundary have no effect."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.convolve:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.convolve:48
msgid "**out**"
msgstr "**out**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.convolve:-1
msgid "ndarray"
msgstr "ndarray"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.convolve:42
msgid "Discrete, linear convolution of `a` and `v`."
msgstr ""

