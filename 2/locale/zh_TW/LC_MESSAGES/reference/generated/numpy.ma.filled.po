#: ../../../reference/generated/numpy.ma.filled.rst:4
msgid "numpy.ma.filled"
msgstr "numpy.ma.filled"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.filled:2
msgid ""
"Return input as an `~numpy.ndarray`, with masked values replaced by "
"`fill_value`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.filled:5
msgid ""
"If `a` is not a `MaskedArray`, `a` itself is returned. If `a` is a "
"`MaskedArray` with no masked values, then ``a.data`` is returned. If `a` is "
"a `MaskedArray` and `fill_value` is None, `fill_value` is set to ``a."
"fill_value``."
msgstr ""

