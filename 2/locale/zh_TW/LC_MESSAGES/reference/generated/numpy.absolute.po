msgid "**absolute**"
msgstr ""

#: ../../../../docstring of numpy.absolute:-1
msgid "ndarray"
msgstr "ndarray"

#: ../../../../docstring of numpy.absolute:32
msgid ""
"An ndarray containing the absolute value of each element in `x`.  For "
"complex input, ``a + ib``, the absolute value is :math:`\\sqrt{ a^2 + b^2 }"
"`. This is a scalar if `x` is a scalar."
msgstr ""

