#: ../../../reference/generated/numpy.nanstd.rst:4
msgid "numpy.nanstd"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:2
msgid ""
"Compute the standard deviation along the specified axis, while ignoring NaNs."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:5
msgid ""
"Returns the standard deviation, a measure of the spread of a distribution, "
"of the non-NaN array elements. The standard deviation is computed for the "
"flattened array by default, otherwise over the specified axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:10
msgid ""
"For all-NaN slices or slices with zero degrees of freedom, NaN is returned "
"and a `RuntimeWarning` is raised."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:16
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:16
msgid "Calculate the standard deviation of the non-NaN values."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:20
msgid "**axis**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:-1
msgid "{int, tuple of int, None}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:19
msgid ""
"Axis or axes along which the standard deviation is computed. The default is "
"to compute the standard deviation of the flattened array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:25
msgid "**dtype**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:-1
msgid "dtype, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:23
msgid ""
"Type to use in computing the standard deviation. For arrays of integer type "
"the default is float64, for arrays of float types it is the same as the "
"array type."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:30
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:-1
msgid "ndarray, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:28
msgid ""
"Alternative output array in which to place the result. It must have the same "
"shape as the expected output but the type (of the calculated values) will be "
"cast if necessary."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:35
msgid "**ddof**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:-1
msgid "{int, float}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:33
msgid ""
"Means Delta Degrees of Freedom.  The divisor used in calculations is ``N - "
"ddof``, where ``N`` represents the number of non-NaN elements.  By default "
"`ddof` is zero."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:45
msgid "**keepdims**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:38
msgid ""
"If this is set to True, the axes which are reduced are left in the result as "
"dimensions with size one. With this option, the result will broadcast "
"correctly against the original `a`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:42
msgid ""
"If this value is anything but the default it is passed through as-is to the "
"relevant functions of the sub-classes.  If these functions do not have a "
"`keepdims` kwarg, a RuntimeError will be raised."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:51
msgid "**where**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:-1
msgid "array_like of bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:48
msgid ""
"Elements to include in the standard deviation. See `~numpy.ufunc.reduce` for "
"details."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:59
msgid "**mean**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:54
msgid ""
"Provide the mean to prevent its recalculation. The mean should have a shape "
"as if it was calculated with ``keepdims=True``. The axis for the calculation "
"of the mean should be the same as used in the call to this std function."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:65
msgid "**correction**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:62
msgid ""
"Array API compatible name for the ``ddof`` parameter. Only one of them can "
"be provided at the same time."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:79
msgid "**standard_deviation**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:-1
msgid "ndarray, see dtype parameter above."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:70
msgid ""
"If `out` is None, return a new array containing the standard deviation, "
"otherwise return a reference to the output array. If ddof is >= the number "
"of non-NaN elements in a slice or the slice contains only NaNs, then the "
"result for that slice is NaN."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:84
msgid ":obj:`var`, :obj:`mean`, :obj:`std`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:86
msgid ":obj:`nanvar`, :obj:`nanmean`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:88
msgid ":ref:`ufuncs-output-type`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:92
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:93
msgid ""
"The standard deviation is the square root of the average of the squared "
"deviations from the mean: ``std = sqrt(mean(abs(x - x.mean())**2))``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:96
msgid ""
"The average squared deviation is normally calculated as ``x.sum() / N``, "
"where ``N = len(x)``.  If, however, `ddof` is specified, the divisor ``N - "
"ddof`` is used instead. In standard statistical practice, ``ddof=1`` "
"provides an unbiased estimator of the variance of the infinite population. "
"``ddof=0`` provides a maximum likelihood estimate of the variance for "
"normally distributed variables. The standard deviation computed in this "
"function is the square root of the estimated variance, so even with "
"``ddof=1``, it will not be an unbiased estimate of the standard deviation "
"per se."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:106
msgid ""
"Note that, for complex numbers, `std` takes the absolute value before "
"squaring, so that the result is always real and nonnegative."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanstd:109
msgid ""
"For floating-point input, the *std* is computed using the same precision the "
"input has. Depending on the input data, this can cause the results to be "
"inaccurate, especially for float32 (see example below).  Specifying a higher-"
"accuracy accumulator using the `dtype` keyword can alleviate this issue."
msgstr ""

