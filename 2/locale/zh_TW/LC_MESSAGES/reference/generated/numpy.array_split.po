#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array_split:2
msgid "Split an array into multiple sub-arrays."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array_split:4
msgid ""
"Please refer to the ``split`` documentation.  The only difference between "
"these functions is that ``array_split`` allows `indices_or_sections` to be "
"an integer that does *not* equally divide the axis. For an array of length l "
"that should be split into n sections, it returns l % n sub-arrays of size l//"
"n + 1 and the rest of size l//n."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array_split:22
msgid ":obj:`split`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array_split:23
msgid "Split array into multiple sub-arrays of equal size."
msgstr ""

