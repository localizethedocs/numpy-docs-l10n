#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.assert_array_almost_equal:2
msgid ""
"Raises an AssertionError if two objects are not equal up to desired "
"precision."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.assert_array_almost_equal:5
msgid ""
"It is recommended to use one of `assert_allclose`, "
"`assert_array_almost_equal_nulp` or `assert_array_max_ulp` instead of this "
"function for more consistent floating point comparisons."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.assert_array_almost_equal:10
msgid ""
"The test verifies identical shapes and that the elements of ``actual`` and "
"``desired`` satisfy::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.assert_array_almost_equal:13
msgid "abs(desired-actual) < 1.5 * 10**(-decimal)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.assert_array_almost_equal:15
msgid ""
"That is a looser test than originally documented, but agrees with what the "
"actual implementation did up to rounding vagaries. An exception is raised at "
"shape mismatch or conflicting values. In contrast to the standard usage in "
"numpy, NaNs are compared like numbers, no assertion is raised if both "
"objects have NaNs in the same positions."
msgstr ""

