#: ../../../reference/generated/numpy.mintypecode.rst:4
msgid "numpy.mintypecode"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.mintypecode:2
msgid ""
"Return the character for the minimum-size type to which given types can be "
"safely cast."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.mintypecode:5
msgid ""
"The returned type character must represent the smallest size dtype such that "
"an array of the returned type can handle the data from an array of all types "
"in `typechars` (or if `typechars` is an array, then its dtype.char)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.mintypecode:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.mintypecode:14
msgid "**typechars**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.mintypecode:-1
msgid "list of str or array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.mintypecode:13
msgid ""
"If a list of strings, each string should represent a dtype. If array_like, "
"the character representation of the array dtype is used."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.mintypecode:18
msgid "**typeset**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.mintypecode:-1
msgid "str or list of str, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.mintypecode:17
msgid ""
"The set of characters that the returned character is chosen from. The "
"default set is 'GDFgdf'."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.mintypecode:22
msgid "**default**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.mintypecode:-1
msgid "str, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.mintypecode:21
msgid ""
"The default character, this is returned if none of the characters in "
"`typechars` matches a character in `typeset`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.mintypecode:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.mintypecode:33
msgid "**typechar**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.mintypecode:-1
msgid "str"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.mintypecode:27
msgid "The character representing the minimum-size type that was found."
msgstr ""

