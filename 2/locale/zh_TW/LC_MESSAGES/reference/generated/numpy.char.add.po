#: ../../../reference/generated/numpy.char.add.rst:4
msgid "numpy.char.add"
msgstr ""

#: ../../../../docstring of numpy.add:2
msgid "Add arguments element-wise."
msgstr ""

#: ../../../../docstring of numpy.add:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.add:10
msgid "**x1, x2**"
msgstr ""

#: ../../../../docstring of numpy.add:-1
msgid "array_like"
msgstr ""

#: ../../../../docstring of numpy.add:8
msgid ""
"The arrays to be added. If ``x1.shape != x2.shape``, they must be "
"broadcastable to a common shape (which becomes the shape of the output)."
msgstr ""

#: ../../../../docstring of numpy.add:16
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.add:-1
msgid "ndarray, None, or tuple of ndarray and None, optional"
msgstr ""

#: ../../../../docstring of numpy.add:13
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or None, a freshly-"
"allocated array is returned. A tuple (possible only as a keyword argument) "
"must have length equal to the number of outputs."
msgstr ""

#: ../../../../docstring of numpy.add:24
msgid "**where**"
msgstr ""

#: ../../../../docstring of numpy.add:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../docstring of numpy.add:19
msgid ""
"This condition is broadcast over the input. At locations where the condition "
"is True, the `out` array will be set to the ufunc result. Elsewhere, the "
"`out` array will retain its original value. Note that if an uninitialized "
"`out` array is created via the default ``out=None``, locations within it "
"where the condition is False will remain uninitialized."
msgstr ""

#: ../../../../docstring of numpy.add:28
msgid "**\\*\\*kwargs**"
msgstr ""

#: ../../../../docstring of numpy.add:27
msgid ""
"For other keyword-only arguments, see the :ref:`ufunc docs <ufuncs.kwargs>`."
msgstr ""

#: ../../../../docstring of numpy.add:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.add:41
msgid "**add**"
msgstr ""

#: ../../../../docstring of numpy.add:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.add:33
msgid ""
"The sum of `x1` and `x2`, element-wise. This is a scalar if both `x1` and "
"`x2` are scalars."
msgstr ""

#: ../../../../docstring of numpy.add:44
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.add:45
msgid "Equivalent to `x1` + `x2` in terms of array broadcasting."
msgstr ""

#: ../../../../docstring of numpy.add:49
msgid "Examples"
msgstr ""

#: ../../../../docstring of numpy.add:64
msgid ""
"The ``+`` operator can be used as a shorthand for ``np.add`` on ndarrays."
msgstr ""

