msgid "numpy.polynomial.polynomial.polyval2d"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyval2d:2
msgid "Evaluate a 2-D polynomial at points (x, y)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyval2d:4
msgid "This function returns the value"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyval2d:6
msgid ""
"p(x,y) = \\sum_{i,j} c_{i,j} * x^i * y^j\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyval2d:8
msgid ""
"The parameters `x` and `y` are converted to arrays only if they are tuples "
"or a lists, otherwise they are treated as a scalars and they must have the "
"same shape after conversion. In either case, either `x` and `y` or their "
"elements must support multiplication and addition both with themselves and "
"with the elements of `c`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyval2d:14
msgid ""
"If `c` has fewer than two dimensions, ones are implicitly appended to its "
"shape to make it 2-D. The shape of the result will be c.shape[2:] + x.shape."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyval2d:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyval2d:24
msgid "**x, y**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyval2d:-1
msgid "array_like, compatible objects"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyval2d:21
msgid ""
"The two dimensional series is evaluated at the points ``(x, y)``, where `x` "
"and `y` must have the same shape. If `x` or `y` is a list or tuple, it is "
"first converted to an ndarray, otherwise it is left unchanged and, if it "
"isn't an ndarray, it is treated as a scalar."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyval2d:30
msgid "**c**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyval2d:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyval2d:27
msgid ""
"Array of coefficients ordered so that the coefficient of the term of multi-"
"degree i,j is contained in ``c[i,j]``. If `c` has dimension greater than two "
"the remaining indices enumerate multiple sets of coefficients."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyval2d:0
