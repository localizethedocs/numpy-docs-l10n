#: of numpy.binary_repr:24
msgid "**width**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.binary_repr:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.binary_repr:20
msgid ""
"The length of the returned string if `num` is positive, or the length of the "
"two's complement if `num` is negative, provided that `width` is at least a "
"sufficient number of bits for `num` to be represented in the designated "
"form. If the `width` value is insufficient, an error is raised."
msgstr ""

