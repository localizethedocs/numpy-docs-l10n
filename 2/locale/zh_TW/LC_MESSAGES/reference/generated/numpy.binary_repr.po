#: ../../../reference/generated/numpy.binary_repr.rst:4
msgid "numpy.binary\\_repr"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.binary_repr:2
msgid "Return the binary representation of the input number as a string."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.binary_repr:4
msgid ""
"For negative numbers, if width is not given, a minus sign is added to the "
"front. If width is given, the two's complement of the number is returned, "
"with respect to that width."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.binary_repr:8
msgid ""
"In a two's-complement system negative numbers are represented by the two's "
"complement of the absolute value. This is the most common method of "
"representing signed integers on computers [R962252997619-1]_. A N-bit two's-"
"complement system can represent every integer in the range :math:`-2^{N-1}` "
"to :math:`+2^{N-1}-1`."
msgstr ""

