#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/_polybase.py:docstring
#: of numpy.polynomial._polybase.ABCPolyBase.trim:4
msgid ""
"Remove trailing coefficients until a coefficient is reached whose absolute "
"value greater than `tol` or the beginning of the series is reached. If all "
"the coefficients would be removed the series is set to ``[0]``. A new series "
"instance is returned with the new coefficients.  The current instance "
"remains unchanged."
msgstr ""

