#: ../../../reference/generated/numpy.lib.scimath.arccos.rst:4
msgid "numpy.lib.scimath.arccos"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arccos:2
msgid "Compute the inverse cosine of x."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arccos:4
msgid ""
"Return the \"principal value\" (for a description of this, see `numpy."
"arccos`) of the inverse cosine of `x`. For real `x` such that `abs(x) <= 1`, "
"this is a real number in the closed interval :math:`[0, \\pi]`.  Otherwise, "
"the complex principle value is returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arccos:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arccos:12
msgid "**x**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arccos:-1
msgid "array_like or scalar"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arccos:12
msgid "The value(s) whose arccos is (are) required."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arccos:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arccos:24
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arccos:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arccos:17
msgid ""
"The inverse cosine(s) of the `x` value(s). If `x` was a scalar, so is `out`, "
"otherwise an array object is returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arccos:29
msgid ":obj:`numpy.arccos`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arccos:33
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arccos:34
msgid ""
"For an arccos() that returns ``NAN`` when real `x` is not in the interval "
"``[-1,1]``, use `numpy.arccos`."
msgstr ""

