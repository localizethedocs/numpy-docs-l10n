#: ../../../reference/generated/numpy.arccos.rst:4
msgid "numpy.arccos"
msgstr ""

#: ../../../../docstring of numpy.arccos:2
msgid "Trigonometric inverse cosine, element-wise."
msgstr ""

#: ../../../../docstring of numpy.arccos:4
msgid ""
"The inverse of `cos` so that, if ``y = cos(x)``, then ``x = arccos(y)``."
msgstr ""

#: ../../../../docstring of numpy.arccos:0
msgid "Parameters"
msgstr "參數"

#: ../../../../docstring of numpy.arccos:10
msgid "**x**"
msgstr ""

#: ../../../../docstring of numpy.arccos:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../docstring of numpy.arccos:9
msgid ""
"`x`-coordinate on the unit circle. For real arguments, the domain is [-1, 1]."
msgstr ""

#: ../../../../docstring of numpy.arccos:16
msgid "**out**"
msgstr "**out**"

#: ../../../../docstring of numpy.arccos:-1
msgid "ndarray, None, or tuple of ndarray and None, optional"
msgstr ""

#: ../../../../docstring of numpy.arccos:13
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or None, a freshly-"
"allocated array is returned. A tuple (possible only as a keyword argument) "
"must have length equal to the number of outputs."
msgstr ""

#: ../../../../docstring of numpy.arccos:24
msgid "**where**"
msgstr "**where**"

#: ../../../../docstring of numpy.arccos:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../docstring of numpy.arccos:19
msgid ""
"This condition is broadcast over the input. At locations where the condition "
"is True, the `out` array will be set to the ufunc result. Elsewhere, the "
"`out` array will retain its original value. Note that if an uninitialized "
"`out` array is created via the default ``out=None``, locations within it "
"where the condition is False will remain uninitialized."
msgstr ""

#: ../../../../docstring of numpy.arccos:28
msgid "**\\*\\*kwargs**"
msgstr "**\\*\\*kwargs**"

#: ../../../../docstring of numpy.arccos:27
msgid ""
"For other keyword-only arguments, see the :ref:`ufunc docs <ufuncs.kwargs>`."
msgstr ""

#: ../../../../docstring of numpy.arccos:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../docstring of numpy.arccos:41
msgid "**angle**"
msgstr ""

#: ../../../../docstring of numpy.arccos:-1
msgid "ndarray"
msgstr "ndarray"

#: ../../../../docstring of numpy.arccos:33
msgid ""
"The angle of the ray intersecting the unit circle at the given `x`-"
"coordinate in radians [0, pi]. This is a scalar if `x` is a scalar."
msgstr ""

#: ../../../../docstring of numpy.arccos:46
msgid ":obj:`cos`, :obj:`arctan`, :obj:`arcsin`, :obj:`emath.arccos`"
msgstr ""

#: ../../../../docstring of numpy.arccos:50
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.arccos:51
msgid ""
"`arccos` is a multivalued function: for each `x` there are infinitely many "
"numbers `z` such that ``cos(z) = x``. The convention is to return the angle "
"`z` whose real part lies in `[0, pi]`."
msgstr ""

#: ../../../../docstring of numpy.arccos:55
msgid ""
"For real-valued input data types, `arccos` always returns real output. For "
"each value that cannot be expressed as a real number or infinity, it yields "
"``nan`` and sets the `invalid` floating point error flag."
msgstr ""

#: ../../../../docstring of numpy.arccos:59
msgid ""
"For complex-valued input, `arccos` is a complex analytic function that has "
"branch cuts ``[-inf, -1]`` and `[1, inf]` and is continuous from above on "
"the former and from below on the latter."
msgstr ""

#: ../../../../docstring of numpy.arccos:63
msgid "The inverse `cos` is also known as `acos` or cos^-1."
msgstr ""

#: ../../../../docstring of numpy.arccos:66
msgid "References"
msgstr ""

#: ../../../../docstring of numpy.arccos:67
msgid ""
"M. Abramowitz and I.A. Stegun, \"Handbook of Mathematical Functions\", 10th "
"printing, 1964, pp. 79. https://personal.math.ubc.ca/~cbm/aands/page_79.htm"
msgstr ""

