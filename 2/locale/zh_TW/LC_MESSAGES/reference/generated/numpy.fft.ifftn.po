#: ../../../reference/generated/numpy.fft.ifftn.rst:4
msgid "numpy.fft.ifftn"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifftn:2
msgid "Compute the N-dimensional inverse discrete Fourier Transform."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifftn:4
msgid ""
"This function computes the inverse of the N-dimensional discrete Fourier "
"Transform over any number of axes in an M-dimensional array by means of the "
"Fast Fourier Transform (FFT).  In other words, ``ifftn(fftn(a)) == a`` to "
"within numerical accuracy. For a description of the definitions and "
"conventions used, see `numpy.fft`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifftn:10
msgid ""
"The input, analogously to `ifft`, should be ordered in the same way as is "
"returned by `fftn`, i.e. it should have the term for zero frequency in all "
"axes in the low-order corner, the positive frequency terms in the first half "
"of all axes, the term for the Nyquist frequency in the middle of all axes "
"and the negative frequency terms in the second half of all axes, in order of "
"decreasingly negative frequency."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifftn:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifftn:20
msgid "**a**"
msgstr "**a**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifftn:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifftn:20
msgid "Input array, can be complex."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifftn:45
msgid "**s**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifftn:-1
msgid "sequence of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifftn:23
msgid ""
"Shape (length of each transformed axis) of the output (``s[0]`` refers to "
"axis 0, ``s[1]`` to axis 1, etc.). This corresponds to ``n`` for ``ifft(x, "
"n)``. Along any axis, if the given shape is smaller than that of the input, "
"the input is cropped. If it is larger, the input is padded with zeros."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifftn:31
msgid "If it is ``-1``, the whole input is used (no padding/trimming)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifftn:33
msgid ""
"If `s` is not given, the shape of the input along the axes specified by "
"`axes` is used. See notes for issue on `ifft` zero padding."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifftn:38
msgid "If `s` is not ``None``, `axes` must not be ``None`` either."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifftn:42
msgid ""
"`s` must contain only ``int`` s, not ``None`` values. ``None`` values "
"currently mean that the default value for ``n`` is used in the corresponding "
"1-D transform, but this behaviour is deprecated."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifftn:56
msgid "**axes**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifftn:48
msgid ""
"Axes over which to compute the IFFT.  If not given, the last ``len(s)`` axes "
"are used, or all axes if `s` is also not specified. Repeated indices in "
"`axes` means that the inverse transform over that axis is performed multiple "
"times."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifftn:55
msgid ""
"If `s` is specified, the corresponding `axes` to be transformed must be "
"explicitly specified too."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifftn:65
msgid "**norm**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifftn:-1
msgid "{\"backward\", \"ortho\", \"forward\"}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifftn:59
msgid ""
"Normalization mode (see `numpy.fft`). Default is \"backward\". Indicates "
"which direction of the forward/backward pair of transforms is scaled and "
"with what normalization factor."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifftn:65
msgid "The \"backward\", \"forward\" values were added."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifftn:74 numpy.fft.ifftn:84
msgid "**out**"
msgstr "**out**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifftn:-1
msgid "complex ndarray, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifftn:68
msgid ""
"If provided, the result will be placed in this array. It should be of the "
"appropriate shape and dtype for all axes (and hence is incompatible with "
"passing in all but the trivial ``s``)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifftn:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifftn:-1
msgid "complex ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifftn:79
msgid ""
"The truncated or zero-padded input, transformed along the axes indicated by "
"`axes`, or by a combination of `s` or `a`, as explained in the parameters "
"section above."
msgstr ""

