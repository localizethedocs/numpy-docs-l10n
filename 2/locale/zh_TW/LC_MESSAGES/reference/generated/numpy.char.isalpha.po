#: ../../../reference/generated/numpy.char.isalpha.rst:4
msgid "numpy.char.isalpha"
msgstr ""

#: ../../../../docstring of numpy.strings.isalpha:2
msgid ""
"Returns true for each element if all characters in the data interpreted as a "
"string are alphabetic and there is at least one character, false otherwise."
msgstr ""

#: ../../../../docstring of numpy.strings.isalpha:6
msgid ""
"For byte strings (i.e. ``bytes``), alphabetic characters are those byte "
"values in the sequence "
"b'abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ'. For Unicode "
"strings, alphabetic characters are those characters defined in the Unicode "
"character database as “Letter”."
msgstr ""

