msgid "numpy.histogram2d"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:2
msgid "Compute the bi-dimensional histogram of two data samples."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:9
msgid "**x**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:-1
msgid "array_like, shape (N,)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:8
msgid "An array containing the x coordinates of the points to be histogrammed."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:13
msgid "**y**"
msgstr "**y**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:12
msgid "An array containing the y coordinates of the points to be histogrammed."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:26
msgid "**bins**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:-1
msgid "int or array_like or [int, int] or [array, array], optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:16
msgid "The bin specification:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:18
msgid "If int, the number of bins for the two dimensions (nx=ny=bins)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:19
msgid ""
"If array_like, the bin edges for the two dimensions (x_edges=y_edges=bins)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:21
msgid "If [int, int], the number of bins in each dimension (nx, ny = bins)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:23
msgid ""
"If [array, array], the bin edges in each dimension (x_edges, y_edges = bins)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:25
msgid ""
"A combination [int, array] or [array, int], where int is the number of bins "
"and array is the bin edges."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:32
msgid "**range**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:-1
msgid "array_like, shape(2,2), optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:29
msgid ""
"The leftmost and rightmost edges of the bins along each dimension (if not "
"specified explicitly in the `bins` parameters): ``[[xmin, xmax], [ymin, "
"ymax]]``. All values outside of this range will be considered outliers and "
"not tallied in the histogram."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:37
msgid "**density**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:35
msgid ""
"If False, the default, returns the number of samples in each bin. If True, "
"returns the probability *density* function at the bin, ``bin_count / "
"sample_count / bin_area``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:43
msgid "**weights**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:-1
msgid "array_like, shape(N,), optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:40
msgid ""
"An array of values ``w_i`` weighing each sample ``(x_i, y_i)``. Weights are "
"normalized to 1 if `density` is True. If `density` is False, the values of "
"the returned histogram are equal to the sum of the weights belonging to the "
"samples falling into each bin."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:50
msgid "**H**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:-1
msgid "ndarray, shape(nx, ny)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:48
msgid ""
"The bi-dimensional histogram of samples `x` and `y`. Values in `x` are "
"histogrammed along the first dimension and values in `y` are histogrammed "
"along the second dimension."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:53
msgid "**xedges**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:-1
msgid "ndarray, shape(nx+1,)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:53
msgid "The bin edges along the first dimension."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:62
msgid "**yedges**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:-1
msgid "ndarray, shape(ny+1,)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:56
msgid "The bin edges along the second dimension."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:67
msgid ":obj:`histogram`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:68
msgid "1D histogram"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:69
msgid ":obj:`histogramdd`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:70
msgid "Multidimensional histogram"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:74
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:75
msgid ""
"When `density` is True, then the returned histogram is the sample density, "
"defined such that the sum over bins of the product ``bin_value * bin_area`` "
"is 1."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogram2d:79
msgid ""
"Please note that the histogram does not follow the Cartesian convention "
"where `x` values are on the abscissa and `y` values on the ordinate axis.  "
"Rather, `x` is histogrammed along the first dimension of the array "
"(vertical), and `y` along the second dimension of the array (horizontal).  "
"This ensures compatibility with `histogramdd`."
msgstr ""

