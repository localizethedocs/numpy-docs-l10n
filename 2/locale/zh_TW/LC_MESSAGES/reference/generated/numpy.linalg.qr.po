msgid "numpy.linalg.qr"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.qr:2
msgid "Compute the qr factorization of a matrix."
msgstr "計算矩陣的QR分解。"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.qr:4
msgid ""
"Factor the matrix `a` as *qr*, where `q` is orthonormal and `r` is upper-"
"triangular."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.qr:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.qr:10
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.qr:-1
msgid "array_like, shape (..., M, N)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.qr:10
msgid "An array-like object with the dimensionality of at least 2."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.qr:28
msgid "**mode**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.qr:-1
msgid "{'reduced', 'complete', 'r', 'raw'}, optional, default: 'reduced'"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.qr:13
msgid "If K = min(M, N), then"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.qr:15
msgid "'reduced'  : returns Q, R with dimensions (..., M, K), (..., K, N)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.qr:16
msgid "'complete' : returns Q, R with dimensions (..., M, M), (..., M, N)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.qr:17
msgid "'r'        : returns R only with dimensions (..., K, N)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.qr:18
msgid "'raw'      : returns h, tau with dimensions (..., N, M), (..., K,)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.qr:20
msgid ""
"The options 'reduced', 'complete, and 'raw' are new in numpy 1.8, see the "
"notes for more information. The default is 'reduced', and to maintain "
"backward compatibility with earlier versions of numpy both it and the old "
"default 'full' can be omitted. Note that array h returned in 'raw' mode is "
"transposed for calling Fortran. The 'economic' mode is deprecated.  The "
"modes 'full' and 'economic' may be passed using only the first letter for "
"backwards compatibility, but all others must be spelled out. See the Notes "
"for more explanation."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.qr:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.qr:38
msgid "**Q**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.qr:-1
msgid "ndarray of float or complex, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.qr:33
msgid ""
"A matrix with orthonormal columns. When mode = 'complete' the result is an "
"orthogonal/unitary matrix depending on whether or not a is real/complex. The "
"determinant may be either +/- 1 in that case. In case the number of "
"dimensions in the input array is greater than 2 then a stack of the matrices "
"with above properties is returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.qr:43
msgid "**R**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.qr:41
msgid ""
"The upper-triangular matrix or a stack of upper-triangular matrices if the "
"number of dimensions in the input array is greater than 2."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.qr:51
msgid "**(h, tau)**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.qr:-1
msgid "ndarrays of np.double or np.cdouble, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.qr:46
msgid ""
"The array h contains the Householder reflectors that generate q along with "
"r. The tau array contains scaling factors for the reflectors. In the "
"deprecated  'economic' mode only h is returned."
msgstr ""

