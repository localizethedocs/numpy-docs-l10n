#: ../../../reference/generated/numpy.char.isnumeric.rst:4
msgid "numpy.char.isnumeric"
msgstr ""

#: ../../../../docstring of numpy.strings.isnumeric:2
msgid ""
"For each element, return True if there are only numeric characters in the "
"element."
msgstr ""

#: ../../../../docstring of numpy.strings.isnumeric:5
msgid ""
"Numeric characters include digit characters, and all characters that have "
"the Unicode numeric value property, e.g. ``U+2155, VULGAR FRACTION ONE "
"FIFTH``."
msgstr ""

