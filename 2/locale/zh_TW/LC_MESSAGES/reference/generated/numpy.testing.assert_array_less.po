msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.assert_array_less:55
msgid ""
"When one of `x` and `y` is a scalar and the other is array_like, the "
"function performs the comparison as though the scalar were broadcasted to "
"the shape of the array. This behaviour can be disabled with the `strict` "
"parameter."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.assert_array_less:62
msgid "Examples"
msgstr "範例"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.assert_array_less:67
msgid ""
"The following assertion passes because each finite element of `x` is "
"strictly less than the corresponding element of `y`, and the NaNs are in "
"corresponding locations."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.assert_array_less:75
msgid ""
"The following assertion fails because the zeroth element of `x` is no longer "
"strictly less than the zeroth element of `y`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.assert_array_less:93
msgid ""
"Here, `y` is a scalar, so each element of `x` is compared to `y`, and the "
"assertion passes."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.assert_array_less:100
msgid ""
"However, with ``strict=True``, the assertion will fail because the shapes do "
"not match."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.assert_array_less:113
msgid ""
"With ``strict=True``, the assertion also fails if the dtypes of the two "
"arrays do not match."
msgstr ""

