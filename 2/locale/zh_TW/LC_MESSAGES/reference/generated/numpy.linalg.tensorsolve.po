msgid "LinAlgError"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorsolve:35
msgid "If `a` is singular or not 'square' (in the above sense)."
msgstr ""

