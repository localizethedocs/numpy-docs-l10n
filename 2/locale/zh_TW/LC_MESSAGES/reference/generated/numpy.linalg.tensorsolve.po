#: ../../../reference/generated/numpy.linalg.tensorsolve.rst:4
msgid "numpy.linalg.tensorsolve"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorsolve:2
msgid "Solve the tensor equation ``a x = b`` for x."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorsolve:4
msgid ""
"It is assumed that all indices of `x` are summed over in the product, "
"together with the rightmost indices of `a`, as is done in, for example, "
"``tensordot(a, x, axes=x.ndim)``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorsolve:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorsolve:15
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorsolve:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorsolve:11
msgid ""
"Coefficient tensor, of shape ``b.shape + Q``. `Q`, a tuple, equals the shape "
"of that sub-tensor of `a` consisting of the appropriate number of its "
"rightmost indices, and must be such that ``prod(Q) == prod(b.shape)`` (in "
"which sense `a` is said to be 'square')."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorsolve:18
msgid "**b**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorsolve:18
msgid "Right-hand tensor, which can be of any shape."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorsolve:22
msgid "**axes**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorsolve:-1
msgid "tuple of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorsolve:21
msgid ""
"Axes in `a` to reorder to the right, before inversion. If None (default), no "
"reordering is done."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorsolve:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorsolve:30
msgid "**x**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorsolve:-1
msgid "ndarray, shape Q"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorsolve:0
msgid "Raises"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
