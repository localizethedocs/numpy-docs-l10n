#: ../../../reference/generated/numpy.trace.rst:4
msgid "numpy.trace"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.trace:2
msgid "Return the sum along diagonals of the array."
msgstr "傳回數組對角線上的所有元素總和。"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.trace:4
msgid ""
"If `a` is 2-D, the sum along its diagonal with the given offset is returned, "
"i.e., the sum of elements ``a[i,i+offset]`` for all i."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.trace:7
msgid ""
"If `a` has more than two dimensions, then the axes specified by axis1 and "
"axis2 are used to determine the 2-D sub-arrays whose traces are returned. "
"The shape of the resulting array is the same as that of `a` with `axis1` and "
"`axis2` removed."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.trace:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.trace:15
msgid "**a**"
msgstr "**a**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.trace:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.trace:15
msgid "Input array, from which the diagonals are taken."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.trace:19
msgid "**offset**"
msgstr "**offset**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.trace:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.trace:18
msgid ""
"Offset of the diagonal from the main diagonal. Can be both positive and "
"negative. Defaults to 0."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.trace:24
msgid "**axis1, axis2**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.trace:22
msgid ""
"Axes to be used as the first and second axis of the 2-D sub-arrays from "
"which the diagonals should be taken. Defaults are the first two axes of `a`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.trace:31
msgid "**dtype**"
msgstr "**dtype**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.trace:-1
msgid "dtype, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.trace:27
msgid ""
"Determines the data-type of the returned array and of the accumulator where "
"the elements are summed. If dtype has the value None and `a` is of integer "
"type of precision less than the default integer precision, then the default "
"integer precision is used. Otherwise, the precision is the same as that of "
"`a`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.trace:37
msgid "**out**"
msgstr "**out**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.trace:-1
msgid "ndarray, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.trace:34
msgid ""
"Array into which the output is placed. Its type is preserved and it must be "
"of the right shape to hold the output."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.trace:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.trace:49
msgid "**sum_along_diagonals**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.trace:-1
msgid "ndarray"
msgstr "ndarray"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.trace:42
msgid ""
"If `a` is 2-D, the sum along the diagonal is returned.  If `a` has larger "
"dimensions, then an array of sums along diagonals is returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.trace:54
msgid ":obj:`diag`, :obj:`diagonal`, :obj:`diagflat`"
msgstr ""

