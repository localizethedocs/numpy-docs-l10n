#: ../../../reference/generated/numpy.polysub.rst:4
msgid "numpy.polysub"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polysub:2
msgid "Difference (subtraction) of two polynomials."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polysub:5
msgid ""
"This forms part of the old polynomial API. Since version 1.4, the new "
"polynomial API defined in `numpy.polynomial` is preferred. A summary of the "
"differences can be found in the :doc:`transition guide </reference/routines."
"polynomials>`."
msgstr ""
"這是舊版多項式 API 的一部分。自 1.4 版本起，建議使用 `numpy.polynomial` 中定"
"義的新版多項式 API。有關差異的概述，請參閱 :doc:`transition guide </"
"reference/routines.polynomials>`。"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polysub:10
msgid ""
"Given two polynomials `a1` and `a2`, returns ``a1 - a2``. `a1` and `a2` can "
"be either array_like sequences of the polynomials' coefficients (including "
"coefficients equal to zero), or `poly1d` objects."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polysub:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polysub:17
msgid "**a1, a2**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polysub:-1
msgid "array_like or poly1d"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polysub:17
msgid "Minuend and subtrahend polynomials, respectively."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polysub:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polysub:28
msgid "**out**"
msgstr "**out**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polysub:-1
msgid "ndarray or poly1d"
msgstr "ndarray 或 poly1d"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polysub:22
msgid "Array or `poly1d` object of the difference polynomial's coefficients."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
