#: ../../../reference/generated/numpy.char.chararray.tofile.rst:4
msgid "numpy.char.chararray.tofile"
msgstr ""

#: ../../../reference/generated/numpy.char.chararray.tofile.rst:8
msgid "method"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.tofile:2
msgid "Write array to a file as text or binary (default)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.tofile:4
msgid ""
"Data is always written in 'C' order, independent of the order of `a`. The "
"data produced by this method can be recovered using the function fromfile()."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.tofile:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.tofile:11
msgid "**fid**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.tofile:-1
msgid "file or str or Path"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.tofile:11
msgid "An open file object, or a string containing a filename."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.tofile:16
msgid "**sep**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.tofile:-1
msgid "str"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.tofile:14
msgid ""
"Separator between array items for text output. If \"\" (empty), a binary "
"file is written, equivalent to ``file.write(a.tobytes())``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.tofile:29
msgid "**format**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.tofile:19
msgid ""
"Format string for text file output. Each entry in the array is formatted to "
"text by first converting it to the closest Python type, and then using "
"\"format\" % item."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.tofile:32
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.tofile:33
msgid ""
"This is a convenience function for quick storage of array data. Information "
"on endianness and precision is lost, so this method is not a good choice for "
"files intended to archive data or transport data between machines with "
"different endianness. Some of these problems can be overcome by outputting "
"the data as text files, at the expense of speed and file size."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.tofile:40
msgid ""
"When fid is a file object, array contents are directly written to the file, "
"bypassing the file object's ``write`` method. As a result, tofile cannot be "
"used with files objects supporting compression (e.g., GzipFile) or file-like "
"objects that do not support ``fileno()`` (e.g., BytesIO)."
msgstr ""
