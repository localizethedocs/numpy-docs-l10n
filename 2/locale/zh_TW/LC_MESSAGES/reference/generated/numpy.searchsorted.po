#: of numpy.searchsorted:30
msgid "**side**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.searchsorted:-1
msgid "{'left', 'right'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.searchsorted:28
msgid ""
"If 'left', the index of the first suitable location found is given. If "
"'right', return the last such index.  If there is no suitable index, return "
"either 0 or N (where N is the length of `a`)."
msgstr ""

