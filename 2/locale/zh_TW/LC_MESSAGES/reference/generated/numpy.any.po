msgid "numpy.any"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.any:2
msgid "Test whether any array element along a given axis evaluates to True."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.any:4
msgid "Returns single boolean if `axis` is ``None``"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.any:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.any:9
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.any:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.any:9
msgid "Input array or object that can be converted to an array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.any:17
msgid "**axis**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.any:-1
msgid "None or int or tuple of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.any:12
msgid ""
"Axis or axes along which a logical OR reduction is performed. The default "
"(``axis=None``) is to perform a logical OR over all the dimensions of the "
"input array. `axis` may be negative, in which case it counts from the last "
"to the first axis. If this is a tuple of ints, a reduction is performed on "
"multiple axes, instead of a single axis or all the axes as before."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.any:24
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.any:-1
msgid "ndarray, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.any:20
msgid ""
"Alternate output array in which to place the result.  It must have the same "
"shape as the expected output and its type is preserved (e.g., if it is of "
"type float, then it will remain so, returning 1.0 for True and 0.0 for "
"False, regardless of the type of `a`). See :ref:`ufuncs-output-type` for "
"more details."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.any:35
msgid "**keepdims**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.any:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.any:27
msgid ""
"If this is set to True, the axes which are reduced are left in the result as "
"dimensions with size one. With this option, the result will broadcast "
"correctly against the input array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.any:31
msgid ""
"If the default value is passed, then `keepdims` will not be passed through "
"to the `any` method of sub-classes of `ndarray`, however any non-default "
"value will be.  If the sub-class' method does not implement `keepdims` any "
"exceptions will be raised."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.any:41
msgid "**where**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.any:-1
msgid "array_like of bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.any:38
msgid ""
"Elements to include in checking for any `True` values. See `~numpy.ufunc."
"reduce` for details."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.any:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.any:53
msgid "**any**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.any:-1
msgid "bool or ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.any:46
msgid ""
"A new boolean or `ndarray` is returned unless `out` is specified, in which "
"case a reference to `out` is returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.any:58
msgid ":obj:`ndarray.any`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
