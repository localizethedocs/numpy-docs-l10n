msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.any:60
msgid ":obj:`all`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.any:61
msgid "Test whether all elements along a given axis evaluate to True."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.any:65
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.any:66
msgid ""
"Not a Number (NaN), positive infinity and negative infinity evaluate to "
"`True` because these are not equal to zero."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.any:69
msgid ""
"Before NumPy 2.0, ``any`` did not return booleans for object dtype input "
"arrays. This behavior is still available via ``np.logical_or.reduce``."
msgstr ""

