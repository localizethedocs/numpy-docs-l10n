msgid "numpy.ma.getmask"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.getmask:2
msgid "Return the mask of a masked array, or nomask."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.getmask:4
msgid ""
"Return the mask of `a` as an ndarray if `a` is a `MaskedArray` and the mask "
"is not `nomask`, else return `nomask`. To guarantee a full array of booleans "
"of the same shape as a, use `getmaskarray`."
msgstr ""

