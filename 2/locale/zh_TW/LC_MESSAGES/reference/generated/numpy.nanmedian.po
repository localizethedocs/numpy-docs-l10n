msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmedian:9
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmedian:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmedian:9
msgid "Input array or object that can be converted to an array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmedian:14
msgid "**axis**"
msgstr "**axis**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmedian:-1
msgid "{int, sequence of int, None}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmedian:12
msgid ""
"Axis or axes along which the medians are computed. The default is to compute "
"the median along a flattened version of the array. A sequence of axes is "
"supported since version 1.9.0."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmedian:19
msgid "**out**"
msgstr "**out**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmedian:-1
msgid "ndarray, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmedian:17
msgid ""
"Alternative output array in which to place the result. It must have the same "
"shape and buffer length as the expected output, but the type (of the output) "
"will be cast if necessary."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmedian:28
msgid "**overwrite_input**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmedian:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmedian:22
msgid ""
"If True, then allow use of memory of input array `a` for calculations. The "
"input array will be modified by the call to `median`. This will save memory "
"when you do not need to preserve the contents of the input array. Treat the "
"input as undefined, but it will probably be fully or partially sorted. "
"Default is False. If `overwrite_input` is ``True`` and `a` is not already an "
"`ndarray`, an error will be raised."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmedian:39
msgid "**keepdims**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmedian:31
msgid ""
"If this is set to True, the axes which are reduced are left in the result as "
"dimensions with size one. With this option, the result will broadcast "
"correctly against the original `a`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmedian:35
msgid ""
"If this is anything but the default value it will be passed through (in the "
"special case of an empty array) to the `mean` function of the underlying "
"array.  If the array is a sub-class and `mean` does not have the kwarg "
"`keepdims` this will raise a RuntimeError."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmedian:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmedian:54
msgid "**median**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmedian:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmedian:44
msgid ""
"A new array holding the result. If the input contains integers or floats "
"smaller than ``float64``, then the output data-type is ``np.float64``.  "
"Otherwise, the data-type of the output is the same as that of the input. If "
"`out` is specified, that array is returned instead."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmedian:59
msgid ":obj:`mean`, :obj:`median`, :obj:`percentile`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmedian:63
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmedian:64
msgid ""
"Given a vector ``V`` of length ``N``, the median of ``V`` is the middle "
"value of a sorted copy of ``V``, ``V_sorted`` - i.e., ``V_sorted[(N-1)/2]``, "
"when ``N`` is odd and the average of the two middle values of ``V_sorted`` "
"when ``N`` is even."
msgstr ""

