msgid "An N-dimensional iterator object to index arrays."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ndindex:4
msgid ""
"Given the shape of an array, an `ndindex` instance iterates over the N-"
"dimensional index of the array. At each iteration a tuple of indices is "
"returned, the last dimension is iterated over first."
msgstr ""

