#: of numpy.ma.core.zeros_like:-1
msgid "MaskedArray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.zeros_like:39
msgid "Array of zeros with the same shape and type as `a`."
msgstr ""

