#: ../../../reference/generated/numpy.hypot.rst:4
msgid "numpy.hypot"
msgstr ""

#: ../../../../docstring of numpy.hypot:2
msgid "Given the \"legs\" of a right triangle, return its hypotenuse."
msgstr ""

#: ../../../../docstring of numpy.hypot:4
msgid ""
"Equivalent to ``sqrt(x1**2 + x2**2)``, element-wise.  If `x1` or `x2` is "
"scalar_like (i.e., unambiguously cast-able to a scalar type), it is "
"broadcast for use with each element of the other argument. (See Examples)"
msgstr ""

#: ../../../../docstring of numpy.hypot:0
msgid "Parameters"
msgstr "參數"

#: ../../../../docstring of numpy.hypot:14
msgid "**x1, x2**"
msgstr ""

#: ../../../../docstring of numpy.hypot:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../docstring of numpy.hypot:12
msgid ""
"Leg of the triangle(s). If ``x1.shape != x2.shape``, they must be "
"broadcastable to a common shape (which becomes the shape of the output)."
msgstr ""

#: ../../../../docstring of numpy.hypot:20
msgid "**out**"
msgstr "**out**"

#: ../../../../docstring of numpy.hypot:-1
msgid "ndarray, None, or tuple of ndarray and None, optional"
msgstr ""

#: ../../../../docstring of numpy.hypot:17
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or None, a freshly-"
"allocated array is returned. A tuple (possible only as a keyword argument) "
"must have length equal to the number of outputs."
msgstr ""

#: ../../../../docstring of numpy.hypot:28
msgid "**where**"
msgstr "**where**"

#: ../../../../docstring of numpy.hypot:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../docstring of numpy.hypot:23
msgid ""
"This condition is broadcast over the input. At locations where the condition "
"is True, the `out` array will be set to the ufunc result. Elsewhere, the "
"`out` array will retain its original value. Note that if an uninitialized "
"`out` array is created via the default ``out=None``, locations within it "
"where the condition is False will remain uninitialized."
msgstr ""

#: ../../../../docstring of numpy.hypot:32
msgid "**\\*\\*kwargs**"
msgstr "**\\*\\*kwargs**"

#: ../../../../docstring of numpy.hypot:31
msgid ""
"For other keyword-only arguments, see the :ref:`ufunc docs <ufuncs.kwargs>`."
msgstr ""

#: ../../../../docstring of numpy.hypot:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../docstring of numpy.hypot:47
msgid "**z**"
msgstr ""

#: ../../../../docstring of numpy.hypot:-1
msgid "ndarray"
msgstr "ndarray"

#: ../../../../docstring of numpy.hypot:37
msgid ""
"The hypotenuse of the triangle(s). This is a scalar if both `x1` and `x2` "
"are scalars."
msgstr ""

