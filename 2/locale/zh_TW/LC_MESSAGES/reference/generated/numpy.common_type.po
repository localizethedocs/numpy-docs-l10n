#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.common_type:2
msgid "Return a scalar type which is common to the input arrays."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.common_type:4
msgid ""
"The return type will always be an inexact (i.e. floating point) scalar type, "
"even if all the arrays are integer arrays. If one of the inputs is an "
"integer array, the minimum precision type that is returned is a 64-bit "
"floating point dtype."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.common_type:9
msgid ""
"All input arrays except int64 and uint64 can be safely cast to the returned "
"dtype without loss of information."
msgstr ""

