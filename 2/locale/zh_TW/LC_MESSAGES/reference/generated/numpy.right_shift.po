#: ../../../reference/generated/numpy.right_shift.rst:4
msgid "numpy.right\\_shift"
msgstr ""

#: ../../../../docstring of numpy.right_shift:2
msgid "Shift the bits of an integer to the right."
msgstr ""

#: ../../../../docstring of numpy.right_shift:4
msgid ""
"Bits are shifted to the right `x2`.  Because the internal representation of "
"numbers is in binary format, this operation is equivalent to dividing `x1` "
"by ``2**x2``."
msgstr ""

#: ../../../../docstring of numpy.right_shift:0
msgid "Parameters"
msgstr "參數"

#: ../../../../docstring of numpy.right_shift:11
msgid "**x1**"
msgstr ""

#: ../../../../docstring of numpy.right_shift:-1
msgid "array_like, int"
msgstr ""

#: ../../../../docstring of numpy.right_shift:11
msgid "Input values."
msgstr ""

#: ../../../../docstring of numpy.right_shift:16
msgid "**x2**"
msgstr ""

#: ../../../../docstring of numpy.right_shift:14
msgid ""
"Number of bits to remove at the right of `x1`. If ``x1.shape != x2.shape``, "
"they must be broadcastable to a common shape (which becomes the shape of the "
"output)."
msgstr ""

#: ../../../../docstring of numpy.right_shift:22 numpy.right_shift:46
msgid "**out**"
msgstr "**out**"

#: ../../../../docstring of numpy.right_shift:-1
msgid "ndarray, None, or tuple of ndarray and None, optional"
msgstr ""

#: ../../../../docstring of numpy.right_shift:19
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or None, a freshly-"
"allocated array is returned. A tuple (possible only as a keyword argument) "
"must have length equal to the number of outputs."
msgstr ""

#: ../../../../docstring of numpy.right_shift:30
msgid "**where**"
msgstr ""

#: ../../../../docstring of numpy.right_shift:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../docstring of numpy.right_shift:25
msgid ""
"This condition is broadcast over the input. At locations where the condition "
"is True, the `out` array will be set to the ufunc result. Elsewhere, the "
"`out` array will retain its original value. Note that if an uninitialized "
"`out` array is created via the default ``out=None``, locations within it "
"where the condition is False will remain uninitialized."
msgstr ""

#: ../../../../docstring of numpy.right_shift:34
msgid "**\\*\\*kwargs**"
msgstr ""

#: ../../../../docstring of numpy.right_shift:33
msgid ""
"For other keyword-only arguments, see the :ref:`ufunc docs <ufuncs.kwargs>`."
msgstr ""

#: ../../../../docstring of numpy.right_shift:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../docstring of numpy.right_shift:-1
msgid "ndarray, int"
msgstr ""

#: ../../../../docstring of numpy.right_shift:39
msgid ""
"Return `x1` with bits shifted `x2` times to the right. This is a scalar if "
"both `x1` and `x2` are scalars."
msgstr ""

#: ../../../../docstring of numpy.right_shift:51
msgid ":obj:`left_shift`"
msgstr ""

#: ../../../../docstring of numpy.right_shift:52
msgid "Shift the bits of an integer to the left."
msgstr ""

#: ../../../../docstring of numpy.right_shift:53
msgid ":obj:`binary_repr`"
msgstr ""

#: ../../../../docstring of numpy.right_shift:54
msgid "Return the binary representation of the input number as a string."
msgstr ""

#: ../../../../docstring of numpy.right_shift:60
msgid "Examples"
msgstr "範例"

#: ../../../../docstring of numpy.right_shift:76
msgid ""
"The ``>>`` operator can be used as a shorthand for ``np.right_shift`` on "
"ndarrays."
msgstr ""

