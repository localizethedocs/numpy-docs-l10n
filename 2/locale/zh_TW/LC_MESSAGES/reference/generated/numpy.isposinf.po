#: of numpy.isposinf:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isposinf:11
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the input broadcasts to. If not provided or None, a freshly-"
"allocated boolean array is returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isposinf:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isposinf:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isposinf:18
msgid ""
"A boolean array with the same dimensions as the input. If second argument is "
"not supplied then a boolean array is returned with values True where the "
"corresponding element of the input is positive infinity and values False "
"where the element of the input is not positive infinity."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isposinf:24
msgid ""
"If a second argument is supplied the result is stored there. If the type of "
"that array is a numeric type the result is represented as zeros and ones, if "
"the type is boolean then as False and True. The return value `out` is then a "
"reference to that array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isposinf:38
msgid ":obj:`isinf`, :obj:`isneginf`, :obj:`isfinite`, :obj:`isnan`"
msgstr ""

