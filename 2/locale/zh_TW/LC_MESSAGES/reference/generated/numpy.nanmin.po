#: of numpy.nanmin:34
msgid ""
"The maximum value of an output element. Must be present to allow computation "
"on empty slice. See `~numpy.ufunc.reduce` for details."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmin:45
msgid "**where**"
msgstr "**where**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmin:-1
msgid "array_like of bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmin:40
