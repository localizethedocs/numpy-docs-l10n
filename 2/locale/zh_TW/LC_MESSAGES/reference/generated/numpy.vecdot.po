#: ../../../reference/generated/numpy.vecdot.rst:4
msgid "numpy.vecdot"
msgstr ""

#: ../../../../docstring of numpy.vecdot:2
msgid "Vector dot product of two arrays."
msgstr ""

#: ../../../../docstring of numpy.vecdot:4
msgid ""
"Let :math:`\\mathbf{a}` be a vector in `x1` and :math:`\\mathbf{b}` be a "
"corresponding vector in `x2`. The dot product is defined as:"
msgstr ""

#: ../../../../docstring of numpy.vecdot:7
msgid ""
"\\mathbf{a} \\cdot \\mathbf{b} = \\sum_{i=0}^{n-1} \\overline{a_i}b_i\n"
"\n"
msgstr ""

#: ../../../../docstring of numpy.vecdot:10
msgid ""
"where the sum is over the last dimension (unless `axis` is specified) and "
"where :math:`\\overline{a_i}` denotes the complex conjugate if :math:`a_i` "
"is complex and the identity otherwise."
msgstr ""

