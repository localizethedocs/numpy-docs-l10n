#: ../../../reference/generated/numpy.ma.clip.rst:4
msgid "numpy.ma.clip"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.clip:2
msgid "Clip (limit) the values in an array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.clip:4
msgid ""
"Given an interval, values outside the interval are clipped to the interval "
"edges.  For example, if an interval of ``[0, 1]`` is specified, values "
"smaller than 0 become 0, and values larger than 1 become 1."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.clip:9
msgid ""
"Equivalent to but faster than ``np.minimum(a_max, np.maximum(a, a_min))``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.clip:11
msgid "No check is performed to ensure ``a_min < a_max``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.clip:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.clip:16
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.clip:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.clip:16
msgid "Array containing elements to clip."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.clip:22
msgid "**a_min, a_max**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.clip:-1
msgid "array_like or None"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.clip:19
msgid ""
"Minimum and maximum value. If ``None``, clipping is not performed on the "
"corresponding edge. If both ``a_min`` and ``a_max`` are ``None``, the "
"elements of the returned array stay the same. Both are broadcasted against "
"``a``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.clip:27
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.clip:-1
msgid "ndarray, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.clip:25
msgid ""
"The results will be placed in this array. It may be the input array for in-"
"place clipping.  `out` must be of the right shape to hold the output.  Its "
"type is preserved."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.clip:34
msgid "**min, max**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.clip:30
msgid ""
"Array API compatible alternatives for ``a_min`` and ``a_max`` arguments. "
"Either ``a_min`` and ``a_max`` or ``min`` and ``max`` can be passed at the "
"same time. Default: ``None``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.clip:38
msgid "**\\*\\*kwargs**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.clip:37
msgid ""
"For other keyword-only arguments, see the :ref:`ufunc docs <ufuncs.kwargs>`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.clip:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.clip:51
msgid "**clipped_array**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.clip:-1
msgid "MaskedArray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.clip:43
msgid ""
"An array with the elements of `a`, but where values < `a_min` are replaced "
"with `a_min`, and those > `a_max` with `a_max`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.clip:56
msgid ":ref:`ufuncs-output-type`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.clip:60
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.clip:61
msgid ""
"When `a_min` is greater than `a_max`, `clip` returns an array in which all "
"values are equal to `a_max`, as shown in the second example."
msgstr ""

