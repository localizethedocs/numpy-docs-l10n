msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:-1
msgid "ndarray, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:55
msgid ""
"The indices of the first occurrences of the unique values in the original "
"array. Only provided if `return_index` is True."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:60
msgid "**unique_inverse**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:59
msgid ""
"The indices to reconstruct the original array from the unique array. Only "
"provided if `return_inverse` is True."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:70
msgid "**unique_counts**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:63
msgid ""
"The number of times each of the unique values comes up in the original "
"array. Only provided if `return_counts` is True."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:75
msgid ":obj:`repeat`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:76
msgid "Repeat elements of an array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:77
msgid ":obj:`sort`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:78
msgid "Return a sorted copy of an array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:82
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:83
msgid ""
"When an axis is specified the subarrays indexed by the axis are sorted. This "
"is done by making the specified axis the first dimension of the array (move "
"the axis to the first dimension to keep the order of the other axes) and "
"then flattening the subarrays in C order. The flattened subarrays are then "
"viewed as a structured type with each element given a label, with the effect "
"that we end up with a 1-D array of structured types that can be treated in "
"the same way as any other 1-D array. The result is that the flattened "
"subarrays are sorted in lexicographic order starting with the first element."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:93
msgid ""
"Like np.sort, NaN will sort to the end of the values. For complex arrays all "
"NaN values are considered equivalent (no matter whether the NaN is in the "
"real or imaginary part). As the representant for the returned array the "
"smallest one in the lexicographical order is chosen - see np.sort for how "
"the lexicographical order is defined for complex arrays."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:101
msgid ""
"For multi-dimensional inputs, ``unique_inverse`` is reshaped such that the "
"input can be reconstructed using ``np.take(unique, unique_inverse, "
"axis=axis)``. The result is now not 1-dimensional when ``axis=None``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:107
msgid ""
"Note that in NumPy 2.0.0 a higher dimensional array was returned also when "
"``axis`` was not ``None``.  This was reverted, but ``inverse.reshape(-1)`` "
"can be used to ensure compatibility with both versions."
msgstr ""

