msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:14
msgid ""
"Input array. Unless `axis` is specified, this will be flattened if it is not "
"already 1-D."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:19
msgid "**return_index**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:18
msgid ""
"If True, also return the indices of `ar` (along the specified axis, if "
"provided, or in the flattened array) that result in the unique array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:23
msgid "**return_inverse**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:22
msgid ""
"If True, also return the indices of the unique array (for the specified "
"axis, if provided) that can be used to reconstruct `ar`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:27
msgid "**return_counts**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:26
msgid ""
"If True, also return the number of times each unique item appears in `ar`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:35
msgid "**axis**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:-1
msgid "int or None, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:30
msgid ""
"The axis to operate on. If None, `ar` will be flattened. If an integer, the "
"subarrays indexed by the given axis will be flattened and treated as the "
"elements of a 1-D array with the dimension of the given axis, see the notes "
"for more details.  Object arrays or structured arrays that contain objects "
"are not supported if the `axis` kwarg is used. The default is None."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:40
msgid "**equal_nan**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:38
msgid "If True, collapses multiple NaN values in the return array into one."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:47
msgid "**sorted**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:43
msgid ""
"If True, the unique elements are sorted. Elements may be sorted in practice "
"even if ``sorted=False``, but this could change without notice."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:52
msgid "**unique**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:52
msgid "The sorted unique values."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:56
