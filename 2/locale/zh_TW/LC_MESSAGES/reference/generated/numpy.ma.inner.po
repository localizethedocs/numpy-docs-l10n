msgid "Masked values are replaced by 0."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.inner:48
msgid "For vectors (1-D arrays) it computes the ordinary inner-product::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.inner:50
msgid "np.inner(a, b) = sum(a[:]*b[:])"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.inner:52
msgid "More generally, if ``ndim(a) = r > 0`` and ``ndim(b) = s > 0``::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.inner:54
msgid "np.inner(a, b) = np.tensordot(a, b, axes=(-1,-1))"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.inner:56
msgid "or explicitly::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.inner:58
msgid ""
"np.inner(a, b)[i0,...,ir-2,j0,...,js-2]\n"
"     = sum(a[i0,...,ir-2,:]*b[j0,...,js-2,:])"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.inner:61
msgid "In addition `a` or `b` may be scalars, in which case::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.inner:63
msgid "np.inner(a,b) = a*b"
msgstr ""

