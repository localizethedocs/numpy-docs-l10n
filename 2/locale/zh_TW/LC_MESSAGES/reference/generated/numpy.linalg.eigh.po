#: ../../../reference/generated/numpy.linalg.eigh.rst:4
msgid "numpy.linalg.eigh"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.eigh:2
msgid ""
"Return the eigenvalues and eigenvectors of a complex Hermitian (conjugate "
"symmetric) or a real symmetric matrix."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.eigh:5
msgid ""
"Returns two objects, a 1-D array containing the eigenvalues of `a`, and a 2-"
"D square array or matrix (depending on the input type) of the corresponding "
"eigenvectors (in columns)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.eigh:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.eigh:13
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.eigh:-1
msgid "(..., M, M) array"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.eigh:12
msgid ""
"Hermitian or real symmetric matrices whose eigenvalues and eigenvectors are "
"to be computed."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.eigh:21
msgid "**UPLO**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.eigh:-1
msgid "{'L', 'U'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.eigh:16
msgid ""
"Specifies whether the calculation is done with the lower triangular part of "
"`a` ('L', default) or the upper triangular part ('U'). Irrespective of this "
"value only the real parts of the diagonal will be considered in the "
"computation to preserve the notion of a Hermitian matrix. It therefore "
"follows that the imaginary part of the diagonal will always be treated as "
"zero."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.eigh:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.eigh:26
msgid "A namedtuple with the following attributes:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.eigh:30
msgid "**eigenvalues**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.eigh:-1
msgid "(..., M) ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.eigh:29
msgid ""
"The eigenvalues in ascending order, each repeated according to its "
"multiplicity."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.eigh:38
msgid "**eigenvectors**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.eigh:-1
msgid "{(..., M, M) ndarray, (..., M, M) matrix}"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.eigh:33
msgid ""
"The column ``eigenvectors[:, i]`` is the normalized eigenvector "
"corresponding to the eigenvalue ``eigenvalues[i]``.  Will return a matrix "
"object if `a` is a matrix object."
msgstr ""

