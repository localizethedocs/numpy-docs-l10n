msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.eigh:65
msgid ""
"The eigenvalues/eigenvectors are computed using LAPACK routines ``_syevd``, "
"``_heevd``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.eigh:68
msgid ""
"The eigenvalues of real symmetric or complex Hermitian matrices are always "
"real. [Rc702e98a756a-1]_ The array `eigenvalues` of (column) eigenvectors is "
"unitary and `a`, `eigenvalues`, and `eigenvectors` satisfy the equations "
"``dot(a, eigenvectors[:, i]) = eigenvalues[i] * eigenvectors[:, i]``."
msgstr ""

