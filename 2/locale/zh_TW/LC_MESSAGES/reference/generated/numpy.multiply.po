#: ../../../../docstring of numpy.multiply:2
msgid "Multiply arguments element-wise."
msgstr ""

#: ../../../../docstring of numpy.multiply:0
msgid "Parameters"
msgstr "參數"

#: ../../../../docstring of numpy.multiply:10
msgid "**x1, x2**"
msgstr ""

#: ../../../../docstring of numpy.multiply:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../docstring of numpy.multiply:8
msgid ""
"Input arrays to be multiplied. If ``x1.shape != x2.shape``, they must be "
"broadcastable to a common shape (which becomes the shape of the output)."
msgstr ""

#: ../../../../docstring of numpy.multiply:16
msgid "**out**"
msgstr "**out**"

#: ../../../../docstring of numpy.multiply:-1
msgid "ndarray, None, or tuple of ndarray and None, optional"
msgstr ""

#: ../../../../docstring of numpy.multiply:13
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or None, a freshly-"
"allocated array is returned. A tuple (possible only as a keyword argument) "
"must have length equal to the number of outputs."
msgstr ""

#: ../../../../docstring of numpy.multiply:24
msgid "**where**"
msgstr "**where**"

#: ../../../../docstring of numpy.multiply:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../docstring of numpy.multiply:19
msgid ""
"This condition is broadcast over the input. At locations where the condition "
"is True, the `out` array will be set to the ufunc result. Elsewhere, the "
"`out` array will retain its original value. Note that if an uninitialized "
"`out` array is created via the default ``out=None``, locations within it "
"where the condition is False will remain uninitialized."
msgstr ""

#: ../../../../docstring of numpy.multiply:30
msgid "**\\*\\*kwargs**"
msgstr "**\\*\\*kwargs**"

#: ../../../../docstring of numpy.multiply:27
msgid ""
"For other keyword-only arguments, see the :ref:`ufunc docs <ufuncs.kwargs>`."
msgstr ""

#: ../../../../docstring of numpy.multiply:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../docstring of numpy.multiply:43
msgid "**y**"
msgstr "**y**"

#: ../../../../docstring of numpy.multiply:-1
msgid "ndarray"
msgstr "ndarray"

#: ../../../../docstring of numpy.multiply:35
msgid ""
"The product of `x1` and `x2`, element-wise. This is a scalar if both `x1` "
"and `x2` are scalars."
msgstr ""

#: ../../../../docstring of numpy.multiply:46
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.multiply:47
msgid "Equivalent to `x1` * `x2` in terms of array broadcasting."
msgstr ""

