#: ../../../reference/routines.strings.rst:25
msgid ""
"Prior to NumPy 2.0, all string functionality was in `numpy.char`, which only "
"operated on fixed-width strings. That module will not be getting updates and "
"will be deprecated at some point in the future."
msgstr ""

#: ../../../reference/routines.strings.rst:30
msgid "String operations"
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ""
":py:obj:`add <numpy.strings.add>`\\ \\(x1\\, x2\\, \\/\\[\\, out\\, where\\, "
"casting\\, order\\, ...\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid "Add arguments element-wise."
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ""
":py:obj:`center <numpy.strings.center>`\\ \\(a\\, width\\[\\, fillchar\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ""
"Return a copy of `a` with its elements centered in a string of length "
"`width`."
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ":py:obj:`capitalize <numpy.strings.capitalize>`\\ \\(a\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ""
"Return a copy of ``a`` with only the first character of each element "
"capitalized."
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ""
":py:obj:`decode <numpy.strings.decode>`\\ \\(a\\[\\, encoding\\, errors\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid "Calls :meth:`bytes.decode` element-wise."
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ""
":py:obj:`encode <numpy.strings.encode>`\\ \\(a\\[\\, encoding\\, errors\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid "Calls :meth:`str.encode` element-wise."
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ""
":py:obj:`expandtabs <numpy.strings.expandtabs>`\\ \\(a\\[\\, tabsize\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ""
"Return a copy of each string element where all tab characters are replaced "
"by one or more spaces."
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ""
":py:obj:`ljust <numpy.strings.ljust>`\\ \\(a\\, width\\[\\, fillchar\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ""
"Return an array with the elements of `a` left-justified in a string of "
"length `width`."
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ":py:obj:`lower <numpy.strings.lower>`\\ \\(a\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid "Return an array with the elements converted to lowercase."
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ":py:obj:`lstrip <numpy.strings.lstrip>`\\ \\(a\\[\\, chars\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ""
"For each element in `a`, return a copy with the leading characters removed."
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ":py:obj:`mod <numpy.strings.mod>`\\ \\(a\\, values\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ""
"Return (a % i), that is pre-Python 2.6 string formatting (interpolation), "
"element-wise for a pair of array_likes of str or unicode."
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ":py:obj:`multiply <numpy.strings.multiply>`\\ \\(a\\, i\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid "Return (a * i), that is string multiple concatenation, element-wise."
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ":py:obj:`partition <numpy.strings.partition>`\\ \\(a\\, sep\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid "Partition each element in ``a`` around ``sep``."
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ""
":py:obj:`replace <numpy.strings.replace>`\\ \\(a\\, old\\, new\\[\\, "
"count\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ""
"For each element in ``a``, return a copy of the string with occurrences of "
"substring ``old`` replaced by ``new``."
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ""
":py:obj:`rjust <numpy.strings.rjust>`\\ \\(a\\, width\\[\\, fillchar\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ""
"Return an array with the elements of `a` right-justified in a string of "
"length `width`."
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ":py:obj:`rpartition <numpy.strings.rpartition>`\\ \\(a\\, sep\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid "Partition (split) each element around the right-most separator."
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ":py:obj:`rstrip <numpy.strings.rstrip>`\\ \\(a\\[\\, chars\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ""
"For each element in `a`, return a copy with the trailing characters removed."
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ""
":py:obj:`slice <numpy.strings.slice>`\\ \\(a\\[\\, start\\, stop\\, "
"step\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ""
"Slice the strings in `a` by slices specified by `start`, `stop`, `step`."
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ":py:obj:`strip <numpy.strings.strip>`\\ \\(a\\[\\, chars\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ""
"For each element in `a`, return a copy with the leading and trailing "
"characters removed."
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ":py:obj:`swapcase <numpy.strings.swapcase>`\\ \\(a\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ""
"Return element-wise a copy of the string with uppercase characters converted "
"to lowercase and vice versa."
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ":py:obj:`title <numpy.strings.title>`\\ \\(a\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid "Return element-wise title cased version of string or unicode."
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ""
":py:obj:`translate <numpy.strings.translate>`\\ \\(a\\, table\\[\\, "
"deletechars\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ""
"For each element in `a`, return a copy of the string where all characters "
"occurring in the optional argument `deletechars` are removed, and the "
"remaining characters have been mapped through the given translation table."
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ":py:obj:`upper <numpy.strings.upper>`\\ \\(a\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid "Return an array with the elements converted to uppercase."
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid ":py:obj:`zfill <numpy.strings.zfill>`\\ \\(a\\, width\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:58:<autosummary>:1
msgid "Return the numeric string left-filled with zeros."
msgstr ""

#: ../../../reference/routines.strings.rst:60
msgid "Comparison"
msgstr ""

#: ../../../reference/routines.strings.rst:62
msgid ""
"The `numpy.strings` module also exports the comparison universal functions "
"that can now operate on string arrays as well."
msgstr ""

#: ../../../reference/routines.strings.rst:74:<autosummary>:1
msgid ""
":py:obj:`equal <numpy.strings.equal>`\\ \\(x1\\, x2\\, \\/\\[\\, out\\, "
"where\\, casting\\, ...\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:74:<autosummary>:1
msgid "Return (x1 == x2) element-wise."
msgstr ""

#: ../../../reference/routines.strings.rst:74:<autosummary>:1
msgid ""
":py:obj:`not_equal <numpy.strings.not_equal>`\\ \\(x1\\, x2\\, \\/\\[\\, "
"out\\, where\\, casting\\, ...\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:74:<autosummary>:1
msgid "Return (x1 != x2) element-wise."
msgstr ""

#: ../../../reference/routines.strings.rst:74:<autosummary>:1
msgid ""
":py:obj:`greater_equal <numpy.strings.greater_equal>`\\ \\(x1\\, x2\\, \\/"
"\\[\\, out\\, where\\, ...\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:74:<autosummary>:1
msgid "Return the truth value of (x1 >= x2) element-wise."
msgstr ""

#: ../../../reference/routines.strings.rst:74:<autosummary>:1
msgid ""
":py:obj:`less_equal <numpy.strings.less_equal>`\\ \\(x1\\, x2\\, \\/\\[\\, "
"out\\, where\\, casting\\, ...\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:74:<autosummary>:1
msgid "Return the truth value of (x1 <= x2) element-wise."
msgstr ""

#: ../../../reference/routines.strings.rst:74:<autosummary>:1
msgid ""
":py:obj:`greater <numpy.strings.greater>`\\ \\(x1\\, x2\\, \\/\\[\\, out\\, "
"where\\, casting\\, ...\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:74:<autosummary>:1
msgid "Return the truth value of (x1 > x2) element-wise."
msgstr ""

#: ../../../reference/routines.strings.rst:74:<autosummary>:1
msgid ""
":py:obj:`less <numpy.strings.less>`\\ \\(x1\\, x2\\, \\/\\[\\, out\\, "
"where\\, casting\\, ...\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:74:<autosummary>:1
msgid "Return the truth value of (x1 < x2) element-wise."
msgstr ""

#: ../../../reference/routines.strings.rst:76
msgid "String information"
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
":py:obj:`count <numpy.strings.count>`\\ \\(a\\, sub\\[\\, start\\, end\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
"Returns an array with the number of non-overlapping occurrences of substring "
"``sub`` in the range [``start``, ``end``)."
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
":py:obj:`endswith <numpy.strings.endswith>`\\ \\(a\\, suffix\\[\\, start\\, "
"end\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
"Returns a boolean array which is `True` where the string element in ``a`` "
"ends with ``suffix``, otherwise `False`."
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
":py:obj:`find <numpy.strings.find>`\\ \\(a\\, sub\\[\\, start\\, end\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
"For each element, return the lowest index in the string where substring "
"``sub`` is found, such that ``sub`` is contained in the range [``start``, "
"``end``)."
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
":py:obj:`index <numpy.strings.index>`\\ \\(a\\, sub\\[\\, start\\, end\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
"Like `find`, but raises :exc:`ValueError` when the substring is not found."
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
":py:obj:`isalnum <numpy.strings.isalnum>`\\ \\(x\\, \\/\\[\\, out\\, "
"where\\, casting\\, order\\, ...\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
"Returns true for each element if all characters in the string are "
"alphanumeric and there is at least one character, false otherwise."
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
":py:obj:`isalpha <numpy.strings.isalpha>`\\ \\(x\\, \\/\\[\\, out\\, "
"where\\, casting\\, order\\, ...\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
"Returns true for each element if all characters in the data interpreted as a "
"string are alphabetic and there is at least one character, false otherwise."
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
":py:obj:`isdecimal <numpy.strings.isdecimal>`\\ \\(x\\, \\/\\[\\, out\\, "
"where\\, casting\\, ...\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
"For each element, return True if there are only decimal characters in the "
"element."
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
":py:obj:`isdigit <numpy.strings.isdigit>`\\ \\(x\\, \\/\\[\\, out\\, "
"where\\, casting\\, order\\, ...\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
"Returns true for each element if all characters in the string are digits and "
"there is at least one character, false otherwise."
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
":py:obj:`islower <numpy.strings.islower>`\\ \\(x\\, \\/\\[\\, out\\, "
"where\\, casting\\, order\\, ...\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
"Returns true for each element if all cased characters in the string are "
"lowercase and there is at least one cased character, false otherwise."
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
":py:obj:`isnumeric <numpy.strings.isnumeric>`\\ \\(x\\, \\/\\[\\, out\\, "
"where\\, casting\\, ...\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
"For each element, return True if there are only numeric characters in the "
"element."
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
":py:obj:`isspace <numpy.strings.isspace>`\\ \\(x\\, \\/\\[\\, out\\, "
"where\\, casting\\, order\\, ...\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
"Returns true for each element if there are only whitespace characters in the "
"string and there is at least one character, false otherwise."
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
":py:obj:`istitle <numpy.strings.istitle>`\\ \\(x\\, \\/\\[\\, out\\, "
"where\\, casting\\, order\\, ...\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
"Returns true for each element if the element is a titlecased string and "
"there is at least one character, false otherwise."
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
":py:obj:`isupper <numpy.strings.isupper>`\\ \\(x\\, \\/\\[\\, out\\, "
"where\\, casting\\, order\\, ...\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
"Return true for each element if all cased characters in the string are "
"uppercase and there is at least one character, false otherwise."
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
":py:obj:`rfind <numpy.strings.rfind>`\\ \\(a\\, sub\\[\\, start\\, end\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
"For each element, return the highest index in the string where substring "
"``sub`` is found, such that ``sub`` is contained in the range [``start``, "
"``end``)."
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
":py:obj:`rindex <numpy.strings.rindex>`\\ \\(a\\, sub\\[\\, start\\, "
"end\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
"Like `rfind`, but raises :exc:`ValueError` when the substring `sub` is not "
"found."
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
":py:obj:`startswith <numpy.strings.startswith>`\\ \\(a\\, prefix\\[\\, "
"start\\, end\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
"Returns a boolean array which is `True` where the string element in ``a`` "
"starts with ``prefix``, otherwise `False`."
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid ""
":py:obj:`str_len <numpy.strings.str_len>`\\ \\(x\\, \\/\\[\\, out\\, "
"where\\, casting\\, order\\, ...\\]\\)"
msgstr ""

#: ../../../reference/routines.strings.rst:97:<autosummary>:1
msgid "Returns the length of each element."
msgstr ""
