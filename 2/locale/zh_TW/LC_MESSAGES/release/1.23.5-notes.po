#: ../../../release/1.23.5-notes.rst:5
msgid "NumPy 1.23.5 Release Notes"
msgstr "NumPy 1.23.5 發行備註"

#: ../../../release/1.23.5-notes.rst:6
msgid ""
"NumPy 1.23.5 is a maintenance release that fixes bugs discovered after the "
"1.23.4 release and keeps the build infrastructure current. The Python "
"versions supported for this release are 3.8-3.11."
msgstr ""

