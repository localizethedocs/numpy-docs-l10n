#: ../../../release/1.17.4-notes.rst:5
msgid "NumPy 1.17.4 Release Notes"
msgstr "NumPy 1.17.4 發行備註"

#: ../../../release/1.17.4-notes.rst:7
msgid ""
"This release contains fixes for bugs reported against NumPy 1.17.3 along "
"with some build improvements. The Python versions supported in this release "
"are 3.5-3.8."
msgstr ""

#: ../../../release/1.17.4-notes.rst:11
msgid ""
"Downstream developers should use Cython >= 0.29.13 for Python 3.8 support "
"and OpenBLAS >= 3.7 to avoid errors on the Skylake architecture."
msgstr ""

#: ../../../release/1.17.4-notes.rst:16
msgid "Highlights"
msgstr ""

#: ../../../release/1.17.4-notes.rst:18
msgid ""
"Fixed `random.random_integers` biased generation of 8 and 16 bit integers."
msgstr ""

#: ../../../release/1.17.4-notes.rst:19
msgid "Fixed `np.einsum` regression on Power9 and z/Linux."
msgstr ""

#: ../../../release/1.17.4-notes.rst:20
msgid "Fixed histogram problem with signed integer arrays."
msgstr ""

