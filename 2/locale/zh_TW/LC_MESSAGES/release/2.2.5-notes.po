#: ../../../release/2.2.5-notes.rst:5
msgid "NumPy 2.2.5 Release Notes"
msgstr ""

#: ../../../release/2.2.5-notes.rst:7
msgid ""
"NumPy 2.2.5 is a patch release that fixes bugs found after the 2.2.4 "
"release. It has a large number of typing fixes/improvements as well as the "
"normal bug fixes and some CI maintenance."
msgstr ""

#: ../../../release/2.2.5-notes.rst:11
msgid "This release supports Python versions 3.10-3.13."
msgstr ""

