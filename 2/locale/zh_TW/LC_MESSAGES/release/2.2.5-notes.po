#: ../../../release/2.2.5-notes.rst:35
msgid ""
"`#28582 <https://github.com/numpy/numpy/pull/28582>`__: BUG: Fix return type "
"of NpyIter_GetIterNext in Cython declarations"
msgstr ""

#: ../../../release/2.2.5-notes.rst:36
msgid ""
"`#28583 <https://github.com/numpy/numpy/pull/28583>`__: BUG: avoid deadlocks "
"with C++ shared mutex in dispatch cache"
msgstr ""

#: ../../../release/2.2.5-notes.rst:37
msgid ""
"`#28585 <https://github.com/numpy/numpy/pull/28585>`__: TYP: fix typing "
"errors in ``_core.strings``"
msgstr ""

#: ../../../release/2.2.5-notes.rst:38
msgid ""
"`#28631 <https://github.com/numpy/numpy/pull/28631>`__: MAINT, CI: Update "
"Ubuntu to 22.04 in azure-pipelines"
msgstr ""

#: ../../../release/2.2.5-notes.rst:39
msgid ""
"`#28632 <https://github.com/numpy/numpy/pull/28632>`__: BUG: Set writeable "
"flag for writeable dlpacks."
msgstr ""

#: ../../../release/2.2.5-notes.rst:40
msgid ""
"`#28633 <https://github.com/numpy/numpy/pull/28633>`__: BUG: Fix "
"crackfortran parsing error when a division occurs within..."
msgstr ""

#: ../../../release/2.2.5-notes.rst:41
msgid ""
"`#28650 <https://github.com/numpy/numpy/pull/28650>`__: TYP: fix ``ndarray."
"tolist()`` and ``.item()`` for unknown dtype"
msgstr ""

#: ../../../release/2.2.5-notes.rst:42
msgid ""
"`#28654 <https://github.com/numpy/numpy/pull/28654>`__: BUG: fix deepcopying "
"StringDType arrays (#28643)"
msgstr ""

#: ../../../release/2.2.5-notes.rst:43
msgid ""
"`#28661 <https://github.com/numpy/numpy/pull/28661>`__: TYP: Accept objects "
"that ``write()`` to ``str`` in ``savetxt``"
msgstr ""

#: ../../../release/2.2.5-notes.rst:44
msgid ""
"`#28663 <https://github.com/numpy/numpy/pull/28663>`__: CI: Replace QEMU "
"armhf with native (32-bit compatibility mode)"
msgstr ""

#: ../../../release/2.2.5-notes.rst:45
msgid ""
"`#28682 <https://github.com/numpy/numpy/pull/28682>`__: SIMD: Resolve "
"Highway QSort symbol linking error on aarch32/ASIMD"
msgstr ""

#: ../../../release/2.2.5-notes.rst:46
msgid ""
"`#28683 <https://github.com/numpy/numpy/pull/28683>`__: TYP: add missing "
"``\"b1\"`` literals for ``dtype[bool]``"
msgstr ""

#: ../../../release/2.2.5-notes.rst:47
msgid ""
"`#28705 <https://github.com/numpy/numpy/pull/28705>`__: TYP: Fix false "
"rejection of ``NDArray[object_].__abs__()``"
msgstr ""

#: ../../../release/2.2.5-notes.rst:48
msgid ""
"`#28706 <https://github.com/numpy/numpy/pull/28706>`__: TYP: Fix "
"inconsistent ``NDArray[float64].__[r]truediv__`` return..."
msgstr ""

#: ../../../release/2.2.5-notes.rst:49
msgid ""
