#: ../../../release/1.21.3-notes.rst:5
msgid "NumPy 1.21.3 Release Notes"
msgstr "NumPy 1.21.3 發行備註"

#: ../../../release/1.21.3-notes.rst:7
msgid ""
"NumPy 1.21.3 is a maintenance release that fixes a few bugs discovered after "
"1.21.2. It also provides 64 bit Python 3.10.0 wheels. Note a few oddities "
"about Python 3.10:"
msgstr ""

#: ../../../release/1.21.3-notes.rst:11
msgid "There are no 32 bit wheels for Windows, Mac, or Linux."
msgstr ""

#: ../../../release/1.21.3-notes.rst:12
msgid "The Mac Intel builds are only available in universal2 wheels."
msgstr ""

#: ../../../release/1.21.3-notes.rst:14
msgid ""
"The Python versions supported in this release are 3.7-3.10. If you want to "
"compile your own version using gcc-11, you will need to use gcc-11.2+ to "
"avoid problems."
msgstr ""

