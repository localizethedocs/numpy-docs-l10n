"The MS Windows version of Python discussed here installs to a non-"
"deterministic path using a hash. This needs to be added to the ``PATH`` "
"variable."
msgstr ""

#: ../../../f2py/windows/index.rst:182
msgid ""
"$Env:Path += \";$env:LOCALAPPDATA\\packages\\pythonsoftwarefoundation."
"python.3.10_qbz5n2kfra8p0\\localcache\\local-packages\\python310\\scripts\""
msgstr ""
