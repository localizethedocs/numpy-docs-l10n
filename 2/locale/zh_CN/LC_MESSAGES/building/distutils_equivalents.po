#: ../../../building/distutils_equivalents.rst:4
msgid "Meson and ``distutils`` ways of doing things"
msgstr ""

#: ../../../building/distutils_equivalents.rst:6
msgid "*Old workflows (numpy.distutils based):*"
msgstr ""

#: ../../../building/distutils_equivalents.rst:8
msgid "``python runtests.py``"
msgstr ""

#: ../../../building/distutils_equivalents.rst:9
msgid ""
"``python setup.py build_ext -i`` + ``export PYTHONPATH=/home/username/path/"
"to/numpy/reporoot`` (and then edit pure Python code in NumPy and run it with "
"``python some_script.py``)."
msgstr ""

#: ../../../building/distutils_equivalents.rst:12
msgid ""
"``python setup.py develop`` - this is similar to (2), except in-place build "
"is made permanently visible in env."
msgstr ""

#: ../../../building/distutils_equivalents.rst:14
msgid ""
"``python setup.py bdist_wheel`` + ``pip install dist/numpy*.whl`` - build "
"wheel in current env and install it."
msgstr ""

#: ../../../building/distutils_equivalents.rst:16
msgid ""
"``pip install .`` - build wheel in an isolated build env against deps in "
"``pyproject.toml`` and install it. *Note: be careful, this is usually not "
"the correct command for development installs - typically you want to use (4) "
"or* ``pip install . -v --no-build-isolation``."
msgstr ""

#: ../../../building/distutils_equivalents.rst:21
msgid "*New workflows (Meson and meson-python based):*"
msgstr ""

#: ../../../building/distutils_equivalents.rst:23
msgid "``spin test``"
msgstr ""

#: ../../../building/distutils_equivalents.rst:24
msgid ""
"``pip install -e . --no-build-isolation`` (note: only for working on NumPy "
"itself - for more details, see :ref:`IDE support & editable installs <meson-"
"editable-installs>`)"
msgstr ""

#: ../../../building/distutils_equivalents.rst:27
msgid "the same as (2)"
msgstr ""

#: ../../../building/distutils_equivalents.rst:28
msgid ""
"``python -m build --no-isolation`` + ``pip install dist/numpy*.whl`` - see "
"`pypa/build <https://pypa-build.readthedocs.io/en/latest/>`_."
msgstr ""

#: ../../../building/distutils_equivalents.rst:30
msgid "``pip install .``"
msgstr ""
