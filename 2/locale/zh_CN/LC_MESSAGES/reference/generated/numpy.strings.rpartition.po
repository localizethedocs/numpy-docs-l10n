#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/strings/__init__.py:docstring
#: of numpy.strings.rpartition:2
msgid "Partition (split) each element around the right-most separator."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/strings/__init__.py:docstring
#: of numpy.strings.rpartition:4
msgid ""
"For each element in ``a``, split the element at the last occurrence of "
"``sep``, and return a 3-tuple containing the part before the separator, the "
"separator itself, and the part after the separator. If the separator is not "
"found, the third item of the tuple will contain the whole string, and the "
"first and second ones will be the empty string."
msgstr ""

