#: ../../../reference/generated/numpy.tile.rst:4
msgid "numpy.tile"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.tile:2
msgid "Construct an array by repeating A the number of times given by reps."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.tile:4
msgid ""
"If `reps` has length ``d``, the result will have dimension of ``max(d, A."
"ndim)``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.tile:7
msgid ""
"If ``A.ndim < d``, `A` is promoted to be d-dimensional by prepending new "
"axes. So a shape (3,) array is promoted to (1, 3) for 2-D replication, or "
"shape (1, 1, 3) for 3-D replication. If this is not the desired behavior, "
"promote `A` to d-dimensions manually before calling this function."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.tile:13
msgid ""
"If ``A.ndim > d``, `reps` is promoted to `A`.ndim by prepending 1's to it. "
"Thus for an `A` of shape (2, 3, 4, 5), a `reps` of (2, 2) is treated as (1, "
"1, 2, 2)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.tile:17
msgid ""
"Note : Although tile may be used for broadcasting, it is strongly "
"recommended to use numpy's broadcasting operations and functions."
msgstr ""

