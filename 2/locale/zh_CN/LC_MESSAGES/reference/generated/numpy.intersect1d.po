msgid ""
"If True, the input arrays are both assumed to be unique, which can speed up "
"the calculation.  If True but ``ar1`` or ``ar2`` are not unique, incorrect "
"results and out-of-bounds indices could result. Default is False."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.intersect1d:20
msgid "**return_indices**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.intersect1d:18
msgid ""
"If True, the indices which correspond to the intersection of the two arrays "
"are returned. The first instance of a value is used if there are multiple. "
"Default is False."
msgstr ""

