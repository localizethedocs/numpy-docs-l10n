#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermder:24
msgid ""
"Each differentiation is multiplied by `scl`.  The end result is "
"multiplication by ``scl**m``.  This is for use in a linear change of "
"variable. (Default: 1)"
msgstr ""

