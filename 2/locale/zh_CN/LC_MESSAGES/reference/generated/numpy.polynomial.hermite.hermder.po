#: ../../../reference/generated/numpy.polynomial.hermite.hermder.rst:4
msgid "numpy.polynomial.hermite.hermder"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermder:2
msgid "Differentiate a Hermite series."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermder:4
msgid ""
"Returns the Hermite series coefficients `c` differentiated `m` times along "
"`axis`.  At each iteration the result is multiplied by `scl` (the scaling "
"factor is for use in a linear change of variable). The argument `c` is an "
"array of coefficients from low to high degree along each axis, e.g., [1,2,3] "
"represents the series ``1*H_0 + 2*H_1 + 3*H_2`` while [[1,2],[1,2]] "
"represents ``1*H_0(x)*H_0(y) + 1*H_1(x)*H_0(y) + 2*H_0(x)*H_1(y) + "
"2*H_1(x)*H_1(y)`` if axis=0 is ``x`` and axis=1 is ``y``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermder:0
msgid "Parameters"
msgstr ""

