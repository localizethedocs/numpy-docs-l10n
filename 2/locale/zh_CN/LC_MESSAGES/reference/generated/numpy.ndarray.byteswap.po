#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ndarray.byteswap:4
msgid ""
"Toggle between low-endian and big-endian data representation by returning a "
"byteswapped array, optionally swapped in-place. Arrays of byte-strings are "
"not swapped. The real and imaginary parts of a complex number are swapped "
"individually."
msgstr ""

