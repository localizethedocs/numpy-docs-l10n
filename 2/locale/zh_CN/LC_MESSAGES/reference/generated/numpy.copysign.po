#: ../../../reference/generated/numpy.copysign.rst:4
msgid "numpy.copysign"
msgstr ""

#: ../../../../docstring of numpy.copysign:2
msgid "Change the sign of x1 to that of x2, element-wise."
msgstr ""

#: ../../../../docstring of numpy.copysign:4
msgid "If `x2` is a scalar, its sign will be copied to all elements of `x1`."
msgstr ""

#: ../../../../docstring of numpy.copysign:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.copysign:9
msgid "**x1**"
msgstr ""

#: ../../../../docstring of numpy.copysign:-1
msgid "array_like"
msgstr ""

#: ../../../../docstring of numpy.copysign:9
msgid "Values to change the sign of."
msgstr ""

#: ../../../../docstring of numpy.copysign:14
msgid "**x2**"
msgstr ""

#: ../../../../docstring of numpy.copysign:12
msgid ""
"The sign of `x2` is copied to `x1`. If ``x1.shape != x2.shape``, they must "
"be broadcastable to a common shape (which becomes the shape of the output)."
msgstr ""

#: ../../../../docstring of numpy.copysign:20 numpy.copysign:44
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.copysign:-1
msgid "ndarray, None, or tuple of ndarray and None, optional"
msgstr ""

#: ../../../../docstring of numpy.copysign:17
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or None, a freshly-"
"allocated array is returned. A tuple (possible only as a keyword argument) "
"must have length equal to the number of outputs."
msgstr ""

#: ../../../../docstring of numpy.copysign:28
msgid "**where**"
msgstr ""

#: ../../../../docstring of numpy.copysign:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../docstring of numpy.copysign:23
msgid ""
"This condition is broadcast over the input. At locations where the condition "
"is True, the `out` array will be set to the ufunc result. Elsewhere, the "
"`out` array will retain its original value. Note that if an uninitialized "
"`out` array is created via the default ``out=None``, locations within it "
"where the condition is False will remain uninitialized."
msgstr ""

#: ../../../../docstring of numpy.copysign:32
msgid "**\\*\\*kwargs**"
msgstr ""

#: ../../../../docstring of numpy.copysign:31
msgid ""
"For other keyword-only arguments, see the :ref:`ufunc docs <ufuncs.kwargs>`."
msgstr ""

#: ../../../../docstring of numpy.copysign:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.copysign:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.copysign:37
msgid ""
"The values of `x1` with the sign of `x2`. This is a scalar if both `x1` and "
"`x2` are scalars."
msgstr ""

#: ../../../../docstring of numpy.copysign:49
msgid ":obj:`sign`"
msgstr ""

#: ../../../../docstring of numpy.copysign:51
msgid ":obj:`signbit`"
msgstr ""

