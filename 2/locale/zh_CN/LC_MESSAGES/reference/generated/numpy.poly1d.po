msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.poly1d:17
msgid ""
"The polynomial's coefficients, in decreasing powers, or if the value of the "
"second parameter is True, the polynomial's roots (values where the "
"polynomial evaluates to 0).  For example, ``poly1d([1, 2, 3])`` returns an "
"object that represents :math:`x^2 + 2x + 3`, whereas ``poly1d([1, 2, 3], "
"True)`` returns one that represents :math:`(x-1)(x-2)(x-3) = x^3 - 6x^2 + "
"11x -6`."
msgstr ""

