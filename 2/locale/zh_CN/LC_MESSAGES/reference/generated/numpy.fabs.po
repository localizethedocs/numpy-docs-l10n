#: ../../../reference/generated/numpy.fabs.rst:4
msgid "numpy.fabs"
msgstr ""

#: ../../../../docstring of numpy.fabs:2
msgid "Compute the absolute values element-wise."
msgstr ""

#: ../../../../docstring of numpy.fabs:4
msgid ""
"This function returns the absolute values (positive magnitude) of the data "
"in `x`. Complex values are not handled, use `absolute` to find the absolute "
"values of complex data."
msgstr ""

#: ../../../../docstring of numpy.fabs:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.fabs:12
msgid "**x**"
msgstr ""

#: ../../../../docstring of numpy.fabs:-1
msgid "array_like"
msgstr ""

#: ../../../../docstring of numpy.fabs:11
msgid ""
"The array of numbers for which the absolute values are required. If `x` is a "
"scalar, the result `y` will also be a scalar."
msgstr ""

#: ../../../../docstring of numpy.fabs:18
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.fabs:-1
msgid "ndarray, None, or tuple of ndarray and None, optional"
msgstr ""

#: ../../../../docstring of numpy.fabs:15
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or None, a freshly-"
"allocated array is returned. A tuple (possible only as a keyword argument) "
"must have length equal to the number of outputs."
msgstr ""

#: ../../../../docstring of numpy.fabs:26
msgid "**where**"
msgstr ""

#: ../../../../docstring of numpy.fabs:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../docstring of numpy.fabs:21
msgid ""
"This condition is broadcast over the input. At locations where the condition "
"is True, the `out` array will be set to the ufunc result. Elsewhere, the "
"`out` array will retain its original value. Note that if an uninitialized "
"`out` array is created via the default ``out=None``, locations within it "
"where the condition is False will remain uninitialized."
msgstr ""

#: ../../../../docstring of numpy.fabs:30
msgid "**\\*\\*kwargs**"
msgstr ""

#: ../../../../docstring of numpy.fabs:29
msgid ""
"For other keyword-only arguments, see the :ref:`ufunc docs <ufuncs.kwargs>`."
msgstr ""

#: ../../../../docstring of numpy.fabs:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.fabs:42
msgid "**y**"
msgstr ""

#: ../../../../docstring of numpy.fabs:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.fabs:35
msgid ""
"The absolute values of `x`, the returned values are always floats. This is a "
"scalar if `x` is a scalar."
msgstr ""

#: ../../../../docstring of numpy.fabs:47
msgid ":obj:`absolute`"
msgstr ""

#: ../../../../docstring of numpy.fabs:48
msgid "Absolute values including `complex` types."
msgstr ""

