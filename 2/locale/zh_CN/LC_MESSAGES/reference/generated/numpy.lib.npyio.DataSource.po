#: ../../../reference/generated/numpy.lib.npyio.DataSource.rst:2
msgid "numpy.lib.npyio.DataSource"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/npyio.py:docstring
#: of numpy.lib.npyio.DataSource:2
msgid "A generic data source file (file, http, ftp, ...)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/npyio.py:docstring
#: of numpy.lib.npyio.DataSource:4
msgid ""
"DataSources can be local files or remote files/URLs.  The files may also be "
"compressed or uncompressed. DataSource hides some of the low-level details "
"of downloading the file, allowing you to simply pass in a valid file path "
"(or URL) and obtain a file object."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/npyio.py:docstring
#: of numpy.lib.npyio.DataSource:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/npyio.py:docstring
#: of numpy.lib.npyio.DataSource:22
msgid "**destpath**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/npyio.py:docstring
#: of numpy.lib.npyio.DataSource:-1
msgid "str or None, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/npyio.py:docstring
#: of numpy.lib.npyio.DataSource:12
msgid ""
"Path to the directory where the source file gets downloaded to for use.  If "
"`destpath` is None, a temporary directory will be created. The default path "
"is the current directory."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/npyio.py:docstring
#: of numpy.lib.npyio.DataSource:25
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/npyio.py:docstring
#: of numpy.lib.npyio.DataSource:26
msgid ""
"URLs require a scheme string (``http://``) to be used, without it they will "
"fail::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/npyio.py:docstring
#: of numpy.lib.npyio.DataSource:29
msgid ""
">>> repos = np.lib.npyio.DataSource()\n"
">>> repos.exists('www.google.com/index.html')\n"
"False\n"
">>> repos.exists('http://www.google.com/index.html')\n"
"True"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/npyio.py:docstring
#: of numpy.lib.npyio.DataSource:35
msgid "Temporary directories are deleted when the DataSource is deleted."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/npyio.py:docstring
#: of numpy.lib.npyio.DataSource:39
msgid "Examples"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/npyio.py:docstring
#: of numpy.lib.npyio.DataSource:46
msgid ""
">>> ds = np.lib.npyio.DataSource('/home/guido')\n"
">>> urlname = 'http://www.google.com/'\n"
">>> gfile = ds.open('http://www.google.com/')\n"
">>> ds.abspath(urlname)\n"
"'/home/guido/www.google.com/index.html'\n"
"\n"
">>> ds = np.lib.npyio.DataSource(None)  # use with temporary file\n"
">>> ds.open('/home/guido/foobar.txt')\n"
"<open file '/home/guido.foobar.txt', mode 'r' at 0x91d4430>\n"
">>> ds.abspath('/home/guido/foobar.txt')\n"
"'/tmp/.../home/guido/foobar.txt'"
msgstr ""

