msgid "Return the data of a masked array as an ndarray."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.getdata:4
msgid ""
"Return the data of `a` (if any) as an ndarray if `a` is a ``MaskedArray``, "
"else return `a` as a ndarray or subclass (depending on `subok`) if not."
msgstr ""

