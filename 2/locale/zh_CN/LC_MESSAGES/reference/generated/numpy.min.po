msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:11
msgid ""
"Axis or axes along which to operate.  By default, flattened input is used."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:14
msgid ""
"If this is a tuple of ints, the minimum is selected over multiple axes, "
"instead of a single axis or all the axes as before."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:20
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:-1
msgid "ndarray, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:18
msgid ""
"Alternative output array in which to place the result.  Must be of the same "
"shape and buffer length as the expected output. See :ref:`ufuncs-output-"
"type` for more details."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:31
msgid "**keepdims**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:23
msgid ""
"If this is set to True, the axes which are reduced are left in the result as "
"dimensions with size one. With this option, the result will broadcast "
"correctly against the input array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:27
msgid ""
"If the default value is passed, then `keepdims` will not be passed through "
"to the ``min`` method of sub-classes of `ndarray`, however any non-default "
"value will be.  If the sub-class' method does not implement `keepdims` any "
"exceptions will be raised."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:35
msgid "**initial**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:-1
msgid "scalar, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:34
msgid ""
"The maximum value of an output element. Must be present to allow computation "
"on empty slice. See `~numpy.ufunc.reduce` for details."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:39
msgid "**where**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:-1
msgid "array_like of bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:38
msgid ""
"Elements to compare for the minimum. See `~numpy.ufunc.reduce` for details."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:53
msgid "**min**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:44
msgid ""
"Minimum of `a`. If `axis` is None, the result is a scalar value. If `axis` "
"is an int, the result is an array of dimension ``a.ndim - 1``.  If `axis` is "
"a tuple, the result is an array of dimension ``a.ndim - len(axis)``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:58
msgid ":obj:`amax`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:59
msgid "The maximum value of an array along a given axis, propagating any NaNs."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:60
msgid ":obj:`nanmin`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:61
msgid "The minimum value of an array along a given axis, ignoring any NaNs."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:62
msgid ":obj:`minimum`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:63
msgid "Element-wise minimum of two arrays, propagating any NaNs."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:64
msgid ":obj:`fmin`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:65
msgid "Element-wise minimum of two arrays, ignoring any NaNs."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:66
msgid ":obj:`argmin`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:67
msgid "Return the indices of the minimum values."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:68
msgid ":obj:`nanmax`, :obj:`maximum`, :obj:`fmax`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:72
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:73
msgid ""
"NaN values are propagated, that is if at least one item is NaN, the "
"corresponding min value will be NaN as well. To ignore NaN values (MATLAB "
"behavior), please use nanmin."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:77
msgid ""
"Don't use `~numpy.min` for element-wise comparison of 2 arrays; when ``a."
"shape[0]`` is 2, ``minimum(a[0], a[1])`` is faster than ``min(a, axis=0)``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:83
msgid "Examples"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:114
msgid ""
"Notice that the initial value is used as one of the elements for which the "
"minimum is determined, unlike for the default argument Python's max "
"function, which is only used for empty iterables."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.min:118
msgid "Notice that this isn't the same as Python's ``default`` argument."
msgstr ""

