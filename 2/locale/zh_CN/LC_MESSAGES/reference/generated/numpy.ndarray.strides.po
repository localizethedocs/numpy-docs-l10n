#: ../../../reference/generated/numpy.ndarray.strides.rst:4
msgid "numpy.ndarray.strides"
msgstr ""

#: ../../../reference/generated/numpy.ndarray.strides.rst:8
msgid "attribute"
msgstr ""

#: ../../../../docstring of numpy.ndarray.strides:2
msgid "Tuple of bytes to step in each dimension when traversing an array."
msgstr ""

#: ../../../../docstring of numpy.ndarray.strides:4
msgid ""
"The byte offset of element ``(i[0], i[1], ..., i[n])`` in an array `a` is::"
msgstr ""

#: ../../../../docstring of numpy.ndarray.strides:7
msgid "offset = sum(np.array(i) * a.strides)"
msgstr ""

#: ../../../../docstring of numpy.ndarray.strides:9
msgid ""
"A more detailed explanation of strides can be found in :ref:`arrays.ndarray`."
msgstr ""

#: ../../../../docstring of numpy.ndarray.strides:14
msgid ""
"Setting ``arr.strides`` is discouraged and may be deprecated in the future.  "
"`numpy.lib.stride_tricks.as_strided` should be preferred to create a new "
"view of the same data in a safer way."
msgstr ""

#: ../../../../docstring of numpy.ndarray.strides:29
msgid ":obj:`numpy.lib.stride_tricks.as_strided`"
msgstr ""

#: ../../../../docstring of numpy.ndarray.strides:33
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.ndarray.strides:34
msgid "Imagine an array of 32-bit integers (each 4 bytes)::"
msgstr ""

#: ../../../../docstring of numpy.ndarray.strides:36
msgid ""
"x = np.array([[0, 1, 2, 3, 4],\n"
"              [5, 6, 7, 8, 9]], dtype=np.int32)"
msgstr ""

#: ../../../../docstring of numpy.ndarray.strides:39
msgid ""
"This array is stored in memory as 40 bytes, one after the other (known as a "
"contiguous block of memory).  The strides of an array tell us how many bytes "
"we have to skip in memory to move to the next position along a certain "
"axis.  For example, we have to skip 4 bytes (1 value) to move to the next "
"column, but 20 bytes (5 values) to get to the same position in the next "
"row.  As such, the strides for the array `x` will be ``(20, 4)``."
msgstr ""

