msgstr ""

#: ../../../../docstring of numpy.logical_not:-1
msgid "bool or ndarray of bool"
msgstr ""

#: ../../../../docstring of numpy.logical_not:31
msgid ""
"Boolean result with the same shape as `x` of the NOT operation on elements "
"of `x`. This is a scalar if `x` is a scalar."
msgstr ""

