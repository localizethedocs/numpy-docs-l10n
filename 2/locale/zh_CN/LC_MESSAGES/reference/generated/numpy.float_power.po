#: ../../../reference/generated/numpy.float_power.rst:4
msgid "numpy.float\\_power"
msgstr ""

#: ../../../../docstring of numpy.float_power:2
msgid "First array elements raised to powers from second array, element-wise."
msgstr ""

#: ../../../../docstring of numpy.float_power:4
msgid ""
"Raise each base in `x1` to the positionally-corresponding power in `x2`. "
"`x1` and `x2` must be broadcastable to the same shape. This differs from the "
"power function in that integers, float16, and float32  are promoted to "
"floats with a minimum precision of float64 so that the result is always "
"inexact.  The intent is that the function will return a usable result for "
"negative powers and seldom overflow for positive powers."
msgstr ""

#: ../../../../docstring of numpy.float_power:11
msgid ""
"Negative values raised to a non-integral value will return ``nan``. To get "
"complex results, cast the input to complex, or specify the ``dtype`` to be "
"``complex`` (see the example below)."
msgstr ""

#: ../../../../docstring of numpy.float_power:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.float_power:18
msgid "**x1**"
msgstr ""

#: ../../../../docstring of numpy.float_power:-1
msgid "array_like"
msgstr ""

#: ../../../../docstring of numpy.float_power:18
msgid "The bases."
msgstr ""

#: ../../../../docstring of numpy.float_power:23
msgid "**x2**"
msgstr ""

#: ../../../../docstring of numpy.float_power:21
msgid ""
"The exponents. If ``x1.shape != x2.shape``, they must be broadcastable to a "
"common shape (which becomes the shape of the output)."
msgstr ""

#: ../../../../docstring of numpy.float_power:29
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.float_power:-1
msgid "ndarray, None, or tuple of ndarray and None, optional"
msgstr ""

#: ../../../../docstring of numpy.float_power:26
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or None, a freshly-"
"allocated array is returned. A tuple (possible only as a keyword argument) "
"must have length equal to the number of outputs."
msgstr ""

#: ../../../../docstring of numpy.float_power:37
msgid "**where**"
msgstr ""

#: ../../../../docstring of numpy.float_power:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../docstring of numpy.float_power:32
msgid ""
"This condition is broadcast over the input. At locations where the condition "
"is True, the `out` array will be set to the ufunc result. Elsewhere, the "
"`out` array will retain its original value. Note that if an uninitialized "
"`out` array is created via the default ``out=None``, locations within it "
"where the condition is False will remain uninitialized."
msgstr ""

#: ../../../../docstring of numpy.float_power:41
msgid "**\\*\\*kwargs**"
msgstr ""

#: ../../../../docstring of numpy.float_power:40
msgid ""
"For other keyword-only arguments, see the :ref:`ufunc docs <ufuncs.kwargs>`."
msgstr ""

