#: ../../../reference/generated/numpy.s_.rst:4
msgid "numpy.s\\_"
msgstr ""

#: ../../../../docstring of numpy.s_:2
msgid "A nicer way to build up index tuples for arrays."
msgstr ""

#: ../../../../docstring of numpy.s_:5
msgid ""
"Use one of the two predefined instances ``index_exp`` or `s_` rather than "
"directly using `IndexExpression`."
msgstr ""

#: ../../../../docstring of numpy.s_:8
msgid ""
"For any index combination, including slicing and axis insertion, "
"``a[indices]`` is the same as ``a[np.index_exp[indices]]`` for any array "
"`a`. However, ``np.index_exp[indices]`` can be used anywhere in Python code "
"and returns a tuple of slice objects that can be used in the construction of "
"complex index expressions."
msgstr ""

#: ../../../../docstring of numpy.s_:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.s_:24
msgid "**maketuple**"
msgstr ""

#: ../../../../docstring of numpy.s_:-1
msgid "bool"
msgstr ""

#: ../../../../docstring of numpy.s_:17
msgid "If True, always returns a tuple."
msgstr ""

#: ../../../../docstring of numpy.s_:29
msgid ":obj:`s_`"
msgstr ""

#: ../../../../docstring of numpy.s_:30
msgid ""
"Predefined instance without tuple conversion: `s_ = "
"IndexExpression(maketuple=False)`. The ``index_exp`` is another predefined "
"instance that always returns a tuple: `index_exp = "
"IndexExpression(maketuple=True)`."
msgstr ""

#: ../../../../docstring of numpy.s_:34
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.s_:35
msgid ""
"You can do all this with :class:`slice` plus a few special objects, but "
"there's a lot to remember and this version is simpler because it uses the "
"standard array indexing syntax."
msgstr ""

