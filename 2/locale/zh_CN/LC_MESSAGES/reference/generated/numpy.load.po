msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:64
msgid "If the input file does not exist or cannot be read."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:67
msgid "UnpicklingError"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:67
msgid "If ``allow_pickle=True``, but the file cannot be loaded as a pickle."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:70
msgid "ValueError"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:70
msgid "The file contains an object array, but ``allow_pickle=False`` given."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:76
msgid "EOFError"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:73
msgid ""
"When calling ``np.load`` multiple times on the same file handle, if all data "
"has already been read"
msgstr ""

