#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:90
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:91
msgid ""
"If the file contains pickle data, then whatever object is stored in the "
"pickle is returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:93
msgid "If the file is a ``.npy`` file, then a single array is returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:94
msgid ""
"If the file is a ``.npz`` file, then a dictionary-like object is returned, "
"containing ``{filename: array}`` key-value pairs, one for each file in the "
"archive."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:97
msgid ""
"If the file is a ``.npz`` file, the returned value supports the context "
"manager protocol in a similar fashion to the open function::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:100
msgid ""
"with load('foo.npz') as data:\n"
"    a = data['a']"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:103
msgid "The underlying file descriptor is closed when exiting the 'with' block."
msgstr ""

