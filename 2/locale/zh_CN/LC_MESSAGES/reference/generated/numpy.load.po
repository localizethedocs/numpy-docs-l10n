#: ../../../reference/generated/numpy.load.rst:4
msgid "numpy.load"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:2
msgid ""
"Load arrays or pickled objects from ``.npy``, ``.npz`` or pickled files."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:4
msgid ""
"Loading files that contain object arrays uses the ``pickle`` module, which "
"is not secure against erroneous or maliciously constructed data. Consider "
"passing ``allow_pickle=False`` to load data that is known not to contain "
"object arrays for the safer handling of untrusted sources."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:16
msgid "**file**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:-1
msgid "file-like object, string, or pathlib.Path"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:13
msgid ""
"The file to read. File-like objects must support the ``seek()`` and "
"``read()`` methods and must always be opened in binary mode.  Pickled files "
"require that the file-like object support the ``readline()`` method as well."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:24
msgid "**mmap_mode**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:-1
msgid "{None, 'r+', 'r', 'w+', 'c'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:19
msgid ""
"If not None, then memory-map the file, using the given mode (see `numpy."
"memmap` for a detailed description of the modes).  A memory-mapped array is "
"kept on disk. However, it can be accessed and sliced like any ndarray.  "
"Memory mapping is especially useful for accessing small fragments of large "
"files without reading the entire file into memory."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:30
msgid "**allow_pickle**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:27
msgid ""
"Allow loading pickled object arrays stored in npy files. Reasons for "
"disallowing pickles include security, as loading pickled data can execute "
"arbitrary code. If pickles are disallowed, loading object arrays will fail. "
"Default: False"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:36
msgid "**fix_imports**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:33
msgid ""
"Only useful when loading Python 2 generated pickled files, which includes "
"npy/npz files containing object arrays. If `fix_imports` is True, pickle "
"will try to map the old Python 2 names to the new names used in Python 3."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:43
msgid "**encoding**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:-1
msgid "str, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:39
msgid ""
"What encoding to use when reading Python 2 strings. Only useful when loading "
"Python 2 generated pickled files, which includes npy/npz files containing "
"object arrays. Values other than 'latin1', 'ASCII', and 'bytes' are not "
"allowed, as they can corrupt numerical data. Default: 'ASCII'"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:50
msgid "**max_header_size**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:46
msgid ""
"Maximum allowed size of the header.  Large headers may not be safe to load "
"securely and thus require explicitly passing a larger value. See :py:func:"
"`ast.literal_eval()` for details. This option is ignored when `allow_pickle` "
"is passed.  In that case the file is by definition trusted and the limit is "
"unnecessary."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:59
msgid "**result**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:-1
msgid "array, tuple, dict, etc."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.load:55
msgid ""
"Data stored in the file. For ``.npz`` files, the returned instance of "
"NpzFile class must be closed to avoid leaking file descriptors."
msgstr ""

