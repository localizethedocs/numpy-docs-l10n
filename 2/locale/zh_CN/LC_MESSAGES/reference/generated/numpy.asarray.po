#: of numpy.asarray:62
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.asarray:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.asarray:54
msgid ""
"Array interpretation of ``a``.  No copy is performed if the input is already "
"an ndarray with matching dtype and order.  If ``a`` is a subclass of "
"ndarray, a base class ndarray is returned."
msgstr ""

