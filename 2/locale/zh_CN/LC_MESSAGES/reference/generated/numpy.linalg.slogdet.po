#: ../../../reference/generated/numpy.linalg.slogdet.rst:4
msgid "numpy.linalg.slogdet"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.slogdet:2
msgid ""
"Compute the sign and (natural) logarithm of the determinant of an array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.slogdet:4
msgid ""
"If an array has a very small or very large determinant, then a call to `det` "
"may overflow or underflow. This routine is more robust against such issues, "
"because it computes the logarithm of the determinant rather than the "
"determinant itself."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.slogdet:0
msgid "Parameters"
msgstr ""

