#: ../../../reference/generated/numpy.ravel.rst:4
msgid "numpy.ravel"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ravel:2
msgid "Return a contiguous flattened array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ravel:4
msgid ""
"A 1-D array, containing the elements of the input, is returned.  A copy is "
"made only if needed."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ravel:7
msgid ""
"As of NumPy 1.10, the returned array will have the same type as the input "
"array. (for example, a masked array will be returned for a masked array "
"input)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ravel:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ravel:15
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ravel:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ravel:14
msgid ""
"Input array.  The elements in `a` are read in the order specified by "
"`order`, and packed as a 1-D array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ravel:31
msgid "**order**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ravel:-1
msgid "{'C','F', 'A', 'K'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ravel:18
msgid ""
"The elements of `a` are read using this index order. 'C' means to index the "
"elements in row-major, C-style order, with the last axis index changing "
"fastest, back to the first axis index changing slowest.  'F' means to index "
"the elements in column-major, Fortran-style order, with the first index "
"changing fastest, and the last index changing slowest. Note that the 'C' and "
"'F' options take no account of the memory layout of the underlying array, "
"and only refer to the order of axis indexing.  'A' means to read the "
"elements in Fortran-like index order if `a` is Fortran *contiguous* in "
"memory, C-like order otherwise.  'K' means to read the elements in the order "
"they occur in memory, except for reversing the data when strides are "
"negative.  By default, 'C' index order is used."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ravel:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ravel:45
msgid "**y**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ravel:36
msgid ""
"y is a contiguous 1-D array of the same subtype as `a`, with shape ``(a."
"size,)``. Note that matrices are special cased for backward compatibility, "
"if `a` is a matrix, then y is a 1-D ndarray."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ravel:50
msgid ":obj:`ndarray.flat`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ravel:51
msgid "1-D iterator over an array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ravel:52
msgid ":obj:`ndarray.flatten`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ravel:53
msgid "1-D array copy of the elements of an array in row-major order."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ravel:54
msgid ":obj:`ndarray.reshape`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ravel:55
msgid "Change the shape of an array without changing its data."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ravel:59
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ravel:60
msgid ""
"In row-major, C-style order, in two dimensions, the row index varies the "
"slowest, and the column index the quickest.  This can be generalized to "
"multiple dimensions, where row-major order implies that the index along the "
"first axis varies slowest, and the index along the last quickest.  The "
"opposite holds for column-major, Fortran-style index ordering."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ravel:67
msgid ""
"When a view is desired in as many cases as possible, ``arr.reshape(-1)`` may "
"be preferable. However, ``ravel`` supports ``K`` in the optional ``order`` "
"argument while ``reshape`` does not."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ravel:73
msgid "Examples"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ravel:78
msgid "It is equivalent to ``reshape(-1, order=order)``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ravel:91
msgid ""
"When ``order`` is 'A', it will preserve the array's 'C' or 'F' ordering:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ravel:98
msgid ""
"When ``order`` is 'K', it will preserve orderings that are neither 'C' nor "
"'F', but won't reverse axes:"
msgstr ""

