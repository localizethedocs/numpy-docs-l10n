#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.measure:2
msgid "Return elapsed time for executing code in the namespace of the caller."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.measure:4
msgid ""
"The supplied code string is compiled with the Python builtin ``compile``. "
"The precision of the timing is 10 milli-seconds. If the code will execute "
"fast on this timescale, it can be executed many times to get reasonable "
"timing accuracy."
msgstr ""

