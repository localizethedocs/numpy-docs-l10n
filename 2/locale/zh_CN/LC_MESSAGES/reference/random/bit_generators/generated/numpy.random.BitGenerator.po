#: ../../../reference/random/bit_generators/generated/numpy.random.BitGenerator.rst:2
msgid "numpy.random.BitGenerator"
msgstr ""

#: ../../../../docstring of numpy.random.bit_generator.BitGenerator:2
msgid ""
"Base Class for generic BitGenerators, which provide a stream of random bits "
"based on different algorithms. Must be overridden."
msgstr ""

#: ../../../../docstring of numpy.random.bit_generator.BitGenerator:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.random.bit_generator.BitGenerator:21
msgid "**seed**"
msgstr ""

#: ../../../../docstring of numpy.random.bit_generator.BitGenerator:-1
msgid "{None, int, array_like[ints], SeedSequence}, optional"
msgstr ""

#: ../../../../docstring of numpy.random.bit_generator.BitGenerator:9
msgid ""
"A seed to initialize the `BitGenerator`. If None, then fresh, unpredictable "
"entropy will be pulled from the OS. If an ``int`` or ``array_like[ints]`` is "
"passed, then it will be passed to `~numpy.random.SeedSequence` to derive the "
"initial `BitGenerator` state. One may also pass in a `SeedSequence` "
"instance. All integer values must be non-negative."
msgstr ""

#: ../../../../docstring of numpy.random.bit_generator.BitGenerator:26
msgid ":obj:`SeedSequence`"
msgstr ""

