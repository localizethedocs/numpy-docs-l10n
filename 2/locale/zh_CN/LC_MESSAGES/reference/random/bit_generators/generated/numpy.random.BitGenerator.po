msgid "Attributes"
msgstr ""

#: ../../../../docstring of numpy.random.bit_generator.BitGenerator:38
msgid "**lock**"
msgstr ""

#: ../../../../docstring of numpy.random.bit_generator.BitGenerator:-1
msgid "threading.Lock"
msgstr ""

#: ../../../../docstring of numpy.random.bit_generator.BitGenerator:35
msgid ""
"Lock instance that is shared so that the same BitGenerator can be used in "
"multiple Generators without corrupting the state. Code that generates values "
"from a bit generator should hold the bit generator's lock."
msgstr ""

