#: ../../../../docstring of numpy.random._generator.Generator.beta:2
msgid "Draw samples from a Beta distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.beta:4
msgid ""
"The Beta distribution is a special case of the Dirichlet distribution, and "
"is related to the Gamma distribution. It has the probability distribution "
"function"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.beta:8
msgid ""
"f(x; a,b) = \\frac{1}{B(\\alpha, \\beta)} x^{\\alpha - 1}\n"
"(1 - x)^{\\beta - 1},\n"
"\n"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.beta:11
msgid "where the normalization, B, is the beta function,"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.beta:13
msgid ""
"B(\\alpha, \\beta) = \\int_0^1 t^{\\alpha - 1}\n"
"(1 - t)^{\\beta - 1} dt.\n"
"\n"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.beta:16
msgid "It is often seen in Bayesian inference and order statistics."
msgstr ""

