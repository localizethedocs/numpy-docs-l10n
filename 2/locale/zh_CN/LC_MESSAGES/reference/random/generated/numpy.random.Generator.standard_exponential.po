#: ../../../../docstring of
#: numpy.random._generator.Generator.standard_exponential:2
msgid "Draw samples from the standard exponential distribution."
msgstr ""

#: ../../../../docstring of
#: numpy.random._generator.Generator.standard_exponential:4
msgid ""
"`standard_exponential` is identical to the exponential distribution with a "
"scale parameter of 1."
msgstr ""

#: ../../../../docstring of
#: numpy.random._generator.Generator.standard_exponential:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of
#: numpy.random._generator.Generator.standard_exponential:12
msgid "**size**"
msgstr ""

#: ../../../../docstring of
#: numpy.random._generator.Generator.standard_exponential:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../docstring of
#: numpy.random._generator.Generator.standard_exponential:10
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn.  Default is None, in which case a single value is "
"returned."
msgstr ""

#: ../../../../docstring of
#: numpy.random._generator.Generator.standard_exponential:16
msgid "**dtype**"
msgstr ""

#: ../../../../docstring of
#: numpy.random._generator.Generator.standard_exponential:-1
msgid "dtype, optional"
msgstr ""

#: ../../../../docstring of
#: numpy.random._generator.Generator.standard_exponential:15
msgid ""
"Desired dtype of the result, only `float64` and `float32` are supported. "
"Byteorder must be native. The default value is np.float64."
msgstr ""

#: ../../../../docstring of
#: numpy.random._generator.Generator.standard_exponential:20
msgid "**method**"
msgstr ""

#: ../../../../docstring of
#: numpy.random._generator.Generator.standard_exponential:-1
msgid "str, optional"
msgstr ""

#: ../../../../docstring of
#: numpy.random._generator.Generator.standard_exponential:19
msgid ""
"Either 'inv' or 'zig'. 'inv' uses the default inverse CDF method. 'zig' uses "
"the much faster Ziggurat method of Marsaglia and Tsang."
msgstr ""

