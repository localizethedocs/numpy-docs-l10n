"Convenience function that accepts dimensions as input, e.g., ``rand(2,2)`` "
"would generate a 2-by-2 array of floats, uniformly distributed over ``[0, "
"1)``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
