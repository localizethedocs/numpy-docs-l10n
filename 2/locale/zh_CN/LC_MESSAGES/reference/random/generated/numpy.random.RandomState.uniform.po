msgid "numpy.random.RandomState.uniform"
msgstr ""

#: ../../../reference/random/generated/numpy.random.RandomState.uniform.rst:8
msgid "method"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.uniform:2
msgid "Draw samples from a uniform distribution."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.uniform:4
msgid ""
"Samples are uniformly distributed over the half-open interval ``[low, "
"high)`` (includes low, but excludes high).  In other words, any value within "
"the given interval is equally likely to be drawn by `uniform`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.uniform:10
msgid ""
"New code should use the `~numpy.random.Generator.uniform` method of a "
"`~numpy.random.Generator` instance instead; please see the :ref:`random-"
"quick-start`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.uniform:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.uniform:18
msgid "**low**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.uniform:-1
msgid "float or array_like of floats, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.uniform:17
msgid ""
"Lower boundary of the output interval.  All values generated will be greater "
"than or equal to low.  The default value is 0."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.uniform:25
msgid "**high**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.uniform:-1
msgid "float or array_like of floats"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.uniform:21
msgid ""
"Upper boundary of the output interval.  All values generated will be less "
"than or equal to high.  The high limit may be included in the returned array "
"of floats due to floating-point rounding in the equation ``low + (high-low) "
"* random_sample()``.  The default value is 1.0."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.uniform:33
msgid "**size**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.uniform:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.uniform:28
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn.  If size is ``None`` (default), a single value is "
"returned if ``low`` and ``high`` are both scalars. Otherwise, ``np."
"broadcast(low, high).size`` samples are drawn."
msgstr ""

