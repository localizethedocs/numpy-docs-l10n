#: ../../../reference/random/generated/numpy.random.Generator.zipf.rst:4
msgid "numpy.random.Generator.zipf"
msgstr ""

#: ../../../reference/random/generated/numpy.random.Generator.zipf.rst:8
msgid "method"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.zipf:2
msgid "Draw samples from a Zipf distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.zipf:4
msgid ""
"Samples are drawn from a Zipf distribution with specified parameter `a` > 1."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.zipf:7
msgid ""
"The Zipf distribution (also known as the zeta distribution) is a discrete "
"probability distribution that satisfies Zipf's law: the frequency of an item "
"is inversely proportional to its rank in a frequency table."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.zipf:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.zipf:15
msgid "**a**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.zipf:-1
msgid "float or array_like of floats"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.zipf:15
msgid "Distribution parameter. Must be greater than 1."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.zipf:21
msgid "**size**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.zipf:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.zipf:18
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn.  If size is ``None`` (default), a single value is "
"returned if ``a`` is a scalar. Otherwise, ``np.array(a).size`` samples are "
"drawn."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.zipf:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.zipf:32
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.zipf:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.zipf:26
msgid "Drawn samples from the parameterized Zipf distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.zipf:37
msgid ":obj:`scipy.stats.zipf`"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.zipf:38
msgid ""
"probability density function, distribution, or cumulative density function, "
"etc."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.zipf:42
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.zipf:43
msgid "The probability mass function (PMF) for the Zipf distribution is"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.zipf:45
msgid ""
"p(k) = \\frac{k^{-a}}{\\zeta(a)},\n"
"\n"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.zipf:47
msgid ""
"for integers :math:`k \\geq 1`, where :math:`\\zeta` is the Riemann Zeta "
"function."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.zipf:50
msgid ""
"It is named for the American linguist George Kingsley Zipf, who noted that "
"the frequency of any word in a sample of a language is inversely "
"proportional to its rank in the frequency table."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.zipf:55
msgid "References"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.zipf:56
msgid ""
"Zipf, G. K., \"Selected Studies of the Principle of Relative Frequency in "
"Language,\" Cambridge, MA: Harvard Univ. Press, 1932."
msgstr ""

