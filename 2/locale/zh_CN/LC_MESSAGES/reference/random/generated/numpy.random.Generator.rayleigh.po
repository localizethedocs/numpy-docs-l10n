#: ../../../reference/random/generated/numpy.random.Generator.rayleigh.rst:4
msgid "numpy.random.Generator.rayleigh"
msgstr ""

#: ../../../reference/random/generated/numpy.random.Generator.rayleigh.rst:8
msgid "method"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.rayleigh:2
msgid "Draw samples from a Rayleigh distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.rayleigh:4
msgid ""
"The :math:`\\chi` and Weibull distributions are generalizations of the "
"Rayleigh."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.rayleigh:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.rayleigh:10
msgid "**scale**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.rayleigh:-1
msgid "float or array_like of floats, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.rayleigh:10
msgid "Scale, also equals the mode. Must be non-negative. Default is 1."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.rayleigh:16
msgid "**size**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.rayleigh:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.rayleigh:13
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn.  If size is ``None`` (default), a single value is "
"returned if ``scale`` is a scalar.  Otherwise, ``np.array(scale).size`` "
"samples are drawn."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.rayleigh:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.rayleigh:28
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.rayleigh:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.rayleigh:21
msgid "Drawn samples from the parameterized Rayleigh distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.rayleigh:31
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.rayleigh:32
msgid "The probability density function for the Rayleigh distribution is"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.rayleigh:34
msgid ""
"P(x;scale) = \\frac{x}{scale^2}e^{\\frac{-x^2}{2 \\cdotp scale^2}}\n"
"\n"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.rayleigh:36
msgid ""
"The Rayleigh distribution would arise, for example, if the East and North "
"components of the wind velocity had identical zero-mean Gaussian "
"distributions.  Then the wind speed would have a Rayleigh distribution."
msgstr ""

