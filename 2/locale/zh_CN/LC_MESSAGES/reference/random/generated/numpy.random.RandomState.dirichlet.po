msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:2
msgid "Draw samples from the Dirichlet distribution."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:4
msgid ""
"Draw `size` samples of dimension k from a Dirichlet distribution. A "
"Dirichlet-distributed random variable can be seen as a multivariate "
"generalization of a Beta distribution. The Dirichlet distribution is a "
"conjugate prior of a multinomial distribution in Bayesian inference."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:11
msgid ""
"New code should use the `~numpy.random.Generator.dirichlet` method of a "
"`~numpy.random.Generator` instance instead; please see the :ref:`random-"
"quick-start`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:19
