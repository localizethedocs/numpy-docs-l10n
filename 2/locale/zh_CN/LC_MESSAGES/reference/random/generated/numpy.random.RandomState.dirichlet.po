msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:49
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:50
msgid ""
"The Dirichlet distribution is a distribution over vectors :math:`x` that "
"fulfil the conditions :math:`x_i>0` and :math:`\\sum_{i=1}^k x_i = 1`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:54
msgid ""
"The probability density function :math:`p` of a Dirichlet-distributed random "
"vector :math:`X` is proportional to"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:58
msgid ""
"p(x) \\propto \\prod_{i=1}^{k}{x^{\\alpha_i-1}_i},\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:60
msgid ""
"where :math:`\\alpha` is a vector containing the positive concentration "
"parameters."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:63
msgid ""
"The method uses the following property for computation: let :math:`Y` be a "
"random vector which has components that follow a standard gamma "
"distribution, then :math:`X = \\frac{1}{\\sum_{i=1}^k{Y_i}} Y` is Dirichlet-"
"distributed"
msgstr ""

