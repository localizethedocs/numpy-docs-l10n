#: ../../../reference/swig.interface-file.rst:618
msgid "**array_numdims(a)**"
msgstr ""

#: ../../../reference/swig.interface-file.rst:617
msgid ""
"Evaluates to the integer number of dimensions of ``a``, assuming ``a`` can "
"be cast to a ``PyArrayObject*``."
msgstr ""

#: ../../../reference/swig.interface-file.rst:623
msgid "**array_dimensions(a)**"
msgstr ""

#: ../../../reference/swig.interface-file.rst:621
msgid ""
"Evaluates to an array of type ``npy_intp`` and length ``array_numdims(a)``, "
"giving the lengths of all of the dimensions of ``a``, assuming ``a`` can be "
"cast to a ``PyArrayObject*``."
msgstr ""

#: ../../../reference/swig.interface-file.rst:627
msgid "**array_size(a,i)**"
msgstr ""

#: ../../../reference/swig.interface-file.rst:626
msgid ""
"Evaluates to the ``i``-th dimension size of ``a``, assuming ``a`` can be "
"cast to a ``PyArrayObject*``."
msgstr ""

#: ../../../reference/swig.interface-file.rst:634
msgid "**array_strides(a)**"
msgstr ""

#: ../../../reference/swig.interface-file.rst:630
msgid ""
"Evaluates to an array of type ``npy_intp`` and length ``array_numdims(a)``, "
"giving the stridess of all of the dimensions of ``a``, assuming ``a`` can be "
"cast to a ``PyArrayObject*``.  A stride is the distance in bytes between an "
"element and its immediate neighbor along the same axis."
msgstr ""

#: ../../../reference/swig.interface-file.rst:638
msgid "**array_stride(a,i)**"
msgstr ""

#: ../../../reference/swig.interface-file.rst:637
msgid ""
"Evaluates to the ``i``-th stride of ``a``, assuming ``a`` can be cast to a "
"``PyArrayObject*``."
msgstr ""

#: ../../../reference/swig.interface-file.rst:642
msgid "**array_data(a)**"
msgstr ""

#: ../../../reference/swig.interface-file.rst:641
msgid ""
"Evaluates to a pointer of type ``void*`` that points to the data buffer of "
"``a``, assuming ``a`` can be cast to a ``PyArrayObject*``."
msgstr ""

#: ../../../reference/swig.interface-file.rst:647
msgid "**array_descr(a)**"
msgstr ""

#: ../../../reference/swig.interface-file.rst:645
msgid ""
"Returns a borrowed reference to the dtype property (``PyArray_Descr*``) of "
"``a``, assuming ``a`` can be cast to a ``PyArrayObject*``."
msgstr ""

#: ../../../reference/swig.interface-file.rst:651
msgid "**array_flags(a)**"
msgstr ""

#: ../../../reference/swig.interface-file.rst:650
msgid ""
"Returns an integer representing the flags of ``a``, assuming ``a`` can be "
"cast to a ``PyArrayObject*``."
msgstr ""

#: ../../../reference/swig.interface-file.rst:655
msgid "**array_enableflags(a,f)**"
msgstr ""

#: ../../../reference/swig.interface-file.rst:654
msgid ""
"Sets the flag represented by ``f`` of ``a``, assuming ``a`` can be cast to a "
