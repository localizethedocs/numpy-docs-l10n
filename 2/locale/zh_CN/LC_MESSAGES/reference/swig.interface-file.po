msgstr ""

#: ../../../reference/swig.interface-file.rst:659
msgid "**array_is_contiguous(a)**"
msgstr ""

#: ../../../reference/swig.interface-file.rst:658
msgid ""
"Evaluates as true if ``a`` is a contiguous array.  Equivalent to "
