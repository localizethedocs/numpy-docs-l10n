#: ../../../release/1.25.2-notes.rst:5
msgid "NumPy 1.25.2 Release Notes"
msgstr ""

#: ../../../release/1.25.2-notes.rst:6
msgid ""
"NumPy 1.25.2 is a maintenance release that fixes bugs and regressions "
"discovered after the 1.25.1 release. This is the last planned release in the "
"1.25.x series, the next release will be 1.26.0, which will use the meson "
"build system and support Python 3.12. The Python versions supported by this "
"release are 3.9-3.11."
msgstr ""

