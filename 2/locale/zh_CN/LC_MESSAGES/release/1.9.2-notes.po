#: ../../../release/1.9.2-notes.rst:3
msgid "NumPy 1.9.2 Release Notes"
msgstr ""

#: ../../../release/1.9.2-notes.rst:5
msgid "This is a bugfix only release in the 1.9.x series."
msgstr ""

#: ../../../release/1.9.2-notes.rst:8
msgid "Issues fixed"
msgstr ""

#: ../../../release/1.9.2-notes.rst:10
msgid ""
"`#5316 <https://github.com/numpy/numpy/issues/5316>`__: fix too large dtype "
"alignment of strings and complex types"
msgstr ""

#: ../../../release/1.9.2-notes.rst:11
msgid ""
"`#5424 <https://github.com/numpy/numpy/issues/5424>`__: fix ma.median when "
"used on ndarrays"
msgstr ""

#: ../../../release/1.9.2-notes.rst:12
msgid ""
"`#5481 <https://github.com/numpy/numpy/issues/5481>`__: Fix astype for "
"structured array fields of different byte order"
msgstr ""

#: ../../../release/1.9.2-notes.rst:13
msgid ""
"`#5354 <https://github.com/numpy/numpy/issues/5354>`__: fix segfault when "
"clipping complex arrays"
msgstr ""

#: ../../../release/1.9.2-notes.rst:14
msgid ""
"`#5524 <https://github.com/numpy/numpy/issues/5524>`__: allow np."
"argpartition on non ndarrays"
msgstr ""

#: ../../../release/1.9.2-notes.rst:15
msgid ""
"`#5612 <https://github.com/numpy/numpy/issues/5612>`__: Fixes ndarray.fill "
"to accept full range of uint64"
msgstr ""

#: ../../../release/1.9.2-notes.rst:16
msgid ""
"`#5155 <https://github.com/numpy/numpy/issues/5155>`__: Fix loadtxt with "
"comments=None and a string None data"
msgstr ""

#: ../../../release/1.9.2-notes.rst:17
msgid ""
"`#4476 <https://github.com/numpy/numpy/issues/4476>`__: Masked array view "
"fails if structured dtype has datetime component"
msgstr ""

#: ../../../release/1.9.2-notes.rst:18
msgid ""
"`#5388 <https://github.com/numpy/numpy/issues/5388>`__: Make RandomState."
"set_state and RandomState.get_state threadsafe"
msgstr ""

#: ../../../release/1.9.2-notes.rst:19
msgid ""
"`#5390 <https://github.com/numpy/numpy/issues/5390>`__: make seed, randint "
"and shuffle threadsafe"
msgstr ""

#: ../../../release/1.9.2-notes.rst:20
msgid ""
"`#5374 <https://github.com/numpy/numpy/issues/5374>`__: Fixed incorrect "
"assert_array_almost_equal_nulp documentation"
msgstr ""

#: ../../../release/1.9.2-notes.rst:21
msgid ""
"`#5393 <https://github.com/numpy/numpy/issues/5393>`__: Add support for "
"ATLAS > 3.9.33."
msgstr ""

#: ../../../release/1.9.2-notes.rst:22
msgid ""
"`#5313 <https://github.com/numpy/numpy/issues/5313>`__: PyArray_AsCArray "
"caused segfault for 3d arrays"
msgstr ""

#: ../../../release/1.9.2-notes.rst:23
msgid ""
"`#5492 <https://github.com/numpy/numpy/issues/5492>`__: handle out of memory "
"in rfftf"
msgstr ""

#: ../../../release/1.9.2-notes.rst:24
msgid ""
"`#4181 <https://github.com/numpy/numpy/issues/4181>`__: fix a few bugs in "
"the random.pareto docstring"
msgstr ""

#: ../../../release/1.9.2-notes.rst:25
msgid ""
"`#5359 <https://github.com/numpy/numpy/issues/5359>`__: minor changes to "
"linspace docstring"
msgstr ""

#: ../../../release/1.9.2-notes.rst:26
msgid ""
"`#4723 <https://github.com/numpy/numpy/issues/4723>`__: fix a compile issues "
"on AIX"
msgstr ""
