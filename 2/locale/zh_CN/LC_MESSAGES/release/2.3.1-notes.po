#: ../../../release/2.3.1-notes.rst:5
msgid "NumPy 2.3.1 Release Notes"
msgstr ""

#: ../../../release/2.3.1-notes.rst:7
msgid ""
"The NumPy 2.3.1 release is a patch release with several bug fixes, "
"annotation improvements, and better support for OpenBSD. Highlights are:"
msgstr ""

#: ../../../release/2.3.1-notes.rst:10
msgid "Fix bug in ``matmul`` for non-contiguous out kwarg parameter"
msgstr ""

#: ../../../release/2.3.1-notes.rst:11
msgid "Fix for Accelerate runtime warnings on M4 hardware"
msgstr ""

#: ../../../release/2.3.1-notes.rst:12
msgid "Fix new in NumPy 2.3.0 ``np.vectorize`` casting errors"
msgstr ""

#: ../../../release/2.3.1-notes.rst:13
msgid "Improved support of cpu features for FreeBSD and OpenBSD"
msgstr ""

#: ../../../release/2.3.1-notes.rst:15
msgid ""
"This release supports Python versions 3.11-3.13, Python 3.14 will be "
"supported when it is released."
msgstr ""

