#: ../../../reference/random/generated/numpy.random.Generator.permuted.rst:4
msgid "numpy.random.Generator.permuted"
msgstr ""

#: ../../../reference/random/generated/numpy.random.Generator.permuted.rst:8
msgid "method"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.permuted:2
msgid "Randomly permute `x` along axis `axis`."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.permuted:4
msgid ""
"Unlike `shuffle`, each slice along the given axis is shuffled independently "
"of the others."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.permuted:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.permuted:10
msgid "**x**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.permuted:-1
msgid "array_like, at least one-dimensional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.permuted:10
msgid "Array to be shuffled."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.permuted:15
msgid "**axis**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.permuted:-1
msgid "int, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.permuted:13
msgid ""
"Slices of `x` in this axis are shuffled. Each slice is shuffled "
"independently of the others.  If `axis` is None, the flattened array is "
"shuffled."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.permuted:19
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.permuted:-1
msgid "ndarray, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.permuted:18
msgid ""
"If given, this is the destination of the shuffled array. If `out` is None, a "
"shuffled copy of the array is returned."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.permuted:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.permuted:32
msgid "ndarray"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.permuted:24
msgid ""
"If `out` is None, a shuffled copy of `x` is returned. Otherwise, the "
"shuffled array is stored in `out`, and `out` is returned"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.permuted:37
msgid ":obj:`shuffle`"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.permuted:39
msgid ":obj:`permutation`"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.permuted:43
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.permuted:44
msgid ""
"An important distinction between methods ``shuffle``  and ``permuted`` is "
"how they both treat the ``axis`` parameter which can be found at :ref:"
"`generator-handling-axis-parameter`."
msgstr ""

