#: ../../../reference/random/generated/numpy.random.geometric.rst:4
msgid "numpy.random.geometric"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.geometric:2
msgid "Draw samples from the geometric distribution."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.geometric:4
msgid ""
"Bernoulli trials are experiments with one of two outcomes: success or "
"failure (an example of such an experiment is flipping a coin).  The "
"geometric distribution models the number of trials that must be run in order "
"to achieve success.  It is therefore supported on the positive integers, ``k "
"= 1, 2, ...``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.geometric:10
msgid "The probability mass function of the geometric distribution is"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.geometric:12
msgid ""
"f(k) = (1 - p)^{k - 1} p\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.geometric:14
msgid "where `p` is the probability of success of an individual trial."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.geometric:17
msgid ""
"New code should use the `~numpy.random.Generator.geometric` method of a "
"`~numpy.random.Generator` instance instead; please see the :ref:`random-"
"quick-start`."
msgstr ""

