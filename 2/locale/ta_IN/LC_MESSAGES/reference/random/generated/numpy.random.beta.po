#: ../../../reference/random/generated/numpy.random.beta.rst:4
msgid "numpy.random.beta"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.beta:2
msgid "Draw samples from a Beta distribution."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.beta:4
msgid ""
"The Beta distribution is a special case of the Dirichlet distribution, and "
"is related to the Gamma distribution.  It has the probability distribution "
"function"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.beta:8
msgid ""
"f(x; a,b) = \\frac{1}{B(\\alpha, \\beta)} x^{\\alpha - 1}\n"
"(1 - x)^{\\beta - 1},\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.beta:11
msgid "where the normalization, B, is the beta function,"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.beta:13
msgid ""
"B(\\alpha, \\beta) = \\int_0^1 t^{\\alpha - 1}\n"
"(1 - t)^{\\beta - 1} dt.\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.beta:16
msgid "It is often seen in Bayesian inference and order statistics."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
