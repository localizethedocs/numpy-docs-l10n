#: ../../../reference/generated/numpy.correlate.rst:4
msgid "numpy.correlate"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:2
msgid "Cross-correlation of two 1-dimensional sequences."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:4
msgid ""
"This function computes the correlation as generally defined in signal "
"processing texts [Rd663958e4897-1]_:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:7
msgid ""
"c_k = \\sum_n a_{n+k} \\cdot \\overline{v}_n\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:9
msgid ""
"with a and v sequences being zero-padded where necessary and :math:"
"`\\overline v` denoting complex conjugation."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:15
msgid "**a, v**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:15
msgid "Input sequences."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:19
msgid "**mode**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:-1
msgid "{'valid', 'same', 'full'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:18
msgid ""
"Refer to the `convolve` docstring.  Note that the default is 'valid', unlike "
"`convolve`, which uses 'full'."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:30
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:24
msgid "Discrete cross-correlation of `a` and `v`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:35
msgid ":obj:`convolve`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:36
msgid "Discrete, linear convolution of two one-dimensional sequences."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:37
msgid ":obj:`scipy.signal.correlate`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:38
msgid "uses FFT which has superior performance on large arrays."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:42
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:43
msgid ""
"The definition of correlation above is not unique and sometimes correlation "
"may be defined differently. Another common definition is [Rd663958e4897-1]_:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:46
msgid ""
"c'_k = \\sum_n a_{n} \\cdot \\overline{v_{n+k}}\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:48
msgid "which is related to :math:`c_k` by :math:`c'_k = c_{-k}`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:50
msgid ""
"`numpy.correlate` may perform slowly in large arrays (i.e. n = 1e5) because "
"it does not use the FFT to compute the convolution; in that case, `scipy."
"signal.correlate` might be preferable."
msgstr ""

