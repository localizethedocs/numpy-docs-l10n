#: ../../../reference/generated/numpy.log.rst:4
msgid "numpy.log"
msgstr ""

#: ../../../../docstring of numpy.log:2
msgid "Natural logarithm, element-wise."
msgstr ""

#: ../../../../docstring of numpy.log:4
msgid ""
"The natural logarithm `log` is the inverse of the exponential function, so "
"that `log(exp(x)) = x`. The natural logarithm is logarithm in base `e`."
msgstr ""

#: ../../../../docstring of numpy.log:0
msgid "Parameters"
msgstr ""

