#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.masked_all:35
msgid ""
"Unlike other masked array creation functions (e.g. `numpy.ma.zeros`, `numpy."
"ma.ones`, `numpy.ma.full`), `masked_all` does not initialize the values of "
"the array, and may therefore be marginally faster. However, the values "
"stored in the newly allocated array are arbitrary. For reproducible "
"behavior, be sure to set each element of the array before reading."
msgstr ""

