#: ../../../reference/generated/numpy.polynomial.polynomial.polyvalfromroots.rst:4
msgid "numpy.polynomial.polynomial.polyvalfromroots"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalfromroots:2
msgid "Evaluate a polynomial specified by its roots at points x."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalfromroots:4
msgid "If `r` is of length ``N``, this function returns the value"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalfromroots:6
msgid ""
"p(x) = \\prod_{n=1}^{N} (x - r_n)\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalfromroots:8
msgid ""
"The parameter `x` is converted to an array only if it is a tuple or a list, "
"otherwise it is treated as a scalar. In either case, either `x` or its "
"elements must support multiplication and addition both with themselves and "
"with the elements of `r`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalfromroots:13
msgid ""
"If `r` is a 1-D array, then ``p(x)`` will have the same shape as `x`.  If "
"`r` is multidimensional, then the shape of the result depends on the value "
"of `tensor`. If `tensor` is ``True`` the shape will be r.shape[1:] + x."
"shape; that is, each polynomial is evaluated at every value of `x`. If "
"`tensor` is ``False``, the shape will be r.shape[1:]; that is, each "
"polynomial is evaluated only for the corresponding broadcast value of `x`. "
"Note that scalars have shape (,)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalfromroots:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalfromroots:27
msgid "**x**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalfromroots:-1
msgid "array_like, compatible object"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalfromroots:24
msgid ""
"If `x` is a list or tuple, it is converted to an ndarray, otherwise it is "
"left unchanged and treated as a scalar. In either case, `x` or its elements "
"must support addition and multiplication with with themselves and with the "
"elements of `r`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalfromroots:33
msgid "**r**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalfromroots:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalfromroots:30
msgid ""
"Array of roots. If `r` is multidimensional the first index is the root "
"index, while the remaining indices enumerate multiple polynomials. For "
"instance, in the two dimensional case the roots of each polynomial may be "
"thought of as stored in the columns of `r`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalfromroots:43
msgid "**tensor**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalfromroots:-1
msgid "boolean, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalfromroots:36
msgid ""
"If True, the shape of the roots array is extended with ones on the right, "
"one for each dimension of `x`. Scalars have dimension 0 for this action. The "
"result is that every column of coefficients in `r` is evaluated for every "
"element of `x`. If False, `x` is broadcast over the columns of `r` for the "
"evaluation.  This keyword is useful when `r` is multidimensional. The "
"default value is True."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalfromroots:0
msgid "Returns"
msgstr ""

