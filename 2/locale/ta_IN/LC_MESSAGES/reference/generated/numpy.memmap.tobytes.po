msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap.tobytes:-1
msgid "{'C', 'F', 'A'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap.tobytes:11
msgid ""
"Controls the memory layout of the bytes object. 'C' means C-order, 'F' means "
"F-order, 'A' (short for *Any*) means 'F' if `a` is Fortran contiguous, 'C' "
"otherwise. Default is 'C'."
msgstr ""

