#: ../../../reference/generated/numpy.polynomial.laguerre.lagint.rst:4
msgid "numpy.polynomial.laguerre.lagint"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagint:2
msgid "Integrate a Laguerre series."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagint:4
msgid ""
"Returns the Laguerre series coefficients `c` integrated `m` times from "
"`lbnd` along `axis`. At each iteration the resulting series is "
"**multiplied** by `scl` and an integration constant, `k`, is added. The "
"scaling factor is for use in a linear change of variable.  (\"Buyer "
"beware\": note that, depending on what one is doing, one may want `scl` to "
"be the reciprocal of what one might expect; for more information, see the "
"Notes section below.)  The argument `c` is an array of coefficients from low "
"to high degree along each axis, e.g., [1,2,3] represents the series ``L_0 + "
"2*L_1 + 3*L_2`` while [[1,2],[1,2]] represents ``1*L_0(x)*L_0(y) + "
"1*L_1(x)*L_0(y) + 2*L_0(x)*L_1(y) + 2*L_1(x)*L_1(y)`` if axis=0 is ``x`` and "
"axis=1 is ``y``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagint:0
msgid "Parameters"
msgstr ""

