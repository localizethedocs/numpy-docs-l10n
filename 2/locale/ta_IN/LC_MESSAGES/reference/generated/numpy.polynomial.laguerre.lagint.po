#: of numpy.polynomial.laguerre.lagint:19
msgid ""
"Array of Laguerre series coefficients. If `c` is multidimensional the "
"different axis correspond to different variables with the degree in each "
"axis given by the corresponding index."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagint:24
msgid "**m**"
