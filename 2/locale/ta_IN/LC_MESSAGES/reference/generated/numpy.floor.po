msgid "**y**"
msgstr ""

#: ../../../../docstring of numpy.floor:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.floor:33
msgid "The floor of each element in `x`. This is a scalar if `x` is a scalar."
msgstr ""

#: ../../../../docstring of numpy.floor:45
msgid ":obj:`ceil`, :obj:`trunc`, :obj:`rint`, :obj:`fix`"
msgstr ""

#: ../../../../docstring of numpy.floor:49
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.floor:50
msgid ""
"Some spreadsheet programs calculate the \"floor-towards-zero\", where "
"``floor(-2.5) == -2``.  NumPy instead uses the definition of `floor` where "
"`floor(-2.5) == -3`. The \"floor-towards-zero\" function is called ``fix`` "
"in NumPy."
msgstr ""

