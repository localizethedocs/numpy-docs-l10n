#: ../../../reference/generated/numpy.floor.rst:4
msgid "numpy.floor"
msgstr ""

#: ../../../../docstring of numpy.floor:2
msgid "Return the floor of the input, element-wise."
msgstr ""

#: ../../../../docstring of numpy.floor:4
msgid ""
"The floor of the scalar `x` is the largest integer `i`, such that `i <= x`.  "
"It is often denoted as :math:`\\lfloor x \\rfloor`."
msgstr ""

#: ../../../../docstring of numpy.floor:0
msgid "Parameters"
msgstr ""

