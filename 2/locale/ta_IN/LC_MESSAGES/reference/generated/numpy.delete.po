#: ../../../reference/generated/numpy.delete.rst:4
msgid "numpy.delete"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.delete:2
msgid ""
"Return a new array with sub-arrays along an axis deleted. For a one "
"dimensional array, this returns those entries not returned by `arr[obj]`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.delete:0
msgid "Parameters"
msgstr ""

