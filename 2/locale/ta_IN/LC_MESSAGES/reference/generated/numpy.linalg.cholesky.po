msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.cholesky:27
msgid ""
"Lower or upper-triangular Cholesky factor of `a`. Returns a matrix object if "
"`a` is a matrix object."
