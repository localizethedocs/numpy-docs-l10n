#: ../../../reference/generated/numpy.linalg.cholesky.rst:4
msgid "numpy.linalg.cholesky"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.cholesky:2
msgid "Cholesky decomposition."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.cholesky:4
msgid ""
"Return the lower or upper Cholesky decomposition, ``L * L.H`` or ``U.H * "
"U``, of the square matrix ``a``, where ``L`` is lower-triangular, ``U`` is "
"upper-triangular, and ``.H`` is the conjugate transpose operator (which is "
"the ordinary transpose if ``a`` is real-valued). ``a`` must be Hermitian "
"(symmetric if real-valued) and positive-definite. No checking is performed "
"to verify whether ``a`` is Hermitian or not. In addition, only the lower or "
"upper-triangular and diagonal elements of ``a`` are used. Only ``L`` or "
"``U`` is actually returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.cholesky:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.cholesky:17
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.cholesky:-1
msgid "(..., M, M) array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.cholesky:16
msgid ""
"Hermitian (symmetric if all elements are real), positive-definite input "
"matrix."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.cholesky:22
msgid "**upper**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.cholesky:-1
msgid "bool"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.cholesky:20
msgid ""
"If ``True``, the result must be the upper-triangular Cholesky factor. If "
"``False``, the result must be the lower-triangular Cholesky factor. Default: "
"``False``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.cholesky:0
