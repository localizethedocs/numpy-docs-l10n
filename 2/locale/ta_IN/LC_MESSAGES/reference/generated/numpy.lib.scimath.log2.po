#: ../../../reference/generated/numpy.lib.scimath.log2.rst:4
msgid "numpy.lib.scimath.log2"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log2:2
msgid "Compute the logarithm base 2 of `x`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log2:4
msgid ""
"Return the \"principal value\" (for a description of this, see `numpy.log2`) "
"of :math:`log_2(x)`. For real `x > 0`, this is a real number (``log2(0)`` "
"returns ``-inf`` and ``log2(np.inf)`` returns ``inf``). Otherwise, the "
"complex principle value is returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log2:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log2:12
msgid "**x**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log2:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log2:12
msgid "The value(s) whose log base 2 is (are) required."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log2:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log2:24
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log2:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log2:17
msgid ""
"The log base 2 of the `x` value(s). If `x` was a scalar, so is `out`, "
"otherwise an array is returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log2:29
msgid ":obj:`numpy.log2`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log2:33
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log2:34
msgid ""
"For a log2() that returns ``NAN`` when real `x < 0`, use `numpy.log2` (note, "
"however, that otherwise `numpy.log2` and this `log2` are identical, i.e., "
"both return ``-inf`` for `x = 0`, ``inf`` for `x = inf`, and, notably, the "
"complex principle value if ``x.imag != 0``)."
msgstr ""

