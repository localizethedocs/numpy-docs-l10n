#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/chebyshev.py:docstring
#: of numpy.polynomial.chebyshev.chebint:27
msgid ""
"Integration constant(s).  The value of the first integral at zero is the "
"first value in the list, the value of the second integral at zero is the "
"second value, etc.  If ``k == []`` (the default), all constants are set to "
"zero.  If ``m == 1``, a single scalar can be given instead of a list."
msgstr ""

