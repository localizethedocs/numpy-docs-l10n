msgid "Save several arrays into a compressed ``.npz`` archive"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:71
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:72
msgid ""
"Further explanation of the `fmt` parameter (``%[flag]width[."
"precision]specifier``):"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:80
msgid "flags:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:76
msgid "``-`` : left justify"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:78
msgid "``+`` : Forces to precede result with + or -."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:80
msgid "``0`` : Left pad the number with zeros instead of space (see width)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:84
msgid "width:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:83
msgid ""
"Minimum number of characters to be printed. The value is not truncated if it "
"has more characters."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:92
msgid "precision:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:87
msgid "For integer specifiers (eg. ``d,i,o,x``), the minimum number of digits."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:89
msgid ""
"For ``e, E`` and ``f`` specifiers, the number of digits to print after the "
"decimal point."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:91
msgid "For ``g`` and ``G``, the maximum number of significant digits."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:92
msgid "For ``s``, the maximum number of characters."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:111
msgid "specifiers:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:95
msgid "``c`` : character"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:97
msgid "``d`` or ``i`` : signed decimal integer"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:99
msgid "``e`` or ``E`` : scientific notation with ``e`` or ``E``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:101
msgid "``f`` : decimal floating point"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:103
msgid "``g,G`` : use the shorter of ``e,E`` or ``f``"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:105
msgid "``o`` : signed octal"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:107
msgid "``s`` : string of characters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:109
msgid "``u`` : unsigned decimal integer"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:111
msgid "``x,X`` : unsigned hexadecimal integer"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savetxt:113
msgid ""
"This explanation of ``fmt`` is not complete, for an exhaustive specification "
"see [R672d4d5b6143-1]_."
msgstr ""

