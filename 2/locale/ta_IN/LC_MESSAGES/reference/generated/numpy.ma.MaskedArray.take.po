"The axis over which to select values. By default, the flattened input array "
"is used."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.take:23 numpy.ma.core.MaskedArray.take:45
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.take:-1
msgid "MaskedArray, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.take:21
msgid ""
"If provided, the result will be placed in this array. It should be of the "
"appropriate shape and dtype. Note that `out` is always buffered if "
"`mode='raise'`; use other modes for better performance."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.take:34
msgid "**mode**"
msgstr ""

