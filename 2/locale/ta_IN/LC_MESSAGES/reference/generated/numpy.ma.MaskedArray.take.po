#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.take:2
msgid "Take elements from a masked array along an axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.take:4
msgid ""
"This function does the same thing as \"fancy\" indexing (indexing arrays "
"using arrays) for masked arrays. It can be easier to use if you need "
"elements along a given axis."
msgstr ""

