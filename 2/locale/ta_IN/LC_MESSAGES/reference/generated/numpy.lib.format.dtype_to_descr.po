#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.dtype_to_descr:2
msgid "Get a serializable descriptor from the dtype."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.dtype_to_descr:4
msgid ""
"The .descr attribute of a dtype object cannot be round-tripped through the "
"dtype() constructor. Simple types, like dtype('float32'), have a descr which "
"looks like a record array with one field with '' as a name. The dtype() "
"constructor interprets this as a request to give a default name.  Instead, "
"we construct descriptor that can be passed to dtype()."
msgstr ""

