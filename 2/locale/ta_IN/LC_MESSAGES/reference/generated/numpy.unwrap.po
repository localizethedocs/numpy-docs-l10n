#: ../../../reference/generated/numpy.unwrap.rst:4
msgid "numpy.unwrap"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unwrap:2
msgid ""
"Unwrap by taking the complement of large deltas with respect to the period."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unwrap:4
msgid ""
"This unwraps a signal `p` by changing elements which have an absolute "
"difference from their predecessor of more than ``max(discont, period/2)`` to "
"their `period`-complementary values."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unwrap:8
msgid ""
"For the default case where `period` is :math:`2\\pi` and `discont` is :math:"
"`\\pi`, this unwraps a radian phase `p` such that adjacent differences are "
"never greater than :math:`\\pi` by adding :math:`2k\\pi` for some integer :"
"math:`k`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unwrap:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unwrap:16
msgid "**p**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unwrap:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unwrap:16
msgid "Input array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unwrap:22
msgid "**discont**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unwrap:-1
msgid "float, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unwrap:19
msgid ""
"Maximum discontinuity between values, default is ``period/2``. Values below "
"``period/2`` are treated as if they were ``period/2``. To have an effect "
"different from the default, `discont` should be larger than ``period/2``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unwrap:25
msgid "**axis**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unwrap:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unwrap:25
msgid "Axis along which unwrap will operate, default is the last axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unwrap:31
msgid "**period**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unwrap:28
msgid ""
"Size of the range over which the input wraps. By default, it is ``2 pi``."
msgstr ""

