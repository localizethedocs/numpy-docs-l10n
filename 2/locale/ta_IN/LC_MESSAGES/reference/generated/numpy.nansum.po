#: of numpy.nansum:51
msgid "**where**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nansum:-1
msgid "array_like of bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nansum:49
msgid "Elements to include in the sum. See `~numpy.ufunc.reduce` for details."
msgstr ""

