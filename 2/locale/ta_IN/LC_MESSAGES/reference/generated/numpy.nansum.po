#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nansum:56
msgid ""
"A new array holding the result is returned unless `out` is specified, in "
"which it is returned. The result has the same size as `a`, and the same "
"shape as `a` if `axis` is not None or `a` is a 1-d array."
msgstr ""

