msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.all:67
msgid ""
"Not a Number (NaN), positive infinity and negative infinity evaluate to "
"`True` because these are not equal to zero."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.all:70
msgid ""
"Before NumPy 2.0, ``all`` did not return booleans for object dtype input "
"arrays. This behavior is still available via ``np.logical_and.reduce``."
msgstr ""

