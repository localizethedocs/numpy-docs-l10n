#: ../../../reference/generated/numpy.put_along_axis.rst:4
msgid "numpy.put\\_along\\_axis"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.put_along_axis:2
msgid ""
"Put values into the destination array by matching 1d index and data slices."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.put_along_axis:4
msgid ""
"This iterates over matching 1d slices oriented along the specified axis in "
"the index and data arrays, and uses the former to place values into the "
"latter. These slices can be different lengths."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.put_along_axis:8
msgid ""
"Functions returning an index along an axis, like `argsort` and "
"`argpartition`, produce suitable indices for this function."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.put_along_axis:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.put_along_axis:14
msgid "**arr**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.put_along_axis:-1
msgid "ndarray (Ni..., M, Nk...)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.put_along_axis:14
msgid "Destination array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.put_along_axis:19
msgid "**indices**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.put_along_axis:-1
msgid "ndarray (Ni..., J, Nk...)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.put_along_axis:17
msgid ""
"Indices to change along each 1d slice of `arr`. This must match the "
"dimension of arr, but dimensions in Ni and Nj may be 1 to broadcast against "
"`arr`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.put_along_axis:23
msgid "**values**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.put_along_axis:-1
msgid "array_like (Ni..., J, Nk...)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.put_along_axis:22
msgid ""
"values to insert at those indices. Its shape and dimension are broadcast to "
"match that of `indices`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.put_along_axis:34
msgid "**axis**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.put_along_axis:-1
msgid "int"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.put_along_axis:26
msgid ""
"The axis to take 1d slices along. If axis is None, the destination array is "
"treated as if a flattened 1d view had been created of it."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.put_along_axis:39
msgid ":obj:`take_along_axis`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.put_along_axis:40
msgid "Take values from the input array by matching 1d index and data slices"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.put_along_axis:44
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.put_along_axis:45
msgid ""
"This is equivalent to (but faster than) the following use of `ndindex` and "
"`s_`, which sets each of ``ii`` and ``kk`` to a tuple of indices::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.put_along_axis:48
msgid ""
"Ni, M, Nk = a.shape[:axis], a.shape[axis], a.shape[axis+1:]\n"
"J = indices.shape[axis]  # Need not equal M\n"
"\n"
"for ii in ndindex(Ni):\n"
"    for kk in ndindex(Nk):\n"
"        a_1d       = a      [ii + s_[:,] + kk]\n"
"        indices_1d = indices[ii + s_[:,] + kk]\n"
"        values_1d  = values [ii + s_[:,] + kk]\n"
"        for j in range(J):\n"
"            a_1d[indices_1d[j]] = values_1d[j]"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.put_along_axis:59
msgid "Equivalently, eliminating the inner loop, the last two lines would be::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.put_along_axis:61
msgid "a_1d[indices_1d] = values_1d"
msgstr ""

