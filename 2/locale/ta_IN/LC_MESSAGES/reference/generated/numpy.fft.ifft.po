#: ../../../reference/generated/numpy.fft.ifft.rst:4
msgid "numpy.fft.ifft"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft:2
msgid "Compute the one-dimensional inverse discrete Fourier Transform."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft:4
msgid ""
"This function computes the inverse of the one-dimensional *n*-point discrete "
"Fourier transform computed by `fft`.  In other words, ``ifft(fft(a)) == a`` "
"to within numerical accuracy. For a general description of the algorithm and "
"definitions, see `numpy.fft`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft:10
msgid ""
"The input should be ordered in the same way as is returned by `fft`, i.e.,"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft:13
msgid "``a[0]`` should contain the zero frequency term,"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft:14
msgid "``a[1:n//2]`` should contain the positive-frequency terms,"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft:15
msgid ""
"``a[n//2 + 1:]`` should contain the negative-frequency terms, in increasing "
"order starting from the most negative frequency."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft:18
msgid ""
"For an even number of input points, ``A[n//2]`` represents the sum of the "
"values at the positive and negative Nyquist frequencies, as the two are "
"aliased together. See `numpy.fft` for details."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft:25
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft:25
msgid "Input array, can be complex."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft:32
msgid "**n**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft:28
msgid ""
"Length of the transformed axis of the output. If `n` is smaller than the "
"length of the input, the input is cropped. If it is larger, the input is "
"padded with zeros.  If `n` is not given, the length of the input along the "
"axis specified by `axis` is used. See notes about padding issues."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft:36
msgid "**axis**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft:35
msgid ""
"Axis over which to compute the inverse DFT.  If not given, the last axis is "
"used."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft:45
msgid "**norm**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft:-1
msgid "{\"backward\", \"ortho\", \"forward\"}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft:39
msgid ""
"Normalization mode (see `numpy.fft`). Default is \"backward\". Indicates "
"which direction of the forward/backward pair of transforms is scaled and "
"with what normalization factor."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft:45
msgid "The \"backward\", \"forward\" values were added."
msgstr ""

