#: ../../../reference/generated/numpy.fft.rfftn.rst:4
msgid "numpy.fft.rfftn"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:2
msgid "Compute the N-dimensional discrete Fourier Transform for real input."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:4
msgid ""
"This function computes the N-dimensional discrete Fourier Transform over any "
"number of axes in an M-dimensional real array by means of the Fast Fourier "
"Transform (FFT).  By default, all axes are transformed, with the real "
"transform performed over the last axis, while the remaining transforms are "
"complex."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:13
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:13
msgid "Input array, taken to be real."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:39
msgid "**s**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:-1
msgid "sequence of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:16
msgid ""
"Shape (length along each transformed axis) to use from the input. (``s[0]`` "
"refers to axis 0, ``s[1]`` to axis 1, etc.). The final element of `s` "
"corresponds to `n` for ``rfft(x, n)``, while for the remaining axes, it "
"corresponds to `n` for ``fft(x, n)``. Along any axis, if the given shape is "
"smaller than that of the input, the input is cropped. If it is larger, the "
"input is padded with zeros."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:25
msgid "If it is ``-1``, the whole input is used (no padding/trimming)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:27
msgid ""
"If `s` is not given, the shape of the input along the axes specified by "
"`axes` is used."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:32
msgid "If `s` is not ``None``, `axes` must not be ``None`` either."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:36
msgid ""
"`s` must contain only ``int`` s, not ``None`` values. ``None`` values "
"currently mean that the default value for ``n`` is used in the corresponding "
"1-D transform, but this behaviour is deprecated."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:48
msgid "**axes**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:42
msgid ""
"Axes over which to compute the FFT.  If not given, the last ``len(s)`` axes "
"are used, or all axes if `s` is also not specified."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:47
msgid ""
"If `s` is specified, the corresponding `axes` to be transformed must be "
"explicitly specified too."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:57
msgid "**norm**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:-1
msgid "{\"backward\", \"ortho\", \"forward\"}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:51
msgid ""
"Normalization mode (see `numpy.fft`). Default is \"backward\". Indicates "
"which direction of the forward/backward pair of transforms is scaled and "
"with what normalization factor."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:57
msgid "The \"backward\", \"forward\" values were added."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:64 numpy.fft.rfftn:77
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:-1
msgid "complex ndarray, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:60
msgid ""
"If provided, the result will be placed in this array. It should be of the "
"appropriate shape and dtype for all axes (and hence is incompatible with "
"passing in all but the trivial ``s``)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:-1
msgid "complex ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:69
msgid ""
"The truncated or zero-padded input, transformed along the axes indicated by "
"`axes`, or by a combination of `s` and `a`, as explained in the parameters "
"section above. The length of the last axis transformed will be "
"``s[-1]//2+1``, while the remaining transformed axes will have lengths "
"according to `s`, or unchanged from the input."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:0
msgid "Raises"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:82
msgid "ValueError"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:82
msgid "If `s` and `axes` have different length."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:87
msgid "IndexError"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:85
msgid "If an element of `axes` is larger than than the number of axes of `a`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:92
msgid ":obj:`irfftn`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:93
msgid ""
"The inverse of `rfftn`, i.e. the inverse of the n-dimensional FFT of real "
"input."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:94
msgid ":obj:`fft`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:95
msgid "The one-dimensional FFT, with definitions and conventions used."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:96
msgid ":obj:`rfft`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:97
msgid "The one-dimensional FFT of real input."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:98
msgid ":obj:`fftn`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:99
msgid "The n-dimensional FFT."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:100
msgid ":obj:`rfft2`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:101
msgid "The two-dimensional FFT of real input."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:105
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:106
msgid ""
"The transform for real input is performed over the last transformation axis, "
"as by `rfft`, then the transform over the remaining axes is performed as by "
"`fftn`.  The order of the output is as for `rfft` for the final "
"transformation axis, and as for `fftn` for the remaining transformation axes."
msgstr ""

