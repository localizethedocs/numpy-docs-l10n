#: ../../../reference/generated/numpy.polyval.rst:4
msgid "numpy.polyval"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polyval:2
msgid "Evaluate a polynomial at specific values."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polyval:5
msgid ""
"This forms part of the old polynomial API. Since version 1.4, the new "
"polynomial API defined in `numpy.polynomial` is preferred. A summary of the "
"differences can be found in the :doc:`transition guide </reference/routines."
"polynomials>`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polyval:10
msgid "If `p` is of length N, this function returns the value::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polyval:12
msgid "p[0]*x**(N-1) + p[1]*x**(N-2) + ... + p[N-2]*x + p[N-1]"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polyval:14
msgid ""
"If `x` is a sequence, then ``p(x)`` is returned for each element of ``x``. "
"If `x` is another polynomial then the composite polynomial ``p(x(t))`` is "
"returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polyval:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polyval:23
msgid "**p**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polyval:-1
msgid "array_like or poly1d object"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polyval:21
msgid ""
"1D array of polynomial coefficients (including coefficients equal to zero) "
"from highest degree to the constant term, or an instance of poly1d."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polyval:29
msgid "**x**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polyval:26
msgid ""
"A number, an array of numbers, or an instance of poly1d, at which to "
"evaluate `p`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polyval:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polyval:44
msgid "**values**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polyval:-1
msgid "ndarray or poly1d"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polyval:34
msgid ""
"If `x` is a poly1d instance, the result is the composition of the two "
"polynomials, i.e., `x` is \"substituted\" in `p` and the simplified result "
"is returned. In addition, the type of `x` - array_like or poly1d - governs "
"the type of the output: `x` array_like => `values` array_like, `x` a poly1d "
"object => `values` is also."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polyval:49
msgid ":obj:`poly1d`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polyval:50
msgid "A polynomial class."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polyval:54
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polyval:55
msgid ""
"Horner's scheme [R138ee7027ddf-1]_ is used to evaluate the polynomial. Even "
"so, for polynomials of high degree the values may be inaccurate due to "
"rounding errors. Use carefully."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polyval:59
msgid ""
"If `x` is a subtype of `ndarray` the return value will be of the same type."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polyval:62
msgid "References"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polyval:63
