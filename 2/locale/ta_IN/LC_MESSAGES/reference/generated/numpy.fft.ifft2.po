msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft2:98
msgid ":obj:`fft2`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft2:99
msgid "The forward 2-dimensional FFT, of which `ifft2` is the inverse."
msgstr ""

