#: of numpy.polynomial.polyutils.trimcoef:-1
msgid "number, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polyutils.py:docstring
#: of numpy.polynomial.polyutils.trimcoef:15
msgid ""
"Trailing (i.e., highest order) elements with absolute value less than or "
"equal to `tol` (default value is zero) are removed."
msgstr ""

