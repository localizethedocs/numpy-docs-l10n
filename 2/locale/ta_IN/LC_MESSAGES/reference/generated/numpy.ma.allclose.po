#: of numpy.ma.core.allclose:44
msgid "the non-masked `allclose`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.allclose:48
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.allclose:49
msgid ""
"If the following equation is element-wise True, then `allclose` returns "
"True::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.allclose:52
msgid "absolute(`a` - `b`) <= (`atol` + `rtol` * absolute(`b`))"
msgstr ""

