msgid "numpy.flatiter"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.flatiter:2
msgid "Flat iterator object to iterate over arrays."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.flatiter:4
msgid ""
"A `flatiter` iterator is returned by ``x.flat`` for any array `x`. It allows "
"iterating over the array as if it were a 1-D array, either in a for-loop or "
"by calling its `next` method."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.flatiter:8
msgid ""
"Iteration is done in row-major, C-style order (the last index varying the "
"fastest). The iterator can also be indexed using basic slicing or advanced "
"indexing."
msgstr ""

