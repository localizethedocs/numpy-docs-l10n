#: of numpy.char.chararray.item:-1
msgid "Arguments (variable number and type)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.item:8
msgid ""
"none: in this case, the method only works for arrays with one element (`a."
"size == 1`), which element is copied into a standard Python scalar object "
"and returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.item:12
msgid ""
"int_type: this argument is interpreted as a flat index into the array, "
"specifying which element to copy and return."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.item:15
msgid ""
"tuple of int_types: functions as does a single int_type argument, except "
"that the argument is interpreted as an nd-index into the array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.item:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.item:30
msgid "**z**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.item:-1
msgid "Standard Python scalar object"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.item:22
msgid ""
"A copy of the specified element of the array as a suitable Python scalar"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.item:33
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.item:34
msgid ""
"When the data type of `a` is longdouble or clongdouble, item() returns a "
"scalar array object because there is no available Python scalar that would "
"not lose information. Void arrays return a buffer object for item(), unless "
"fields are defined, in which case a tuple is returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.item:39
msgid ""
"`item` is very similar to a[args], except, instead of an array scalar, a "
"standard Python scalar is returned. This can be useful for speeding up "
"access to elements of the array and doing arithmetic on elements of the "
"array using Python's optimized math."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.item:46
msgid "Examples"
msgstr ""

