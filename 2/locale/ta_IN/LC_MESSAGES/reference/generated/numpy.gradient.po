#: of numpy.gradient:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:12
msgid "**f**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:12
msgid "An N-dimensional array containing samples of a scalar function."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:28
msgid "**varargs**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:-1
msgid "list of scalar or array, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:15
msgid ""
"Spacing between f values. Default unitary spacing for all dimensions. "
"Spacing can be specified using:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:18
msgid "Single scalar to specify a sample distance for all dimensions."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:19
msgid ""
"N scalars to specify a constant sample distance for each dimension. i.e. "
"`dx`, `dy`, `dz`, ..."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:21
msgid ""
"N arrays to specify the coordinates of the values along each dimension of F. "
"The length of the array must match the size of the corresponding dimension"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:24
msgid "Any combination of N scalars/arrays with the meaning of 2. and 3."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:26
msgid ""
"If `axis` is given, the number of varargs must equal the number of axes "
"specified in the axis parameter. Default: 1. (see Examples below)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:32
msgid "**edge_order**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:-1
msgid "{1, 2}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:31
msgid ""
"Gradient is calculated using N-th order accurate differences at the "
"boundaries. Default: 1."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:40
msgid "**axis**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:-1
msgid "None or int or tuple of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:35
msgid ""
"Gradient is calculated only along the given axis or axes. The default (axis "
"= None) is to calculate the gradient for all the axes of the input array. "
"axis may be negative, in which case it counts from the last to the first "
"axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:54
msgid "**gradient**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:-1
msgid "ndarray or tuple of ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:45
msgid ""
"A tuple of ndarrays (or a single ndarray if there is only one dimension) "
"corresponding to the derivatives of f with respect to each dimension. Each "
"derivative has the same shape as f."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:57
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:58
msgid ""
"Assuming that :math:`f\\in C^{3}` (i.e., :math:`f` has at least 3 continuous "
"derivatives) and let :math:`h_{*}` be a non-homogeneous stepsize, we "
"minimize the \"consistency error\" :math:`\\eta_{i}` between the true "
"gradient and its estimate from a linear combination of the neighboring grid-"
"points:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:63
msgid ""
"\\eta_{i} = f_{i}^{\\left(1\\right)} -\n"
"            \\left[ \\alpha f\\left(x_{i}\\right) +\n"
"                    \\beta f\\left(x_{i} + h_{d}\\right) +\n"
"                    \\gamma f\\left(x_{i}-h_{s}\\right)\n"
"            \\right]"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:71
msgid ""
"By substituting :math:`f(x_{i} + h_{d})` and :math:`f(x_{i} - h_{s})` with "
"their Taylor series expansion, this translates into solving the following "
"the linear system:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:75
msgid ""
"\\left\\{\n"
"    \\begin{array}{r}\n"
"        \\alpha+\\beta+\\gamma=0 \\\\\n"
"        \\beta h_{d}-\\gamma h_{s}=1 \\\\\n"
"        \\beta h_{d}^{2}+\\gamma h_{s}^{2}=0\n"
"    \\end{array}\n"
"\\right."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:85
msgid "The resulting approximation of :math:`f_{i}^{(1)}` is the following:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:87
msgid ""
"\\hat f_{i}^{(1)} =\n"
"    \\frac{\n"
"        h_{s}^{2}f\\left(x_{i} + h_{d}\\right)\n"
"        + \\left(h_{d}^{2} - h_{s}^{2}\\right)f\\left(x_{i}\\right)\n"
"        - h_{d}^{2}f\\left(x_{i}-h_{s}\\right)}\n"
"        { h_{s}h_{d}\\left(h_{d} + h_{s}\\right)}\n"
"    + \\mathcal{O}\\left(\\frac{h_{d}h_{s}^{2}\n"
"                        + h_{s}h_{d}^{2}}{h_{d}\n"
"                        + h_{s}}\\right)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:99
msgid ""
"It is worth noting that if :math:`h_{s}=h_{d}` (i.e., data are evenly "
"spaced) we find the standard second order approximation:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:103
msgid ""
"\\hat f_{i}^{(1)}=\n"
"    \\frac{f\\left(x_{i+1}\\right) - f\\left(x_{i-1}\\right)}{2h}\n"
"    + \\mathcal{O}\\left(h^{2}\\right)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.gradient:109
msgid ""
"With a similar procedure the forward/backward approximations used for "
"boundaries can be derived."
msgstr ""

