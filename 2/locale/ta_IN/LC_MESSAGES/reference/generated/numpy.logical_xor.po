#: ../../../reference/generated/numpy.logical_xor.rst:4
msgid "numpy.logical\\_xor"
msgstr ""

#: ../../../../docstring of numpy.logical_xor:2
msgid "Compute the truth value of x1 XOR x2, element-wise."
msgstr ""

#: ../../../../docstring of numpy.logical_xor:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.logical_xor:10
msgid "**x1, x2**"
msgstr ""

#: ../../../../docstring of numpy.logical_xor:-1
msgid "array_like"
msgstr ""

#: ../../../../docstring of numpy.logical_xor:8
msgid ""
"Logical XOR is applied to the elements of `x1` and `x2`. If ``x1.shape != x2."
"shape``, they must be broadcastable to a common shape (which becomes the "
"shape of the output)."
msgstr ""

#: ../../../../docstring of numpy.logical_xor:16
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.logical_xor:-1
msgid "ndarray, None, or tuple of ndarray and None, optional"
msgstr ""

#: ../../../../docstring of numpy.logical_xor:13
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or None, a freshly-"
"allocated array is returned. A tuple (possible only as a keyword argument) "
"must have length equal to the number of outputs."
msgstr ""

#: ../../../../docstring of numpy.logical_xor:24
msgid "**where**"
msgstr ""

#: ../../../../docstring of numpy.logical_xor:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../docstring of numpy.logical_xor:19
msgid ""
"This condition is broadcast over the input. At locations where the condition "
"is True, the `out` array will be set to the ufunc result. Elsewhere, the "
"`out` array will retain its original value. Note that if an uninitialized "
"`out` array is created via the default ``out=None``, locations within it "
"where the condition is False will remain uninitialized."
msgstr ""

#: ../../../../docstring of numpy.logical_xor:28
msgid "**\\*\\*kwargs**"
msgstr ""

#: ../../../../docstring of numpy.logical_xor:27
msgid ""
"For other keyword-only arguments, see the :ref:`ufunc docs <ufuncs.kwargs>`."
msgstr ""

#: ../../../../docstring of numpy.logical_xor:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.logical_xor:41
msgid "**y**"
msgstr ""

#: ../../../../docstring of numpy.logical_xor:-1
msgid "bool or ndarray of bool"
msgstr ""

#: ../../../../docstring of numpy.logical_xor:33
msgid ""
"Boolean result of the logical XOR operation applied to the elements of `x1` "
"and `x2`; the shape is determined by broadcasting. This is a scalar if both "
"`x1` and `x2` are scalars."
msgstr ""

#: ../../../../docstring of numpy.logical_xor:46
msgid ""
":obj:`logical_and`, :obj:`logical_or`, :obj:`logical_not`, :obj:`bitwise_xor`"
msgstr ""

