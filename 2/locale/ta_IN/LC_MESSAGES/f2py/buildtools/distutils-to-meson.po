#: ../../../f2py/buildtools/distutils-to-meson.rst:15
msgid "1.1 Baseline"
msgstr ""

#: ../../../f2py/buildtools/distutils-to-meson.rst:17
msgid ""
"We will start out with a slightly modern variation of the classic Fibonnaci "
"series generator."
msgstr ""

#: ../../../f2py/buildtools/distutils-to-meson.rst:20
msgid ""
"! fib.f90\n"
"subroutine fib(a, n)\n"
"  use iso_c_binding\n"
"   integer(c_int), intent(in) :: n\n"
"   integer(c_int), intent(out) :: a(n)\n"
"   do i = 1, n\n"
"      if (i .eq. 1) then\n"
"         a(i) = 0.0d0\n"
"      elseif (i .eq. 2) then\n"
"         a(i) = 1.0d0\n"
"      else\n"
"         a(i) = a(i - 1) + a(i - 2)\n"
"      end if\n"
"   end do\n"
"end"
msgstr ""

#: ../../../f2py/buildtools/distutils-to-meson.rst:38
msgid "This will not win any awards, but can be a reasonable starting point."
msgstr ""

