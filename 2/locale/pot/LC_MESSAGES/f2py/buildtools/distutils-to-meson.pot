#: ../../../f2py/buildtools/distutils-to-meson.rst:138
msgid "1.2.4 Dependencies"
msgstr ""

#: ../../../f2py/buildtools/distutils-to-meson.rst:140
msgid "Here, ``meson`` can actually be used to set dependencies more robustly."
msgstr ""

#: ../../../f2py/buildtools/distutils-to-meson.rst:147
msgid "python -m numpy.f2py -c fib.f90 -m fib --backend distutils -llapack"
msgstr ""

#: ../../../f2py/buildtools/distutils-to-meson.rst:151
msgid "Note that this approach in practice is error prone."
msgstr ""

#: ../../../f2py/buildtools/distutils-to-meson.rst:156
msgid "python -m numpy.f2py -c fib.f90 -m fib --backend meson --dep lapack"
msgstr ""

#: ../../../f2py/buildtools/distutils-to-meson.rst:160
msgid ""
"This maps to ``dependency(\"lapack\")`` and so can be used for a wide "
"variety of dependencies. They can be `customized further <https://mesonbuild."
"com/Dependencies.html>`_ to use CMake or other systems to resolve "
"dependencies."
msgstr ""

#: ../../../f2py/buildtools/distutils-to-meson.rst:165
msgid "1.2.5 Libraries"
msgstr ""

#: ../../../f2py/buildtools/distutils-to-meson.rst:167
msgid ""
"Both ``meson`` and ``distutils`` are capable of linking against libraries."
msgstr ""

#: ../../../f2py/buildtools/distutils-to-meson.rst:174
msgid ""
"python -m numpy.f2py -c fib.f90 -m fib --backend distutils -lmylib -L/path/"
"to/mylib"
msgstr ""

#: ../../../f2py/buildtools/distutils-to-meson.rst:181
msgid ""
"python -m numpy.f2py -c fib.f90 -m fib --backend meson -lmylib -L/path/to/"
"mylib"
msgstr ""

#: ../../../f2py/buildtools/distutils-to-meson.rst:186
msgid "1.3 Customizing builds"
msgstr ""

#: ../../../f2py/buildtools/distutils-to-meson.rst:193
msgid ""
"python -m numpy.f2py -c fib.f90 -m fib --backend distutils --build-dir blah"
msgstr ""

#: ../../../f2py/buildtools/distutils-to-meson.rst:197
msgid ""
"This can be technically integrated with other codes, see :ref:`f2py-"
"distutils`."
msgstr ""

#: ../../../f2py/buildtools/distutils-to-meson.rst:202
msgid "python -m numpy.f2py -c fib.f90 -m fib --backend meson --build-dir blah"
msgstr ""

#: ../../../f2py/buildtools/distutils-to-meson.rst:206
msgid ""
"The resulting build can be customized via the `Meson Build How-To Guide "
"<https://mesonbuild.com/howtox.html>`_. In fact, the resulting set of files "
"can even be committed directly and used as a meson subproject in a separate "
"codebase."
msgstr ""
