#: ../../../release/2.0.1-notes.rst:5
msgid "NumPy 2.0.1 Release Notes"
msgstr ""

#: ../../../release/2.0.1-notes.rst:7
msgid ""
"NumPy 2.0.1 is a maintenance release that fixes bugs and regressions "
"discovered after the 2.0.0 release. NumPy 2.0.1 is the last planned release "
"in the 2.0.x series, 2.1.0rc1 should be out shortly."
msgstr ""

#: ../../../release/2.0.1-notes.rst:11
msgid "The Python versions supported by this release are 3.9-3.12."
msgstr ""

#: ../../../release/2.0.1-notes.rst:14
msgid "Improvements"
msgstr ""

#: ../../../release/2.0.1-notes.rst:17
msgid ""
"``np.quantile`` with method ``closest_observation`` chooses nearest even "
"order statistic"
msgstr ""

#: ../../../release/2.0.1-notes.rst:18
msgid ""
"This changes the definition of nearest for border cases from the nearest odd "
"order statistic to nearest even order statistic. The numpy implementation "
"now matches other reference implementations."
msgstr ""

