#: ../../../release/1.18.3-notes.rst:5
msgid "NumPy 1.18.3 Release Notes"
msgstr ""

#: ../../../release/1.18.3-notes.rst:7
msgid "This release contains various bug/regression fixes."
msgstr ""

#: ../../../release/1.18.3-notes.rst:9
msgid ""
"The Python versions supported in this release are 3.5-3.8. Downstream "
"developers should use Cython >= 0.29.15 for Python 3.8 support and OpenBLAS "
">= 3.7 to avoid errors on the Skylake architecture."
msgstr ""

#: ../../../release/1.18.3-notes.rst:15
msgid "Highlights"
msgstr ""

#: ../../../release/1.18.3-notes.rst:17
msgid ""
"Fix for the `method='eigh'` and `method='cholesky'` methods in `numpy.random."
"multivariate_normal`. Those were producing samples from the wrong "
"distribution."
msgstr ""

