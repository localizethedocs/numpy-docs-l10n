#: ../../../release/1.20.0-notes.rst:982
msgid "``np.linspace`` on integers now uses floor"
msgstr ""

#: ../../../release/1.20.0-notes.rst:983
msgid ""
"When using a ``int`` dtype in `numpy.linspace`, previously float values "
"would be rounded towards zero. Now `numpy.floor` is used instead, which "
"rounds toward ``-inf``. This changes the results for negative values. For "
"example, the following would previously give::"
msgstr ""

#: ../../../release/1.20.0-notes.rst:988
msgid ""
">>> np.linspace(-3, 1, 8, dtype=int)\n"
"array([-3, -2, -1, -1,  0,  0,  0,  1])"
msgstr ""

#: ../../../release/1.20.0-notes.rst:991
msgid "and now results in::"
msgstr ""

#: ../../../release/1.20.0-notes.rst:993
msgid ""
">>> np.linspace(-3, 1, 8, dtype=int)\n"
"array([-3, -3, -2, -2, -1, -1,  0,  1])"
msgstr ""

#: ../../../release/1.20.0-notes.rst:996
msgid "The former result can still be obtained with::"
msgstr ""

#: ../../../release/1.20.0-notes.rst:998
msgid ""
">>> np.linspace(-3, 1, 8).astype(int)\n"
"array([-3, -2, -1, -1,  0,  0,  0,  1])"
msgstr ""

#: ../../../release/1.20.0-notes.rst:1001
msgid "(`gh-16841 <https://github.com/numpy/numpy/pull/16841>`__)"
msgstr ""
