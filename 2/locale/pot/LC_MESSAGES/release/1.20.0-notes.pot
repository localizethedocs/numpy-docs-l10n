#: ../../../release/1.20.0-notes.rst:795
msgid ""
"Object arrays containing multi-line objects have a more readable ``repr``"
msgstr ""

#: ../../../release/1.20.0-notes.rst:796
msgid ""
"If elements of an object array have a ``repr`` containing new lines, then "
"the wrapped lines will be aligned by column. Notably, this improves the "
"``repr`` of nested arrays::"
msgstr ""

#: ../../../release/1.20.0-notes.rst:800
msgid ""
">>> np.array([np.eye(2), np.eye(3)], dtype=object)\n"
"array([array([[1., 0.],\n"
"              [0., 1.]]),\n"
"       array([[1., 0., 0.],\n"
"              [0., 1., 0.],\n"
"              [0., 0., 1.]])], dtype=object)"
msgstr ""

#: ../../../release/1.20.0-notes.rst:807
msgid "(`gh-15997 <https://github.com/numpy/numpy/pull/15997>`__)"
msgstr ""

#: ../../../release/1.20.0-notes.rst:810
msgid "Concatenate supports providing an output dtype"
msgstr ""

#: ../../../release/1.20.0-notes.rst:811
msgid ""
"Support was added to `~numpy.concatenate` to provide an output ``dtype`` and "
"``casting`` using keyword arguments. The ``dtype`` argument cannot be "
"provided in conjunction with the ``out`` one."
msgstr ""

#: ../../../release/1.20.0-notes.rst:819
