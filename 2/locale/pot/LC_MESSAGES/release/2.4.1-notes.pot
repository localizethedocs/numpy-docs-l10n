#: ../../../release/2.4.1-notes.rst:5
msgid "NumPy 2.4.1 Release Notes"
msgstr ""

#: ../../../release/2.4.1-notes.rst:7
msgid ""
"The NumPy 2.4.1 is a patch release that fixes bugs discoved after the 2.4.0 "
"release. In particular, the typo `SeedlessSequence` is preserved to enable "
"wheels using the random Cython API and built against NumPy < 2.4.0 to run "
"without errors."
msgstr ""

#: ../../../release/2.4.1-notes.rst:12
msgid "This release supports Python versions 3.11-3.14"
msgstr ""

