msgid "NumPy 1.12.1 Release Notes"
msgstr ""

#: ../../../release/1.12.1-notes.rst:5
msgid ""
"NumPy 1.12.1 supports Python 2.7 and 3.4 - 3.6 and fixes bugs and "
"regressions found in NumPy 1.12.0. In particular, the regression in f2py "
"constant parsing is fixed. Wheels for Linux, Windows, and OSX can be found "
"on PyPI,"
msgstr ""

