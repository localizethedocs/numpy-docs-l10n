#: ../../../reference/random/generated/numpy.random.Generator.binomial.rst:4
msgid "numpy.random.Generator.binomial"
msgstr ""

#: ../../../reference/random/generated/numpy.random.Generator.binomial.rst:8
msgid "method"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.binomial:2
msgid "Draw samples from a binomial distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.binomial:4
msgid ""
"Samples are drawn from a binomial distribution with specified parameters, n "
"trials and p probability of success where n an integer >= 0 and p is in the "
"interval [0,1]. (n may be input as a float, but it is truncated to an "
"integer in use)"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.binomial:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.binomial:13
msgid "**n**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.binomial:-1
msgid "int or array_like of ints"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.binomial:12
msgid ""
"Parameter of the distribution, >= 0. Floats are also accepted, but they will "
"be truncated to integers."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.binomial:16
msgid "**p**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.binomial:-1
msgid "float or array_like of floats"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.binomial:16
msgid "Parameter of the distribution, >= 0 and <=1."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.binomial:22
msgid "**size**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.binomial:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.binomial:19
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn.  If size is ``None`` (default), a single value is "
"returned if ``n`` and ``p`` are both scalars. Otherwise, ``np.broadcast(n, "
"p).size`` samples are drawn."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.binomial:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.binomial:34
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.binomial:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.binomial:27
msgid ""
"Drawn samples from the parameterized binomial distribution, where each "
"sample is equal to the number of successes over the n trials."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.binomial:39
msgid ":obj:`scipy.stats.binom`"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.binomial:40
msgid ""
"probability density function, distribution or cumulative density function, "
"etc."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.binomial:44
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.binomial:45
msgid "The probability mass function (PMF) for the binomial distribution is"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.binomial:47
msgid ""
"P(N) = \\binom{n}{N}p^N(1-p)^{n-N},\n"
"\n"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.binomial:49
msgid ""
"where :math:`n` is the number of trials, :math:`p` is the probability of "
"success, and :math:`N` is the number of successes."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.binomial:52
msgid ""
"When estimating the standard error of a proportion in a population by using "
"a random sample, the normal distribution works well unless the product p*n "
"<=5, where p = population proportion estimate, and n = number of samples, in "
"which case the binomial distribution is used instead. For example, a sample "
"of 15 people shows 4 who are left handed, and 11 who are right handed. Then "
"p = 4/15 = 27%. 0.27*15 = 4, so the binomial distribution should be used in "
"this case."
msgstr ""

