#: ../../../reference/random/generated/numpy.random.Generator.weibull.rst:4
msgid "numpy.random.Generator.weibull"
msgstr ""

#: ../../../reference/random/generated/numpy.random.Generator.weibull.rst:8
msgid "method"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.weibull:2
msgid "Draw samples from a Weibull distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.weibull:4
msgid ""
"Draw samples from a 1-parameter Weibull distribution with the given shape "
"parameter `a`."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.weibull:7
msgid ""
"X = (-ln(U))^{1/a}\n"
"\n"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.weibull:9
msgid "Here, U is drawn from the uniform distribution over (0,1]."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.weibull:11
msgid ""
"The more common 2-parameter Weibull, including a scale parameter :math:"
"`\\lambda` is just :math:`X = \\lambda(-ln(U))^{1/a}`."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.weibull:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.weibull:17
msgid "**a**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.weibull:-1
msgid "float or array_like of floats"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.weibull:17
msgid "Shape parameter of the distribution.  Must be nonnegative."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.weibull:25
msgid "**size**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.weibull:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.weibull:20
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn.  If size is ``None`` (default), a single value is "
"returned if ``a`` is a scalar.  Otherwise, ``np.array(a).size`` samples are "
"drawn."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.weibull:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.weibull:36
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.weibull:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.weibull:30
msgid "Drawn samples from the parameterized Weibull distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.weibull:41
msgid ":obj:`scipy.stats.weibull_max`"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.weibull:43
msgid ":obj:`scipy.stats.weibull_min`"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.weibull:45
msgid ":obj:`scipy.stats.genextreme`"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.weibull:47
msgid ":obj:`gumbel`"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.weibull:51
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.weibull:52
msgid ""
"The Weibull (or Type III asymptotic extreme value distribution for smallest "
"values, SEV Type III, or Rosin-Rammler distribution) is one of a class of "
"Generalized Extreme Value (GEV) distributions used in modeling extreme value "
"problems. This class includes the Gumbel and Frechet distributions."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.weibull:58
msgid "The probability density for the Weibull distribution is"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.weibull:60
msgid ""
"p(x) = \\frac{a}\n"
"{\\lambda}(\\frac{x}{\\lambda})^{a-1}e^{-(x/\\lambda)^a},\n"
"\n"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.weibull:63
msgid "where :math:`a` is the shape and :math:`\\lambda` the scale."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.weibull:65
msgid ""
"The function has its peak (the mode) at :math:`\\lambda(\\frac{a-1}{a})^{1/a}"
"`."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.weibull:68
msgid ""
"When ``a = 1``, the Weibull distribution reduces to the exponential "
"distribution."
msgstr ""

