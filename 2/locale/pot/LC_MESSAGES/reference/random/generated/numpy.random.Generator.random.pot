#: ../../../../docstring of numpy.random._generator.Generator.random:2
msgid "Return random floats in the half-open interval [0.0, 1.0)."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.random:4
msgid ""
"Results are from the \"continuous uniform\" distribution over the stated "
"interval.  To sample :math:`Unif[a, b), b > a` use `uniform` or multiply the "
"output of `random` by ``(b - a)`` and add ``a``::"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.random:8
msgid "(b - a) * random() + a"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.random:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.random:15
msgid "**size**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.random:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.random:13
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn.  Default is None, in which case a single value is "
"returned."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.random:19
msgid "**dtype**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.random:-1
msgid "dtype, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.random:18
msgid ""
"Desired dtype of the result, only `float64` and `float32` are supported. "
"Byteorder must be native. The default value is np.float64."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.random:26
#: numpy.random._generator.Generator.random:38
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.random:-1
msgid "ndarray, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.random:22
msgid ""
"Alternative output array in which to place the result. If size is not None, "
"it must have the same shape as the provided size and must match the type of "
"the output values."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.random:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.random:-1
msgid "float or ndarray of floats"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.random:31
msgid ""
"Array of random floats of shape `size` (unless ``size=None``, in which case "
"a single float is returned)."
msgstr ""

