"The probability density function for the noncentral Chi-square distribution "
"is"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.noncentral_chisquare:50
