#: ../../../reference/generated/numpy.strings.isdigit.rst:4
msgid "numpy.strings.isdigit"
msgstr ""

#: ../../../../docstring of numpy.strings.isdigit:2
msgid ""
"Returns true for each element if all characters in the string are digits and "
"there is at least one character, false otherwise."
msgstr ""

#: ../../../../docstring of numpy.strings.isdigit:5
msgid ""
"For byte strings, digits are the byte values in the sequence b'0123456789'. "
"For Unicode strings, digits include decimal characters and digits that need "
"special handling, such as the compatibility superscript digits. This also "
"covers digits which cannot be used to form numbers in base 10, like the "
"Kharosthi numbers."
msgstr ""

