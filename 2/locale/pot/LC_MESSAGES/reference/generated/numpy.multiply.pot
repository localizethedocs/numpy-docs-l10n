msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.multiply:41
msgid "**y**"
msgstr ""

#: ../../../../docstring of numpy.multiply:-1
msgid "ndarray"
msgstr ""

#: ../../../../docstring of numpy.multiply:33
msgid ""
"The product of `x1` and `x2`, element-wise. This is a scalar if both `x1` "
"and `x2` are scalars."
msgstr ""

#: ../../../../docstring of numpy.multiply:44
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.multiply:45
msgid "Equivalent to `x1` * `x2` in terms of array broadcasting."
msgstr ""

