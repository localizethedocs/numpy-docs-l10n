#: of numpy.linalg.svdvals:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.svdvals:23
msgid ""
"An array with shape (..., K) that contains the vector(s) of singular values "
"of length K, where K = min(M, N)."
