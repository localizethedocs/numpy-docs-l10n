msgid ""
"The kind of data types to return. If ``None``, all data types are returned. "
"If a string, only data types of that kind are returned. If a tuple, a "
"dictionary containing the union of the given kinds is returned. The "
"following kinds are supported:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/_array_api_info.py:docstring
#: of numpy._array_api_info.__array_namespace_info__.dtypes:19
msgid "``'bool'``: boolean data types (i.e., ``bool``)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/_array_api_info.py:docstring
#: of numpy._array_api_info.__array_namespace_info__.dtypes:20
msgid ""
"``'signed integer'``: signed integer data types (i.e., ``int8``, ``int16``, "
"``int32``, ``int64``)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/_array_api_info.py:docstring
#: of numpy._array_api_info.__array_namespace_info__.dtypes:22
msgid ""
"``'unsigned integer'``: unsigned integer data types (i.e., ``uint8``, "
"``uint16``, ``uint32``, ``uint64``)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/_array_api_info.py:docstring
#: of numpy._array_api_info.__array_namespace_info__.dtypes:24
msgid ""
"``'integral'``: integer data types. Shorthand for ``('signed integer', "
"'unsigned integer')``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/_array_api_info.py:docstring
#: of numpy._array_api_info.__array_namespace_info__.dtypes:26
msgid ""
"``'real floating'``: real-valued floating-point data types (i.e., "
"``float32``, ``float64``)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/_array_api_info.py:docstring
#: of numpy._array_api_info.__array_namespace_info__.dtypes:28
msgid ""
"``'complex floating'``: complex floating-point data types (i.e., "
"``complex64``, ``complex128``)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/_array_api_info.py:docstring
#: of numpy._array_api_info.__array_namespace_info__.dtypes:30
msgid ""
"``'numeric'``: numeric data types. Shorthand for ``('integral', 'real "
"floating', 'complex floating')``."
msgstr ""

