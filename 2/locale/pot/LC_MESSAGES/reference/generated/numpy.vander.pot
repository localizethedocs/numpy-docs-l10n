#: of numpy.vander:17
msgid ""
"Number of columns in the output.  If `N` is not specified, a square array is "
"returned (``N = len(x)``)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.vander:22
msgid "**increasing**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.vander:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.vander:21
msgid ""
"Order of the powers of the columns.  If True, the powers increase from left "
"to right, if False (the default) they are reversed."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.vander:0
msgid "Returns"
msgstr ""

