#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/strings/__init__.py:docstring
#: of numpy.strings.partition:2
msgid "Partition each element in ``a`` around ``sep``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/strings/__init__.py:docstring
#: of numpy.strings.partition:4
msgid ""
"For each element in ``a``, split the element at the first occurrence of "
"``sep``, and return a 3-tuple containing the part before the separator, the "
"separator itself, and the part after the separator. If the separator is not "
"found, the first item of the tuple will contain the whole string, and the "
"second and third ones will be the empty string."
msgstr ""

