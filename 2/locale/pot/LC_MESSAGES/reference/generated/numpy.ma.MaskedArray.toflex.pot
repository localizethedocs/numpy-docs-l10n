#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.toflex:2
msgid "Transforms a masked array into a flexible-type array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.toflex:4
msgid "The flexible type array that is returned will have two fields:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.toflex:6
msgid "the ``_data`` field stores the ``_data`` part of the array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.toflex:7
msgid "the ``_mask`` field stores the ``_mask`` part of the array."
msgstr ""

