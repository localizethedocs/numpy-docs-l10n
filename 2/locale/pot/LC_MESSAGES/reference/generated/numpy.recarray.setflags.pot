msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.setflags:37
msgid ""
"Array flags provide information about how the memory area used for the array "
"is to be interpreted. There are 7 Boolean flags in use, only three of which "
"can be changed by the user: WRITEBACKIFCOPY, WRITEABLE, and ALIGNED."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.setflags:42
msgid "WRITEABLE (W) the data area can be written to;"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.setflags:44
msgid ""
"ALIGNED (A) the data and strides are aligned appropriately for the hardware "
"(as determined by the compiler);"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.setflags:47
msgid ""
"WRITEBACKIFCOPY (X) this array is a copy of some other array (referenced by ."
"base). When the C-API function PyArray_ResolveWritebackIfCopy is called, the "
"base array will be updated with the contents of this array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.setflags:51
msgid ""
"All flags can be accessed using the single (upper case) letter as well as "
"the full name."
msgstr ""

