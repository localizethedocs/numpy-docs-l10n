msgid "int"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagvander:26
msgid "Degree of the resulting matrix."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagvander:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagvander:45
msgid "**vander**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagvander:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagvander:33
msgid ""
"The pseudo-Vandermonde matrix. The shape of the returned matrix is ``x.shape "
"+ (deg + 1,)``, where The last index is the degree of the corresponding "
"Laguerre polynomial.  The dtype will be the same as the converted `x`."
msgstr ""

