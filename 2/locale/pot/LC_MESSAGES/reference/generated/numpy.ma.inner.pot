msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.inner:15
msgid ""
"If `a` and `b` are both scalars or both 1-D arrays then a scalar is "
"returned; otherwise an array is returned. ``out.shape = (*a.shape[:-1], *b."
"shape[:-1])``"
msgstr ""

