msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.inner:10
msgid "If `a` and `b` are nonscalar, their last dimensions must match."
msgstr ""

