#: of numpy.cumulative_prod:27
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.cumulative_prod:-1
msgid "ndarray, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.cumulative_prod:24
msgid ""
"Alternative output array in which to place the result. It must have the same "
"shape and buffer length as the expected output but the type of the resulting "
"values will be cast if necessary. See :ref:`ufuncs-output-type` for more "
"details."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.cumulative_prod:35
msgid "**include_initial**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.cumulative_prod:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.cumulative_prod:30
msgid ""
"Boolean indicating whether to include the initial value (ones) as the first "
"value in the output. With ``include_initial=True`` the shape of the output "
"is different than the shape of the input. Default: ``False``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
