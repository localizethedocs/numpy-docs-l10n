"Axis along which the cumulative product is computed. The default (None) is "
"only allowed for one-dimensional arrays. For arrays with more than one "
"dimension ``axis`` is required."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.cumulative_prod:21
msgid "**dtype**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
