msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.cumulative_prod:40
msgid ""
"A new array holding the result is returned unless ``out`` is specified, in "
"which case a reference to ``out`` is returned. The result has the same shape "
"as ``x`` if ``include_initial=False``."
msgstr ""

