#: ../../../reference/generated/numpy.meshgrid.rst:4
msgid "numpy.meshgrid"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.meshgrid:2
msgid "Return a tuple of coordinate matrices from coordinate vectors."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.meshgrid:4
msgid ""
"Make N-D coordinate arrays for vectorized evaluations of N-D scalar/vector "
"fields over N-D grids, given one-dimensional coordinate arrays x1, x2,..., "
"xn."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.meshgrid:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.meshgrid:11
msgid "**x1, x2,..., xn**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.meshgrid:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.meshgrid:11
msgid "1-D arrays representing the coordinates of a grid."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.meshgrid:15
msgid "**indexing**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.meshgrid:-1
msgid "{'xy', 'ij'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.meshgrid:14
msgid ""
"Cartesian ('xy', default) or matrix ('ij') indexing of output. See Notes for "
"more details."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.meshgrid:25
msgid "**sparse**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.meshgrid:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.meshgrid:18
msgid ""
"If True the shape of the returned coordinate array for dimension *i* is "
"reduced from ``(N1, ..., Ni, ... Nn)`` to ``(1, ..., 1, Ni, 1, ..., 1)``.  "
"These sparse coordinate grids are intended to be used with :ref:`basics."
"broadcasting`.  When all coordinates are used in an expression, broadcasting "
"still leads to a fully-dimensonal result array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.meshgrid:25
msgid "Default is False."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.meshgrid:33
msgid "**copy**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.meshgrid:28
msgid ""
"If False, a view into the original arrays are returned in order to conserve "
"memory.  Default is True.  Please note that ``sparse=False, copy=False`` "
"will likely return non-contiguous arrays.  Furthermore, more than one "
"element of a broadcast array may refer to a single memory location.  If you "
"need to write to the arrays, make copies first."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.meshgrid:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.meshgrid:48
msgid "**X1, X2,..., XN**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.meshgrid:-1
msgid "tuple of ndarrays"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.meshgrid:38
msgid ""
"For vectors `x1`, `x2`,..., `xn` with lengths ``Ni=len(xi)``, returns ``(N1, "
"N2, N3,..., Nn)`` shaped arrays if indexing='ij' or ``(N2, N1, N3,..., Nn)`` "
"shaped arrays if indexing='xy' with the elements of `xi` repeated to fill "
"the matrix along the first dimension for `x1`, the second for `x2` and so on."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.meshgrid:53
msgid ":obj:`mgrid`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.meshgrid:54
msgid "Construct a multi-dimensional \"meshgrid\" using indexing notation."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.meshgrid:55
msgid ":obj:`ogrid`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.meshgrid:56
msgid ""
"Construct an open multi-dimensional \"meshgrid\" using indexing notation."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.meshgrid:57
msgid ":ref:`how-to-index`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.meshgrid:61
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.meshgrid:62
msgid ""
"This function supports both indexing conventions through the indexing "
"keyword argument.  Giving the string 'ij' returns a meshgrid with matrix "
"indexing, while 'xy' returns a meshgrid with Cartesian indexing. In the 2-D "
"case with inputs of length M and N, the outputs are of shape (N, M) for 'xy' "
"indexing and (M, N) for 'ij' indexing.  In the 3-D case with inputs of "
"length M, N and P, outputs are of shape (N, M, P) for 'xy' indexing and (M, "
"N, P) for 'ij' indexing.  The difference is illustrated by the following "
"code snippet::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.meshgrid:71
msgid ""
"xv, yv = np.meshgrid(x, y, indexing='ij')\n"
"for i in range(nx):\n"
"    for j in range(ny):\n"
"        # treat xv[i,j], yv[i,j]\n"
"\n"
"xv, yv = np.meshgrid(x, y, indexing='xy')\n"
"for i in range(nx):\n"
"    for j in range(ny):\n"
"        # treat xv[j,i], yv[j,i]"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.meshgrid:81
msgid ""
"In the 1-D and 0-D case, the indexing and sparse keywords have no effect."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.meshgrid:85
msgid "Examples"
msgstr ""

#: ../../../reference/generated/numpy.meshgrid.rst:15
msgid "The result of `meshgrid` is a coordinate grid:"
msgstr ""

#: ../../../reference/generated/numpy.meshgrid.rst:46
msgid ""
"You can create sparse output arrays to save memory and computation time."
msgstr ""

#: ../../../reference/generated/numpy.meshgrid.rst:55
msgid ""
"`meshgrid` is very useful to evaluate functions on a grid. If the function "
"depends on all coordinates, both dense and sparse outputs can be used."
msgstr ""

