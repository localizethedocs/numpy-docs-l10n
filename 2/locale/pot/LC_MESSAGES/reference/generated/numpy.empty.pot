#: of numpy.empty:52
msgid ":obj:`ones`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.empty:53
msgid "Return a new array setting values to one."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.empty:54
msgid ":obj:`zeros`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.empty:55
msgid "Return a new array setting values to zero."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.empty:56
msgid ":obj:`full`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.empty:57
msgid "Return a new array of given shape filled with value."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.empty:61
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.empty:62
msgid ""
"Unlike other array creation functions (e.g. `zeros`, `ones`, `full`), "
"`empty` does not initialize the values of the array, and may therefore be "
"marginally faster. However, the values stored in the newly allocated array "
"are arbitrary. For reproducible behavior, be sure to set each element of the "
"array before reading."
msgstr ""

