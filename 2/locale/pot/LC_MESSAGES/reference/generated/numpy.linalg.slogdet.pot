#: ../../../reference/generated/numpy.linalg.slogdet.rst:4
msgid "numpy.linalg.slogdet"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.slogdet:2
msgid ""
"Compute the sign and (natural) logarithm of the determinant of an array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.slogdet:4
msgid ""
"If an array has a very small or very large determinant, then a call to `det` "
"may overflow or underflow. This routine is more robust against such issues, "
"because it computes the logarithm of the determinant rather than the "
"determinant itself."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.slogdet:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.slogdet:14
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.slogdet:-1
msgid "(..., M, M) array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.slogdet:12
msgid "Input array, has to be a square 2-D array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.slogdet:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.slogdet:19
msgid "A namedtuple with the following attributes:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.slogdet:24
msgid "**sign**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.slogdet:-1
msgid "(...) array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.slogdet:22
msgid ""
"A number representing the sign of the determinant. For a real matrix, this "
"is 1, 0, or -1. For a complex matrix, this is a complex number with absolute "
"value 1 (i.e., it is on the unit circle), or else 0."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.slogdet:27
msgid "**logabsdet**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.slogdet:27
msgid "The natural log of the absolute value of the determinant."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.slogdet:30
msgid "If the determinant is zero, then `sign` will be 0 and `logabsdet`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.slogdet:33
msgid "will be -inf. In all cases, the determinant is equal to"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.slogdet:42
msgid "``sign * np.exp(logabsdet)``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.slogdet:47
msgid ":obj:`det`"
msgstr ""

