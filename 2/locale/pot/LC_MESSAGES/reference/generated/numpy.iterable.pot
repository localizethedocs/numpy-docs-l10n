#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.iterable:27
msgid ""
"In most cases, the results of ``np.iterable(obj)`` are consistent with "
"``isinstance(obj, collections.abc.Iterable)``. One notable exception is the "
"treatment of 0-dimensional arrays::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.iterable:31
msgid ""
">>> from collections.abc import Iterable\n"
">>> a = np.array(1.0)  # 0-dimensional numpy array\n"
">>> isinstance(a, Iterable)\n"
"True\n"
">>> np.iterable(a)\n"
"False"
msgstr ""

