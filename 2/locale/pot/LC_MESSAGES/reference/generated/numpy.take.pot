#: of numpy.take:92
msgid "Examples"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:103
msgid "In this example if `a` is an ndarray, \"fancy\" indexing can be used."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:109
msgid ""
"If `indices` is not one dimensional, the output also has these dimensions."
msgstr ""

