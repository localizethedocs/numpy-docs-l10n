#: ../../../reference/generated/numpy.take.rst:4
msgid "numpy.take"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:2
msgid "Take elements from an array along an axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:4
msgid ""
"When axis is not None, this function does the same thing as \"fancy\" "
"indexing (indexing arrays using arrays); however, it can be easier to use if "
"you need elements along a given axis. A call such as ``np.take(arr, indices, "
"axis=3)`` is equivalent to ``arr[:,:,:,indices,...]``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:10
msgid ""
"Explained without fancy indexing, this is equivalent to the following use of "
"`ndindex`, which sets each of ``ii``, ``jj``, and ``kk`` to a tuple of "
"indices::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:14
msgid ""
"Ni, Nk = a.shape[:axis], a.shape[axis+1:]\n"
"Nj = indices.shape\n"
"for ii in ndindex(Ni):\n"
"    for jj in ndindex(Nj):\n"
"        for kk in ndindex(Nk):\n"
"            out[ii + jj + kk] = a[ii + (indices[jj],) + kk]"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:24
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:-1
msgid "array_like (Ni..., M, Nk...)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:24
msgid "The source array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:28
msgid "**indices**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:-1
msgid "array_like (Nj...)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:27
msgid "The indices of the values to extract. Also allow scalars for indices."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:32
msgid "**axis**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:31
msgid ""
"The axis over which to select values. By default, the flattened input array "
"is used."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:37 numpy.take:61
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:-1
msgid "ndarray, optional (Ni..., Nj..., Nk...)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:35
msgid ""
"If provided, the result will be placed in this array. It should be of the "
"appropriate shape and dtype. Note that `out` is always buffered if "
"`mode='raise'`; use other modes for better performance."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:50
msgid "**mode**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:-1
msgid "{'raise', 'wrap', 'clip'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:40
msgid "Specifies how out-of-bounds indices will behave."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:42
msgid "'raise' -- raise an error (default)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:43
msgid "'wrap' -- wrap around"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:44
msgid "'clip' -- clip to the range"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:46
msgid ""
"'clip' mode means that all indices that are too large are replaced by the "
"index that addresses the last element along that axis. Note that this "
"disables indexing with negative numbers."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:-1
msgid "ndarray (Ni..., Nj..., Nk...)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:55
msgid "The returned array has the same type as `a`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:66
msgid ":obj:`compress`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:67
msgid "Take elements using a boolean mask"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:68
msgid ":obj:`ndarray.take`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:69
msgid "equivalent method"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:70
msgid ":obj:`take_along_axis`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:71
msgid "Take elements by matching the array and the index arrays"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:75
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:76
msgid ""
"By eliminating the inner loop in the description above, and using `s_` to "
"build simple slice objects, `take` can be expressed  in terms of applying "
"fancy indexing to each 1-d slice::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:80
msgid ""
"Ni, Nk = a.shape[:axis], a.shape[axis+1:]\n"
"for ii in ndindex(Ni):\n"
"    for kk in ndindex(Nk):\n"
"        out[ii + s_[...,] + kk] = a[ii + s_[:,] + kk][indices]"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:85
msgid ""
"For this reason, it is equivalent to (but faster than) the following use of "
"`apply_along_axis`::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take:88
msgid "out = np.apply_along_axis(lambda a_1d: a_1d[indices], axis, a)"
msgstr ""

