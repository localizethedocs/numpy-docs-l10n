#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.atleast_3d:8
msgid ""
"One or more array-like sequences.  Non-array inputs are converted to "
"arrays.  Arrays that already have three or more dimensions are preserved."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.atleast_3d:0
msgid "Returns"
msgstr ""

