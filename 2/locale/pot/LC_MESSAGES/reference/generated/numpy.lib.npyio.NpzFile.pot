#: ../../../reference/generated/numpy.lib.npyio.NpzFile.rst:2
msgid "numpy.lib.npyio.NpzFile"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/npyio.py:docstring
#: of numpy.lib.npyio.NpzFile:2
msgid ""
"A dictionary-like object with lazy-loading of files in the zipped archive "
"provided on construction."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/npyio.py:docstring
#: of numpy.lib.npyio.NpzFile:5
msgid ""
"`NpzFile` is used to load files in the NumPy ``.npz`` data archive format. "
"It assumes that files in the archive have a ``.npy`` extension, other files "
"are ignored."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/npyio.py:docstring
#: of numpy.lib.npyio.NpzFile:9
msgid ""
"The arrays and file strings are lazily loaded on either getitem access using "
"``obj['key']`` or attribute lookup using ``obj.f.key``. A list of all files "
"(without ``.npy`` extensions) can be obtained with ``obj.files`` and the "
"ZipFile object itself using ``obj.zip``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/npyio.py:docstring
#: of numpy.lib.npyio.NpzFile:0
msgid "Parameters"
msgstr ""

