#: ../../../reference/generated/numpy.busday_offset.rst:4
msgid "numpy.busday\\_offset"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busday_offset:2
msgid ""
"First adjusts the date to fall on a valid day according to the ``roll`` "
"rule, then applies offsets to the given dates counted in valid days."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busday_offset:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busday_offset:10
msgid "**dates**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busday_offset:-1
msgid "array_like of datetime64[D]"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busday_offset:10
msgid "The array of dates to process."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busday_offset:13
msgid "**offsets**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busday_offset:-1
msgid "array_like of int"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busday_offset:13
msgid "The array of offsets, which is broadcast with ``dates``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busday_offset:30
msgid "**roll**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busday_offset:-1
msgid ""
"{'raise', 'nat', 'forward', 'following', 'backward', 'preceding',         "
"'modifiedfollowing', 'modifiedpreceding'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busday_offset:16
msgid ""
"How to treat dates that do not fall on a valid day. The default is 'raise'."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busday_offset:19
msgid "'raise' means to raise an exception for an invalid day."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busday_offset:20
msgid "'nat' means to return a NaT (not-a-time) for an invalid day."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busday_offset:21
msgid ""
"'forward' and 'following' mean to take the first valid day later in time."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busday_offset:23
msgid ""
"'backward' and 'preceding' mean to take the first valid day earlier in time."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busday_offset:25
msgid ""
"'modifiedfollowing' means to take the first valid day later in time unless "
"it is across a Month boundary, in which case to take the first valid day "
"earlier in time."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busday_offset:28
msgid ""
"'modifiedpreceding' means to take the first valid day earlier in time unless "
"it is across a Month boundary, in which case to take the first valid day "
"later in time."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busday_offset:38
msgid "**weekmask**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busday_offset:-1
msgid "str or array_like of bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busday_offset:33
msgid ""
"A seven-element array indicating which of Monday through Sunday are valid "
"days. May be specified as a length-seven list or array, like "
"[1,1,1,1,1,0,0]; a length-seven string, like '1111100'; or a string like "
"\"Mon Tue Wed Thu Fri\", made up of 3-character abbreviations for weekdays, "
"optionally separated by white space. Valid abbreviations are: Mon Tue Wed "
"Thu Fri Sat Sun"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busday_offset:44
msgid "**holidays**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busday_offset:-1
msgid "array_like of datetime64[D], optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busday_offset:41
msgid ""
"An array of dates to consider as invalid dates.  They may be specified in "
"any order, and NaT (not-a-time) dates are ignored. This list is saved in a "
"normalized form that is suited for fast calculations of valid days."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busday_offset:49
msgid "**busdaycal**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busday_offset:-1
msgid "busdaycalendar, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busday_offset:47
msgid ""
"A `busdaycalendar` object which specifies the valid days. If this parameter "
"is provided, neither weekmask nor holidays may be provided."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busday_offset:52 numpy.busday_offset:64
msgid "**out**"
