msgstr ""

#: ../../../../docstring of numpy.modf:2
msgid "Return the fractional and integral parts of an array, element-wise."
msgstr ""

#: ../../../../docstring of numpy.modf:4
msgid ""
"The fractional and integral parts are negative if the given number is "
"negative."
msgstr ""

