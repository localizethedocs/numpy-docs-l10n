#: of numpy.resize:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.resize:12
msgid "Array to be resized."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.resize:17
msgid "**new_shape**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.resize:-1
msgid "int or tuple of int"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.resize:15
msgid "Shape of resized array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.resize:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.resize:30
msgid "**reshaped_array**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.resize:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.resize:22
msgid ""
"The new array is formed from the data in the old array, repeated if "
"necessary to fill out the required number of elements.  The data are "
"repeated iterating over the array in C-order."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.resize:35
msgid ":obj:`numpy.reshape`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.resize:36
msgid "Reshape an array without changing the total size."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.resize:37
msgid ":obj:`numpy.pad`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.resize:38
msgid "Enlarge and pad an array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.resize:39
msgid ":obj:`numpy.repeat`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.resize:40
msgid "Repeat elements of an array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.resize:41
msgid ":obj:`ndarray.resize`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.resize:42
msgid "resize an array in-place."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.resize:46
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.resize:47
msgid ""
"When the total size of the array does not change `~numpy.reshape` should be "
"used.  In most other cases either indexing (to reduce the size) or padding "
"(to increase the size) may be a more appropriate solution."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.resize:51
msgid ""
"Warning: This functionality does **not** consider axes separately, i.e. it "
"does not apply interpolation/extrapolation. It fills the return array with "
"the required number of elements, iterating over `a` in C-order, disregarding "
"axes (and cycling back from the start if the new shape is larger).  This "
"functionality is therefore not suitable to resize images, or data where each "
"axis represents a separate and distinct entity."
msgstr ""

