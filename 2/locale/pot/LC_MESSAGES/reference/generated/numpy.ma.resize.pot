#: ../../../reference/generated/numpy.ma.resize.rst:4
msgid "numpy.ma.resize"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.resize:2
msgid "Return a new masked array with the specified size and shape."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.resize:4
msgid ""
"This is the masked equivalent of the `numpy.resize` function. The new array "
"is filled with repeated copies of `x` (in the order that the data are stored "
"in memory). If `x` is masked, the new array will be masked, and the new mask "
"will be a repetition of the old one."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.resize:22
msgid ":obj:`numpy.resize`"
msgstr ""

