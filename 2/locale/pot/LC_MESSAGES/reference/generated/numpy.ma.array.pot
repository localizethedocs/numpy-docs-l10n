#: ../../../reference/generated/numpy.ma.array.rst:4
msgid "numpy.ma.array"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:2
msgid "An array class with possibly masked values."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:4
msgid ""
"Masked values of True exclude the corresponding element from any computation."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:7
msgid "Construction::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:9
msgid ""
"x = MaskedArray(data, mask=nomask, dtype=None, copy=False, subok=True,\n"
"                ndmin=0, fill_value=None, keep_mask=True, hard_mask=None,\n"
"                shrink=True, order=None)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:16
msgid "**data**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:16
msgid "Input data."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:20
msgid "**mask**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:-1
msgid "sequence, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:19
msgid ""
"Mask. Must be convertible to an array of booleans with the same shape as "
"`data`. True indicates a masked (i.e. invalid) data."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:26
msgid "**dtype**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:-1
msgid "dtype, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:23
msgid ""
"Data type of the output. If `dtype` is None, the type of the data argument "
"(``data.dtype``) is used. If `dtype` is not None and different from ``data."
"dtype``, a copy is performed."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:30
msgid "**copy**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:29
msgid ""
"Whether to copy the input data (True), or to use a reference instead. "
"Default is False."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:34
msgid "**subok**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:33
msgid ""
"Whether to return a subclass of `MaskedArray` if possible (True) or a plain "
"`MaskedArray`. Default is True."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:37
msgid "**ndmin**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:37
msgid "Minimum number of dimensions. Default is 0."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:41
msgid "**fill_value**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:-1
msgid "scalar, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:40
msgid ""
"Value used to fill in the masked values when necessary. If None, a default "
"based on the data-type is used."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:45
msgid "**keep_mask**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:44
msgid ""
"Whether to combine `mask` with the mask of the input data, if any (True), or "
"to use only `mask` for the output (False). Default is True."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:49
msgid "**hard_mask**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:48
msgid ""
"Whether to use a hard mask or not. With a hard mask, masked values cannot be "
"unmasked. Default is False."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:52
msgid "**shrink**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:52
msgid "Whether to force compression of an empty mask. Default is True."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:71
msgid "**order**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:-1
msgid "{'C', 'F', 'A'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:55
msgid ""
"Specify the order of the array.  If order is 'C', then the array will be in "
"C-contiguous order (last-index varies the fastest). If order is 'F', then "
"the returned array will be in Fortran-contiguous order (first-index varies "
"the fastest). If order is 'A' (default), then the returned array may be in "
"any order (either C-, Fortran-contiguous, or even discontiguous), unless a "
"copy is required, in which case it will be C-contiguous."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:74
msgid "Examples"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:81
msgid ""
"The ``mask`` can be initialized with an array of boolean values with the "
"same shape as ``data``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:94
msgid ""
"Alternatively, the ``mask`` can be initialized to homogeneous boolean array "
"with the same shape as ``data`` by passing in a scalar boolean value:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.array:116
msgid ""
"The recommended practice for initializing ``mask`` with a scalar boolean "
"value is to use ``True``/``False`` rather than ``np.True_``/``np.False_``. "
"The reason is :attr:`nomask` is represented internally as ``np.False_``."
msgstr ""
