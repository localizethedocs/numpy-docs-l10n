msgid ""
"\\quad -\\frac{M-1}{2} \\leq n \\leq \\frac{M-1}{2},\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.kaiser:46
msgid "where :math:`I_0` is the modified zeroth-order Bessel function."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.kaiser:48
msgid ""
"The Kaiser was named for Jim Kaiser, who discovered a simple approximation "
"to the DPSS window based on Bessel functions.  The Kaiser window is a very "
"good approximation to the Digital Prolate Spheroidal Sequence, or Slepian "
"window, which is the transform which maximizes the energy in the main lobe "
"of the window relative to total energy."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.kaiser:54
msgid ""
"The Kaiser can approximate many other windows by varying the beta parameter."
msgstr ""

