#: ../../../reference/generated/numpy.unpackbits.rst:4
msgid "numpy.unpackbits"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unpackbits:2
msgid "Unpacks elements of a uint8 array into a binary-valued output array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unpackbits:4
msgid ""
"Each element of `a` represents a bit-field that should be unpacked into a "
"binary-valued output array. The shape of the output array is either 1-D (if "
"`axis` is ``None``) or the same shape as the input array with unpacking done "
"along the axis specified."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unpackbits:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unpackbits:12
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unpackbits:-1
msgid "ndarray, uint8 type"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unpackbits:12
msgid "Input array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unpackbits:16
msgid "**axis**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unpackbits:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unpackbits:15
msgid ""
"The dimension over which bit-unpacking is done. ``None`` implies unpacking "
"the flattened array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unpackbits:26
msgid "**count**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unpackbits:-1
msgid "int or None, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unpackbits:19
msgid ""
"The number of elements to unpack along `axis`, provided as a way of undoing "
"the effect of packing a size that is not a multiple of eight. A non-negative "
"number means to only unpack `count` bits. A negative number means to trim "
"off that many bits from the end. ``None`` means to unpack the entire array "
"(the default). Counts larger than the available number of bits will add zero "
"padding to the output. Negative counts must not exceed the available number "
"of bits."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unpackbits:32
msgid "**bitorder**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unpackbits:-1
msgid "{'big', 'little'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unpackbits:29
msgid ""
"The order of the returned bits. 'big' will mimic bin(val), ``3 = 0b00000011 "
"=> [0, 0, 0, 0, 0, 0, 1, 1]``, 'little' will reverse the order to ``[1, 1, "
"0, 0, 0, 0, 0, 0]``. Defaults to 'big'."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unpackbits:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unpackbits:43
msgid "**unpacked**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unpackbits:37
msgid "The elements are binary-valued (0 or 1)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unpackbits:48
msgid ":obj:`packbits`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unpackbits:49
msgid "Packs the elements of a binary-valued array into bits in a uint8 array."
msgstr ""

