#: ../../../reference/generated/numpy.fft.fftfreq.rst:4
msgid "numpy.fft.fftfreq"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fftfreq:2
msgid "Return the Discrete Fourier Transform sample frequencies."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fftfreq:4
msgid ""
"The returned float array `f` contains the frequency bin centers in cycles "
"per unit of the sample spacing (with zero at the start).  For instance, if "
"the sample spacing is in seconds, then the frequency unit is cycles/second."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fftfreq:8
msgid "Given a window length `n` and a sample spacing `d`::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fftfreq:10
msgid ""
"f = [0, 1, ...,   n/2-1,     -n/2, ..., -1] / (d*n)   if n is even\n"
"f = [0, 1, ..., (n-1)/2, -(n-1)/2, ..., -1] / (d*n)   if n is odd"
msgstr ""

