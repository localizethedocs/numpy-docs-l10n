#: ../../../reference/generated/numpy.vecmat.rst:4
msgid "numpy.vecmat"
msgstr ""

#: ../../../../docstring of numpy.vecmat:2
msgid "Vector-matrix dot product of two arrays."
msgstr ""

#: ../../../../docstring of numpy.vecmat:4
msgid ""
"Given a vector (or stack of vector) :math:`\\mathbf{v}` in ``x1`` and a "
"matrix (or stack of matrices) :math:`\\mathbf{A}` in ``x2``, the vector-"
"matrix product is defined as:"
msgstr ""

#: ../../../../docstring of numpy.vecmat:8
msgid ""
"\\mathbf{v} \\cdot \\mathbf{A} = \\sum_{i=0}^{n-1} \\overline{v_i}A_{ij}\n"
"\n"
msgstr ""

#: ../../../../docstring of numpy.vecmat:11
msgid ""
"where the sum is over the last dimension of ``x1`` and the one-but-last "
"dimensions in ``x2`` (unless `axes` is specified) and where :math:"
"`\\overline{v_i}` denotes the complex conjugate if :math:`v` is complex and "
"the identity otherwise. (For a non-conjugated vector-matrix product, use "
"``np.matvec(x2.mT, x1)``.)"
msgstr ""

