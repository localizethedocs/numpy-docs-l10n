msgid "numpy.ma.hsplit"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.hsplit:2
msgid "Split an array into multiple sub-arrays horizontally (column-wise)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.hsplit:4
msgid ""
"Please refer to the `split` documentation.  `hsplit` is equivalent to "
"`split` with ``axis=1``, the array is always split along the second axis "
"except for 1-D arrays, where it is split at ``axis=0``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.hsplit:19
msgid ":obj:`split`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.hsplit:20
msgid "Split an array into multiple sub-arrays of equal size."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.hsplit:24
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.hsplit:25
msgid ""
"The function is applied to both the ``_data`` and the ``_mask``, if any."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.hsplit:29
msgid "Examples"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.hsplit:61
msgid ""
"With a higher dimensional array the split is still along the second axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.hsplit:75
msgid "With a 1-D array, the split is along axis 0."
msgstr ""

