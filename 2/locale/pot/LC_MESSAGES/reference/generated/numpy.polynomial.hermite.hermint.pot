#: ../../../reference/generated/numpy.polynomial.hermite.hermint.rst:4
msgid "numpy.polynomial.hermite.hermint"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermint:2
msgid "Integrate a Hermite series."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermint:4
msgid ""
"Returns the Hermite series coefficients `c` integrated `m` times from `lbnd` "
"along `axis`. At each iteration the resulting series is **multiplied** by "
"`scl` and an integration constant, `k`, is added. The scaling factor is for "
"use in a linear change of variable.  (\"Buyer beware\": note that, depending "
"on what one is doing, one may want `scl` to be the reciprocal of what one "
"might expect; for more information, see the Notes section below.)  The "
"argument `c` is an array of coefficients from low to high degree along each "
"axis, e.g., [1,2,3] represents the series ``H_0 + 2*H_1 + 3*H_2`` while "
"[[1,2],[1,2]] represents ``1*H_0(x)*H_0(y) + 1*H_1(x)*H_0(y) + "
"2*H_0(x)*H_1(y) + 2*H_1(x)*H_1(y)`` if axis=0 is ``x`` and axis=1 is ``y``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermint:0
msgid "Parameters"
msgstr ""

