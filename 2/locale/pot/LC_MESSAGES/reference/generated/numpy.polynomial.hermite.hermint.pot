#: of numpy.polynomial.hermite.hermint:24
msgid "Order of integration, must be positive. (Default: 1)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermint:31
msgid "**k**"
