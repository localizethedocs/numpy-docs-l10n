#: ../../../reference/generated/numpy.geomspace.rst:4
msgid "numpy.geomspace"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:2
msgid "Return numbers spaced evenly on a log scale (a geometric progression)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:4
msgid ""
"This is similar to `logspace`, but with endpoints specified directly. Each "
"output sample is a constant multiple of the previous."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:10
msgid "**start**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:10
msgid "The starting value of the sequence."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:16
msgid "**stop**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:13
msgid ""
"The final value of the sequence, unless `endpoint` is False. In that case, "
"``num + 1`` values are spaced over the interval in log-space, of which all "
"but the last (a sequence of length `num`) are returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:19
msgid "**num**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:-1
msgid "integer, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:19
msgid "Number of samples to generate.  Default is 50."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:23
msgid "**endpoint**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:-1
msgid "boolean, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:22
msgid ""
"If true, `stop` is the last sample. Otherwise, it is not included. Default "
"is True."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:29
msgid "**dtype**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:-1
msgid "dtype"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:26
msgid ""
"The type of the output array.  If `dtype` is not given, the data type is "
"inferred from `start` and `stop`. The inferred dtype will never be an "
"integer; `float` is chosen even if the arguments would produce an array of "
"integers."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:34
msgid "**axis**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:32
msgid ""
"The axis in the result to store the samples.  Relevant only if start or stop "
"are array-like.  By default (0), the samples will be along a new axis "
"inserted at the beginning. Use -1 to get an axis at the end."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:45
msgid "**samples**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:39
msgid "`num` samples, equally spaced on a log scale."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:50
msgid ":obj:`logspace`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:51
msgid "Similar to geomspace, but with endpoints specified using log and base."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:52
msgid ":obj:`linspace`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:53
msgid ""
"Similar to geomspace, but with arithmetic instead of geometric progression."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:54
msgid ":obj:`arange`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:55
msgid ""
"Similar to linspace, with the step size specified instead of the number of "
"samples."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:56
msgid ":ref:`how-to-partition`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:60
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geomspace:61
msgid ""
"If the inputs or dtype are complex, the output will follow a logarithmic "
"spiral in the complex plane.  (There are an infinite number of spirals "
"passing through two points; the output will follow the shortest such path.)"
msgstr ""

