#: ../../../reference/generated/numpy.power.rst:4
msgid "numpy.power"
msgstr ""

#: ../../../../docstring of numpy.power:2
msgid "First array elements raised to powers from second array, element-wise."
msgstr ""

#: ../../../../docstring of numpy.power:4
msgid ""
"Raise each base in `x1` to the positionally-corresponding power in `x2`.  "
"`x1` and `x2` must be broadcastable to the same shape."
msgstr ""

#: ../../../../docstring of numpy.power:7
msgid ""
"An integer type raised to a negative integer power will raise a "
"``ValueError``."
msgstr ""

#: ../../../../docstring of numpy.power:10
msgid ""
"Negative values raised to a non-integral value will return ``nan``. To get "
"complex results, cast the input to complex, or specify the ``dtype`` to be "
"``complex`` (see the example below)."
msgstr ""

#: ../../../../docstring of numpy.power:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.power:17
msgid "**x1**"
msgstr ""

#: ../../../../docstring of numpy.power:-1
msgid "array_like"
msgstr ""

#: ../../../../docstring of numpy.power:17
msgid "The bases."
msgstr ""

#: ../../../../docstring of numpy.power:22
msgid "**x2**"
msgstr ""

#: ../../../../docstring of numpy.power:20
msgid ""
"The exponents. If ``x1.shape != x2.shape``, they must be broadcastable to a "
"common shape (which becomes the shape of the output)."
msgstr ""

#: ../../../../docstring of numpy.power:28
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.power:-1
msgid "ndarray, None, or tuple of ndarray and None, optional"
msgstr ""

#: ../../../../docstring of numpy.power:25
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or None, a freshly-"
"allocated array is returned. A tuple (possible only as a keyword argument) "
"must have length equal to the number of outputs."
msgstr ""

#: ../../../../docstring of numpy.power:36
msgid "**where**"
msgstr ""

#: ../../../../docstring of numpy.power:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../docstring of numpy.power:31
msgid ""
"This condition is broadcast over the input. At locations where the condition "
"is True, the `out` array will be set to the ufunc result. Elsewhere, the "
"`out` array will retain its original value. Note that if an uninitialized "
"`out` array is created via the default ``out=None``, locations within it "
"where the condition is False will remain uninitialized."
msgstr ""

#: ../../../../docstring of numpy.power:40
msgid "**\\*\\*kwargs**"
msgstr ""

#: ../../../../docstring of numpy.power:39
msgid ""
"For other keyword-only arguments, see the :ref:`ufunc docs <ufuncs.kwargs>`."
msgstr ""

#: ../../../../docstring of numpy.power:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.power:52
msgid "**y**"
msgstr ""

#: ../../../../docstring of numpy.power:-1
msgid "ndarray"
msgstr ""

#: ../../../../docstring of numpy.power:45
msgid ""
"The bases in `x1` raised to the exponents in `x2`. This is a scalar if both "
"`x1` and `x2` are scalars."
msgstr ""

#: ../../../../docstring of numpy.power:57
msgid ":obj:`float_power`"
msgstr ""

#: ../../../../docstring of numpy.power:58
msgid "power function that promotes integers to float"
msgstr ""

#: ../../../../docstring of numpy.power:64
msgid "Examples"
msgstr ""

#: ../../../../docstring of numpy.power:71
msgid "Cube each element in an array."
msgstr ""

#: ../../../../docstring of numpy.power:79
msgid "Raise the bases to different exponents."
msgstr ""

#: ../../../../docstring of numpy.power:85
msgid "The effect of broadcasting."
msgstr ""

#: ../../../../docstring of numpy.power:95
msgid ""
"The ``**`` operator can be used as a shorthand for ``np.power`` on ndarrays."
msgstr ""

#: ../../../../docstring of numpy.power:103
msgid ""
"Negative values raised to a non-integral value will result in ``nan`` (and a "
"warning will be generated)."
msgstr ""

#: ../../../../docstring of numpy.power:113
msgid "To get complex results, give the argument ``dtype=complex``."
msgstr ""

