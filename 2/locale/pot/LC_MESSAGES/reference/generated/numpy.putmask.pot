msgid "numpy.putmask"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.putmask:2
msgid "Changes elements of an array based on conditional and input values."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.putmask:4
msgid "Sets ``a.flat[n] = values[n]`` for each n where ``mask.flat[n]==True``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.putmask:6
msgid ""
"If `values` is not the same size as `a` and `mask` then it will repeat. This "
"gives behavior different from ``a[mask] = values``."
msgstr ""

