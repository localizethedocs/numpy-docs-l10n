msgid "Subtract one Laguerre series from another."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagsub:4
msgid ""
"Returns the difference of two Laguerre series `c1` - `c2`.  The sequences of "
"coefficients are from lowest order term to highest, i.e., [1,2,3] represents "
"the series ``P_0 + 2*P_1 + 3*P_2``."
msgstr ""

