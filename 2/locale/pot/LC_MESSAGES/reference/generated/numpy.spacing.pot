#: ../../../reference/generated/numpy.spacing.rst:4
msgid "numpy.spacing"
msgstr ""

#: ../../../../docstring of numpy.spacing:2
msgid "Return the distance between x and the nearest adjacent number."
msgstr ""

#: ../../../../docstring of numpy.spacing:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.spacing:8
msgid "**x**"
msgstr ""

#: ../../../../docstring of numpy.spacing:-1
msgid "array_like"
msgstr ""

#: ../../../../docstring of numpy.spacing:8
msgid "Values to find the spacing of."
msgstr ""

#: ../../../../docstring of numpy.spacing:14 numpy.spacing:39
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.spacing:-1
msgid "ndarray, None, or tuple of ndarray and None, optional"
msgstr ""

#: ../../../../docstring of numpy.spacing:11
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or None, a freshly-"
"allocated array is returned. A tuple (possible only as a keyword argument) "
"must have length equal to the number of outputs."
msgstr ""

#: ../../../../docstring of numpy.spacing:22
msgid "**where**"
msgstr ""

#: ../../../../docstring of numpy.spacing:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../docstring of numpy.spacing:17
msgid ""
"This condition is broadcast over the input. At locations where the condition "
"is True, the `out` array will be set to the ufunc result. Elsewhere, the "
"`out` array will retain its original value. Note that if an uninitialized "
"`out` array is created via the default ``out=None``, locations within it "
"where the condition is False will remain uninitialized."
msgstr ""

#: ../../../../docstring of numpy.spacing:26
msgid "**\\*\\*kwargs**"
msgstr ""

#: ../../../../docstring of numpy.spacing:25
msgid ""
"For other keyword-only arguments, see the :ref:`ufunc docs <ufuncs.kwargs>`."
msgstr ""

#: ../../../../docstring of numpy.spacing:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.spacing:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.spacing:31
msgid "The spacing of values of `x`. This is a scalar if `x` is a scalar."
msgstr ""

#: ../../../../docstring of numpy.spacing:42
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.spacing:43
msgid ""
"It can be considered as a generalization of EPS: ``spacing(np.float64(1)) == "
"np.finfo(np.float64).eps``, and there should not be any representable number "
"between ``x + spacing(x)`` and x for any finite x."
msgstr ""

#: ../../../../docstring of numpy.spacing:48
msgid "Spacing of +- inf and NaN is NaN."
msgstr ""

