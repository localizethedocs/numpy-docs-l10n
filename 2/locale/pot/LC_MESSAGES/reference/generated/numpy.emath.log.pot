#: ../../../reference/generated/numpy.emath.log.rst:4
msgid "numpy.emath.log"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log:2
msgid "Compute the natural logarithm of `x`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log:4
msgid ""
"Return the \"principal value\" (for a description of this, see `numpy.log`) "
"of :math:`log_e(x)`. For real `x > 0`, this is a real number (``log(0)`` "
"returns ``-inf`` and ``log(np.inf)`` returns ``inf``). Otherwise, the "
"complex principle value is returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log:14
msgid "**x**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log:12
msgid "The value(s) whose log is (are) required."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log:26
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log:19
msgid ""
"The log of the `x` value(s). If `x` was a scalar, so is `out`, otherwise an "
"array is returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log:31
msgid ":obj:`numpy.log`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log:35
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log:36
msgid ""
"For a log() that returns ``NAN`` when real `x < 0`, use `numpy.log` (note, "
"however, that otherwise `numpy.log` and this `log` are identical, i.e., both "
"return ``-inf`` for `x = 0`, ``inf`` for `x = inf`, and, notably, the "
"complex principle value if ``x.imag != 0``)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log:43
msgid "Examples"
msgstr ""

