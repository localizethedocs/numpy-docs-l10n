msgid "numpy.searchsorted"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.searchsorted:2
msgid "Find indices where elements should be inserted to maintain order."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.searchsorted:4
msgid ""
"Find the indices into a sorted array `a` such that, if the corresponding "
"elements in `v` were inserted before the indices, the order of `a` would be "
"preserved."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.searchsorted:8
msgid "Assuming that `a` is sorted:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.searchsorted:11
msgid "`side`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.searchsorted:11
msgid "returned index `i` satisfies"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.searchsorted:13
msgid "left"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.searchsorted:13
msgid "``a[i-1] < v <= a[i]``"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.searchsorted:14
msgid "right"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.searchsorted:14
msgid "``a[i-1] <= v < a[i]``"
msgstr ""

