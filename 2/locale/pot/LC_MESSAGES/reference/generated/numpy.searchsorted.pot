#: of numpy.searchsorted:-1
msgid "1-D array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.searchsorted:20
msgid ""
"Input array. If `sorter` is None, then it must be sorted in ascending order, "
"otherwise `sorter` must be an array of indices that sort it."
msgstr ""

