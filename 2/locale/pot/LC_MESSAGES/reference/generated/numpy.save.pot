msgid "numpy.save"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.save:2
msgid "Save an array to a binary file in NumPy ``.npy`` format."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.save:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.save:11
msgid "**file**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.save:-1
msgid "file, str, or pathlib.Path"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.save:8
msgid ""
"File or filename to which the data is saved. If file is a file-object, then "
"the filename is unchanged.  If file is a string or Path, a ``.npy`` "
"extension will be appended to the filename if it does not already have one."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.save:14
msgid "**arr**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.save:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.save:14
msgid "Array data to be saved."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.save:30
msgid "**allow_pickle**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.save:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.save:17
msgid ""
"Allow saving object arrays using Python pickles. Reasons for disallowing "
"pickles include security (loading pickled data can execute arbitrary code) "
"and portability (pickled objects may not be loadable on different Python "
"installations, for example if the stored objects require libraries that are "
"not available, and not all pickled data is compatible between different "
"versions of Python). Default: True"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.save:35
msgid ":obj:`savez`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.save:36
msgid "Save several arrays into a ``.npz`` archive"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.save:37
msgid ":obj:`savetxt`, :obj:`load`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.save:41
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.save:42
msgid ""
"For a description of the ``.npy`` format, see :py:mod:`numpy.lib.format`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.save:44
msgid "Any data saved to the file is appended to the end of the file."
msgstr ""

