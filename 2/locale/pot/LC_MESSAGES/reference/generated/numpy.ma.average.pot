#: ../../../reference/generated/numpy.ma.average.rst:4
msgid "numpy.ma.average"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:2
msgid "Return the weighted average of array over the given axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:9
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:8
msgid ""
"Data to be averaged. Masked entries are not taken into account in the "
"computation."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:16
msgid "**axis**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:-1
msgid "None or int or tuple of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:12
msgid ""
"Axis or axes along which to average `a`.  The default, `axis=None`, will "
"average over all of the elements of the input array. If axis is a tuple of "
"ints, averaging is performed on all of the axes specified in the tuple "
"instead of a single axis or all the axes as before."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:32
msgid "**weights**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:19
msgid ""
"An array of weights associated with the values in `a`. Each value in `a` "
"contributes to the average according to its associated weight. The array of "
"weights must be the same shape as `a` if no axis is specified, otherwise the "
"weights must have dimensions and shape consistent with `a` along the "
"specified axis. If `weights=None`, then all data in `a` are assumed to have "
"a weight equal to one. The calculation is::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:28
msgid "avg = sum(a * weights) / sum(weights)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:30
msgid ""
"where the sum is over all included elements. The only constraint on the "
"values of `weights` is that `sum(weights)` must not be 0."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:37
msgid "**returned**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:35
msgid ""
"Flag indicating whether a tuple ``(result, sum of weights)`` should be "
"returned as output (True), or just the result (False). Default is False."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:46
msgid "**keepdims**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:40
msgid ""
"If this is set to True, the axes which are reduced are left in the result as "
"dimensions with size one. With this option, the result will broadcast "
"correctly against the original `a`. *Note:* `keepdims` will not work with "
"instances of `numpy.matrix` or other classes whose methods do not support "
"`keepdims`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:59
msgid "**average, [sum_of_weights]**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:-1
msgid "(tuple of) scalar or MaskedArray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:51
msgid ""
"The average along the specified axis. When returned is `True`, return a "
"tuple with the average as the first element and the sum of the weights as "
"the second element. The return type is `np.float64` if `a` is of integer "
"type and floats smaller than `float64`, or the input data-type, otherwise. "
"If returned, `sum_of_weights` is always `float64`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:0
msgid "Raises"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:65
msgid "ZeroDivisionError"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:64
msgid ""
"When all weights along axis are zero. See `numpy.ma.average` for a version "
"robust to this type of error."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:68
msgid "TypeError"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:68
msgid "When `weights` does not have the same shape as `a`, and `axis=None`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:77
msgid "ValueError"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:71
msgid ""
"When `weights` does not have dimensions and shape consistent with `a` along "
"specified `axis`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:80
msgid "Examples"
msgstr ""

