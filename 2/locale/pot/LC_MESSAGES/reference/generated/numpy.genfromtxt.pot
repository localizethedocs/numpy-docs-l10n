#: of numpy.genfromtxt:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:13
msgid "**fname**"
