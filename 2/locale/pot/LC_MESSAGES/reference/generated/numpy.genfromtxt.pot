#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:-1
msgid "file, str, pathlib.Path, list of str, generator"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:10
msgid ""
"File, filename, list, or generator to read.  If the filename extension is ``."
"gz`` or ``.bz2``, the file is first decompressed. Note that generators must "
"return bytes or strings. The strings in a list or produced by a generator "
"are treated as lines."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:18
msgid "**dtype**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:-1
msgid "dtype, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:16
msgid ""
"Data type of the resulting array. If None, the dtypes will be determined by "
"the contents of each column, individually."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:22
msgid "**comments**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:-1
msgid "str, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:21
msgid ""
"The character used to indicate the start of a comment. All the characters "
"occurring on a line after a comment are discarded."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:27
msgid "**delimiter**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:-1
msgid "str, int, or sequence, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:25
msgid ""
"The string used to separate values.  By default, any consecutive whitespaces "
"act as delimiter.  An integer or sequence of integers can also be provided "
"as width(s) of each field."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:30
msgid "**skiprows**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:30
msgid "`skiprows` was removed in numpy 1.10. Please use `skip_header` instead."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:33
msgid "**skip_header**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:33
msgid "The number of lines to skip at the beginning of the file."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:36
msgid "**skip_footer**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:36
msgid "The number of lines to skip at the end of the file."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:41
msgid "**converters**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:-1
msgid "variable, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:39
msgid ""
"The set of functions that convert the data of a column to a value. The "
"converters can also be used to provide a default value for missing data: "
"``converters = {3: lambda s: float(s or 0)}``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:45
msgid "**missing**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:44
msgid ""
"`missing` was removed in numpy 1.10. Please use `missing_values` instead."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:48
msgid "**missing_values**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:48
msgid "The set of strings corresponding to missing data."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:51
msgid "**filling_values**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:51
msgid "The set of values to be used as default when the data are missing."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:55
msgid "**usecols**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:-1
msgid "sequence, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:54
msgid ""
"Which columns to read, with 0 being the first.  For example, ``usecols = (1, "
"4, 5)`` will extract the 2nd, 5th and 6th columns."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:64
msgid "**names**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:-1
msgid "{None, True, str, sequence}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:58
msgid ""
"If `names` is True, the field names are read from the first line after the "
"first `skip_header` lines. This line can optionally be preceded by a comment "
"delimiter. Any content before the comment delimiter is discarded. If `names` "
"is a sequence or a single-string of comma-separated names, the names will be "
"used to define the field names in a structured dtype. If `names` is None, "
"the names of the dtype fields will be used, if any."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:69
msgid "**excludelist**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:67
msgid ""
"A list of names to exclude. This list is appended to the default list "
"['return','file','print']. Excluded names are appended with an underscore: "
"for example, `file` would become `file_`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:73
msgid "**deletechars**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:72
msgid ""
"A string combining invalid characters that must be deleted from the names."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:76
msgid "**defaultfmt**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:76
msgid ""
"A format used to define default field names, such as \"f%i\" or \"f_%02i\"."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:79
msgid "**autostrip**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:79
msgid "Whether to automatically strip white spaces from the variables."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:83
msgid "**replace_space**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:-1
msgid "char, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:82
msgid ""
"Character(s) used in replacement of white spaces in the variable names. By "
"default, use a '_'."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:88
msgid "**case_sensitive**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:-1
msgid "{True, False, 'upper', 'lower'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:86
msgid ""
"If True, field names are case sensitive. If False or 'upper', field names "
"are converted to upper case. If 'lower', field names are converted to lower "
"case."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:94
msgid "**unpack**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:91
msgid ""
"If True, the returned array is transposed, so that arguments may be unpacked "
"using ``x, y, z = genfromtxt(...)``.  When used with a structured data-type, "
"arrays are returned for each field. Default is False."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:98
msgid "**usemask**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:97
msgid "If True, return a masked array. If False, return a regular array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:101
msgid "**loose**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:101
msgid "If True, do not raise errors for invalid values."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:106
msgid "**invalid_raise**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:104
msgid ""
"If True, an exception is raised if an inconsistency is detected in the "
"number of columns. If False, a warning is emitted and the offending lines "
"are skipped."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:111
msgid "**max_rows**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:-1
msgid "int,  optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:109
msgid ""
"The maximum number of rows to read. Must not be used with skip_footer at the "
"same time.  If given, the value must be at least 1. Default is to read the "
"entire file."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:124
msgid "**encoding**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:114
msgid ""
"Encoding used to decode the inputfile. Does not apply when `fname` is a file "
"object. The special value 'bytes' enables backward compatibility workarounds "
"that ensure that you receive byte arrays when possible and passes latin1 "
"encoded strings to converters. Override this value to receive unicode arrays "
"and pass strings as input to converters.  If set to None the system default "
"is used. The default value is 'bytes'."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:122
msgid ""
"Before NumPy 2, the default was ``'bytes'`` for Python 2 compatibility. The "
"default is now ``None``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:129
msgid "**ndmin**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:127
msgid "Same parameter as `loadtxt`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:138
msgid "**like**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.genfromtxt:132
msgid ""
"Reference object to allow the creation of arrays which are not NumPy arrays. "
"If an array-like passed in as ``like`` supports the ``__array_function__`` "
"protocol, the result will be defined by it. In this case, it ensures the "
"creation of an array object compatible with that passed in via this argument."
msgstr ""

