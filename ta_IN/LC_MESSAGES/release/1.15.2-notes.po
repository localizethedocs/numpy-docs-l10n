#: ../../../release/1.15.2-notes.rst:3
msgid "NumPy 1.15.2 Release Notes"
msgstr ""

#: ../../../release/1.15.2-notes.rst:5
msgid ""
"This is a bugfix release for bugs and regressions reported following the "
"1.15.1 release."
msgstr ""

#: ../../../release/1.15.2-notes.rst:8
msgid "The matrix PendingDeprecationWarning is now suppressed in pytest 3.8."
msgstr ""

#: ../../../release/1.15.2-notes.rst:9
msgid "The new cached allocations machinery has been fixed to be thread safe."
msgstr ""

#: ../../../release/1.15.2-notes.rst:10
msgid "The boolean indexing of subclasses now works correctly."
msgstr ""

#: ../../../release/1.15.2-notes.rst:11
msgid "A small memory leak in PyArray_AdaptFlexibleDType has been fixed."
msgstr ""

#: ../../../release/1.15.2-notes.rst:13
msgid ""
"The Python versions supported by this release are 2.7, 3.4-3.7. The wheels "
"are linked with OpenBLAS v0.3.0, which should fix some of the linalg "
"problems reported for NumPy 1.14."
msgstr ""

#: ../../../release/1.15.2-notes.rst:18
msgid "Compatibility Note"
msgstr ""

#: ../../../release/1.15.2-notes.rst:20
msgid ""
"The NumPy 1.15.x OS X wheels released on PyPI no longer contain 32-bit "
"binaries.  That will also be the case in future releases. See `#11625 "
"<https://github.com/numpy/numpy/issues/11625>`__ for the related "
"discussion.  Those needing 32-bit support should look elsewhere or build "
"from source."
msgstr ""

