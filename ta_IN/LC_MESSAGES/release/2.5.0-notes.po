msgstr ""

#: ../../../release/2.5.0-notes.rst:164 ../../../release/2.5.0-notes.rst:169
msgid "(`gh-30463 <https://github.com/numpy/numpy/pull/30463>`__)"
msgstr ""

#: ../../../release/2.5.0-notes.rst:166
msgid "``get_array_wrap`` has been removed. (deprecated since 2.0)"
msgstr ""

#: ../../../release/2.5.0-notes.rst:171
msgid ""
"``recfromtxt`` and ``recfromcsv`` have been removed from ``numpy.lib."
"_npyio`` in favor of ``numpy.genfromtxt``. (deprecated since 2.0)"
msgstr ""

#: ../../../release/2.5.0-notes.rst:175
msgid "(`gh-30467 <https://github.com/numpy/numpy/pull/30467>`__)"
msgstr ""

#: ../../../release/2.5.0-notes.rst:177
msgid ""
"The ``numpy.chararray`` re-export of ``numpy.char.chararray`` has been "
"removed. (deprecated since 2.0)"
msgstr ""

#: ../../../release/2.5.0-notes.rst:180
msgid "(`gh-30604 <https://github.com/numpy/numpy/pull/30604>`__)"
msgstr ""

#: ../../../release/2.5.0-notes.rst:182
msgid ""
"``bincount`` now raises a ``TypeError`` for non-integer inputs. (deprecated "
"since 2.1)"
msgstr ""

#: ../../../release/2.5.0-notes.rst:185
msgid "(`gh-30610 <https://github.com/numpy/numpy/pull/30610>`__)"
