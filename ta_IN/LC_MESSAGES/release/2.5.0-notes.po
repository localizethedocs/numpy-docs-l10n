msgstr ""

#: ../../../release/2.5.0-notes.rst:154
msgid "(`gh-30461 <https://github.com/numpy/numpy/pull/30461>`__)"
msgstr ""

#: ../../../release/2.5.0-notes.rst:156
msgid ""
"``numpy._core.numerictypes.maximum_sctype`` has been removed. (deprecated "
"since 2.0)"
msgstr ""

#: ../../../release/2.5.0-notes.rst:159
msgid "(`gh-30462 <https://github.com/numpy/numpy/pull/30462>`__)"
msgstr ""

#: ../../../release/2.5.0-notes.rst:161
msgid ""
"``numpy.row_stack`` has been removed in favor of ``numpy.vstack``. "
