msgstr ""

#: ../../../release/2.5.0-notes.rst:191
msgid "(`gh-30612 <https://github.com/numpy/numpy/pull/30612>`__)"
msgstr ""

#: ../../../release/2.5.0-notes.rst:193
msgid ""
"Data type alias ``'a'`` was removed in favor of ``'S'``. (deprecated since "
"2.0)"
msgstr ""

#: ../../../release/2.5.0-notes.rst:196
msgid "(`gh-30613 <https://github.com/numpy/numpy/pull/30613>`__)"
