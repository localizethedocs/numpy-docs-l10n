#: ../../../f2py/windows/msys2.rst:5
msgid "F2PY and Windows with MSYS2"
msgstr ""

#: ../../../f2py/windows/msys2.rst:7
msgid ""
"Follow the standard `installation instructions`_. Then, to grab the "
"requisite Fortran compiler with ``MVSC``:"
msgstr ""

#: ../../../f2py/windows/msys2.rst:9
msgid ""
"# Assuming a fresh install\n"
"pacman -Syu # Restart the terminal\n"
"pacman -Su  # Update packages\n"
"# Get the toolchains\n"
"pacman -S --needed base-devel gcc-fortran\n"
"pacman -S mingw-w64-x86_64-toolchain"
msgstr ""
