#: of numpy.random.RandomState.get_state:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.get_state:9
msgid ""
"Flag indicating to return a legacy tuple state when the BitGenerator is "
"MT19937, instead of a dict. Raises ValueError if the underlying bit "
"generator is not an instance of MT19937."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.get_state:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.get_state:33
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.get_state:-1
msgid "{tuple(str, ndarray of 624 uints, int, int, float), dict}"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.get_state:18
msgid "If legacy is True, the returned tuple has the following items:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.get_state:20
msgid "the string 'MT19937'."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.get_state:21
msgid "a 1-D array of 624 unsigned integer keys."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.get_state:22
msgid "an integer ``pos``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.get_state:23
msgid "an integer ``has_gauss``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.get_state:24
msgid "a float ``cached_gaussian``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.get_state:26
msgid ""
"If `legacy` is False, or the BitGenerator is not MT19937, then state is "
"returned as a dictionary."
msgstr ""

