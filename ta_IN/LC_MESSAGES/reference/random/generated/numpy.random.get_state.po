#: of numpy.random.RandomState.get_state:4
msgid "For more details, see `set_state`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.get_state:0
msgid "Parameters"
