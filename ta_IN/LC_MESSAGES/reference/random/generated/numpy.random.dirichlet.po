#: ../../../reference/random/generated/numpy.random.dirichlet.rst:4
msgid "numpy.random.dirichlet"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:2
msgid "Draw samples from the Dirichlet distribution."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:4
msgid ""
"Draw `size` samples of dimension k from a Dirichlet distribution. A "
"Dirichlet-distributed random variable can be seen as a multivariate "
"generalization of a Beta distribution. The Dirichlet distribution is a "
"conjugate prior of a multinomial distribution in Bayesian inference."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:11
msgid ""
"New code should use the `~numpy.random.Generator.dirichlet` method of a "
"`~numpy.random.Generator` instance instead; please see the :ref:`random-"
"quick-start`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:19
msgid "**alpha**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:-1
msgid "sequence of floats, length k"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:18
msgid ""
"Parameter of the distribution (length ``k`` for sample of length ``k``)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:26
msgid "**size**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:22
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n)``, then ``m * n * k`` "
"samples are drawn.  Default is None, in which case a vector of length ``k`` "
"is returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:34
msgid "**samples**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:-1
msgid "ndarray,"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:31
msgid "The drawn samples, of shape ``(size, k)``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:0
msgid "Raises"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:41
msgid "ValueError"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:39
msgid "If any value in ``alpha`` is less than or equal to zero"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:46
msgid ":obj:`random.Generator.dirichlet`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:47
msgid "which should be used for new code."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:51
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:52
msgid ""
"The Dirichlet distribution is a distribution over vectors :math:`x` that "
"fulfil the conditions :math:`x_i>0` and :math:`\\sum_{i=1}^k x_i = 1`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:56
msgid ""
"The probability density function :math:`p` of a Dirichlet-distributed random "
"vector :math:`X` is proportional to"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:60
msgid ""
"p(x) \\propto \\prod_{i=1}^{k}{x^{\\alpha_i-1}_i},\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:62
msgid ""
"where :math:`\\alpha` is a vector containing the positive concentration "
"parameters."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:65
msgid ""
"The method uses the following property for computation: let :math:`Y` be a "
"random vector which has components that follow a standard gamma "
"distribution, then :math:`X = \\frac{1}{\\sum_{i=1}^k{Y_i}} Y` is Dirichlet-"
"distributed"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:71
msgid "References"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:72
msgid ""
"David McKay, \"Information Theory, Inference and Learning Algorithms,\" "
"chapter 23, https://www.inference.org.uk/mackay/itila/"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.dirichlet:75
msgid ""
"Wikipedia, \"Dirichlet distribution\", https://en.wikipedia.org/wiki/"
"Dirichlet_distribution"
msgstr ""

