msgid "Return a copy of a, rounded to 'decimals' places."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.round_:4
msgid "`numpy.ma.round_` is deprecated. Use `numpy.ma.round` instead."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.round_:7
msgid ""
"When 'decimals' is negative, it specifies the number of positions to the "
"left of the decimal point.  The real and imaginary parts of complex numbers "
"are rounded separately. Nothing is done if the array is not of float type "
"and 'decimals' is greater than or equal to 0."
msgstr ""

