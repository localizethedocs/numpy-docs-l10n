#: ../../../reference/generated/numpy.nextafter.rst:4
msgid "numpy.nextafter"
msgstr ""

#: ../../../../docstring of numpy.nextafter:2
msgid "Return the next floating-point value after x1 towards x2, element-wise."
msgstr ""

#: ../../../../docstring of numpy.nextafter:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.nextafter:8
msgid "**x1**"
msgstr ""

#: ../../../../docstring of numpy.nextafter:-1
msgid "array_like"
msgstr ""

#: ../../../../docstring of numpy.nextafter:8
msgid "Values to find the next representable value of."
msgstr ""

#: ../../../../docstring of numpy.nextafter:13
msgid "**x2**"
msgstr ""

#: ../../../../docstring of numpy.nextafter:11
msgid ""
"The direction where to look for the next representable value of `x1`. If "
"``x1.shape != x2.shape``, they must be broadcastable to a common shape "
"(which becomes the shape of the output)."
msgstr ""

#: ../../../../docstring of numpy.nextafter:19 numpy.nextafter:46
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.nextafter:-1
msgid "ndarray, None, or tuple of ndarray and None, optional"
msgstr ""

#: ../../../../docstring of numpy.nextafter:16
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or None, a freshly-"
"allocated array is returned. A tuple (possible only as a keyword argument) "
"must have length equal to the number of outputs."
msgstr ""

#: ../../../../docstring of numpy.nextafter:27
msgid "**where**"
msgstr ""

#: ../../../../docstring of numpy.nextafter:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../docstring of numpy.nextafter:22
msgid ""
"This condition is broadcast over the input. At locations where the condition "
"is True, the `out` array will be set to the ufunc result. Elsewhere, the "
"`out` array will retain its original value. Note that if an uninitialized "
"`out` array is created via the default ``out=None``, locations within it "
"where the condition is False will remain uninitialized."
msgstr ""

#: ../../../../docstring of numpy.nextafter:31
msgid "**\\*\\*kwargs**"
msgstr ""

#: ../../../../docstring of numpy.nextafter:30
msgid ""
"For other keyword-only arguments, see the :ref:`ufunc docs <ufuncs.kwargs>`."
msgstr ""

#: ../../../../docstring of numpy.nextafter:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.nextafter:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.nextafter:36
msgid ""
"The next representable values of `x1` in the direction of `x2`. This is a "
"scalar if both `x1` and `x2` are scalars."
msgstr ""

