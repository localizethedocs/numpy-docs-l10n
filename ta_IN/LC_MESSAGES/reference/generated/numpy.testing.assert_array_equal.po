#: ../../../reference/generated/numpy.testing.assert_array_equal.rst:4
msgid "numpy.testing.assert\\_array\\_equal"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.assert_array_equal:2
msgid "Raises an AssertionError if two array_like objects are not equal."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.assert_array_equal:4
msgid ""
"Given two array_like objects, check that the shape is equal and all elements "
"of these objects are equal (but see the Notes for the special handling of a "
"scalar). An exception is raised at shape mismatch or conflicting values. In "
"contrast to the standard usage in numpy, NaNs are compared like numbers, no "
"assertion is raised if both objects have NaNs in the same positions."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.assert_array_equal:11
msgid ""
"The usual caution for verifying equality with floating point numbers is "
"advised."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.assert_array_equal:14
msgid ""
"When either `actual` or `desired` is already an instance of `numpy.ndarray` "
"and `desired` is not a ``dict``, the behavior of ``assert_equal(actual, "
"desired)`` is identical to the behavior of this function. Otherwise, this "
"function performs `np.asanyarray` on the inputs before comparison, whereas "
"`assert_equal` defines special comparison rules for common Python types. For "
"example, only `assert_equal` can be used to compare nested Python lists. In "
"new code, consider using only `assert_equal`, explicitly converting either "
"`actual` or `desired` to arrays if the behavior of `assert_array_equal` is "
"desired."
msgstr ""

