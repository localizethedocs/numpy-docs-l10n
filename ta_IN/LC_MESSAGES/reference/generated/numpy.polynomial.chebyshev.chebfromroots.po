#: ../../../reference/generated/numpy.polynomial.chebyshev.chebfromroots.rst:4
msgid "numpy.polynomial.chebyshev.chebfromroots"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/chebyshev.py:docstring
#: of numpy.polynomial.chebyshev.chebfromroots:2
msgid "Generate a Chebyshev series with given roots."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/chebyshev.py:docstring
#: of numpy.polynomial.chebyshev.chebfromroots:4
msgid "The function returns the coefficients of the polynomial"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/chebyshev.py:docstring
#: of numpy.polynomial.chebyshev.chebfromroots:6
msgid ""
"p(x) = (x - r_0) * (x - r_1) * ... * (x - r_n),\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/chebyshev.py:docstring
#: of numpy.polynomial.chebyshev.chebfromroots:8
msgid ""
"in Chebyshev form, where the :math:`r_n` are the roots specified in "
"`roots`.  If a zero has multiplicity n, then it must appear in `roots` n "
"times.  For instance, if 2 is a root of multiplicity three and 3 is a root "
"of multiplicity 2, then `roots` looks something like [2, 2, 2, 3, 3]. The "
"roots can appear in any order."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/chebyshev.py:docstring
#: of numpy.polynomial.chebyshev.chebfromroots:14
msgid "If the returned coefficients are `c`, then"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/chebyshev.py:docstring
#: of numpy.polynomial.chebyshev.chebfromroots:16
msgid ""
"p(x) = c_0 + c_1 * T_1(x) + ... +  c_n * T_n(x)\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/chebyshev.py:docstring
#: of numpy.polynomial.chebyshev.chebfromroots:18
msgid ""
"The coefficient of the last term is not generally 1 for monic polynomials in "
"Chebyshev form."
msgstr ""

