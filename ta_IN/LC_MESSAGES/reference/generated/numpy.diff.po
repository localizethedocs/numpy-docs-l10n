#: ../../../reference/generated/numpy.diff.rst:4
msgid "numpy.diff"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.diff:2
msgid "Calculate the n-th discrete difference along the given axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.diff:4
msgid ""
"The first difference is given by ``out[i] = a[i+1] - a[i]`` along the given "
"axis, higher differences are calculated by using `diff` recursively."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.diff:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.diff:11
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.diff:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.diff:11
msgid "Input array"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.diff:15
msgid "**n**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.diff:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.diff:14
msgid ""
"The number of times values are differenced. If zero, the input is returned "
"as-is."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.diff:19
msgid "**axis**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.diff:18
msgid "The axis along which the difference is taken, default is the last axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.diff:28
msgid "**prepend, append**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.diff:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.diff:22
msgid ""
"Values to prepend or append to `a` along axis prior to performing the "
"difference.  Scalar values are expanded to arrays with length 1 in the "
"direction of axis and the shape of the input array in along all other axes.  "
"Otherwise the dimension and shape must match `a` except along axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.diff:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.diff:44
msgid "**diff**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.diff:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.diff:33
msgid ""
"The n-th differences. The shape of the output is the same as `a` except "
"along `axis` where the dimension is smaller by `n`. The type of the output "
"is the same as the type of the difference between any two elements of `a`. "
"This is the same as the type of `a` in most cases. A notable exception is "
"`datetime64`, which results in a `timedelta64` output array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.diff:49
msgid ":obj:`gradient`, :obj:`ediff1d`, :obj:`cumsum`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.diff:53
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.diff:54
msgid ""
"Type is preserved for boolean arrays, so the result will contain `False` "
"when consecutive elements are the same and `True` when they differ."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.diff:58
msgid ""
"For unsigned integer arrays, the results will also be unsigned. This should "
"not be surprising, as the result is consistent with calculating the "
"difference directly:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.diff:68
msgid ""
"If this is not desirable, then the array should be cast to a larger integer "
"type first:"
msgstr ""

