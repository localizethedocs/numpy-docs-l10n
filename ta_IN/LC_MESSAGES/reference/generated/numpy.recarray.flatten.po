#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.flatten:8
msgid ""
"'C' means to flatten in row-major (C-style) order. 'F' means to flatten in "
"column-major (Fortran- style) order. 'A' means to flatten in column-major "
"order if `a` is Fortran *contiguous* in memory, row-major order otherwise. "
"'K' means to flatten `a` in the order the elements occur in memory. The "
"default is 'C'."
msgstr ""

