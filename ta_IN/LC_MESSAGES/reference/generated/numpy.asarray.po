#: of numpy.asarray:16
msgid ""
"Memory layout.  'A' and 'K' depend on the order of input array a. 'C' row-"
"major (C-style), 'F' column-major (Fortran-style) memory representation. "
"'A' (any) means 'F' if `a` is Fortran contiguous, 'C' otherwise 'K' (keep) "
"preserve input order Defaults to 'K'."
msgstr ""

