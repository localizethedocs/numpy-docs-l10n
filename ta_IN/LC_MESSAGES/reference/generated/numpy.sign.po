#: ../../../reference/generated/numpy.sign.rst:4
msgid "numpy.sign"
msgstr ""

#: ../../../../docstring of numpy.sign:2
msgid "Returns an element-wise indication of the sign of a number."
msgstr ""

#: ../../../../docstring of numpy.sign:4
msgid ""
"The `sign` function returns ``-1 if x < 0, 0 if x==0, 1 if x > 0``.  nan is "
"returned for nan inputs."
msgstr ""

#: ../../../../docstring of numpy.sign:7
msgid ""
"For complex inputs, the `sign` function returns ``sign(x.real) + 0j if x."
"real != 0 else sign(x.imag) + 0j``."
msgstr ""

#: ../../../../docstring of numpy.sign:10
msgid "complex(nan, 0) is returned for complex nan inputs."
msgstr ""

