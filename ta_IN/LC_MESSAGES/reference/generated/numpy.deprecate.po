#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/utils.py:docstring
#: of numpy.lib.utils.deprecate:2
msgid ""
"Issues a DeprecationWarning, adds warning to `old_name`'s docstring, rebinds "
"``old_name.__name__`` and returns the new function object."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/utils.py:docstring
#: of numpy.lib.utils.deprecate:6
msgid "This function may also be used as a decorator."
