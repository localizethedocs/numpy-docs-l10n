#: ../../../reference/generated/numpy.vectorize.rst:2
msgid "numpy.vectorize"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:2
msgid "Returns an object that acts like pyfunc, but takes arrays as input."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:4
msgid ""
"Define a vectorized function which takes a nested sequence of objects or "
"numpy arrays as inputs and returns a single numpy array or a tuple of numpy "
"arrays. The vectorized function evaluates `pyfunc` over successive tuples of "
"the input arrays like the python map function, except it uses the "
"broadcasting rules of numpy."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:10
msgid ""
"The data type of the output of `vectorized` is determined by calling the "
"function with the first element of the input.  This can be avoided by "
"specifying the `otypes` argument."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:18
msgid "**pyfunc**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:-1
msgid "callable, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:17
msgid ""
"A python function or method. Can be omitted to produce a decorator with "
"keyword arguments."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:23
msgid "**otypes**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:-1
msgid "str or list of dtypes, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:21
msgid ""
"The output data type. It must be specified as either a string of typecode "
"characters or a list of data type specifiers. There should be one data type "
"specifier for each output."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:27
msgid "**doc**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:-1
msgid "str, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:26
msgid ""
"The docstring for the function. If None, the docstring will be the ``pyfunc."
"__doc__``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:34
msgid "**excluded**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:-1
msgid "set, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:30
msgid ""
"Set of strings or integers representing the positional or keyword arguments "
"for which the function will not be vectorized.  These will be passed "
"directly to `pyfunc` unmodified."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:40
msgid "**cache**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:37
msgid ""
"If `True`, then cache the first function call that determines the number of "
"outputs if `otypes` is not provided."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:49
msgid "**signature**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:-1
msgid "string, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:43
msgid ""
"Generalized universal function signature, e.g., ``(m,n),(n)->(m)`` for "
"vectorized matrix-vector multiplication. If provided, ``pyfunc`` will be "
"called with (and expected to return) arrays with shapes given by the size of "
"corresponding core dimensions. By default, ``pyfunc`` is assumed to take "
"scalars as input and output."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:61
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:-1
msgid "callable"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:54
msgid ""
"A vectorized function if ``pyfunc`` was provided, a decorator otherwise."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:66
msgid ":obj:`frompyfunc`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:67
msgid "Takes an arbitrary Python function and returns a ufunc"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:71
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:72
msgid ""
"The `vectorize` function is provided primarily for convenience, not for "
"performance. The implementation is essentially a for loop."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:75
msgid ""
"If `otypes` is not specified, then a call to the function with the first "
"argument will be used to determine the number of outputs.  The results of "
"this call will be cached if `cache` is `True` to prevent calling the "
"function twice.  However, to implement the cache, the original function must "
"be wrapped which will slow down subsequent calls, so only do this if your "
"function is expensive."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.vectorize:82
msgid ""
"The new keyword argument interface and `excluded` argument support further "
"degrades performance."
msgstr ""

