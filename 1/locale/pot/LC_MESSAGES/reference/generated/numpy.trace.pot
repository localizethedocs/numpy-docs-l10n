msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.trace:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.trace:40
msgid ""
"If `a` is 2-D, the sum along the diagonal is returned.  If `a` has larger "
"dimensions, then an array of sums along diagonals is returned."
msgstr ""

