#: ../../../reference/generated/numpy.linalg.cholesky.rst:4
msgid "numpy.linalg.cholesky"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.cholesky:2
msgid "Cholesky decomposition."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.cholesky:4
msgid ""
"Return the Cholesky decomposition, `L * L.H`, of the square matrix `a`, "
"where `L` is lower-triangular and .H is the conjugate transpose operator "
"(which is the ordinary transpose if `a` is real-valued).  `a` must be "
"Hermitian (symmetric if real-valued) and positive-definite. No checking is "
"performed to verify whether `a` is Hermitian or not. In addition, only the "
"lower-triangular and diagonal elements of `a` are used. Only `L` is actually "
"returned."
msgstr ""

