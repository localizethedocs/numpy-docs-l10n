#: ../../../reference/generated/numpy.ma.empty.rst:4
msgid "numpy.ma.empty"
msgstr ""

#: ../../../../docstring of numpy.ma.empty:2
msgid ""
"Return a new array of given shape and type, without initializing entries."
msgstr ""

#: ../../../../docstring of numpy.ma.empty:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.ma.empty:8
msgid "**shape**"
msgstr ""

#: ../../../../docstring of numpy.ma.empty:-1
msgid "int or tuple of int"
msgstr ""

#: ../../../../docstring of numpy.ma.empty:8
msgid "Shape of the empty array, e.g., ``(2, 3)`` or ``2``."
msgstr ""

#: ../../../../docstring of numpy.ma.empty:12
msgid "**dtype**"
msgstr ""

#: ../../../../docstring of numpy.ma.empty:-1
msgid "data-type, optional"
msgstr ""

#: ../../../../docstring of numpy.ma.empty:11
msgid ""
"Desired output data-type for the array, e.g, `numpy.int8`. Default is `numpy."
"float64`."
msgstr ""

#: ../../../../docstring of numpy.ma.empty:17
msgid "**order**"
msgstr ""

#: ../../../../docstring of numpy.ma.empty:-1
msgid "{'C', 'F'}, optional, default: 'C'"
msgstr ""

#: ../../../../docstring of numpy.ma.empty:15
msgid ""
"Whether to store multi-dimensional data in row-major (C-style) or column-"
"major (Fortran-style) order in memory."
msgstr ""

#: ../../../../docstring of numpy.ma.empty:26
msgid "**like**"
msgstr ""

#: ../../../../docstring of numpy.ma.empty:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../docstring of numpy.ma.empty:20
msgid ""
"Reference object to allow the creation of arrays which are not NumPy arrays. "
"If an array-like passed in as ``like`` supports the ``__array_function__`` "
"protocol, the result will be defined by it. In this case, it ensures the "
"creation of an array object compatible with that passed in via this argument."
msgstr ""

#: ../../../../docstring of numpy.ma.empty:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.ma.empty:38
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.ma.empty:-1
msgid "MaskedArray"
msgstr ""

#: ../../../../docstring of numpy.ma.empty:31
msgid ""
"Array of uninitialized (arbitrary) data of the given shape, dtype, and "
"order.  Object arrays will be initialized to None."
msgstr ""

#: ../../../../docstring of numpy.ma.empty:43
msgid ":obj:`empty_like`"
msgstr ""

#: ../../../../docstring of numpy.ma.empty:44
msgid "Return an empty array with shape and type of input."
msgstr ""

#: ../../../../docstring of numpy.ma.empty:45
msgid ":obj:`ones`"
msgstr ""

#: ../../../../docstring of numpy.ma.empty:46
msgid "Return a new array setting values to one."
msgstr ""

#: ../../../../docstring of numpy.ma.empty:47
msgid ":obj:`zeros`"
msgstr ""

#: ../../../../docstring of numpy.ma.empty:48
msgid "Return a new array setting values to zero."
msgstr ""

#: ../../../../docstring of numpy.ma.empty:49
msgid ":obj:`full`"
msgstr ""

#: ../../../../docstring of numpy.ma.empty:50
msgid "Return a new array of given shape filled with value."
msgstr ""

#: ../../../../docstring of numpy.ma.empty:54
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.ma.empty:55
msgid ""
"`empty`, unlike `zeros`, does not set the array values to zero, and may "
"therefore be marginally faster.  On the other hand, it requires the user to "
"manually set all the values in the array, and should be used with caution."
msgstr ""

