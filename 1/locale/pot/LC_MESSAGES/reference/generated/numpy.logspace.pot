#: ../../../reference/generated/numpy.logspace.rst:4
msgid "numpy.logspace"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:2
msgid "Return numbers spaced evenly on a log scale."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:4
msgid ""
"In linear space, the sequence starts at ``base ** start`` (`base` to the "
"power of `start`) and ends with ``base ** stop`` (see `endpoint` below)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:8
msgid "Non-scalar `start` and `stop` are now supported."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:11
msgid "Non-scalar 'base` is now supported"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:17
msgid "**start**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:17
msgid "``base ** start`` is the starting value of the sequence."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:23
msgid "**stop**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:20
msgid ""
"``base ** stop`` is the final value of the sequence, unless `endpoint` is "
"False.  In that case, ``num + 1`` values are spaced over the interval in log-"
"space, of which all but the last (a sequence of length `num`) are returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:26
msgid "**num**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:-1
msgid "integer, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:26
msgid "Number of samples to generate.  Default is 50."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:30
msgid "**endpoint**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:-1
msgid "boolean, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:29
msgid ""
"If true, `stop` is the last sample. Otherwise, it is not included. Default "
"is True."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:35
msgid "**base**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:33
msgid ""
"The base of the log space. The step size between the elements in "
"``ln(samples) / ln(base)`` (or ``log_base(samples)``) is uniform. Default is "
"10.0."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:41
msgid "**dtype**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:-1
msgid "dtype"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:38
msgid ""
"The type of the output array.  If `dtype` is not given, the data type is "
"inferred from `start` and `stop`. The inferred type will never be an "
"integer; `float` is chosen even if the arguments would produce an array of "
"integers."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:49
msgid "**axis**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:44
msgid ""
"The axis in the result to store the samples.  Relevant only if start, stop, "
"or base are array-like.  By default (0), the samples will be along a new "
"axis inserted at the beginning. Use -1 to get an axis at the end."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:60
msgid "**samples**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:54
msgid "`num` samples, equally spaced on a log scale."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:65
msgid ":obj:`arange`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:66
msgid ""
"Similar to linspace, with the step size specified instead of the number of "
"samples. Note that, when used with a float endpoint, the endpoint may or may "
"not be included."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:67
msgid ":obj:`linspace`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:68
msgid ""
"Similar to logspace, but with the samples uniformly distributed in linear "
"space, instead of log space."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:69
msgid ":obj:`geomspace`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.logspace:70
msgid "Similar to logspace, but with endpoints specified directly."
msgstr ""

