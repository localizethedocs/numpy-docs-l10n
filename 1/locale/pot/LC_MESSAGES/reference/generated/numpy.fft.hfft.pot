#: of numpy.fft.hfft:12
msgid ""
"Length of the transformed axis of the output. For `n` output points, ``n//2 "
"+ 1`` input points are necessary.  If the input is longer than this, it is "
"cropped.  If it is shorter than this, it is padded with zeros.  If `n` is "
"not given, it is taken to be ``2*(m-1)`` where ``m`` is the length of the "
"input along the axis specified by `axis`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.hfft:21
