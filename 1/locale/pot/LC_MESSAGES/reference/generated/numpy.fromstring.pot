#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.fromstring:24
msgid ""
"The string separating numbers in the data; extra whitespace between elements "
"is also ignored."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.fromstring:27
msgid ""
"Passing ``sep=''``, the default, is deprecated since it will trigger the "
"deprecated binary mode of this function. This mode interprets `string` as "
"binary bytes, rather than ASCII text with decimal numbers, an operation "
"which is better spelt ``frombuffer(string, dtype, count)``. If `string` "
"contains unicode text, the binary mode of `fromstring` will first encode it "
"into bytes using utf-8, which will not produce sane results."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.fromstring:43
