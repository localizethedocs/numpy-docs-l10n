#: ../../../reference/generated/numpy.fromfile.rst:4
msgid "numpy.fromfile"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.fromfile:2
msgid "Construct an array from data in a text or binary file."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.fromfile:4
msgid ""
"A highly efficient way of reading binary data with a known data-type, as "
"well as parsing simply formatted text files.  Data written using the "
"`tofile` method can be read using this function."
msgstr ""

