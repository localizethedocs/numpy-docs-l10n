#: ../../../reference/generated/numpy.corrcoef.rst:4
msgid "numpy.corrcoef"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.corrcoef:2
msgid "Return Pearson product-moment correlation coefficients."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.corrcoef:4
msgid ""
"Please refer to the documentation for `cov` for more detail.  The "
"relationship between the correlation coefficient matrix, `R`, and the "
"covariance matrix, `C`, is"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.corrcoef:8
msgid ""
"R_{ij} = \\frac{ C_{ij} } { \\sqrt{ C_{ii} C_{jj} } }\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.corrcoef:10
msgid "The values of `R` are between -1 and 1, inclusive."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.corrcoef:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.corrcoef:17
msgid "**x**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.corrcoef:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.corrcoef:15
msgid ""
"A 1-D or 2-D array containing multiple variables and observations. Each row "
"of `x` represents a variable, and each column a single observation of all "
"those variables. Also see `rowvar` below."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.corrcoef:21
msgid "**y**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.corrcoef:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.corrcoef:20
msgid ""
"An additional set of variables and observations. `y` has the same shape as "
"`x`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.corrcoef:27
msgid "**rowvar**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.corrcoef:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.corrcoef:24
msgid ""
"If `rowvar` is True (default), then each row represents a variable, with "
"observations in the columns. Otherwise, the relationship is transposed: each "
"column represents a variable, while the rows contain observations."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.corrcoef:32
msgid "**bias**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
