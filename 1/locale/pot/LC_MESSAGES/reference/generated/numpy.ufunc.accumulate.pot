#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.accumulate:2
msgid "Accumulate the result of applying the operator to all elements."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.accumulate:4
msgid ""
"For a one-dimensional array, accumulate produces results equivalent to::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.accumulate:6
msgid ""
"r = np.empty(len(A))\n"
"t = op.identity        # op = the ufunc being applied to A's  elements\n"
"for i in range(len(A)):\n"
"    t = op(t, A[i])\n"
"    r[i] = t\n"
"return r"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.accumulate:13
msgid "For example, add.accumulate() is equivalent to np.cumsum()."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.accumulate:15
msgid ""
"For a multi-dimensional array, accumulate is applied along only one axis "
"(axis zero by default; see Examples below) so repeated use is necessary if "
"one wants to accumulate over multiple axes."
msgstr ""

