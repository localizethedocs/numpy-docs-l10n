#: ../../../reference/generated/numpy.fill_diagonal.rst:4
msgid "numpy.fill\\_diagonal"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.fill_diagonal:2
msgid "Fill the main diagonal of the given array of any dimensionality."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.fill_diagonal:4
msgid ""
"For an array `a` with ``a.ndim >= 2``, the diagonal is the list of locations "
"with indices ``a[i, ..., i]`` all identical. This function modifies the "
"input array in-place, it does not return a value."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.fill_diagonal:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.fill_diagonal:11
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.fill_diagonal:-1
msgid "array, at least 2-D."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.fill_diagonal:11
msgid "Array whose diagonal is to be filled, it gets modified in-place."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.fill_diagonal:17
msgid "**val**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.fill_diagonal:-1
msgid "scalar or array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.fill_diagonal:14
msgid ""
"Value(s) to write on the diagonal. If `val` is scalar, the value is written "
"along the diagonal. If array-like, the flattened `val` is written along the "
"diagonal, repeating if necessary to fill all diagonal entries."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.fill_diagonal:29
msgid "**wrap**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.fill_diagonal:-1
msgid "bool"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.fill_diagonal:20
msgid ""
"For tall matrices in NumPy version up to 1.6.2, the diagonal \"wrapped\" "
"after N columns. You can have this behavior with this option. This affects "
"only tall matrices."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.fill_diagonal:34
msgid ":obj:`diag_indices`, :obj:`diag_indices_from`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.fill_diagonal:38
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.fill_diagonal:41
msgid ""
"This functionality can be obtained via `diag_indices`, but internally this "
"version uses a much faster implementation that never constructs the indices "
"and uses simple slicing."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.fill_diagonal:47
msgid "Examples"
msgstr ""

