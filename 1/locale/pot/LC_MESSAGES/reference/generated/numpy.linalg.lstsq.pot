#: ../../../reference/generated/numpy.linalg.lstsq.rst:4
msgid "numpy.linalg.lstsq"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.lstsq:2
msgid "Return the least-squares solution to a linear matrix equation."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.lstsq:4
msgid ""
"Computes the vector `x` that approximately solves the equation ``a @ x = "
"b``. The equation may be under-, well-, or over-determined (i.e., the number "
"of linearly independent rows of `a` can be less than, equal to, or greater "
"than its number of linearly independent columns). If `a` is square and of "
"full rank, then `x` (but for round-off error) is the \"exact\" solution of "
"the equation. Else, `x` minimizes the Euclidean 2-norm :math:`||b - ax||`. "
"If there are multiple minimizing solutions, the one with the smallest 2-"
"norm :math:`||x||` is returned."
msgstr ""

