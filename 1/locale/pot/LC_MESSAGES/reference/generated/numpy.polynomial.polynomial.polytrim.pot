msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/polyutils.py:docstring
#: of numpy.polynomial.polyutils.trimcoef:2
msgid "Remove \"small\" \"trailing\" coefficients from a polynomial."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/polyutils.py:docstring
#: of numpy.polynomial.polyutils.trimcoef:4
msgid ""
"\"Small\" means \"small in absolute value\" and is controlled by the "
"parameter `tol`; \"trailing\" means highest order coefficient(s), e.g., in "
"``[0, 1, 1, 0, 0]`` (which represents ``0 + x + x**2 + 0*x**3 + 0*x**4``) "
"both the 3-rd and 4-th order coefficients would be \"trimmed.\""
msgstr ""

