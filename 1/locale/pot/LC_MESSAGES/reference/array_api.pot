msgid "The ``mT`` attribute for matrix transpose."
msgstr ""

#: ../../../reference/array_api.rst:568
msgid ""
"See `the spec definition <https://data-apis.org/array-api/latest/"
"API_specification/generated/signatures.array_object.array.mT.html>`__ for "
"``mT``."
msgstr ""

