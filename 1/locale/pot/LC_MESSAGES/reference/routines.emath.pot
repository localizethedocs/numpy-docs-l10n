msgid ":py:obj:`log10 <numpy.emath.log10>`\\ \\(x\\)"
msgstr ""

#: ../../../../docstring of numpy.emath:30:<autosummary>:1
msgid "Compute the logarithm base 10 of `x`."
msgstr ""

