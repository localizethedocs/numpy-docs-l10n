#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:2
msgid "Save several arrays into a single file in compressed ``.npz`` format."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:4
msgid ""
"Provide arrays as keyword arguments to store them under the corresponding "
"name in the output file: ``savez(fn, x=x, y=y)``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:7
msgid ""
"If arrays are specified as positional arguments, i.e., ``savez(fn, x, y)``, "
"their names will be `arr_0`, `arr_1`, etc."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:16
msgid "**file**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:-1
msgid "str or file"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:13
msgid ""
"Either the filename (string) or an open file (file-like object) where the "
"data will be saved. If file is a string or a Path, the ``.npz`` extension "
"will be appended to the filename if it is not already there."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:21
