#: ../../../reference/generated/numpy.ma.empty_like.rst:4
msgid "numpy.ma.empty\\_like"
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:2
msgid "Return a new array with the same shape and type as a given array."
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:9
msgid "**prototype**"
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:-1
msgid "array_like"
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:8
msgid ""
"The shape and data-type of `prototype` define these same attributes of the "
"returned array."
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:14
msgid "**dtype**"
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:-1
msgid "data-type, optional"
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:12
msgid "Overrides the data type of the result."
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:22
msgid "**order**"
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:-1
msgid "{'C', 'F', 'A', or 'K'}, optional"
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:17
msgid ""
"Overrides the memory layout of the result. 'C' means C-order, 'F' means F-"
"order, 'A' means 'F' if `prototype` is Fortran contiguous, 'C' otherwise. "
"'K' means match the layout of `prototype` as closely as possible."
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:27
msgid "**subok**"
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:-1
msgid "bool, optional."
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:25
msgid ""
"If True, then the newly created array will use the sub-class type of "
"`prototype`, otherwise it will be a base-class array. Defaults to True."
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:34
msgid "**shape**"
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:-1
msgid "int or sequence of ints, optional."
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:30
msgid ""
"Overrides the shape of the result. If order='K' and the number of dimensions "
"is unchanged, will try to keep order, otherwise, order='C' is implied."
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:46
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:-1
msgid "MaskedArray"
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:39
msgid ""
"Array of uninitialized (arbitrary) data with the same shape and type as "
"`prototype`."
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:51
msgid ":obj:`ones_like`"
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:52
msgid "Return an array of ones with shape and type of input."
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:53
msgid ":obj:`zeros_like`"
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:54
msgid "Return an array of zeros with shape and type of input."
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:55
msgid ":obj:`full_like`"
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:56
msgid "Return a new array with shape of input filled with value."
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:57
msgid ":obj:`empty`"
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:58
msgid "Return a new uninitialized array."
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:62
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.ma.empty_like:63
msgid ""
"This function does *not* initialize the returned array; to do that use "
"`zeros_like` or `ones_like` instead.  It may be marginally faster than the "
"functions that do set the array values."
msgstr ""

