#: of numpy.select:2
msgid ""
"Return an array drawn from elements in choicelist, depending on conditions."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.select:0
msgid "Parameters"
msgstr ""

