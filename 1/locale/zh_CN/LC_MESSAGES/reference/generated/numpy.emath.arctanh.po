#: ../../../reference/generated/numpy.emath.arctanh.rst:4
msgid "numpy.emath.arctanh"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arctanh:2
msgid "Compute the inverse hyperbolic tangent of `x`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arctanh:4
msgid ""
"Return the \"principal value\" (for a description of this, see `numpy."
"arctanh`) of ``arctanh(x)``. For real `x` such that ``abs(x) < 1``, this is "
"a real number.  If `abs(x) > 1`, or if `x` is complex, the result is "
"complex. Finally, `x = 1` returns``inf`` and ``x=-1`` returns ``-inf``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arctanh:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arctanh:13
msgid "**x**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arctanh:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arctanh:13
msgid "The value(s) whose arctanh is (are) required."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arctanh:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/scimath.py:docstring
