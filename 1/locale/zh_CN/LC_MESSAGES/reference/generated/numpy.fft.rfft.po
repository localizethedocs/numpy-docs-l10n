#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfft:68
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfft:69
msgid ""
"When the DFT is computed for purely real input, the output is Hermitian-"
"symmetric, i.e. the negative frequency terms are just the complex conjugates "
"of the corresponding positive-frequency terms, and the negative-frequency "
"terms are therefore redundant.  This function does not compute the negative "
"frequency terms, and the length of the transformed axis of the output is "
"therefore ``n//2 + 1``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfft:76
msgid ""
"When ``A = rfft(a)`` and fs is the sampling frequency, ``A[0]`` contains the "
"zero-frequency term 0*fs, which is real due to Hermitian symmetry."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfft:79
msgid ""
"If `n` is even, ``A[-1]`` contains the term representing both positive and "
"negative Nyquist frequency (+fs/2 and -fs/2), and must also be purely real. "
"If `n` is odd, there is no term at fs/2; ``A[-1]`` contains the largest "
"positive frequency (fs/2*(n-1)/n), and is complex in the general case."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfft:85
msgid "If the input `a` contains an imaginary part, it is silently discarded."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfft:89
msgid "Examples"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfft:95
msgid ""
"Notice how the final element of the `fft` output is the complex conjugate of "
"the second element, for real input. For `rfft`, this symmetry is exploited "
"to compute only the non-negative frequency terms."
msgstr ""
