#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:2
msgid ""
"Create a sliding window view into the array with the given window shape."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:4
msgid ""
"Also known as rolling or moving window, the window slides across all "
"dimensions of the array and extracts subsets of the array at all window "
"positions."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:13
msgid "**x**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:13
msgid "Array to create the sliding window view from."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:19
msgid "**window_shape**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:-1
msgid "int or tuple of int"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:16
msgid ""
"Size of window over each axis that takes part in the sliding window. If "
"`axis` is not present, must have same length as the number of input array "
"dimensions. Single integers `i` are treated as if they were the tuple `(i,)`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:27
msgid "**axis**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:-1
msgid "int or tuple of int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:22
msgid ""
"Axis or axes along which the sliding window is applied. By default, the "
"sliding window is applied to all axes and `window_shape[i]` will refer to "
"axis `i` of `x`. If `axis` is given as a `tuple of int`, `window_shape[i]` "
"will refer to the axis `axis[i]` of `x`. Single integers `i` are treated as "
"if they were the tuple `(i,)`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:31
msgid "**subok**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:30
msgid ""
"If True, sub-classes will be passed-through, otherwise the returned array "
"will be forced to be a base-class array (default)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:37
msgid "**writeable**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:34
msgid ""
"When true, allow writing to the returned view. The default is false, as this "
"should be used with caution: the returned view contains the same memory "
"location multiple times, so writing to one location will cause others to "
"change."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:53
msgid "**view**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:42
msgid ""
"Sliding window view of the array. The sliding window dimensions are inserted "
"at the end, and the original dimensions are trimmed as required by the size "
"of the sliding window. That is, ``view.shape = x_shape_trimmed + "
"window_shape``, where ``x_shape_trimmed`` is ``x.shape`` with every entry "
"reduced by one less than the corresponding window size."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:58
msgid ":obj:`lib.stride_tricks.as_strided`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:59
msgid ""
"A lower-level and less safe routine for creating arbitrary views from custom "
"shape and strides."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:60
msgid ":obj:`broadcast_to`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:61
msgid "broadcast an array to a given shape."
msgstr ""

