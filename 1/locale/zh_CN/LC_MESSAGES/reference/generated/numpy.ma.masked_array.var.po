#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:2
msgid "Compute the variance along the specified axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:4
msgid ""
"Returns the variance of the array elements, a measure of the spread of a "
"distribution.  The variance is computed for the flattened array by default, "
"otherwise over the specified axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:12
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:11
msgid ""
"Array containing numbers whose variance is desired.  If `a` is not an array, "
"a conversion is attempted."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:21
msgid "**axis**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:-1
msgid "None or int or tuple of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:15
msgid ""
"Axis or axes along which the variance is computed.  The default is to "
"compute the variance of the flattened array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:20
msgid ""
"If this is a tuple of ints, a variance is performed over multiple axes, "
"instead of a single axis or all the axes as before."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:26
msgid "**dtype**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:-1
msgid "data-type, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:24
msgid ""
"Type to use in computing the variance.  For arrays of integer type the "
"default is `float64`; for arrays of float types it is the same as the array "
"type."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:31
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:-1
msgid "ndarray, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:29
msgid ""
"Alternate output array in which to place the result.  It must have the same "
"shape as the expected output, but the type is cast if necessary."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:36
msgid "**ddof**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:34
msgid ""
"\"Delta Degrees of Freedom\": the divisor used in the calculation is ``N - "
"ddof``, where ``N`` represents the number of elements. By default `ddof` is "
"zero."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:47
msgid "**keepdims**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:39
msgid ""
"If this is set to True, the axes which are reduced are left in the result as "
"dimensions with size one. With this option, the result will broadcast "
"correctly against the input array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:43
msgid ""
"If the default value is passed, then `keepdims` will not be passed through "
"to the `var` method of sub-classes of `ndarray`, however any non-default "
"value will be.  If the sub-class' method does not implement `keepdims` any "
"exceptions will be raised."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:53
msgid "**where**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:-1
msgid "array_like of bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:50
msgid ""
"Elements to include in the variance. See `~numpy.ufunc.reduce` for details."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:65
msgid "**variance**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:-1
msgid "ndarray, see dtype parameter above"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:58
msgid ""
"If ``out=None``, returns a new array containing the variance; otherwise, a "
"reference to the output array is returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:70
msgid ":obj:`std`, :obj:`mean`, :obj:`nanmean`, :obj:`nanstd`, :obj:`nanvar`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:72
msgid ":ref:`ufuncs-output-type`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:76
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:77
msgid ""
"The variance is the average of the squared deviations from the mean, i.e.,  "
"``var = mean(x)``, where ``x = abs(a - a.mean())**2``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:80
msgid ""
"The mean is typically calculated as ``x.sum() / N``, where ``N = len(x)``. "
"If, however, `ddof` is specified, the divisor ``N - ddof`` is used instead.  "
"In standard statistical practice, ``ddof=1`` provides an unbiased estimator "
"of the variance of a hypothetical infinite population. ``ddof=0`` provides a "
"maximum likelihood estimate of the variance for normally distributed "
"variables."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:87
msgid ""
"Note that for complex numbers, the absolute value is taken before squaring, "
"so that the result is always real and nonnegative."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:90
msgid ""
"For floating-point input, the variance is computed using the same precision "
"the input has.  Depending on the input data, this can cause the results to "
"be inaccurate, especially for `float32` (see example below).  Specifying a "
"higher-accuracy accumulator using the ``dtype`` keyword can alleviate this "
"issue."
msgstr ""

