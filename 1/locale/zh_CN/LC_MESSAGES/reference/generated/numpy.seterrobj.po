#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.seterrobj:2
msgid "Set the object that defines floating-point error handling."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.seterrobj:4
msgid ""
"The error object contains all information that defines the error handling "
"behavior in NumPy. `seterrobj` is used internally by the other functions "
"that set error handling behavior (`seterr`, `seterrcall`)."
msgstr ""

