#: ../../../release/1.23.4-notes.rst:5
msgid "NumPy 1.23.4 Release Notes"
msgstr ""

#: ../../../release/1.23.4-notes.rst:6
msgid ""
"NumPy 1.23.4 is a maintenance release that fixes bugs discovered after the "
"1.23.3 release and keeps the build infrastructure current. The main "
"improvements are fixes for some annotation corner cases, a fix for a long "
"time ``nested_iters`` memory leak, and a fix of complex vector dot for very "
"large arrays. The Python versions supported for this release are 3.8-3.11."
msgstr ""

#: ../../../release/1.23.4-notes.rst:12
msgid ""
"Note that the mypy version needs to be 0.981+ if you test using Python "
"3.10.7, otherwise the typing tests will fail."
msgstr ""

