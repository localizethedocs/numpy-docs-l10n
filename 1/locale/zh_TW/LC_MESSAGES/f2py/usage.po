#: ../../../f2py/usage.rst:343
msgid "Automatic extension module generation"
msgstr ""

#: ../../../f2py/usage.rst:345
msgid ""
"If you want to distribute your f2py extension module, then you only need to "
"include the .pyf file and the Fortran code. The distutils extensions in "
"NumPy allow you to define an extension module entirely in terms of this "
"interface file. A valid ``setup.py`` file allowing distribution of the ``add."
"f`` module (as part of the package ``f2py_examples`` so that it would be "
"loaded as ``f2py_examples.add``) is:"
msgstr ""

#: ../../../f2py/usage.rst:352
msgid ""
"def configuration(parent_package='', top_path=None)\n"
"    from numpy.distutils.misc_util import Configuration\n"
"    config = Configuration('f2py_examples',parent_package, top_path)\n"
"    config.add_extension('add', sources=['add.pyf','add.f'])\n"
"    return config\n"
"\n"
"if __name__ == '__main__':\n"
"    from numpy.distutils.core import setup\n"
"    setup(**configuration(top_path='').todict())"
msgstr ""

#: ../../../f2py/usage.rst:364
msgid "Installation of the new package is easy using::"
msgstr ""

#: ../../../f2py/usage.rst:366
msgid "pip install ."
msgstr ""

#: ../../../f2py/usage.rst:368
msgid ""
"assuming you have the proper permissions to write to the main site- packages "
"directory for the version of Python you are using. For the resulting package "
"to work, you need to create a file named ``__init__.py`` (in the same "
"directory as ``add.pyf``). Notice the extension module is defined entirely "
"in terms of the ``add.pyf`` and ``add.f`` files. The conversion of the .pyf "
"file to a .c file is handled by `numpy.distutils`."
msgstr ""
