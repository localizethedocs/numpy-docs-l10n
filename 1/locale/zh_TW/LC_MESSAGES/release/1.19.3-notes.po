#: ../../../release/1.19.3-notes.rst:5
msgid "NumPy 1.19.3 Release Notes"
msgstr "NumPy 1.19.3 發行備註"

#: ../../../release/1.19.3-notes.rst:7
msgid ""
"NumPy 1.19.3 is a small maintenance release with two major improvements:"
msgstr ""

#: ../../../release/1.19.3-notes.rst:9
msgid "Python 3.9 binary wheels on all supported platforms."
msgstr ""

#: ../../../release/1.19.3-notes.rst:10
msgid "OpenBLAS fixes for Windows 10 version 2004 fmod bug."
msgstr ""

#: ../../../release/1.19.3-notes.rst:12
msgid ""
"This release supports Python 3.6-3.9 and is linked with OpenBLAS 0.3.12 to "
"avoid some of the fmod problems on Windows 10 version 2004. Microsoft is "
"aware of the problem and users should upgrade when the fix becomes "
"available, the fix here is limited in scope."
msgstr ""

