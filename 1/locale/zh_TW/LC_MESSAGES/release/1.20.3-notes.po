#: ../../../release/1.20.3-notes.rst:29
msgid ""
"`#18763 <https://github.com/numpy/numpy/pull/18763>`__: BUG: Correct "
"``datetime64`` missing type overload for ``datetime.date``..."
msgstr ""

#: ../../../release/1.20.3-notes.rst:30
msgid ""
"`#18764 <https://github.com/numpy/numpy/pull/18764>`__: MAINT: Remove "
"``__all__`` in favor of explicit re-exports"
msgstr ""

#: ../../../release/1.20.3-notes.rst:31
msgid ""
"`#18768 <https://github.com/numpy/numpy/pull/18768>`__: BLD: Strip extra "
"newline when dumping gfortran version on MacOS"
msgstr ""

#: ../../../release/1.20.3-notes.rst:32
msgid ""
"`#18769 <https://github.com/numpy/numpy/pull/18769>`__: BUG: fix segfault in "
"object/longdouble operations"
msgstr ""

#: ../../../release/1.20.3-notes.rst:33
msgid ""
"`#18794 <https://github.com/numpy/numpy/pull/18794>`__: MAINT: Use towncrier "
"build explicitly"
msgstr ""

#: ../../../release/1.20.3-notes.rst:34
msgid ""
"`#18887 <https://github.com/numpy/numpy/pull/18887>`__: MAINT: Relax certain "
"integer-type constraints"
msgstr ""

#: ../../../release/1.20.3-notes.rst:35
msgid ""
"`#18915 <https://github.com/numpy/numpy/pull/18915>`__: MAINT: Remove unsafe "
"unions and ABCs from return-annotations"
msgstr ""

#: ../../../release/1.20.3-notes.rst:36
msgid ""
"`#18921 <https://github.com/numpy/numpy/pull/18921>`__: MAINT: Allow more "
"recursion depth for scalar tests."
msgstr ""

#: ../../../release/1.20.3-notes.rst:37
msgid ""
"`#18922 <https://github.com/numpy/numpy/pull/18922>`__: BUG: Initialize the "
"full nditer buffer in case of error"
msgstr ""

#: ../../../release/1.20.3-notes.rst:38
msgid ""
"`#18923 <https://github.com/numpy/numpy/pull/18923>`__: BLD: remove "
"unnecessary flag ``-faltivec`` on macOS"
msgstr ""

#: ../../../release/1.20.3-notes.rst:39
msgid ""
"`#18924 <https://github.com/numpy/numpy/pull/18924>`__: MAINT, CI: treats "
"_SIMD module build warnings as errors through..."
msgstr ""

#: ../../../release/1.20.3-notes.rst:40
msgid ""
"`#18925 <https://github.com/numpy/numpy/pull/18925>`__: BUG: for MINGW, "
"threads.h existence test requires GLIBC > 2.12"
msgstr ""

#: ../../../release/1.20.3-notes.rst:41
msgid ""
"`#18941 <https://github.com/numpy/numpy/pull/18941>`__: BUG: Make changelog "
"recognize gh- as a PR number prefix."
msgstr ""

#: ../../../release/1.20.3-notes.rst:42
msgid ""
"`#18948 <https://github.com/numpy/numpy/pull/18948>`__: REL, DOC: Prepare "
"for the NumPy 1.20.3 release."
msgstr ""

#: ../../../release/1.20.3-notes.rst:43
msgid ""
"`#18953 <https://github.com/numpy/numpy/pull/18953>`__: BUG: Fix failing "
"mypy test in 1.20.x."
msgstr ""
