#: ../../../release/1.14.6-notes.rst:3
msgid "NumPy 1.14.6 Release Notes"
msgstr "NumPy 1.14.6 發行備註"

#: ../../../release/1.14.6-notes.rst:5
msgid ""
"This is a bugfix release for bugs reported following the 1.14.5 release. The "
"most significant fixes are:"
msgstr ""

#: ../../../release/1.14.6-notes.rst:8
msgid "Fix for behavior change in ``ma.masked_values(shrink=True)``"
msgstr ""

#: ../../../release/1.14.6-notes.rst:9
msgid "Fix the new cached allocations machinery to be thread safe."
msgstr ""

#: ../../../release/1.14.6-notes.rst:11
msgid ""
"The Python versions supported in this release are 2.7 and 3.4 - 3.7. The "
"Python 3.6 wheels on PyPI should be compatible with all Python 3.6 versions."
msgstr ""

#: ../../../release/1.14.6-notes.rst:15
msgid "Contributors"
msgstr "貢獻者"

#: ../../../release/1.14.6-notes.rst:17
msgid ""
"A total of 4 people contributed to this release.  People with a \"+\" by "
"their names contributed a patch for the first time."
msgstr ""

