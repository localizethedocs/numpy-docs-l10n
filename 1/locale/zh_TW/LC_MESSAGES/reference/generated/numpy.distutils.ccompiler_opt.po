#: ../../../reference/generated/numpy.distutils.ccompiler_opt.rst:2
msgid "numpy.distutils.ccompiler\\_opt"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/distutils/ccompiler_opt.py:docstring
#: of numpy.distutils.ccompiler_opt:1
msgid ""
"Provides the `CCompilerOpt` class, used for handling the CPU/hardware "
"optimization, starting from parsing the command arguments, to managing the "
"relation between the CPU baseline and dispatch-able features, also "
"generating the required C headers and ending with compiling the sources with "
"proper compiler's flags."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/distutils/ccompiler_opt.py:docstring
#: of numpy.distutils.ccompiler_opt:7
msgid ""
"`CCompilerOpt` doesn't provide runtime detection for the CPU features, "
"instead only focuses on the compiler side, but it creates abstract C headers "
"that can be used later for the final runtime dispatching process."
msgstr ""

