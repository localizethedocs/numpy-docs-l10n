#: ../../../reference/generated/numpy.ma.average.rst:4
msgid "numpy.ma.average"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:2
msgid "Return the weighted average of array over the given axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:9
msgid "**a**"
msgstr "**a**"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:8
msgid ""
"Data to be averaged. Masked entries are not taken into account in the "
"computation."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:13
msgid "**axis**"
msgstr "**axis**"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:12
msgid ""
"Axis along which to average `a`. If None, averaging is done over the "
"flattened array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:24
msgid "**weights**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:16
msgid ""
"The importance that each element has in the computation of the average. The "
"weights array can either be 1-D (in which case its length must be the size "
"of `a` along the given axis) or of the same shape as `a`. If "
"``weights=None``, then all data in `a` are assumed to have a weight equal to "
"one.  The 1-D calculation is::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:22
msgid "avg = sum(a * weights) / sum(weights)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:24
msgid "The only constraint on `weights` is that `sum(weights)` must not be 0."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:29
msgid "**returned**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:27
msgid ""
"Flag indicating whether a tuple ``(result, sum of weights)`` should be "
"returned as output (True), or just the result (False). Default is False."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:38
msgid "**keepdims**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:32
msgid ""
"If this is set to True, the axes which are reduced are left in the result as "
"dimensions with size one. With this option, the result will broadcast "
"correctly against the original `a`. *Note:* `keepdims` will not work with "
"instances of `numpy.matrix` or other classes whose methods do not support "
"`keepdims`."
msgstr ""
"If this is set to True, the axes which are reduced are left in the result as "
"dimensions with size one. With this option, the result will broadcast "
"correctly against the original `a`. *Note:* `keepdims` will not work with "
"instances of `numpy.matrix` or other classes whose methods do not support "
"`keepdims`."

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:57
msgid "**average, [sum_of_weights]**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:-1
msgid "(tuple of) scalar or MaskedArray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:43
msgid ""
"The average along the specified axis. When returned is `True`, return a "
"tuple with the average as the first element and the sum of the weights as "
"the second element. The return type is `np.float64` if `a` is of integer "
"type and floats smaller than `float64`, or the input data-type, otherwise. "
"If returned, `sum_of_weights` is always `float64`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:60
msgid "Examples"
msgstr "範例"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.average:80
msgid "With ``keepdims=True``, the following result has shape (3, 1)."
msgstr ""
