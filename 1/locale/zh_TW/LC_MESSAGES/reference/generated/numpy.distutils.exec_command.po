#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/distutils/exec_command.py:docstring
#: of numpy.distutils.exec_command:3
msgid ""
"Implements exec_command function that is (almost) equivalent to commands."
"getstatusoutput function but on NT, DOS systems the returned status is "
"actually correct (though, the returned status values may be different by a "
"factor). In addition, exec_command takes keyword arguments for (re-)defining "
"environment variables."
msgstr ""

