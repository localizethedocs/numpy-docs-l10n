#: ../../../reference/generated/numpy.resize.rst:4
msgid "numpy.resize"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.resize:2
msgid "Return a new array with the specified shape."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.resize:4
msgid ""
"If the new array is larger than the original array, then the new array is "
"filled with repeated copies of `a`.  Note that this behavior is different "
"from a.resize(new_shape) which fills with zeros instead of repeated copies "
"of `a`."
msgstr ""

