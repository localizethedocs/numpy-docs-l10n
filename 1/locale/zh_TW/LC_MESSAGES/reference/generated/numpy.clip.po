#: of numpy.clip:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.clip:45
msgid "**clipped_array**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.clip:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.clip:37
msgid ""
"An array with the elements of `a`, but where values < `a_min` are replaced "
"with `a_min`, and those > `a_max` with `a_max`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.clip:50
msgid ":ref:`ufuncs-output-type`"
msgstr ""

