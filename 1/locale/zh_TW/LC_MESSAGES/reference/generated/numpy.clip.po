#: ../../../reference/generated/numpy.clip.rst:4
msgid "numpy.clip"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.clip:2
msgid "Clip (limit) the values in an array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.clip:4
msgid ""
"Given an interval, values outside the interval are clipped to the interval "
"edges.  For example, if an interval of ``[0, 1]`` is specified, values "
"smaller than 0 become 0, and values larger than 1 become 1."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.clip:9
msgid ""
"Equivalent to but faster than ``np.minimum(a_max, np.maximum(a, a_min))``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.clip:11
msgid "No check is performed to ensure ``a_min < a_max``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.clip:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.clip:16
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.clip:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.clip:16
msgid "Array containing elements to clip."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.clip:21
msgid "**a_min, a_max**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.clip:-1
msgid "array_like or None"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.clip:19
msgid ""
"Minimum and maximum value. If ``None``, clipping is not performed on the "
"corresponding edge. Only one of `a_min` and `a_max` may be ``None``. Both "
"are broadcast against `a`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.clip:26
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.clip:-1
msgid "ndarray, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.clip:24
msgid ""
"The results will be placed in this array. It may be the input array for in-"
"place clipping.  `out` must be of the right shape to hold the output.  Its "
"type is preserved."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.clip:32
msgid "**\\*\\*kwargs**"
msgstr ""

