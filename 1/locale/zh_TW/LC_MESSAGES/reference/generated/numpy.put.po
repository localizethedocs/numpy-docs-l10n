msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.put:24
msgid "Specifies how out-of-bounds indices will behave."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.put:26
msgid "'raise' -- raise an error (default)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.put:27
msgid "'wrap' -- wrap around"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.put:28
msgid "'clip' -- clip to the range"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.put:30
msgid ""
"'clip' mode means that all indices that are too large are replaced by the "
"index that addresses the last element along that axis. Note that this "
"disables indexing with negative numbers. In 'raise' mode, if an exception "
"occurs the target array may still be modified."
msgstr ""

