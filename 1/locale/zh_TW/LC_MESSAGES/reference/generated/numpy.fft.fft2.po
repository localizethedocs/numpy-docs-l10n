#: ../../../reference/generated/numpy.fft.fft2.rst:4
msgid "numpy.fft.fft2"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:2
msgid "Compute the 2-dimensional discrete Fourier Transform."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:4
msgid ""
"This function computes the *n*-dimensional discrete Fourier Transform over "
"any axes in an *M*-dimensional array by means of the Fast Fourier Transform "
"(FFT).  By default, the transform is computed over the last two axes of the "
"input array, i.e., a 2-dimensional FFT."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:12
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:12
msgid "Input array, can be complex"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:21
msgid "**s**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:-1
msgid "sequence of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:15
msgid ""
"Shape (length of each transformed axis) of the output (``s[0]`` refers to "
"axis 0, ``s[1]`` to axis 1, etc.). This corresponds to ``n`` for ``fft(x, "
"n)``. Along each axis, if the given shape is smaller than that of the input, "
"the input is cropped.  If it is larger, the input is padded with zeros. if "
"`s` is not given, the shape of the input along the axes specified by `axes` "
"is used."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:27
msgid "**axes**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:24
msgid ""
"Axes over which to compute the FFT.  If not given, the last two axes are "
"used.  A repeated index in `axes` means the transform over that axis is "
"performed multiple times.  A one-element sequence means that a one-"
"dimensional FFT is performed."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:38
msgid "**norm**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:-1
msgid "{\"backward\", \"ortho\", \"forward\"}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:32
msgid ""
"Normalization mode (see `numpy.fft`). Default is \"backward\". Indicates "
"which direction of the forward/backward pair of transforms is scaled and "
"with what normalization factor."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:38
msgid "The \"backward\", \"forward\" values were added."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:47
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:-1
msgid "complex ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:43
msgid ""
"The truncated or zero-padded input, transformed along the axes indicated by "
"`axes`, or the last two axes if `axes` is not given."
msgstr ""

