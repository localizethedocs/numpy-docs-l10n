msgid "numpy.char.expandtabs"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/defchararray.py:docstring
#: of numpy.char.expandtabs:2
msgid ""
"Return a copy of each string element where all tab characters are replaced "
"by one or more spaces."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/defchararray.py:docstring
#: of numpy.char.expandtabs:5
msgid "Calls `str.expandtabs` element-wise."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/defchararray.py:docstring
#: of numpy.char.expandtabs:7
msgid ""
"Return a copy of each string element where all tab characters are replaced "
"by one or more spaces, depending on the current column and the given "
"`tabsize`. The column number is reset to zero after each newline occurring "
"in the string. This doesn't understand other non-printing characters or "
"escape sequences."
msgstr ""

