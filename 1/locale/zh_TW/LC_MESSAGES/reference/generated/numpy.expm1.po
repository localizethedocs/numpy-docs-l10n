msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.expm1:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.expm1:31
msgid ""
"Element-wise exponential minus one: ``out = exp(x) - 1``. This is a scalar "
"if `x` is a scalar."
msgstr ""

#: ../../../../docstring of numpy.expm1:43
msgid ":obj:`log1p`"
msgstr ""

#: ../../../../docstring of numpy.expm1:44
msgid "``log(1 + x)``, the inverse of expm1."
msgstr ""

#: ../../../../docstring of numpy.expm1:48
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.expm1:49
msgid ""
"This function provides greater precision than ``exp(x) - 1`` for small "
"values of ``x``."
msgstr ""

#: ../../../../docstring of numpy.expm1:54
msgid "Examples"
msgstr ""

#: ../../../../docstring of numpy.expm1:55
msgid ""
"The true value of ``exp(1e-10) - 1`` is ``1.00000000005e-10`` to about 32 "
"significant digits. This example shows the superiority of expm1 in this case."
msgstr ""
