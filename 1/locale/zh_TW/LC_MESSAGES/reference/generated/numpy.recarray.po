msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray:2
msgid "Construct an ndarray that allows field access using attributes."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray:4
msgid ""
"Arrays may have a data-types containing fields, analogous to columns in a "
"spread sheet.  An example is ``[(x, int), (y, float)]``, where each entry in "
"the array is a pair of ``(int, float)``.  Normally, these attributes are "
"accessed using dictionary lookups such as ``arr['x']`` and ``arr['y']``.  "
"Record arrays allow the fields to be accessed as members of the array, using "
"``arr.x`` and ``arr.y``."
msgstr ""

