#: ../../../reference/generated/numpy.fft.rfftn.rst:4
msgid "numpy.fft.rfftn"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:2
msgid "Compute the N-dimensional discrete Fourier Transform for real input."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:4
msgid ""
"This function computes the N-dimensional discrete Fourier Transform over any "
"number of axes in an M-dimensional real array by means of the Fast Fourier "
"Transform (FFT).  By default, all axes are transformed, with the real "
"transform performed over the last axis, while the remaining transforms are "
"complex."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:13
msgid "**a**"
msgstr "**a**"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:13
msgid "Input array, taken to be real."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:23
msgid "**s**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:-1
msgid "sequence of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:16
msgid ""
"Shape (length along each transformed axis) to use from the input. (``s[0]`` "
"refers to axis 0, ``s[1]`` to axis 1, etc.). The final element of `s` "
"corresponds to `n` for ``rfft(x, n)``, while for the remaining axes, it "
"corresponds to `n` for ``fft(x, n)``. Along any axis, if the given shape is "
"smaller than that of the input, the input is cropped.  If it is larger, the "
"input is padded with zeros. if `s` is not given, the shape of the input "
"along the axes specified by `axes` is used."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:27
msgid "**axes**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:26
msgid ""
"Axes over which to compute the FFT.  If not given, the last ``len(s)`` axes "
"are used, or all axes if `s` is also not specified."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:38
msgid "**norm**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:-1
msgid "{\"backward\", \"ortho\", \"forward\"}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:32
msgid ""
"Normalization mode (see `numpy.fft`). Default is \"backward\". Indicates "
"which direction of the forward/backward pair of transforms is scaled and "
"with what normalization factor."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:38
msgid "The \"backward\", \"forward\" values were added."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:51
msgid "**out**"
msgstr "**out**"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:-1
msgid "complex ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftn:43
msgid ""
"The truncated or zero-padded input, transformed along the axes indicated by "
"`axes`, or by a combination of `s` and `a`, as explained in the parameters "
"section above. The length of the last axis transformed will be "
"``s[-1]//2+1``, while the remaining transformed axes will have lengths "
"according to `s`, or unchanged from the input."
msgstr ""

