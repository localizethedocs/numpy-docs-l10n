#: ../../../reference/generated/numpy.nanmean.rst:4
msgid "numpy.nanmean"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:2
msgid "Compute the arithmetic mean along the specified axis, ignoring NaNs."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:4
msgid ""
"Returns the average of the array elements.  The average is taken over the "
"flattened array by default, otherwise over the specified axis. `float64` "
"intermediate and return values are used for integer inputs."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:8
msgid "For all-NaN slices, NaN is returned and a `RuntimeWarning` is raised."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:16
msgid "**a**"
msgstr "**a**"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:15
msgid ""
"Array containing numbers whose mean is desired. If `a` is not an array, a "
"conversion is attempted."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:20
msgid "**axis**"
msgstr "**axis**"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:-1
msgid "{int, tuple of int, None}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:19
msgid ""
"Axis or axes along which the means are computed. The default is to compute "
"the mean of the flattened array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:25
msgid "**dtype**"
msgstr "**dtype**"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:-1
msgid "data-type, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:23
msgid ""
"Type to use in computing the mean.  For integer inputs, the default is "
"`float64`; for inexact inputs, it is the same as the input dtype."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:31
msgid "**out**"
msgstr "**out**"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:-1
msgid "ndarray, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:28
msgid ""
"Alternate output array in which to place the result.  The default is "
"``None``; if provided, it must have the same shape as the expected output, "
"but the type will be cast if necessary. See :ref:`ufuncs-output-type` for "
"more details."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:41
msgid "**keepdims**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:34
msgid ""
"If this is set to True, the axes which are reduced are left in the result as "
"dimensions with size one. With this option, the result will broadcast "
"correctly against the original `a`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:38
msgid ""
"If the value is anything but the default, then `keepdims` will be passed "
"through to the `mean` or `sum` methods of sub-classes of `ndarray`.  If the "
"sub-classes methods does not implement `keepdims` any exceptions will be "
"raised."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:46
msgid "**where**"
msgstr "**where**"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:-1
msgid "array_like of bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:44
msgid "Elements to include in the mean. See `~numpy.ufunc.reduce` for details."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:59
msgid "**m**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:-1
msgid "ndarray, see dtype parameter above"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:51
msgid ""
"If `out=None`, returns a new array containing the mean values, otherwise a "
"reference to the output array is returned. Nan is returned for slices that "
"contain only NaNs."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:64
msgid ":obj:`average`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:65
msgid "Weighted average"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:66
msgid ":obj:`mean`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:67
msgid "Arithmetic mean taken while not ignoring NaNs"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:68
msgid ":obj:`var`, :obj:`nanvar`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:72
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:73
msgid ""
"The arithmetic mean is the sum of the non-NaN elements along the axis "
"divided by the number of non-NaN elements."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmean:76
msgid ""
"Note that for floating-point input, the mean is computed using the same "
"precision the input has.  Depending on the input data, this can cause the "
"results to be inaccurate, especially for `float32`.  Specifying a higher-"
"precision accumulator using the `dtype` keyword can alleviate this issue."
msgstr ""

