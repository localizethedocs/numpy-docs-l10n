#: of numpy.linalg.tensorinv:13
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorinv:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorinv:12
msgid ""
"Tensor to 'invert'. Its shape must be 'square', i. e., ``prod(a.shape[:ind]) "
"== prod(a.shape[ind:])``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorinv:17
msgid "**ind**"
msgstr ""

