#: ../../../reference/generated/numpy.bitwise_or.rst:4
msgid "numpy.bitwise\\_or"
msgstr ""

#: ../../../../docstring of numpy.bitwise_or:2
msgid "Compute the bit-wise OR of two arrays element-wise."
msgstr ""

#: ../../../../docstring of numpy.bitwise_or:4
msgid ""
"Computes the bit-wise OR of the underlying binary representation of the "
"integers in the input arrays. This ufunc implements the C/Python operator ``|"
"``."
msgstr ""

#: ../../../../docstring of numpy.bitwise_or:0
msgid "Parameters"
msgstr "參數"

#: ../../../../docstring of numpy.bitwise_or:13
msgid "**x1, x2**"
msgstr ""

#: ../../../../docstring of numpy.bitwise_or:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../docstring of numpy.bitwise_or:11
msgid ""
"Only integer and boolean types are handled. If ``x1.shape != x2.shape``, "
"they must be broadcastable to a common shape (which becomes the shape of the "
"output)."
msgstr ""

#: ../../../../docstring of numpy.bitwise_or:19 numpy.bitwise_or:43
msgid "**out**"
msgstr "**out**"

#: ../../../../docstring of numpy.bitwise_or:-1
msgid "ndarray, None, or tuple of ndarray and None, optional"
msgstr ""

#: ../../../../docstring of numpy.bitwise_or:16
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or None, a freshly-"
"allocated array is returned. A tuple (possible only as a keyword argument) "
"must have length equal to the number of outputs."
msgstr ""

#: ../../../../docstring of numpy.bitwise_or:27
msgid "**where**"
msgstr "**where**"

#: ../../../../docstring of numpy.bitwise_or:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../docstring of numpy.bitwise_or:22
msgid ""
"This condition is broadcast over the input. At locations where the condition "
"is True, the `out` array will be set to the ufunc result. Elsewhere, the "
"`out` array will retain its original value. Note that if an uninitialized "
"`out` array is created via the default ``out=None``, locations within it "
"where the condition is False will remain uninitialized."
msgstr ""

#: ../../../../docstring of numpy.bitwise_or:31
msgid "**\\*\\*kwargs**"
msgstr "**\\*\\*kwargs**"

#: ../../../../docstring of numpy.bitwise_or:30
msgid ""
"For other keyword-only arguments, see the :ref:`ufunc docs <ufuncs.kwargs>`."
msgstr ""

