msgid "Returns"
msgstr "回傳值"

#: ../../../../docstring of numpy.bitwise_or:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.bitwise_or:36
msgid "Result. This is a scalar if both `x1` and `x2` are scalars."
msgstr ""

#: ../../../../docstring of numpy.bitwise_or:48
msgid ":obj:`logical_or`"
msgstr ":obj:`logical_or`"

#: ../../../../docstring of numpy.bitwise_or:50
msgid ":obj:`bitwise_and`"
msgstr ":obj:`bitwise_and`"

#: ../../../../docstring of numpy.bitwise_or:52
msgid ":obj:`bitwise_xor`"
msgstr ":obj:`bitwise_xor`"

#: ../../../../docstring of numpy.bitwise_or:54
msgid ":obj:`binary_repr`"
msgstr ":obj:`binary_repr`"

#: ../../../../docstring of numpy.bitwise_or:55
msgid "Return the binary representation of the input number as a string."
msgstr ""

#: ../../../../docstring of numpy.bitwise_or:61
msgid "Examples"
msgstr "範例"

#: ../../../../docstring of numpy.bitwise_or:62
msgid ""
"The number 13 has the binary representation ``00001101``. Likewise, 16 is "
"represented by ``00010000``.  The bit-wise OR of 13 and 16 is then "
"``00011101``, or 29:"
msgstr ""

#: ../../../../docstring of numpy.bitwise_or:88
msgid ""
"The ``|`` operator can be used as a shorthand for ``np.bitwise_or`` on "
"ndarrays."
msgstr ""
