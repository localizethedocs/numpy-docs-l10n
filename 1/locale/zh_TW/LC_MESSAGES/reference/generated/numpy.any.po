#: of numpy.any:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.any:9
msgid "**a**"
msgstr "**a**"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.any:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.any:9
msgid "Input array or object that can be converted to an array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.any:20
msgid "**axis**"
msgstr "**axis**"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.any:-1
msgid "None or int or tuple of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.any:12
msgid ""
"Axis or axes along which a logical OR reduction is performed. The default "
"(``axis=None``) is to perform a logical OR over all the dimensions of the "
"input array. `axis` may be negative, in which case it counts from the last "
"to the first axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.any:19
msgid ""
"If this is a tuple of ints, a reduction is performed on multiple axes, "
"instead of a single axis or all the axes as before."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.any:27
msgid "**out**"
msgstr "**out**"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.any:-1
msgid "ndarray, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.any:23
msgid ""
"Alternate output array in which to place the result.  It must have the same "
"shape as the expected output and its type is preserved (e.g., if it is of "
"type float, then it will remain so, returning 1.0 for True and 0.0 for "
"False, regardless of the type of `a`). See :ref:`ufuncs-output-type` for "
"more details."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.any:38
msgid "**keepdims**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.any:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.any:30
msgid ""
"If this is set to True, the axes which are reduced are left in the result as "
"dimensions with size one. With this option, the result will broadcast "
"correctly against the input array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.any:34
msgid ""
"If the default value is passed, then `keepdims` will not be passed through "
"to the `any` method of sub-classes of `ndarray`, however any non-default "
"value will be.  If the sub-class' method does not implement `keepdims` any "
"exceptions will be raised."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.any:44
msgid "**where**"
msgstr "**where**"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.any:-1
msgid "array_like of bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.any:41
msgid ""
"Elements to include in checking for any `True` values. See `~numpy.ufunc."
"reduce` for details."
msgstr ""

