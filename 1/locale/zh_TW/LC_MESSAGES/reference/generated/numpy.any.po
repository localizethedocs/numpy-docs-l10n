msgid "Test whether any array element along a given axis evaluates to True."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.any:4
msgid "Returns single boolean if `axis` is ``None``"
msgstr ""

