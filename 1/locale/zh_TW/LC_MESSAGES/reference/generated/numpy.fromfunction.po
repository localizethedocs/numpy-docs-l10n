#: of numpy.fromfunction:54
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.fromfunction:55
msgid "Keywords other than `dtype` and `like` are passed to `function`."
msgstr ""

