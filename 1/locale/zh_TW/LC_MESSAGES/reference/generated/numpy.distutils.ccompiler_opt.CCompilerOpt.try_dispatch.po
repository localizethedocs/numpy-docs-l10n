#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/distutils/ccompiler_opt.py:docstring
#: of numpy.distutils.ccompiler_opt.CCompilerOpt.try_dispatch:2
msgid ""
"Compile one or more dispatch-able sources and generates object files, also "
"generates abstract C config headers and macros that used later for the final "
"runtime dispatching process."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/distutils/ccompiler_opt.py:docstring
#: of numpy.distutils.ccompiler_opt.CCompilerOpt.try_dispatch:6
msgid ""
"The mechanism behind it is to takes each source file that specified in "
"'sources' and branching it into several files depend on special "
"configuration statements that must be declared in the top of each source "
"which contains targeted CPU features, then it compiles every branched source "
"with the proper compiler flags."
msgstr ""

