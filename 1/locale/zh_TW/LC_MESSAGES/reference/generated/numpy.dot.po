#: ../../../reference/generated/numpy.dot.rst:4
msgid "numpy.dot"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.dot:2
msgid "Dot product of two arrays. Specifically,"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.dot:4
msgid ""
"If both `a` and `b` are 1-D arrays, it is inner product of vectors (without "
"complex conjugation)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.dot:7
msgid ""
"If both `a` and `b` are 2-D arrays, it is matrix multiplication, but using :"
"func:`matmul` or ``a @ b`` is preferred."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.dot:10
msgid ""
"If either `a` or `b` is 0-D (scalar), it is equivalent to :func:`multiply` "
"and using ``numpy.multiply(a, b)`` or ``a * b`` is preferred."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.dot:14
msgid ""
"If `a` is an N-D array and `b` is a 1-D array, it is a sum product over the "
"last axis of `a` and `b`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.dot:17
msgid ""
"If `a` is an N-D array and `b` is an M-D array (where ``M>=2``), it is a sum "
"product over the last axis of `a` and the second-to-last axis of `b`::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.dot:21
msgid "dot(a, b)[i,j,k,m] = sum(a[i,j,:] * b[k,:,m])"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.dot:23
msgid "It uses an optimized BLAS library when possible (see `numpy.linalg`)."
msgstr ""

