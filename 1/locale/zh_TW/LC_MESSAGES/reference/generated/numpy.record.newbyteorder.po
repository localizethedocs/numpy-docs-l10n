#: of numpy.record.newbyteorder:9
msgid "{'<', 'little'} - little endian"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.record.newbyteorder:10
msgid "{'>', 'big'} - big endian"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.record.newbyteorder:11
msgid "{'=', 'native'} - native order"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.record.newbyteorder:12
msgid "{'|', 'I'} - ignore (no change to byte order)"
msgstr ""

