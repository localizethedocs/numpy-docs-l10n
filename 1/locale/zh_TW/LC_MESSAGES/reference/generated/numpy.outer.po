msgid ""
"Given two vectors `a` and `b` of length ``M`` and ``N``, repsectively, the "
"outer product [R14e6c54b746b-1]_ is::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
