#: ../../../reference/generated/numpy.save.rst:4
msgid "numpy.save"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.save:2
msgid "Save an array to a binary file in NumPy ``.npy`` format."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.save:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.save:11
msgid "**file**"
msgstr "**file**"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.save:-1
msgid "file, str, or pathlib.Path"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.save:8
msgid ""
"File or filename to which the data is saved.  If file is a file-object, then "
"the filename is unchanged.  If file is a string or Path, a ``.npy`` "
"extension will be appended to the filename if it does not already have one."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.save:14
msgid "**arr**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.save:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.save:14
msgid "Array data to be saved."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.save:23
msgid "**allow_pickle**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.save:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.save:17
msgid ""
"Allow saving object arrays using Python pickles. Reasons for disallowing "
"pickles include security (loading pickled data can execute arbitrary code) "
"and portability (pickled objects may not be loadable on different Python "
"installations, for example if the stored objects require libraries that are "
"not available, and not all pickled data is compatible between Python 2 and "
"Python 3). Default: True"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.save:36
msgid "**fix_imports**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.save:26
msgid ""
"Only useful in forcing objects in object arrays on Python 3 to be pickled in "
"a Python 2 compatible way. If `fix_imports` is True, pickle will try to map "
"the new Python 3 names to the old module names used in Python 2, so that the "
"pickle data stream is readable with Python 2."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.save:41
msgid ":obj:`savez`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.save:42
msgid "Save several arrays into a ``.npz`` archive"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.save:43
msgid ":obj:`savetxt`, :obj:`load`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.save:47
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.save:48
msgid ""
"For a description of the ``.npy`` format, see :py:mod:`numpy.lib.format`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.save:50
msgid "Any data saved to the file is appended to the end of the file."
msgstr ""

