#: ../../../reference/generated/numpy.ma.masked_array.partition.rst:4
msgid "numpy.ma.masked\\_array.partition"
msgstr ""

#: ../../../reference/generated/numpy.ma.masked_array.partition.rst:8
msgid "method"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.partition:2
msgid ""
"Rearranges the elements in the array in such a way that the value of the "
"element in kth position is in the position it would be in a sorted array. "
"All elements smaller than the kth element are moved before this element and "
"all equal or greater are moved behind it. The ordering of the elements in "
"the two partitions is undefined."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.partition:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.partition:21
msgid "**kth**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.partition:-1
msgid "int or sequence of ints"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.partition:13
msgid ""
"Element index to partition by. The kth element value will be in its final "
"sorted position and all smaller elements will be moved before it and all "
"equal or greater elements behind it. The order of all elements in the "
"partitions is undefined. If provided with a sequence of kth it will "
"partition all elements indexed by kth of them into their sorted position at "
"once."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.partition:20
msgid "Passing booleans as index is deprecated."
msgstr ""

