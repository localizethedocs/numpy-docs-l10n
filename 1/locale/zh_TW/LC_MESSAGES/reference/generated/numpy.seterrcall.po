#: ../../../reference/generated/numpy.seterrcall.rst:4
msgid "numpy.seterrcall"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.seterrcall:2
msgid "Set the floating-point error callback function or log object."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.seterrcall:4
msgid ""
"There are two ways to capture floating-point error messages.  The first is "
"to set the error-handler to 'call', using `seterr`.  Then, set the function "
"to call using this function."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.seterrcall:8
msgid ""
"The second is to set the error-handler to 'log', using `seterr`. Floating-"
"point errors then trigger a call to the 'write' method of the provided "
"object."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.seterrcall:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.seterrcall:29
msgid "**func**"
msgstr "**func**"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.seterrcall:-1
msgid "callable f(err, flag) or object with write method"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.seterrcall:15
msgid ""
"Function to call upon floating-point errors ('call'-mode) or object whose "
"'write' method is used to log such message ('log'-mode)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.seterrcall:18
msgid ""
"The call function takes two arguments. The first is a string describing the "
"type of error (such as \"divide by zero\", \"overflow\", \"underflow\", or "
"\"invalid value\"), and the second is the status flag.  The flag is a byte, "
"whose four least-significant bits indicate the type of error, one of "
"\"divide\", \"over\", \"under\", \"invalid\"::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.seterrcall:24
msgid "[0 0 0 0 divide over under invalid]"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.seterrcall:26
msgid "In other words, ``flags = divide + 2*over + 4*under + 8*invalid``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.seterrcall:28
msgid ""
"If an object is provided, its write method should take one argument, a "
"string."
msgstr ""

