#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.in1d:19
msgid "**assume_unique**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.in1d:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.in1d:18
msgid ""
"If True, the input arrays are both assumed to be unique, which can speed up "
"the calculation.  Default is False."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.in1d:25
msgid "**invert**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.in1d:22
msgid ""
"If True, the values in the returned array are inverted (that is, False where "
"an element of `ar1` is in `ar2` and True otherwise). Default is False. ``np."
"in1d(a, b, invert=True)`` is equivalent to (but is faster than) ``np."
"invert(in1d(a, b))``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.in1d:48
msgid "**kind**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.in1d:-1
msgid "{None, 'sort', 'table'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.in1d:28
msgid ""
"The algorithm to use. This will not affect the final result, but will affect "
"the speed and memory use. The default, None, will select automatically based "
"on memory considerations."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.in1d:32
msgid ""
"If 'sort', will use a mergesort-based approach. This will have a memory "
"usage of roughly 6 times the sum of the sizes of `ar1` and `ar2`, not "
"accounting for size of dtypes."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.in1d:35
msgid ""
"If 'table', will use a lookup table approach similar to a counting sort. "
"This is only available for boolean and integer arrays. This will have a "
"memory usage of the size of `ar1` plus the max-min value of `ar2`. "
"`assume_unique` has no effect when the 'table' option is used."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.in1d:40
msgid ""
"If None, will automatically choose 'table' if the required memory allocation "
"is less than or equal to 6 times the sum of the sizes of `ar1` and `ar2`, "
"otherwise will use 'sort'. This is done to not use a large amount of memory "
"by default, even though 'table' may be faster in most cases. If 'table' is "
"chosen, `assume_unique` will have no effect."
msgstr ""

