msgid "numpy.in1d"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.in1d:2
msgid ""
"Test whether each element of a 1-D array is also present in a second array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.in1d:4
msgid ""
"Returns a boolean array the same length as `ar1` that is True where an "
"element of `ar1` is in `ar2` and False otherwise."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.in1d:7
msgid "We recommend using :func:`isin` instead of `in1d` for new code."
msgstr ""

