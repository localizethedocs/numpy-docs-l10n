#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/_polybase.py:docstring
#: of numpy.polynomial._polybase.ABCPolyBase.linspace:4
msgid ""
"Returns the x, y values at `n` linearly spaced points across the domain.  "
"Here y is the value of the polynomial at the points x. By default the domain "
"is the same as that of the series instance. This method is intended mostly "
"as a plotting aid."
msgstr ""

