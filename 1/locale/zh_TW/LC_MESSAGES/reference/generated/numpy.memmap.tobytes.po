msgid "Construct Python bytes containing the raw data bytes in the array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap.tobytes:4
msgid ""
"Constructs Python bytes showing a copy of the raw contents of data memory. "
"The bytes object is produced in C-order by default. This behavior is "
"controlled by the ``order`` parameter."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
