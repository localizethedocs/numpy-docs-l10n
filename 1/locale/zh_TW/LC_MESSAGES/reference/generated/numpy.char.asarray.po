#: ../../../reference/generated/numpy.char.asarray.rst:4
msgid "numpy.char.asarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/defchararray.py:docstring
#: of numpy.char.asarray:2
msgid "Convert the input to a `chararray`, copying the data only if necessary."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/defchararray.py:docstring
#: of numpy.char.asarray:5
msgid ""
"Versus a regular NumPy array of type `str` or `unicode`, this class adds the "
"following functionality:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/defchararray.py:docstring
#: of numpy.char.asarray:8
msgid "values automatically have whitespace removed from the end when indexed"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/defchararray.py:docstring
#: of numpy.char.asarray:11
msgid ""
"comparison operators automatically remove whitespace from the end when "
"comparing values"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/defchararray.py:docstring
#: of numpy.char.asarray:14
msgid ""
"vectorized string operations are provided as methods (e.g. `str.endswith`) "
"and infix operators (e.g. ``+``, ``*``,``%``)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/defchararray.py:docstring
#: of numpy.char.asarray:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/defchararray.py:docstring
#: of numpy.char.asarray:20
msgid "**obj**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/defchararray.py:docstring
#: of numpy.char.asarray:-1
msgid "array of str or unicode-like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/defchararray.py:docstring
#: of numpy.char.asarray:28
msgid "**itemsize**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/defchararray.py:docstring
#: of numpy.char.asarray:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/defchararray.py:docstring
#: of numpy.char.asarray:23
msgid ""
"`itemsize` is the number of characters per scalar in the resulting array.  "
"If `itemsize` is None, and `obj` is an object array or a Python list, the "
"`itemsize` will be automatically determined.  If `itemsize` is provided and "
"`obj` is of type str or unicode, then the `obj` string will be chunked into "
"`itemsize` pieces."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/defchararray.py:docstring
#: of numpy.char.asarray:40
msgid "**unicode**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/defchararray.py:docstring
#: of numpy.char.asarray:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/defchararray.py:docstring
#: of numpy.char.asarray:31
msgid ""
"When true, the resulting `chararray` can contain Unicode characters, when "
"false only 8-bit characters.  If unicode is None and `obj` is one of the "
"following:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/defchararray.py:docstring
#: of numpy.char.asarray:35
msgid "a `chararray`,"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/defchararray.py:docstring
#: of numpy.char.asarray:36
msgid "an ndarray of type `str` or 'unicode`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/defchararray.py:docstring
#: of numpy.char.asarray:37
msgid "a Python str or unicode object,"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/defchararray.py:docstring
#: of numpy.char.asarray:39
msgid ""
"then the unicode setting of the output array will be automatically "
"determined."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/defchararray.py:docstring
#: of numpy.char.asarray:60
msgid "**order**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/defchararray.py:docstring
#: of numpy.char.asarray:-1
msgid "{'C', 'F'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/defchararray.py:docstring
#: of numpy.char.asarray:43
msgid ""
"Specify the order of the array.  If order is 'C' (default), then the array "
"will be in C-contiguous order (last-index varies the fastest).  If order is "
"'F', then the returned array will be in Fortran-contiguous order (first-"
"index varies the fastest)."
msgstr ""
