#: of numpy.broadcast_arrays:17
msgid ""
"These arrays are views on the original arrays.  They are typically not "
"contiguous.  Furthermore, more than one element of a broadcasted array may "
"refer to a single memory location. If you need to write to the arrays, make "
"copies first. While you can set the ``writable`` flag True, writing to a "
"single output value may end up changing more than one location in the output "
"array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.broadcast_arrays:24
msgid ""
