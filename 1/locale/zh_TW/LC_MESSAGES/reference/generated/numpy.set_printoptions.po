msgid "**suppress**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:28
msgid ""
"If True, always print floating point numbers using fixed point notation, in "
"which case numbers equal to zero in the current precision will print as "
"zero.  If False, then scientific notation is used when absolute value of the "
"smallest number is < 1e-4 or the ratio of the maximum absolute value to the "
"minimum is > 1e3. The default is False."
msgstr ""

