#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:73
msgid ""
"Controls the interpretation of the `precision` option for floating-point "
"types. Can take the following values (default maxprec_equal):"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:78
msgid "'fixed': Always print exactly `precision` fractional digits,"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:78
msgid ""
"even if this would print more or fewer digits than necessary to specify the "
"value uniquely."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:82
msgid "'unique': Print the minimum number of fractional digits necessary"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:81
msgid ""
"to represent each value uniquely. Different elements may have a different "
"number of digits. The value of the `precision` option is ignored."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:85
msgid "'maxprec': Print at most `precision` fractional digits, but if"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:85
msgid ""
"an element can be uniquely represented with fewer digits only print it with "
"that many."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:90
msgid "'maxprec_equal': Print at most `precision` fractional digits,"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:88
msgid ""
"but if every element in the array can be uniquely represented with an equal "
"number of fewer digits, use that many digits for all elements."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:116
msgid "**legacy** : string or `False`, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:-1
msgid "string or"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:93
msgid ""
"If set to the string `'1.13'` enables 1.13 legacy printing mode. This "
"approximates numpy 1.13 print output by including a space in the sign "
"position of floats and different behavior for 0d arrays. This also enables "
"1.21 legacy printing mode (described below)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:98
msgid ""
"If set to the string `'1.21'` enables 1.21 legacy printing mode. This "
"approximates numpy 1.21 print output of complex structured dtypes by not "
"inserting spaces after commas that separate fields and after colons."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:103
msgid "If set to `False`, disables legacy mode."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.set_printoptions:105
msgid ""
"Unrecognized strings will be ignored with a warning for forward "
"compatibility."
msgstr ""

