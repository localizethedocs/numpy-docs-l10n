#: ../../../reference/generated/numpy.allclose.rst:4
msgid "numpy.allclose"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.allclose:2
msgid "Returns True if two arrays are element-wise equal within a tolerance."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.allclose:4
msgid ""
"The tolerance values are positive, typically very small numbers.  The "
"relative difference (`rtol` * abs(`b`)) and the absolute difference `atol` "
"are added together to compare against the absolute difference between `a` "
"and `b`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.allclose:9
msgid ""
"NaNs are treated as equal if they are in the same place and if "
"``equal_nan=True``.  Infs are treated as equal if they are in the same place "
"and of the same sign in both arrays."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.allclose:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.allclose:16
msgid "**a, b**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.allclose:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.allclose:16
msgid "Input arrays to compare."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.allclose:19
msgid "**rtol**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.allclose:-1
msgid "float"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.allclose:19
msgid "The relative tolerance parameter (see Notes)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.allclose:22
msgid "**atol**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.allclose:22
msgid "The absolute tolerance parameter (see Notes)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.allclose:28
msgid "**equal_nan**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.allclose:-1
msgid "bool"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.allclose:25
msgid ""
"Whether to compare NaN's as equal.  If True, NaN's in `a` will be considered "
"equal to NaN's in `b` in the output array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.allclose:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.allclose:40
msgid "**allclose**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.allclose:33
msgid ""
"Returns True if the two arrays are equal within the given tolerance; False "
"otherwise."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.allclose:45
msgid ":obj:`isclose`, :obj:`all`, :obj:`any`, :obj:`equal`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.allclose:49
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.allclose:50
msgid ""
"If the following equation is element-wise True, then allclose returns True."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.allclose:53
msgid "absolute(`a` - `b`) <= (`atol` + `rtol` * absolute(`b`))"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.allclose:55
msgid ""
"The above equation is not symmetric in `a` and `b`, so that ``allclose(a, "
"b)`` might be different from ``allclose(b, a)`` in some rare cases."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.allclose:59
msgid ""
"The comparison of `a` and `b` uses standard broadcasting, which means that "
"`a` and `b` need not have the same shape in order for ``allclose(a, b)`` to "
"evaluate to True.  The same is true for `equal` but not `array_equal`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.allclose:64
msgid ""
"`allclose` is not defined for non-numeric data types. `bool` is considered a "
"numeric data-type for this purpose."
msgstr ""

