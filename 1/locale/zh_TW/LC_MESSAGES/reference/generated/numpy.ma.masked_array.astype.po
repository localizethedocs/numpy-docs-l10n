msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ma.masked_array.astype:16
msgid "**order**"
msgstr "**命令**"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ma.masked_array.astype:-1
msgid "{'C', 'F', 'A', 'K'}, optional"
msgstr "{'C', 'F', 'A', 'K'}，可選"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ma.masked_array.astype:11
msgid ""
"Controls the memory layout order of the result. 'C' means C order, 'F' means "
"Fortran order, 'A' means 'F' order if all the arrays are Fortran contiguous, "
"'C' order otherwise, and 'K' means as close to the order the array elements "
"appear in memory as possible. Default is 'K'."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ma.masked_array.astype:27
msgid "**casting**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ma.masked_array.astype:-1
msgid "{'no', 'equiv', 'safe', 'same_kind', 'unsafe'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ma.masked_array.astype:19
msgid ""
"Controls what kind of data casting may occur. Defaults to 'unsafe' for "
"backwards compatibility."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ma.masked_array.astype:22
msgid "'no' means the data types should not be cast at all."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ma.masked_array.astype:23
msgid "'equiv' means only byte-order changes are allowed."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ma.masked_array.astype:24
msgid "'safe' means only casts which can preserve values are allowed."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ma.masked_array.astype:25
msgid ""
"'same_kind' means only safe casts or casts within a kind, like float64 to "
"float32, are allowed."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ma.masked_array.astype:27
msgid "'unsafe' means any data conversions may be done."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ma.masked_array.astype:31
msgid "**subok**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ma.masked_array.astype:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ma.masked_array.astype:30
msgid ""
"If True, then sub-classes will be passed-through (default), otherwise the "
"returned array will be forced to be a base-class array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ma.masked_array.astype:37
msgid "**copy**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ma.masked_array.astype:34
msgid ""
"By default, astype always returns a newly allocated array. If this is set to "
"false, and the `dtype`, `order`, and `subok` requirements are satisfied, the "
"input array is returned instead of a copy."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ma.masked_array.astype:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ma.masked_array.astype:48
msgid "**arr_t**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ma.masked_array.astype:-1
msgid "ndarray"
msgstr "ndarray"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ma.masked_array.astype:42
msgid ""
"Unless `copy` is False and the other conditions for returning the input "
"array are satisfied (see description for `copy` input parameter), `arr_t` is "
"a new array of the same shape as the input array, with dtype, order given by "
"`dtype`, `order`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ma.masked_array.astype:0
msgid "Raises"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ma.masked_array.astype:57
msgid "ComplexWarning"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ma.masked_array.astype:53
msgid ""
"When casting from complex to float or int. To avoid this, one should use ``a."
"real.astype(t)``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ma.masked_array.astype:60
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ma.masked_array.astype:61
msgid ""
"Casting between a simple data type and a structured one is possible only for "
"\"unsafe\" casting.  Casting to multiple fields is allowed, but casting from "
"multiple fields is not."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ma.masked_array.astype:66
msgid ""
"Casting from numeric to string types in 'safe' casting mode requires that "
"the string dtype length is long enough to store the max integer/float value "
"converted."
msgstr ""

