#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.isfortran:30
msgid ""
"np.array allows to specify whether the array is written in C-contiguous "
"order (last index varies the fastest), or FORTRAN-contiguous order in memory "
"(first index varies the fastest)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.isfortran:48
msgid "The transpose of a C-ordered array is a FORTRAN-ordered array."
msgstr ""

