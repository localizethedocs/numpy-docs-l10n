#: of numpy.take:34
msgid ""
"The axis over which to select values. By default, the flattened input array "
"is used."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.take:40 numpy.take:62
msgid "**out**"
msgstr ""

