#: ../../../reference/generated/numpy.take.rst:4
msgid "numpy.take"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.take:2
msgid "Take elements from an array along an axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.take:4
msgid ""
"When axis is not None, this function does the same thing as \"fancy\" "
"indexing (indexing arrays using arrays); however, it can be easier to use if "
"you need elements along a given axis. A call such as ``np.take(arr, indices, "
"axis=3)`` is equivalent to ``arr[:,:,:,indices,...]``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.take:10
msgid ""
"Explained without fancy indexing, this is equivalent to the following use of "
"`ndindex`, which sets each of ``ii``, ``jj``, and ``kk`` to a tuple of "
"indices::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.take:14
msgid ""
"Ni, Nk = a.shape[:axis], a.shape[axis+1:]\n"
"Nj = indices.shape\n"
"for ii in ndindex(Ni):\n"
"    for jj in ndindex(Nj):\n"
"        for kk in ndindex(Nk):\n"
"            out[ii + jj + kk] = a[ii + (indices[jj],) + kk]"
msgstr ""

