msgid "numpy.where"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.where:2
msgid "Return elements chosen from `x` or `y` depending on `condition`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.where:5
msgid ""
"When only `condition` is provided, this function is a shorthand for ``np."
"asarray(condition).nonzero()``. Using `nonzero` directly should be "
"preferred, as it behaves correctly for subclasses. The rest of this "
"documentation covers only the case where all three arguments are provided."
msgstr ""

