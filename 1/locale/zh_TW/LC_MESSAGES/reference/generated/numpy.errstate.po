#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.errstate:17
msgid ""
"Keyword arguments. The valid keywords are the possible floating-point "
"exceptions. Each keyword should have a string value that defines the "
"treatment for the particular error. Possible values are {'ignore', 'warn', "
"'raise', 'call', 'print', 'log'}."
msgstr ""

