#: ../../../reference/generated/numpy.errstate.rst:2
msgid "numpy.errstate"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.errstate:2
msgid "Context manager for floating-point error handling."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.errstate:4
msgid ""
"Using an instance of `errstate` as a context manager allows statements in "
"that context to execute with a known error handling behavior. Upon entering "
"the context the error handling is set with `seterr` and `seterrcall`, and "
"upon exiting it is reset to what it was before."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.errstate:9
msgid ""
"`errstate` is also usable as a function decorator, saving a level of "
"indentation if an entire function is wrapped. See :py:class:`contextlib."
"ContextDecorator` for more information."
msgstr ""

