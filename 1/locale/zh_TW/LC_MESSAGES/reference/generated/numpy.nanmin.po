msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmin:82
msgid ""
"NumPy uses the IEEE Standard for Binary Floating-Point for Arithmetic (IEEE "
"754). This means that Not a Number is not equivalent to infinity. Positive "
"infinity is treated as a very large number and negative infinity is treated "
"as a very small (i.e. negative) number."
msgstr ""

