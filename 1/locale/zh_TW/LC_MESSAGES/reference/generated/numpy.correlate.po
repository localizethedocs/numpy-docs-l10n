msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:22
msgid ""
"`old_behavior` was removed in NumPy 1.10. If you need the old behavior, use "
"`multiarray.correlate`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
