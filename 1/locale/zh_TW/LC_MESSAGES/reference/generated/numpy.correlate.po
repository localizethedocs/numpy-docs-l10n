msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:18
msgid ""
"Refer to the `convolve` docstring.  Note that the default is 'valid', unlike "
"`convolve`, which uses 'full'."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:23
msgid "**old_behavior**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
