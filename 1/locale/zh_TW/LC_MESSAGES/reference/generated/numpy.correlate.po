msgstr "**out**"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:28
msgid "Discrete cross-correlation of `a` and `v`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:39
msgid ":obj:`convolve`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:40
msgid "Discrete, linear convolution of two one-dimensional sequences."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.correlate:41
msgid ":obj:`multiarray.correlate`"
msgstr ""

