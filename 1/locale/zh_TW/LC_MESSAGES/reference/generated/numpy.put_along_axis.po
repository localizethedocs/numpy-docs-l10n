#: ../../../reference/generated/numpy.put_along_axis.rst:4
msgid "numpy.put\\_along\\_axis"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.put_along_axis:2
msgid ""
"Put values into the destination array by matching 1d index and data slices."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.put_along_axis:4
msgid ""
"This iterates over matching 1d slices oriented along the specified axis in "
"the index and data arrays, and uses the former to place values into the "
"latter. These slices can be different lengths."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.put_along_axis:8
msgid ""
"Functions returning an index along an axis, like `argsort` and "
"`argpartition`, produce suitable indices for this function."
msgstr ""

