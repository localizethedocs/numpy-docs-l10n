#: of numpy.fft.fftn:20
msgid "**s**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fftn:-1
msgid "sequence of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fftn:14
msgid ""
"Shape (length of each transformed axis) of the output (``s[0]`` refers to "
"axis 0, ``s[1]`` to axis 1, etc.). This corresponds to ``n`` for ``fft(x, "
"n)``. Along any axis, if the given shape is smaller than that of the input, "
"the input is cropped.  If it is larger, the input is padded with zeros. if "
"`s` is not given, the shape of the input along the axes specified by `axes` "
"is used."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fftn:26
msgid "**axes**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fftn:23
msgid ""
"Axes over which to compute the FFT.  If not given, the last ``len(s)`` axes "
"are used, or all axes if `s` is also not specified. Repeated indices in "
"`axes` means that the transform over that axis is performed multiple times."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fftn:37
msgid "**norm**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fftn:-1
msgid "{\"backward\", \"ortho\", \"forward\"}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fftn:31
msgid ""
"Normalization mode (see `numpy.fft`). Default is \"backward\". Indicates "
"which direction of the forward/backward pair of transforms is scaled and "
"with what normalization factor."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fftn:37
msgid "The \"backward\", \"forward\" values were added."
msgstr ""

