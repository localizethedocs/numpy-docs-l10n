msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.integers:33
msgid ""
"If true, sample from the interval [low, high] instead of the default [low, "
"high) Defaults to False"
msgstr ""

