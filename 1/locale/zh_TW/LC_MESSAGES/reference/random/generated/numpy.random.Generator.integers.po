#: ../../../reference/random/generated/numpy.random.Generator.integers.rst:4
msgid "numpy.random.Generator.integers"
msgstr ""

#: ../../../reference/random/generated/numpy.random.Generator.integers.rst:8
msgid "method"
msgstr "方法"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.integers:2
msgid ""
"Return random integers from `low` (inclusive) to `high` (exclusive), or if "
"endpoint=True, `low` (inclusive) to `high` (inclusive). Replaces "
"`RandomState.randint` (with endpoint=False) and `RandomState."
"random_integers` (with endpoint=True)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.integers:7
msgid ""
"Return random integers from the \"discrete uniform\" distribution of the "
"specified dtype. If `high` is None (the default), then results are from 0 to "
"`low`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.integers:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.integers:16
msgid "**low**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.integers:-1
msgid "int or array-like of ints"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.integers:14
msgid ""
"Lowest (signed) integers to be drawn from the distribution (unless "
"``high=None``, in which case this parameter is 0 and this value is used for "
"`high`)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.integers:21
msgid "**high**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.integers:-1
msgid "int or array-like of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.integers:19
msgid ""
"If provided, one above the largest (signed) integer to be drawn from the "
"distribution (see above for behavior if ``high=None``). If array-like, must "
"contain integer values"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.integers:26
msgid "**size**"
msgstr "**size**"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.integers:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.integers:24
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn.  Default is None, in which case a single value is "
"returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.integers:30
msgid "**dtype**"
msgstr "**dtype**"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.integers:-1
msgid "dtype, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.integers:29
msgid ""
"Desired dtype of the result. Byteorder must be native. The default value is "
"np.int64."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.integers:35
