msgid "**samples**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.dirichlet:-1
msgid "ndarray,"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.dirichlet:29
msgid "The drawn samples, of shape ``(size, k)``."
msgstr ""

