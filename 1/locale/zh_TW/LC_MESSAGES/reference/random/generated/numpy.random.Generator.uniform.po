msgid "numpy.random.Generator.uniform"
msgstr ""

#: ../../../reference/random/generated/numpy.random.Generator.uniform.rst:8
msgid "method"
msgstr "方法"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.uniform:2
msgid "Draw samples from a uniform distribution."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.uniform:4
msgid ""
"Samples are uniformly distributed over the half-open interval ``[low, "
"high)`` (includes low, but excludes high).  In other words, any value within "
"the given interval is equally likely to be drawn by `uniform`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.uniform:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.uniform:13
msgid "**low**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.uniform:-1
msgid "float or array_like of floats, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.uniform:12
msgid ""
"Lower boundary of the output interval.  All values generated will be greater "
"than or equal to low.  The default value is 0."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.uniform:20
msgid "**high**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.uniform:-1
msgid "float or array_like of floats"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.uniform:16
msgid ""
"Upper boundary of the output interval.  All values generated will be less "
"than high.  The high limit may be included in the returned array of  floats "
"due to floating-point rounding in the equation  ``low + (high-low) * "
"random_sample()``.  high - low must be  non-negative.  The default value is "
"1.0."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.uniform:26
msgid "**size**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.uniform:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.uniform:23
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn.  If size is ``None`` (default), a single value is "
"returned if ``low`` and ``high`` are both scalars. Otherwise, ``np."
"broadcast(low, high).size`` samples are drawn."
msgstr ""

