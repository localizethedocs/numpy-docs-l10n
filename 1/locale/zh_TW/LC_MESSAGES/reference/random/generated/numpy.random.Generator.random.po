msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.random:4
msgid ""
"Results are from the \"continuous uniform\" distribution over the stated "
"interval.  To sample :math:`Unif[a, b), b > a` use `uniform` or multiply the "
"output of `random` by ``(b - a)`` and add ``a``::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.random:8
msgid "(b - a) * random() + a"
msgstr ""

