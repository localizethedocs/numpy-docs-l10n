#: ../../../reference/generated/numpy.polynomial.legendre.legfit.rst:4
msgid "numpy.polynomial.legendre.legfit"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:2
msgid "Least squares fit of Legendre series to data."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:4
msgid ""
"Return the coefficients of a Legendre series of degree `deg` that is the "
"least squares fit to the data values `y` given at points `x`. If `y` is 1-D "
"the returned coefficients will also be 1-D. If `y` is 2-D multiple fits are "
"done, one for each column of `y`, and the resulting coefficients are stored "
"in the corresponding columns of a 2-D return. The fitted polynomial(s) are "
"in the form"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:11
msgid ""
"p(x) = c_0 + c_1 * L_1(x) + ... + c_n * L_n(x),\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:13
msgid "where `n` is `deg`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:18
msgid "**x**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:-1
msgid "array_like, shape (M,)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:18
msgid "x-coordinates of the M sample points ``(x[i], y[i])``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:23
msgid "**y**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:-1
msgid "array_like, shape (M,) or (M, K)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:21
msgid ""
"y-coordinates of the sample points. Several data sets of sample points "
"sharing the same x-coordinates can be fitted at once by passing in a 2D-"
"array that contains one dataset per column."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:29
msgid "**deg**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:-1
msgid "int or 1-D array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:26
msgid ""
"Degree(s) of the fitting polynomials. If `deg` is a single integer all terms "
"up to and including the `deg`'th term are included in the fit. For NumPy "
"versions >= 1.11.0 a list of integers specifying the degrees of the terms to "
"include may be used instead."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:35
msgid "**rcond**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:-1
msgid "float, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:32
msgid ""
"Relative condition number of the fit. Singular values smaller than this "
"relative to the largest singular value will be ignored. The default value is "
"len(x)*eps, where eps is the relative precision of the float type, about "
"2e-16 in most cases."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:40
msgid "**full**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:38
msgid ""
"Switch determining nature of return value. When it is False (the default) "
"just the coefficients are returned, when True diagnostic information from "
"the singular value decomposition is also returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:49
msgid "**w** : array_like, shape (`M`,), optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:-1
msgid "array_like, shape ("
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:43
msgid ""
"Weights. If not None, the weight ``w[i]`` applies to the unsquared residual "
"``y[i] - y_hat[i]`` at ``x[i]``. Ideally the weights are chosen so that the "
"errors of the products ``w[i]*y[i]`` all have the same variance.  When using "
"inverse-variance weighting, use ``w[i] = 1/sigma(y[i])``.  The default value "
"is None."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:58
msgid "**coef**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:-1
msgid "ndarray, shape (M,) or (M, K)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:54
msgid ""
"Legendre coefficients ordered from low to high. If `y` was 2-D, the "
"coefficients for the data in column k of `y` are in column `k`. If `deg` is "
"specified as a list, coefficients for terms not included in the fit are set "
"equal to zero in the returned `coef`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:72
msgid "**[residuals, rank, singular_values, rcond]**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:-1
msgid "list"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:61
msgid "These values are only returned if ``full == True``"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:63
msgid "residuals -- sum of squared residuals of the least squares fit"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:64
msgid "rank -- the numerical rank of the scaled Vandermonde matrix"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:65
msgid "singular_values -- singular values of the scaled Vandermonde matrix"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:66
msgid "rcond -- value of `rcond`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:68
msgid "For more details, see `numpy.linalg.lstsq`."
msgstr ""

