#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:111
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:112
msgid ""
"The solution is the coefficients of the Legendre series `p` that minimizes "
"the sum of the weighted squared errors"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:115
msgid ""
"E = \\sum_j w_j^2 * |y_j - p(x_j)|^2,\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:117
msgid ""
"where :math:`w_j` are the weights. This problem is solved by setting up as "
"the (typically) overdetermined matrix equation"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:120
msgid ""
"V(x) * c = w * y,\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:122
msgid ""
"where `V` is the weighted pseudo Vandermonde matrix of `x`, `c` are the "
"coefficients to be solved for, `w` are the weights, and `y` are the observed "
"values.  This equation is then solved using the singular value decomposition "
"of `V`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:127
msgid ""
"If some of the singular values of `V` are so small that they are neglected, "
"then a `RankWarning` will be issued. This means that the coefficient values "
"may be poorly determined. Using a lower order fit will usually get rid of "
"the warning.  The `rcond` parameter can also be set to a value smaller than "
"its default, but the resulting fit may be spurious and have large "
"contributions from roundoff error."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legfit:134
msgid ""
"Fits using Legendre series are usually better conditioned than fits using "
"power series, but much can depend on the distribution of the sample points "
"and the smoothness of the data. If the quality of the fit is inadequate "
"splines may be a good alternative."
msgstr ""

