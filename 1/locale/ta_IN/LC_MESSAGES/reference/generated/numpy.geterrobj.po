#: ../../../reference/generated/numpy.geterrobj.rst:4
msgid "numpy.geterrobj"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.geterrobj:2
msgid "Return the current object that defines floating-point error handling."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.geterrobj:4
msgid ""
"The error object contains all information that defines the error handling "
"behavior in NumPy. `geterrobj` is used internally by the other functions "
"that get and set error handling behavior (`geterr`, `seterr`, `geterrcall`, "
"`seterrcall`)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.geterrobj:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
