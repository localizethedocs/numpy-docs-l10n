#: of numpy.pad:109
msgid "**reflect_type**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.pad:-1
msgid "{'even', 'odd'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.pad:106
msgid ""
"Used in 'reflect', and 'symmetric'.  The 'even' style is the default with an "
"unaltered reflection around the edge value.  For the 'odd' style, the "
"extended part of the array is created by subtracting the reflected values "
"from two times the edge value."
msgstr ""

