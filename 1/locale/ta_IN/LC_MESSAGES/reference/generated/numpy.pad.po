"Used in 'linear_ramp'.  The values used for the ending value of the "
"linear_ramp and that will form the edge of the padded array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.pad:94
msgid ""
"``((before_1, after_1), ... (before_N, after_N))`` unique end values for "
"each axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.pad:97
msgid ""
"``(before, after)`` or ``((before, after),)`` yields same before and after "
"end values for each axis."
msgstr ""

