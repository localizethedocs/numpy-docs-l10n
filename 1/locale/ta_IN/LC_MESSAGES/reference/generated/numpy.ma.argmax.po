msgid "**axis**"
msgstr ""

#: ../../../../docstring of numpy.ma.argmax:-1
msgid "{None, integer}"
msgstr ""

#: ../../../../docstring of numpy.ma.argmax:9
msgid ""
"If None, the index is into the flattened array, otherwise along the "
"specified axis"
msgstr ""

#: ../../../../docstring of numpy.ma.argmax:14
msgid "**fill_value**"
msgstr ""

#: ../../../../docstring of numpy.ma.argmax:-1
msgid "scalar or None, optional"
msgstr ""

#: ../../../../docstring of numpy.ma.argmax:13
msgid ""
"Value used to fill in the masked values.  If None, the output of "
"maximum_fill_value(self._data) is used instead."
msgstr ""

