#: ../../../reference/generated/numpy.partition.rst:4
msgid "numpy.partition"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:2
msgid "Return a partitioned copy of an array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:4
msgid ""
"Creates a copy of the array with its elements rearranged in such a way that "
"the value of the element in k-th position is in the position the value would "
"be in a sorted array.  In the partitioned array, all elements before the k-"
"th element are less than or equal to that element, and all the elements "
"after the k-th element are greater than or equal to that element.  The "
"ordering of the elements in the two partitions is undefined."
msgstr ""

