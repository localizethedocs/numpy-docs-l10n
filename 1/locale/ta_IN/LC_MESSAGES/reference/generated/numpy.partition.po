msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:28
msgid "**kth**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:-1
msgid "int or sequence of ints"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:20
msgid ""
"Element index to partition by. The k-th value of the element will be in its "
"final sorted position and all smaller elements will be moved before it and "
"all equal or greater elements behind it. The order of all elements in the "
"partitions is undefined. If provided with a sequence of k-th it will "
"partition all elements indexed by k-th  of them into their sorted position "
"at once."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:27
msgid "Passing booleans as index is deprecated."
msgstr ""

