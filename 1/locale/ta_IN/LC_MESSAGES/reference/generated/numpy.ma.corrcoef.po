#: ../../../reference/generated/numpy.ma.corrcoef.rst:4
msgid "numpy.ma.corrcoef"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.corrcoef:2
msgid "Return Pearson product-moment correlation coefficients."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.corrcoef:4
msgid ""
"Except for the handling of missing data this function does the same as "
"`numpy.corrcoef`. For more details and examples, see `numpy.corrcoef`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.corrcoef:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.corrcoef:12
msgid "**x**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.corrcoef:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.corrcoef:10
msgid ""
"A 1-D or 2-D array containing multiple variables and observations. Each row "
"of `x` represents a variable, and each column a single observation of all "
"those variables. Also see `rowvar` below."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.corrcoef:16
msgid "**y**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.corrcoef:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.corrcoef:15
msgid ""
"An additional set of variables and observations. `y` has the same shape as "
"`x`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.corrcoef:22
msgid "**rowvar**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.corrcoef:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.corrcoef:19
msgid ""
"If `rowvar` is True (default), then each row represents a variable, with "
"observations in the columns. Otherwise, the relationship is transposed: each "
"column represents a variable, while the rows contain observations."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.corrcoef:27
msgid "**bias**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.corrcoef:-1
msgid "_NoValue, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.corrcoef:25 numpy.ma.extras.corrcoef:36
msgid "Has no effect, do not use."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.corrcoef:33
msgid "**allow_masked**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.corrcoef:30
msgid ""
"If True, masked values are propagated pair-wise: if a value is masked in "
"`x`, the corresponding value is masked in `y`. If False, raises an "
"exception.  Because `bias` is deprecated, this argument needs to be treated "
"as keyword only to avoid a warning."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.corrcoef:45
msgid "**ddof**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.corrcoef:50
msgid ":obj:`numpy.corrcoef`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.corrcoef:51
msgid "Equivalent function in top-level NumPy module."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.corrcoef:52
msgid ":obj:`cov`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.corrcoef:53
msgid "Estimate the covariance matrix."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.corrcoef:57
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.corrcoef:58
msgid ""
"This function accepts but discards arguments `bias` and `ddof`.  This is for "
"backwards compatibility with previous versions of this function.  These "
"arguments had no effect on the return values of the function and can be "
"safely ignored in this and previous versions of numpy."
msgstr ""
