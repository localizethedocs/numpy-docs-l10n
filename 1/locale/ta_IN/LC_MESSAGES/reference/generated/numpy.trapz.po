#: ../../../reference/generated/numpy.trapz.rst:4
msgid "numpy.trapz"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.trapz:2
msgid "Integrate along the given axis using the composite trapezoidal rule."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.trapz:4
msgid ""
"If `x` is provided, the integration happens in sequence along its elements - "
"they are not sorted."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.trapz:7
msgid ""
"Integrate `y` (`x`) along each 1d slice on the given axis, compute :math:"
"`\\int y(x) dx`. When `x` is specified, this integrates along the parametric "
"curve, computing :math:`\\int_t y(t) dt = \\int_t y(t) \\left.\\frac{dx}"
"{dt}\\right|_{x=x(t)} dt`."
msgstr ""

