msgid "int or ndarray of ints"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.randint:39
msgid ""
"`size`-shaped array of random integers from the appropriate distribution, or "
"a single such random int if `size` not provided."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.randint:51
msgid ":obj:`random_integers`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.randint:52
msgid ""
"similar to `randint`, only for the closed interval [`low`, `high`], and 1 is "
"the lowest value if `high` is omitted."
