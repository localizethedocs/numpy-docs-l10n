#: ../../../reference/random/generated/numpy.random.chisquare.rst:4
msgid "numpy.random.chisquare"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.chisquare:2
msgid "Draw samples from a chi-square distribution."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.chisquare:4
msgid ""
"When `df` independent random variables, each with standard normal "
"distributions (mean 0, variance 1), are squared and summed, the resulting "
"distribution is chi-square (see Notes).  This distribution is often used in "
"hypothesis testing."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.chisquare:10
msgid ""
"New code should use the `~numpy.random.Generator.chisquare` method of a "
"`~numpy.random.Generator` instance instead; please see the :ref:`random-"
"quick-start`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.chisquare:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.chisquare:17
msgid "**df**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.chisquare:-1
msgid "float or array_like of floats"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.chisquare:17
msgid "Number of degrees of freedom, must be > 0."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.chisquare:23
msgid "**size**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.chisquare:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.chisquare:20
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn.  If size is ``None`` (default), a single value is "
"returned if ``df`` is a scalar.  Otherwise, ``np.array(df).size`` samples "
"are drawn."
msgstr ""

