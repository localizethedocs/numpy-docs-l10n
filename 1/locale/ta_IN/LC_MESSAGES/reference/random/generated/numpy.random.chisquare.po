msgid "ValueError"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.chisquare:36
msgid ""
"When `df` <= 0 or when an inappropriate `size` (e.g. ``size=-1``) is given."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.chisquare:44
msgid ":obj:`random.Generator.chisquare`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.chisquare:45
msgid "which should be used for new code."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.chisquare:49
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.chisquare:50
msgid ""
"The variable obtained by summing the squares of `df` independent, standard "
"normally distributed random variables:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.chisquare:53
msgid ""
"Q = \\sum_{i=0}^{\\mathtt{df}} X^2_i\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.chisquare:55
msgid "is chi-square distributed, denoted"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.chisquare:57
msgid ""
"Q \\sim \\chi^2_k.\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.chisquare:59
msgid "The probability density function of the chi-squared distribution is"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.chisquare:61
msgid ""
"p(x) = \\frac{(1/2)^{k/2}}{\\Gamma(k/2)}\n"
"x^{k/2 - 1} e^{-x/2},\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.chisquare:64
msgid "where :math:`\\Gamma` is the gamma function,"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.chisquare:66
msgid ""
"\\Gamma(x) = \\int_0^{-\\infty} t^{x - 1} e^{-t} dt.\n"
"\n"
msgstr ""

