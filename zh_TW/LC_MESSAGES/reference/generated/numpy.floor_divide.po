#: ../../../reference/generated/numpy.floor_divide.rst:4
msgid "numpy.floor\\_divide"
msgstr ""

#: ../../../../docstring of numpy.floor_divide:2
msgid ""
"Return the largest integer smaller or equal to the division of the inputs. "
"It is equivalent to the Python ``//`` operator and pairs with the Python "
"``%`` (`remainder`), function so that ``a = a % b + b * (a // b)`` up to "
"roundoff."
msgstr ""

