#: ../../../reference/generated/numpy.sinc.rst:4
msgid "numpy.sinc"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.sinc:2
msgid "Return the normalized sinc function."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.sinc:4
msgid ""
"The sinc function is equal to :math:`\\sin(\\pi x)/(\\pi x)` for any "
"argument :math:`x\\ne 0`. ``sinc(0)`` takes the limit value 1, making "
"``sinc`` not only everywhere continuous but also infinitely differentiable."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.sinc:10
msgid ""
"Note the normalization factor of ``pi`` used in the definition. This is the "
"most commonly used definition in signal processing. Use ``sinc(x / np.pi)`` "
"to obtain the unnormalized sinc function :math:`\\sin(x)/x` that is more "
"common in mathematics."
msgstr ""

