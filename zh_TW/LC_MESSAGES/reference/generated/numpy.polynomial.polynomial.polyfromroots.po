msgid "numpy.polynomial.polynomial.polyfromroots"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfromroots:2
msgid "Generate a monic polynomial with given roots."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfromroots:4
msgid "Return the coefficients of the polynomial"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfromroots:6
msgid ""
"p(x) = (x - r_0) * (x - r_1) * ... * (x - r_n),\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfromroots:8
msgid ""
"where the :math:`r_n` are the roots specified in `roots`.  If a zero has "
"multiplicity n, then it must appear in `roots` n times. For instance, if 2 "
"is a root of multiplicity three and 3 is a root of multiplicity 2, then "
"`roots` looks something like [2, 2, 2, 3, 3]. The roots can appear in any "
"order."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfromroots:14
msgid "If the returned coefficients are `c`, then"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfromroots:16
msgid ""
"p(x) = c_0 + c_1 * x + ... +  x^n\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfromroots:18
msgid ""
"The coefficient of the last term is 1 for monic polynomials in this form."
msgstr ""

