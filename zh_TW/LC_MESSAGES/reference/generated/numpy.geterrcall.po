#: ../../../reference/generated/numpy.geterrcall.rst:4
msgid "numpy.geterrcall"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geterrcall:2
msgid "Return the current callback function used on floating-point errors."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geterrcall:4
msgid ""
"When the error handling for a floating-point error (one of \"divide\", "
"\"over\", \"under\", or \"invalid\") is set to 'call' or 'log', the function "
"that is called or the log instance that is written to is returned by "
"`geterrcall`. This function or log instance has been set with `seterrcall`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geterrcall:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geterrcall:23
msgid "**errobj**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geterrcall:-1
msgid "callable, log instance or None"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geterrcall:16
msgid ""
"The current error handler. If no handler was set through `seterrcall`, "
"``None`` is returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geterrcall:28
msgid ":obj:`seterrcall`, :obj:`seterr`, :obj:`geterr`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geterrcall:32
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.geterrcall:33
msgid ""
"For complete documentation of the types of floating-point exceptions and "
"treatment options, see `seterr`."
msgstr ""

