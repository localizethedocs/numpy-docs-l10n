#: ../../../reference/generated/numpy.mask_indices.rst:4
msgid "numpy.mask\\_indices"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.mask_indices:2
msgid "Return the indices to access (n, n) arrays, given a masking function."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.mask_indices:4
msgid ""
"Assume `mask_func` is a function that, for a square array a of size ``(n, "
"n)`` with a possible offset argument `k`, when called as ``mask_func(a, k)`` "
"returns a new array with zeros in certain locations (functions like `triu` "
"or `tril` do precisely this). Then this function returns the indices where "
"the non-zero values would be located."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.mask_indices:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.mask_indices:13
msgid "**n**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.mask_indices:-1
msgid "int"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.mask_indices:13
msgid "The returned indices will be valid to access arrays of shape (n, n)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.mask_indices:18
msgid "**mask_func**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.mask_indices:-1
msgid "callable"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.mask_indices:16
msgid ""
"A function whose call signature is similar to that of `triu`, `tril`. That "
"is, ``mask_func(x, k)`` returns a boolean array, shaped like `x`. `k` is an "
"optional argument to the function."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.mask_indices:23
msgid "**k**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.mask_indices:-1
msgid "scalar"
msgstr "純量（scalar）"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.mask_indices:21
msgid ""
"An optional argument which is passed through to `mask_func`. Functions like "
"`triu`, `tril` take a second argument that is interpreted as an offset."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.mask_indices:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.mask_indices:35
msgid "**indices**"
msgstr "**indices**"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.mask_indices:-1
msgid "tuple of arrays."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.mask_indices:28
msgid ""
"The `n` arrays of indices corresponding to the locations where "
"``mask_func(np.ones((n, n)), k)`` is True."
msgstr ""

