#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.take_along_axis:49
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.take_along_axis:50
msgid ""
"This is equivalent to (but faster than) the following use of `ndindex` and "
"`s_`, which sets each of ``ii`` and ``kk`` to a tuple of indices::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.take_along_axis:53
msgid ""
"Ni, M, Nk = a.shape[:axis], a.shape[axis], a.shape[axis+1:]\n"
"J = indices.shape[axis]  # Need not equal M\n"
"out = np.empty(Ni + (J,) + Nk)\n"
"\n"
"for ii in ndindex(Ni):\n"
"    for kk in ndindex(Nk):\n"
"        a_1d       = a      [ii + s_[:,] + kk]\n"
"        indices_1d = indices[ii + s_[:,] + kk]\n"
"        out_1d     = out    [ii + s_[:,] + kk]\n"
"        for j in range(J):\n"
"            out_1d[j] = a_1d[indices_1d[j]]"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.take_along_axis:65
msgid "Equivalently, eliminating the inner loop, the last two lines would be::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.take_along_axis:67
msgid "out_1d[:] = a_1d[indices_1d]"
msgstr ""

