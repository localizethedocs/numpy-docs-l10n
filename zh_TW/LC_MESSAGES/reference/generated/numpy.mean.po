#: of numpy.mean:61
msgid "**m**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.mean:-1
msgid "ndarray, see dtype parameter above"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.mean:54
msgid ""
"If `out=None`, returns a new array containing the mean values, otherwise a "
"reference to the output array is returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.mean:66
msgid ":obj:`average`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.mean:67
msgid "Weighted average"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.mean:68
msgid ":obj:`std`, :obj:`var`, :obj:`nanmean`, :obj:`nanstd`, :obj:`nanvar`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.mean:72
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.mean:73
msgid ""
"The arithmetic mean is the sum of the elements along the axis divided by the "
"number of elements."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.mean:76
msgid ""
"Note that for floating-point input, the mean is computed using the same "
"precision the input has.  Depending on the input data, this can cause the "
"results to be inaccurate, especially for `float32` (see example below).  "
"Specifying a higher-precision accumulator using the `dtype` keyword can "
"alleviate this issue."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.mean:82
msgid ""
"By default, `float16` results are computed using `float32` intermediates for "
"extra precision."
msgstr ""

