msgid "numpy.ma.MaskedArray.argsort"
msgstr ""

#: ../../../reference/generated/numpy.ma.MaskedArray.argsort.rst:8
msgid "method"
msgstr "方法"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.argsort:2
msgid ""
"Return an ndarray of indices that sort the array along the specified axis.  "
"Masked values are filled beforehand to `fill_value`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.argsort:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.argsort:18
msgid "**axis**"
msgstr "**axis**"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.argsort:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.argsort:10
msgid ""
"Axis along which to sort. If None, the default, the flattened array is used."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.argsort:13
msgid ""
"Previously, the default was documented to be -1, but that was in error. At "
"some future date, the default will change to -1, as originally intended. "
"Until then, the axis should be given explicitly when ``arr.ndim > 1``, to "
"avoid a FutureWarning."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.argsort:21
msgid "**kind**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.argsort:-1
msgid "{'quicksort', 'mergesort', 'heapsort', 'stable'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.argsort:21
msgid "The sorting algorithm used."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.argsort:26
msgid "**order**"
msgstr "**命令**"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.argsort:-1
msgid "list, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.argsort:24
msgid ""
"When `a` is an array with fields defined, this argument specifies which "
"fields to compare first, second, etc.  Not all fields need be specified."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.argsort:33
msgid "**endwith**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.argsort:-1
msgid "{True, False}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.argsort:29
msgid ""
"Whether missing values (if any) should be treated as the largest values "
"(True) or the smallest values (False) When the array contains unmasked "
"values at the same extremes of the datatype, the ordering of these values "
"and the masked values is undefined."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.argsort:37
msgid "**fill_value**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.argsort:-1
msgid "scalar or None, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.argsort:36
msgid ""
"Value used internally for the masked values. If ``fill_value`` is not None, "
"it supersedes ``endwith``."
msgstr ""

