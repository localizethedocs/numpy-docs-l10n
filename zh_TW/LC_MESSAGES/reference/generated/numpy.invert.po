#: ../../../reference/generated/numpy.invert.rst:4
msgid "numpy.invert"
msgstr ""

#: ../../../../docstring of numpy.invert:2
msgid "Compute bit-wise inversion, or bit-wise NOT, element-wise."
msgstr ""

#: ../../../../docstring of numpy.invert:4
msgid ""
"Computes the bit-wise NOT of the underlying binary representation of the "
"integers in the input arrays. This ufunc implements the C/Python operator "
"``~``."
msgstr ""

#: ../../../../docstring of numpy.invert:8
msgid ""
"For signed integer inputs, the bit-wise NOT of the absolute value is "
"returned. In a two's-complement system, this operation effectively flips all "
"the bits, resulting in a representation that corresponds to the negative of "
"the input plus one. This is the most common method of representing signed "
"integers on computers [Rde927b304c4f-1]_. A N-bit two's-complement system "
"can represent every integer in the range :math:`-2^{N-1}` to :math:"
"`+2^{N-1}-1`."
msgstr ""

