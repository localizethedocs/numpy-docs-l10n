#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.laggauss:33
msgid ""
"The results have only been tested up to degree 100 higher degrees may be "
"problematic. The weights are determined by using the fact that"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.laggauss:36
msgid ""
"w_k = c / (L'_n(x_k) * L_{n-1}(x_k))\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
