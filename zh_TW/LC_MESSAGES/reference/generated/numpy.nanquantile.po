#: ../../../reference/generated/numpy.nanquantile.rst:4
msgid "numpy.nanquantile"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:2
msgid ""
"Compute the qth quantile of the data along the specified axis, while "
"ignoring nan values. Returns the qth quantile(s) of the array elements."
msgstr ""

