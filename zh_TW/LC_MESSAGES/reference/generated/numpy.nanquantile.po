msgstr "array_like"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:11
msgid ""
"Input array or object that can be converted to an array, containing nan "
"values to be ignored"
msgstr ""

