#: of numpy.nanquantile:41
msgid "'closest_observation'"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:42
msgid "'interpolated_inverted_cdf'"
