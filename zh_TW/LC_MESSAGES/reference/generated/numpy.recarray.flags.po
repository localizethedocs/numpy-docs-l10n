#: ../../../reference/generated/numpy.recarray.flags.rst:4
msgid "numpy.recarray.flags"
msgstr ""

#: ../../../reference/generated/numpy.recarray.flags.rst:8
msgid "attribute"
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:2
msgid "Information about the memory layout of the array."
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:0
msgid "Attributes"
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:9
msgid "**C_CONTIGUOUS (C)**"
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:9
msgid "The data is in a single, C-style contiguous segment."
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:12
msgid "**F_CONTIGUOUS (F)**"
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:12
msgid "The data is in a single, Fortran-style contiguous segment."
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:15
msgid "**OWNDATA (O)**"
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:15
msgid "The array owns the memory it uses or borrows it from another object."
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:27
msgid "**WRITEABLE (W)**"
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:18
msgid ""
"The data area can be written to.  Setting this to False locks the data, "
"making it read-only.  A view (slice, etc.) inherits WRITEABLE from its base "
"array at creation time, but a view of a writeable array may be subsequently "
"locked while the base array remains writeable. (The opposite is not true, in "
"that a view of a locked array may not be made writeable.  However, "
"currently, locking a base object does not lock any views that already "
"reference it, so under that circumstance it is possible to alter the "
"contents of a locked array via a previously created writeable view onto "
"it.)  Attempting to change a non-writeable array raises a RuntimeError "
"exception."
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:30
msgid "**ALIGNED (A)**"
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:30
msgid "The data and all elements are aligned appropriately for the hardware."
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:35
msgid "**WRITEBACKIFCOPY (X)**"
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:33
msgid ""
"This array is a copy of some other array. The C-API function "
"PyArray_ResolveWritebackIfCopy must be called before deallocating to the "
"base array will be updated with the contents of this array."
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:38
msgid "**FNC**"
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:38
msgid "F_CONTIGUOUS and not C_CONTIGUOUS."
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:41
msgid "**FORC**"
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:41
msgid "F_CONTIGUOUS or C_CONTIGUOUS (one-segment test)."
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:44
msgid "**BEHAVED (B)**"
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:44
msgid "ALIGNED and WRITEABLE."
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:47
msgid "**CARRAY (CA)**"
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:47
msgid "BEHAVED and C_CONTIGUOUS."
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:59
msgid "**FARRAY (FA)**"
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:50
msgid "BEHAVED and F_CONTIGUOUS and not C_CONTIGUOUS."
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:62
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:63
msgid ""
"The `flags` object can be accessed dictionary-like (as in ``a."
"flags['WRITEABLE']``), or by using lowercased attribute names (as in ``a."
"flags.writeable``). Short flag names are only supported in dictionary access."
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:67
msgid ""
"Only the WRITEBACKIFCOPY, WRITEABLE, and ALIGNED flags can be changed by the "
"user, via direct assignment to the attribute or dictionary entry, or by "
"calling `ndarray.setflags`."
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:71
msgid "The array flags cannot be set arbitrarily:"
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:73
msgid "WRITEBACKIFCOPY can only be set ``False``."
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:74
msgid "ALIGNED can only be set ``True`` if the data is truly aligned."
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:75
msgid ""
"WRITEABLE can only be set ``True`` if the array owns its own memory or the "
"ultimate owner of the memory exposes a writeable buffer interface or is a "
"string."
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:79
msgid ""
"Arrays can be both C-style and Fortran-style contiguous simultaneously. This "
"is clear for 1-dimensional arrays, but can also be true for higher "
"dimensional arrays."
msgstr ""

#: ../../../../docstring of numpy.recarray.flags:83
msgid ""
"Even for contiguous arrays a stride for a given dimension ``arr."
"strides[dim]`` may be *arbitrary* if ``arr.shape[dim] == 1`` or the array "
"has no elements. It does *not* generally hold that ``self.strides[-1] == "
"self.itemsize`` for C-style contiguous arrays or ``self.strides[0] == self."
"itemsize`` for Fortran-style contiguous arrays is true."
msgstr ""
