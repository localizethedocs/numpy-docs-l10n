#: ../../../reference/generated/numpy.fft.rfftfreq.rst:4
msgid "numpy.fft.rfftfreq"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftfreq:2
msgid ""
"Return the Discrete Fourier Transform sample frequencies (for usage with "
"rfft, irfft)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftfreq:5
msgid ""
"The returned float array `f` contains the frequency bin centers in cycles "
"per unit of the sample spacing (with zero at the start).  For instance, if "
"the sample spacing is in seconds, then the frequency unit is cycles/second."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftfreq:9
msgid "Given a window length `n` and a sample spacing `d`::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftfreq:11
msgid ""
"f = [0, 1, ...,     n/2-1,     n/2] / (d*n)   if n is even\n"
"f = [0, 1, ..., (n-1)/2-1, (n-1)/2] / (d*n)   if n is odd"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfftfreq:14
msgid ""
"Unlike `fftfreq` (but like `scipy.fftpack.rfftfreq`) the Nyquist frequency "
"component is considered to be positive."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
