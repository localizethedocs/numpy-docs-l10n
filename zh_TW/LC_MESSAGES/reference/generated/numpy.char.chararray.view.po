#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.view:-1
msgid "data-type or ndarray sub-class, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.view:12
msgid ""
"Data-type descriptor of the returned view, e.g., float32 or int16. Omitting "
"it results in the view having the same data-type as `a`. This argument can "
"also be specified as an ndarray sub-class, which then specifies the type of "
"the returned object (this is equivalent to setting the ``type`` parameter)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.view:28
msgid "**type**"
msgstr "**type**"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.view:-1
msgid "Python type, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.view:19
msgid ""
"Type of the returned view, e.g., ndarray or matrix.  Again, omission of the "
"parameter results in type preservation."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.view:31
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.view:32
msgid "``a.view()`` is used two different ways:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.view:34
msgid ""
"``a.view(some_dtype)`` or ``a.view(dtype=some_dtype)`` constructs a view of "
"the array's memory with a different data-type.  This can cause a "
"reinterpretation of the bytes of memory."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.view:38
msgid ""
"``a.view(ndarray_subclass)`` or ``a.view(type=ndarray_subclass)`` just "
"returns an instance of `ndarray_subclass` that looks at the same array (same "
"shape, dtype, etc.)  This does not cause a reinterpretation of the memory."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.view:43
msgid ""
"For ``a.view(some_dtype)``, if ``some_dtype`` has a different number of "
"bytes per entry than the previous dtype (for example, converting a regular "
"array to a structured array), then the last axis of ``a`` must be "
"contiguous. This axis will be resized in the result."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.char.chararray.view:48
msgid ""
"Only the last axis needs to be contiguous. Previously, the entire array had "
"to be C-contiguous."
msgstr ""

