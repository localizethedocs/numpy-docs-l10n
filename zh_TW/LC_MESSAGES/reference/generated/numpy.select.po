#: ../../../reference/generated/numpy.select.rst:4
msgid "numpy.select"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.select:2
msgid ""
"Return an array drawn from elements in choicelist, depending on conditions."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.select:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.select:10
msgid "**condlist**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.select:-1
msgid "list of bool ndarrays"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.select:8
msgid ""
"The list of conditions which determine from which array in `choicelist` the "
"output elements are taken. When multiple conditions are satisfied, the first "
"one encountered in `condlist` is used."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.select:14
msgid "**choicelist**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.select:-1
msgid "list of ndarrays"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.select:13
msgid ""
"The list of arrays from which the output elements are taken. It has to be of "
"the same length as `condlist`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.select:17
msgid "**default**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.select:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.select:17
msgid "The element inserted in `output` when all conditions evaluate to False."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.select:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.select:30
msgid "**output**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.select:-1
msgid "ndarray"
msgstr "ndarray"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.select:22
msgid ""
"The output at position m is the m-th element of the array in `choicelist` "
"where the m-th element of the corresponding array in `condlist` is True."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.select:35
msgid ":obj:`where`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.select:36
msgid "Return elements from one of two arrays depending on condition."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.select:37
msgid ""
":obj:`take`, :obj:`choose`, :obj:`compress`, :obj:`diag`, :obj:`diagonal`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.select:43
msgid "Examples"
msgstr "範例"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.select:50
msgid ""
"Beginning with an array of integers from 0 to 5 (inclusive), elements less "
"than ``3`` are negated, elements greater than ``3`` are squared, and "
"elements not meeting either of these conditions (exactly ``3``) are replaced "
"with a `default` value of ``42``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.select:61
msgid ""
"When multiple conditions are satisfied, the first one encountered in "
"`condlist` is used."
msgstr ""

