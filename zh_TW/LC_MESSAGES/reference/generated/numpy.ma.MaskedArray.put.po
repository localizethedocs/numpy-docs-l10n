#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.put:2
msgid "Set storage-indexed locations to corresponding values."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.put:4
msgid ""
"Sets self._data.flat[n] = values[n] for each n in indices. If `values` is "
"shorter than `indices` then it will repeat. If `values` has some masked "
"values, the initial mask is updated in consequence, else the corresponding "
"values are unmasked."
msgstr ""

