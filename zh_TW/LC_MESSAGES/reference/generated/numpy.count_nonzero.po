#: ../../../reference/generated/numpy.count_nonzero.rst:4
msgid "numpy.count\\_nonzero"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.count_nonzero:2
msgid "Counts the number of non-zero values in the array ``a``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.count_nonzero:4
msgid ""
"The word \"non-zero\" is in reference to the Python 2.x built-in method "
"``__nonzero__()`` (renamed ``__bool__()`` in Python 3.x) of Python objects "
"that tests an object's \"truthfulness\". For example, any number is "
"considered truthful if it is nonzero, whereas any string is considered "
"truthful if it is not the empty string. Thus, this function (recursively) "
"counts how many elements in ``a`` (and in sub-arrays thereof) have their "
"``__nonzero__()`` or ``__bool__()`` method evaluated to ``True``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.count_nonzero:0
msgid "Parameters"
msgstr "參數"

