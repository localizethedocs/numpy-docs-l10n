#: ../../../reference/generated/numpy.polynomial.legendre.legder.rst:4
msgid "numpy.polynomial.legendre.legder"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legder:2
msgid "Differentiate a Legendre series."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legder:4
msgid ""
"Returns the Legendre series coefficients `c` differentiated `m` times along "
"`axis`.  At each iteration the result is multiplied by `scl` (the scaling "
"factor is for use in a linear change of variable). The argument `c` is an "
"array of coefficients from low to high degree along each axis, e.g., [1,2,3] "
"represents the series ``1*L_0 + 2*L_1 + 3*L_2`` while [[1,2],[1,2]] "
"represents ``1*L_0(x)*L_0(y) + 1*L_1(x)*L_0(y) + 2*L_0(x)*L_1(y) + "
"2*L_1(x)*L_1(y)`` if axis=0 is ``x`` and axis=1 is ``y``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legder:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legder:18
msgid "**c**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legder:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legder:16
msgid ""
"Array of Legendre series coefficients. If c is multidimensional the "
"different axis correspond to different variables with the degree in each "
"axis given by the corresponding index."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legder:21
msgid "**m**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legder:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legder:21
msgid "Number of derivatives taken, must be non-negative. (Default: 1)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legder:26
msgid "**scl**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legder:-1
msgid "scalar, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legder:24
msgid ""
"Each differentiation is multiplied by `scl`.  The end result is "
"multiplication by ``scl**m``.  This is for use in a linear change of "
"variable. (Default: 1)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
