msgid "data-type, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap:29
msgid "The data-type used to interpret the file contents. Default is `uint8`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap:48 numpy.memmap:85
msgid "**mode**"
msgstr ""

