#: ../../../reference/generated/numpy.memmap.rst:2
msgid "numpy.memmap"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap:2
msgid "Create a memory-map to an array stored in a *binary* file on disk."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap:4
msgid ""
"Memory-mapped files are used for accessing small segments of large files on "
"disk, without reading the entire file into memory.  NumPy's memmap's are "
"array-like objects.  This differs from Python's ``mmap`` module, which uses "
"file-like objects."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap:9
msgid ""
"This subclass of ndarray has some unpleasant interactions with some "
"operations, because it doesn't quite fit properly as a subclass. An "
"alternative to using this subclass is to create the ``mmap`` object "
"yourself, then create an ndarray with ndarray.__new__ directly, passing the "
"object created in its 'buffer=' parameter."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap:15
msgid ""
"This class may at some point be turned into a factory function which returns "
"a view into an mmap buffer."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap:18
msgid ""
"Flush the memmap instance to write the changes to the file. Currently there "
"is no API to close the underlying ``mmap``. It is tricky to ensure the "
"resource is actually closed, since it may be shared between different memmap "
"instances."
msgstr ""

