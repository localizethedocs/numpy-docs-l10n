#: of numpy.memmap:-1
msgid "{'r+', 'r', 'w+', 'c'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap:33
msgid "The file is opened in this mode:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap:36
msgid "'r'"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap:36
msgid "Open existing file for reading only."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap:38
msgid "'r+'"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap:38
msgid "Open existing file for reading and writing."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap:40
msgid "'w+'"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap:40
msgid ""
"Create or overwrite existing file for reading and writing. If ``mode == "
"'w+'`` then `shape` must also be specified."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap:43
msgid "'c'"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap:43
msgid ""
"Copy-on-write: assignments affect data in memory, but changes are not saved "
"to disk.  The file on disk is read-only."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap:48
msgid "Default is 'r+'."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap:57 numpy.memmap:82
msgid "**offset**"
msgstr "**offset**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap:51
msgid ""
"In the file, array data starts at this offset. Since `offset` is measured in "
"bytes, it should normally be a multiple of the byte-size of `dtype`. When "
"``mode != 'r'``, even positive offsets beyond end of file are valid; The "
"file will be extended to accommodate the additional data. By default, "
"``memmap`` will start at the beginning of the file, even if ``filename`` is "
"a file pointer ``fp`` and ``fp.tell() != 0``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap:68
msgid "**shape**"
msgstr "**shape**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap:-1
msgid "int or sequence of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap:60
msgid ""
"The desired shape of the array. If ``mode == 'r'`` and the number of "
"remaining bytes after `offset` is not a multiple of the byte-size of "
"`dtype`, you must specify `shape`. By default, the returned array will be 1-"
"D with the number of elements determined by file size and data-type."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap:66
msgid ""
"The shape parameter can now be any integer sequence type, previously types "
"were limited to tuple and int."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap:74
msgid "**order**"
msgstr "**命令**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap:-1
msgid "{'C', 'F'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap:71
msgid ""
"Specify the order of the ndarray memory layout: :term:`row-major`, C-style "
"or :term:`column-major`, Fortran-style.  This only has an effect if the "
"shape is greater than 1-D.  The default order is 'C'."
msgstr ""

