#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap:110
msgid ""
"The memmap object can be used anywhere an ndarray is accepted. Given a "
"memmap ``fp``, ``isinstance(fp, numpy.ndarray)`` returns ``True``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap:114
msgid "Memory-mapped files cannot be larger than 2GB on 32-bit systems."
