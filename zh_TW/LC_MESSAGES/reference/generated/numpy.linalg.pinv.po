#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.pinv:2
msgid "Compute the (Moore-Penrose) pseudo-inverse of a matrix."
msgstr "計算矩陣的（摩爾-彭羅斯）偽反向。"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.pinv:4
msgid ""
"Calculate the generalized inverse of a matrix using its singular-value "
"decomposition (SVD) and including all *large* singular values."
msgstr ""

