msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.pinv:14
msgid ""
"Cutoff for small singular values. Singular values less than or equal to "
"``rcond * largest_singular_value`` are set to zero. Broadcasts against the "
"stack of matrices. Default: ``1e-15``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.pinv:22
msgid "**hermitian**"
msgstr ""

