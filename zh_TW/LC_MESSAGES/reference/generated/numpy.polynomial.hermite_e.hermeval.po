#: of numpy.polynomial.hermite_e.hermeval:48
msgid "The shape of the return value is described above."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite_e.py:docstring
#: of numpy.polynomial.hermite_e.hermeval:59
msgid ""
":obj:`hermeval2d`, :obj:`hermegrid2d`, :obj:`hermeval3d`, :obj:`hermegrid3d`"
msgstr ""

