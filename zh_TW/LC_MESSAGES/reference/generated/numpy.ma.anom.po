#: of numpy.ma.core.anom:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.anom:11
msgid ""
"Axis over which the anomalies are taken. The default is to use the mean of "
"the flattened array as reference."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.anom:26
