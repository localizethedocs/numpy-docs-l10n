msgid "numpy.ma.anom"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.anom:2
msgid ""
"Compute the anomalies (deviations from the arithmetic mean) along the given "
"axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.anom:5
msgid ""
"Returns an array of anomalies, with the same shape as the input and where "
"the arithmetic mean is computed along the given axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.anom:0
msgid "Parameters"
msgstr "參數"

