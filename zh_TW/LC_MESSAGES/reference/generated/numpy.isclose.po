#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.isclose:50
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.isclose:53
msgid ""
"For finite values, isclose uses the following equation to test whether two "
"floating point values are equivalent."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.isclose:56
msgid "absolute(`a` - `b`) <= (`atol` + `rtol` * absolute(`b`))"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.isclose:58
msgid ""
"Unlike the built-in `math.isclose`, the above equation is not symmetric in "
"`a` and `b` -- it assumes `b` is the reference value -- so that `isclose(a, "
"b)` might be different from `isclose(b, a)`. Furthermore, the default value "
"of atol is not zero, and is used to determine what small values should be "
"considered close to zero. The default value is appropriate for expected "
"values of order unity: if the expected values are significantly smaller than "
"one, it can result in false positives. `atol` should be carefully selected "
"for the use case at hand. A zero value for `atol` will result in `False` if "
"either `a` or `b` is zero."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.isclose:68
msgid ""
"`isclose` is not defined for non-numeric data types. `bool` is considered a "
"numeric data-type for this purpose."
msgstr ""

