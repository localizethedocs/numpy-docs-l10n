#: of numpy.isclose:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.isclose:39
msgid "**y**"
msgstr "**y**"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.isclose:31
msgid ""
"Returns a boolean array of where `a` and `b` are equal within the given "
"tolerance. If both `a` and `b` are scalars, returns a single boolean value."
msgstr ""

