msgid "bool or ndarray of bool"
msgstr ""

#: ../../../../docstring of numpy.greater_equal:33
msgid ""
"Output array, element-wise comparison of `x1` and `x2`. Typically of type "
"bool, unless ``dtype=object`` is passed. This is a scalar if both `x1` and "
"`x2` are scalars."
msgstr ""

