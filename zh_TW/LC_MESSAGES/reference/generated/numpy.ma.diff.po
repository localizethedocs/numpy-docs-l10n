#: of numpy.ma.core.diff:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.diff:12
msgid "**a**"
msgstr "**a**"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.diff:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.diff:12
msgid "Input array"
msgstr ""

