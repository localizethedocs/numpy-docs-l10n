msgid "numpy.set\\_string\\_function"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/arrayprint.py:docstring
#: of numpy.core.arrayprint.set_string_function:2
msgid "Set a Python function to be used when pretty printing arrays."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/arrayprint.py:docstring
#: of numpy.core.arrayprint.set_string_function:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/arrayprint.py:docstring
#: of numpy.core.arrayprint.set_string_function:11
msgid "**f**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/arrayprint.py:docstring
#: of numpy.core.arrayprint.set_string_function:-1
msgid "function or None"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/arrayprint.py:docstring
#: of numpy.core.arrayprint.set_string_function:8
msgid ""
"Function to be used to pretty print arrays. The function should expect a "
"single array argument and return a string of the representation of the "
"array. If None, the function is reset to the default NumPy function to print "
"arrays."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/arrayprint.py:docstring
#: of numpy.core.arrayprint.set_string_function:23
msgid "**repr**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/arrayprint.py:docstring
#: of numpy.core.arrayprint.set_string_function:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/arrayprint.py:docstring
#: of numpy.core.arrayprint.set_string_function:14
msgid ""
"If True (default), the function for pretty printing (``__repr__``) is set, "
"if False the function that returns the default string representation "
"(``__str__``) is set."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/arrayprint.py:docstring
#: of numpy.core.arrayprint.set_string_function:28
msgid ":obj:`set_printoptions`, :obj:`get_printoptions`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/arrayprint.py:docstring
#: of numpy.core.arrayprint.set_string_function:34
msgid "Examples"
msgstr "範例"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/arrayprint.py:docstring
#: of numpy.core.arrayprint.set_string_function:45
msgid "We can reset the function to the default:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/core/arrayprint.py:docstring
#: of numpy.core.arrayprint.set_string_function:51
msgid ""
"`repr` affects either pretty printing or normal string representation. Note "
"that ``__repr__`` is still affected by setting ``__str__`` because the width "
"of each array element in the returned string becomes equal to the length of "
"the result of ``__str__()``."
msgstr ""
