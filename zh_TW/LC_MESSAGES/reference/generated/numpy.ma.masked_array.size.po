#: ../../../reference/generated/numpy.ma.masked_array.size.rst:4
msgid "numpy.ma.masked\\_array.size"
msgstr ""

#: ../../../reference/generated/numpy.ma.masked_array.size.rst:8
msgid "attribute"
msgstr ""

#: ../../../../docstring of numpy.ma.masked_array.size:2
msgid "Number of elements in the array."
msgstr ""

#: ../../../../docstring of numpy.ma.masked_array.size:4
msgid ""
"Equal to ``np.prod(a.shape)``, i.e., the product of the array's dimensions."
msgstr ""

#: ../../../../docstring of numpy.ma.masked_array.size:17
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.ma.masked_array.size:18
msgid ""
"`a.size` returns a standard arbitrary precision Python integer. This may not "
"be the case with other methods of obtaining the same value (like the "
"suggested ``np.prod(a.shape)``, which returns an instance of ``np.int_``), "
"and may be relevant if the value is used further in calculations that may "
"overflow a fixed size integer type."
msgstr ""

