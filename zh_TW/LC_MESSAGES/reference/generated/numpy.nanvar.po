#: ../../../reference/generated/numpy.nanvar.rst:4
msgid "numpy.nanvar"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:2
msgid "Compute the variance along the specified axis, while ignoring NaNs."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:4
msgid ""
"Returns the variance of the array elements, a measure of the spread of a "
"distribution.  The variance is computed for the flattened array by default, "
"otherwise over the specified axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:8
msgid ""
"For all-NaN slices or slices with zero degrees of freedom, NaN is returned "
"and a `RuntimeWarning` is raised."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:15
msgid "**a**"
msgstr "**a**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:14
msgid ""
"Array containing numbers whose variance is desired.  If `a` is not an array, "
"a conversion is attempted."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:19
msgid "**axis**"
msgstr "**axis**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:-1
msgid "{int, tuple of int, None}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:18
msgid ""
"Axis or axes along which the variance is computed.  The default is to "
"compute the variance of the flattened array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:24
msgid "**dtype**"
msgstr "**dtype**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:-1
msgid "data-type, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:22
msgid ""
"Type to use in computing the variance.  For arrays of integer type the "
"default is `float64`; for arrays of float types it is the same as the array "
"type."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:29
msgid "**out**"
msgstr "**out**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:-1
msgid "ndarray, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:27
msgid ""
"Alternate output array in which to place the result.  It must have the same "
"shape as the expected output, but the type is cast if necessary."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:34
msgid "**ddof**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:-1
msgid "{int, float}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:32
msgid ""
"\"Delta Degrees of Freedom\": the divisor used in the calculation is ``N - "
"ddof``, where ``N`` represents the number of non-NaN elements. By default "
"`ddof` is zero."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:39
msgid "**keepdims**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:37
msgid ""
"If this is set to True, the axes which are reduced are left in the result as "
"dimensions with size one. With this option, the result will broadcast "
"correctly against the original `a`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:45
msgid "**where**"
msgstr "**where**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:-1
msgid "array_like of bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:42
msgid ""
"Elements to include in the variance. See `~numpy.ufunc.reduce` for details."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:53
msgid "**mean**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:48
msgid ""
"Provide the mean to prevent its recalculation. The mean should have a shape "
"as if it was calculated with ``keepdims=True``. The axis for the calculation "
"of the mean should be the same as used in the call to this var function."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:59
msgid "**correction**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:56
msgid ""
"Array API compatible name for the ``ddof`` parameter. Only one of them can "
"be provided at the same time."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:73
msgid "**variance**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:-1
msgid "ndarray, see dtype parameter above"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:64
msgid ""
"If `out` is None, return a new array containing the variance, otherwise "
"return a reference to the output array. If ddof is >= the number of non-NaN "
"elements in a slice or the slice contains only NaNs, then the result for "
"that slice is NaN."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:78
msgid ":obj:`std`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:79
msgid "Standard deviation"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:80
msgid ":obj:`mean`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:81
msgid "Average"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:82
msgid ":obj:`var`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:83
msgid "Variance while not ignoring NaNs"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:84
msgid ":obj:`nanstd`, :obj:`nanmean`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:86
msgid ":ref:`ufuncs-output-type`"
msgstr ":ref:`ufuncs-output-type`"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:90
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:91
msgid ""
"The variance is the average of the squared deviations from the mean, i.e.,  "
"``var = mean(abs(x - x.mean())**2)``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:94
msgid ""
"The mean is normally calculated as ``x.sum() / N``, where ``N = len(x)``. "
"If, however, `ddof` is specified, the divisor ``N - ddof`` is used instead.  "
"In standard statistical practice, ``ddof=1`` provides an unbiased estimator "
"of the variance of a hypothetical infinite population.  ``ddof=0`` provides "
"a maximum likelihood estimate of the variance for normally distributed "
"variables."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:101
msgid ""
"Note that for complex numbers, the absolute value is taken before squaring, "
"so that the result is always real and nonnegative."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:104
msgid ""
"For floating-point input, the variance is computed using the same precision "
"the input has.  Depending on the input data, this can cause the results to "
"be inaccurate, especially for `float32` (see example below).  Specifying a "
"higher-accuracy accumulator using the ``dtype`` keyword can alleviate this "
"issue."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanvar:110
msgid ""
"For this function to work on sub-classes of ndarray, they must define `sum` "
"with the kwarg `keepdims`"
msgstr ""

