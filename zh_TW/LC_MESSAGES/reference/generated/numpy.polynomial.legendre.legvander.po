#: ../../../reference/generated/numpy.polynomial.legendre.legvander.rst:4
msgid "numpy.polynomial.legendre.legvander"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legvander:2
msgid "Pseudo-Vandermonde matrix of given degree."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legvander:4
msgid ""
"Returns the pseudo-Vandermonde matrix of degree `deg` and sample points `x`. "
"The pseudo-Vandermonde matrix is defined by"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legvander:7
msgid ""
"V[..., i] = L_i(x)\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legvander:9
msgid ""
"where ``0 <= i <= deg``. The leading indices of `V` index the elements of "
"`x` and the last index is the degree of the Legendre polynomial."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legvander:12
msgid ""
"If `c` is a 1-D array of coefficients of length ``n + 1`` and `V` is the "
"array ``V = legvander(x, n)``, then ``np.dot(V, c)`` and ``legval(x, c)`` "
"are the same up to roundoff. This equivalence is useful both for least "
"squares fitting and for the evaluation of a large number of Legendre series "
"of the same degree and sample points."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legvander:0
msgid "Parameters"
msgstr "參數"

