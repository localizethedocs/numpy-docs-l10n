msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legvander:26
msgid "Degree of the resulting matrix."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legvander:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
