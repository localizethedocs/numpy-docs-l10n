msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.ix_:16
msgid ""
"Each sequence should be of integer or boolean type. Boolean sequences will "
"be interpreted as boolean masks for the corresponding dimension (equivalent "
"to passing in ``np.nonzero(boolean_sequence)``)."
msgstr ""

