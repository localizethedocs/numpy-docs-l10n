#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.min:78
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.min:79
msgid ""
"NaN values are propagated, that is if at least one item is NaN, the "
"corresponding min value will be NaN as well. To ignore NaN values (MATLAB "
"behavior), please use nanmin."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.min:83
msgid ""
"Don't use `~numpy.min` for element-wise comparison of 2 arrays; when ``a."
"shape[0]`` is 2, ``minimum(a[0], a[1])`` is faster than ``min(a, axis=0)``."
msgstr ""

