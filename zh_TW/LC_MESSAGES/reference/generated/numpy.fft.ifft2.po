#: ../../../reference/generated/numpy.fft.ifft2.rst:4
msgid "numpy.fft.ifft2"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft2:2
msgid "Compute the 2-dimensional inverse discrete Fourier Transform."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft2:4
msgid ""
"This function computes the inverse of the 2-dimensional discrete Fourier "
"Transform over any number of axes in an M-dimensional array by means of the "
"Fast Fourier Transform (FFT).  In other words, ``ifft2(fft2(a)) == a`` to "
"within numerical accuracy.  By default, the inverse transform is computed "
"over the last two axes of the input array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft2:10
msgid ""
"The input, analogously to `ifft`, should be ordered in the same way as is "
"returned by `fft2`, i.e. it should have the term for zero frequency in the "
"low-order corner of the two axes, the positive frequency terms in the first "
"half of these axes, the term for the Nyquist frequency in the middle of the "
"axes and the negative frequency terms in the second half of both axes, in "
"order of decreasingly negative frequency."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft2:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft2:20
msgid "**a**"
msgstr "**a**"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft2:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft2:20
msgid "Input array, can be complex."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft2:28
msgid "**s**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft2:-1
msgid "sequence of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft2:23
msgid ""
"Shape (length of each axis) of the output (``s[0]`` refers to axis 0, "
"``s[1]`` to axis 1, etc.).  This corresponds to `n` for ``ifft(x, n)``. "
"Along each axis, if the given shape is smaller than that of the input, the "
"input is cropped.  If it is larger, the input is padded with zeros. if `s` "
"is not given, the shape of the input along the axes specified by `axes` is "
"used.  See notes for issue on `ifft` zero padding."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft2:34
msgid "**axes**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft2:31
msgid ""
"Axes over which to compute the FFT.  If not given, the last two axes are "
"used.  A repeated index in `axes` means the transform over that axis is "
"performed multiple times.  A one-element sequence means that a one-"
"dimensional FFT is performed."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft2:45
msgid "**norm**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft2:-1
msgid "{\"backward\", \"ortho\", \"forward\"}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft2:39
msgid ""
"Normalization mode (see `numpy.fft`). Default is \"backward\". Indicates "
"which direction of the forward/backward pair of transforms is scaled and "
"with what normalization factor."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.ifft2:45
msgid "The \"backward\", \"forward\" values were added."
msgstr ""

