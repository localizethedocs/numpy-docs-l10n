#: ../../../reference/generated/numpy.lib.stride_tricks.sliding_window_view.rst:4
msgid "numpy.lib.stride\\_tricks.sliding\\_window\\_view"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:2
msgid ""
"Create a sliding window view into the array with the given window shape."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:4
msgid ""
"Also known as rolling or moving window, the window slides across all "
"dimensions of the array and extracts subsets of the array at all window "
"positions."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:13
msgid "**x**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:13
msgid "Array to create the sliding window view from."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:19
msgid "**window_shape**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:-1
msgid "int or tuple of int"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:16
msgid ""
"Size of window over each axis that takes part in the sliding window. If "
"`axis` is not present, must have same length as the number of input array "
"dimensions. Single integers `i` are treated as if they were the tuple `(i,)`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:27
msgid "**axis**"
msgstr "**axis**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:-1
msgid "int or tuple of int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:22
msgid ""
"Axis or axes along which the sliding window is applied. By default, the "
"sliding window is applied to all axes and `window_shape[i]` will refer to "
"axis `i` of `x`. If `axis` is given as a `tuple of int`, `window_shape[i]` "
"will refer to the axis `axis[i]` of `x`. Single integers `i` are treated as "
"if they were the tuple `(i,)`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:31
msgid "**subok**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:30
msgid ""
"If True, sub-classes will be passed-through, otherwise the returned array "
"will be forced to be a base-class array (default)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:39
msgid "**writeable**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:34
msgid ""
"When true, allow writing to the returned view. The default is false, as this "
"should be used with caution: the returned view contains the same memory "
"location multiple times, so writing to one location will cause others to "
"change."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:55
msgid "**view**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:-1
msgid "ndarray"
msgstr "ndarray"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:44
msgid ""
"Sliding window view of the array. The sliding window dimensions are inserted "
"at the end, and the original dimensions are trimmed as required by the size "
"of the sliding window. That is, ``view.shape = x_shape_trimmed + "
"window_shape``, where ``x_shape_trimmed`` is ``x.shape`` with every entry "
"reduced by one less than the corresponding window size."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:60
msgid ":obj:`lib.stride_tricks.as_strided`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:61
msgid ""
"A lower-level and less safe routine for creating arbitrary views from custom "
"shape and strides. Use the ``check_bounds`` parameter for bounds validation."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:62
msgid ":obj:`broadcast_to`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:63
msgid "broadcast an array to a given shape."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:67
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:70
msgid ""
"This function creates views with overlapping memory. When "
"``writeable=True``, writing to the view will modify the original array and "
"may affect multiple view positions. See the examples below and :doc:`this "
"guide </user/basics.copies>` about the difference between copies and views."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:76
msgid ""
"For many applications using a sliding window view can be convenient, but "
"potentially very slow. Often specialized solutions exist, for example:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:79
msgid "`scipy.signal.fftconvolve`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:81
msgid "filtering functions in `scipy.ndimage`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:83
msgid ""
"moving window functions provided by `bottleneck <https://github.com/pydata/"
"bottleneck>`_."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:86
msgid ""
"As a rough estimate, a sliding window approach with an input size of `N` and "
"a window size of `W` will scale as `O(N*W)` where frequently a special "
"algorithm can achieve `O(N)`. That means that the sliding window variant for "
"a window size of 100 can be a 100 times slower than a more specialized "
"version."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/stride_tricks.py:docstring
#: of numpy.lib.stride_tricks.sliding_window_view:92
msgid ""
"Nevertheless, for small window sizes, when no custom algorithm exists, or as "
"a prototyping and developing tool, this function can be a good solution."
msgstr ""

