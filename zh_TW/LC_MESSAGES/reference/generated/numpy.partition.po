#: ../../../reference/generated/numpy.partition.rst:4
msgid "numpy.partition"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:2
msgid "Return a partitioned copy of an array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:4
msgid ""
"Creates a copy of the array and partially sorts it in such a way that the "
"value of the element in the k-th position is in the position it would be in "
"a sorted array. In the output array, all elements that would be to the left "
"of the k-th element in a sorted array are located to the left of this "
"element and all that would be to the right are located to its right. The "
"ordering of the elements in the two partitions on the either side of the k-"
"th element in the output array is undefined."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:15
msgid "**a**"
msgstr "**a**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:15
msgid "Array to be sorted."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:26
msgid "**kth**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:-1
msgid "int or sequence of ints"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:18
msgid ""
"Element index to partition by. In the returned array, the k-th value of the "
"array will be in the position it would be in a sorted array, all elements "
"that are less than this element (or greater if `descending` is True) will be "
"moved before it, and all elements that are greater than or equal to this "
"element (or less than or equal if `descending` is True) will be moved after "
"it. The order of all elements within each partition is undefined. If "
"provided with a sequence of k-th it will partition all elements indexed by k-"
"th of them into their sorted position at once."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:30
msgid "**axis**"
msgstr "**axis**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:-1
msgid "int or None, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:29
msgid ""
"Axis along which to sort. If None, the array is flattened before sorting. "
"The default is -1, which sorts along the last axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:35
msgid "**kind**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:-1
msgid "{'introselect'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:33
msgid ""
"NumPy currently offers only one selection algorithm, 'introselect', and this "
"parameter provides no additional functionality. Default is ``None``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:42
msgid "**order**"
msgstr "**命令**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:-1
msgid "str or list of str, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:38
msgid ""
"When `a` is an array with fields defined, this argument specifies which "
"fields to compare first, second, etc.  A single field can be specified as a "
"string.  Not all fields need be specified, but unspecified fields will still "
"be used, in the order in which they come up in the dtype, to break ties."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:52
msgid "**descending**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:45
msgid ""
"Sort order. If ``True``, the array will be partitioned in descending order. "
"If ``False`` or ``None``, the array will be partitioned in ascending order. "
"Values that are NaN are partitioned towards the end of the array regardless "
"of order. Default: ``None``."
msgstr ""

