msgid ""
"``p[4]`` is 2;  all elements in ``p[:4]`` are less than or equal to "
"``p[4]``, and all elements in ``p[5:]`` are greater than or equal to "
"``p[4]``.  The partition is::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:120
msgid "[0, 1, 2, 1], [2], [5, 2, 3, 3, 6, 7, 7, 7, 7]"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:122
msgid "The next example shows the use of multiple values passed to `kth`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
