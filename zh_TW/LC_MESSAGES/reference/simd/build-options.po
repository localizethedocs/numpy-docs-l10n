#: ../../../reference/simd/build-options.rst:318
msgid "Adding a feature (``+``) includes all implied features"
msgstr ""

#: ../../../reference/simd/build-options.rst:319
msgid ""
"Removing a feature (``-``) excludes all successor features that imply the "
"removed feature"
msgstr ""

#: ../../../reference/simd/build-options.rst:321
msgid "Examples::"
msgstr ""

#: ../../../reference/simd/build-options.rst:323
msgid ""
