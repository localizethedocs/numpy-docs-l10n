#: ../../../reference/random/generated/numpy.random.binomial.rst:4
msgid "numpy.random.binomial"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.binomial:2
msgid "Draw samples from a binomial distribution."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.binomial:4
msgid ""
"Samples are drawn from a binomial distribution with specified parameters, n "
"trials and p probability of success where n an integer >= 0 and p is in the "
"interval [0,1]. (n may be input as a float, but it is truncated to an "
"integer in use)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.binomial:10
msgid ""
"New code should use the `~numpy.random.Generator.binomial` method of a "
"`~numpy.random.Generator` instance instead; please see the :ref:`random-"
"quick-start`."
msgstr ""

