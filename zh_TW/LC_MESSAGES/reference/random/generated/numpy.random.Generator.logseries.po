#: ../../../reference/random/generated/numpy.random.Generator.logseries.rst:4
msgid "numpy.random.Generator.logseries"
msgstr ""

#: ../../../reference/random/generated/numpy.random.Generator.logseries.rst:8
msgid "method"
msgstr "方法"

#: ../../../../docstring of numpy.random._generator.Generator.logseries:2
msgid "Draw samples from a logarithmic series distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logseries:4
msgid ""
"Samples are drawn from a log series distribution with specified shape "
"parameter, 0 <= ``p`` < 1."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logseries:0
msgid "Parameters"
msgstr "參數"

#: ../../../../docstring of numpy.random._generator.Generator.logseries:10
msgid "**p**"
msgstr "**p**"

#: ../../../../docstring of numpy.random._generator.Generator.logseries:-1
msgid "float or array_like of floats"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logseries:10
msgid "Shape parameter for the distribution.  Must be in the range [0, 1)."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logseries:16
msgid "**size**"
msgstr "**size**"

#: ../../../../docstring of numpy.random._generator.Generator.logseries:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logseries:13
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn.  If size is ``None`` (default), a single value is "
"returned if ``p`` is a scalar.  Otherwise, ``np.array(p).size`` samples are "
"drawn."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logseries:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../docstring of numpy.random._generator.Generator.logseries:27
msgid "**out**"
msgstr "**out**"

#: ../../../../docstring of numpy.random._generator.Generator.logseries:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logseries:21
msgid "Drawn samples from the parameterized logarithmic series distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logseries:32
msgid ":obj:`scipy.stats.logser`"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logseries:33
msgid ""
"probability density function, distribution or cumulative density function, "
"etc."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logseries:37
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logseries:38
msgid "The probability mass function for the Log Series distribution is"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logseries:40
msgid ""
"P(k) = \\frac{-p^k}{k \\ln(1-p)},\n"
"\n"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logseries:42
msgid "where p = probability."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logseries:44
msgid ""
"The log series distribution is frequently used to represent species richness "
"and occurrence, first proposed by Fisher, Corbet, and Williams in 1943 "
"[R8738ed783818-2]_.  It may also be used to model the numbers of occupants "
"seen in cars [R8738ed783818-3]_."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logseries:50
msgid "References"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logseries:51
msgid ""
"Buzas, Martin A.; Culver, Stephen J.,  Understanding regional species "
"diversity through the log series distribution of occurrences: BIODIVERSITY "
"RESEARCH Diversity & Distributions, Volume 5, Number 5, September 1999 , pp. "
"187-195(9)."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logseries:55
msgid ""
"Fisher, R.A,, A.S. Corbet, and C.B. Williams. 1943. The relation between the "
"number of species and the number of individuals in a random sample of an "
"animal population. Journal of Animal Ecology, 12:42-58."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logseries:59
msgid ""
"D. J. Hand, F. Daly, D. Lunn, E. Ostrowski, A Handbook of Small Data Sets, "
"CRC Press, 1994."
msgstr ""

