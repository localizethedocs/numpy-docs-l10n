#: ../../../reference/random/generated/numpy.random.Generator.multivariate_hypergeometric.rst:4
msgid "numpy.random.Generator.multivariate\\_hypergeometric"
msgstr ""

#: ../../../reference/random/generated/numpy.random.Generator.multivariate_hypergeometric.rst:8
msgid "method"
msgstr "方法"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:2
msgid "Generate variates from a multivariate hypergeometric distribution."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:4
msgid ""
"The multivariate hypergeometric distribution is a generalization of the "
"hypergeometric distribution."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:7
msgid ""
"Choose ``nsample`` items at random without replacement from a collection "
"with ``N`` distinct types.  ``N`` is the length of ``colors``, and the "
"values in ``colors`` are the number of occurrences of that type in the "
"collection.  The total number of items in the collection is "
"``sum(colors)``.  Each random variate generated by this function is a vector "
"of length ``N`` holding the counts of the different types that occurred in "
"the ``nsample`` items."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:15
msgid ""
"The name ``colors`` comes from a common description of the distribution: it "
"is the probability distribution of the number of marbles of each color "
"selected without replacement from an urn containing marbles of different "
"colors; ``colors[i]`` is the number of marbles in the urn with color ``i``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:27
msgid "**colors**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:-1
msgid "sequence of integers"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:24
msgid ""
"The number of each type of item in the collection from which a sample is "
"drawn.  The values in ``colors`` must be nonnegative. To avoid loss of "
"precision in the algorithm, ``sum(colors)`` must be less than ``10**9`` when "
"`method` is \"marginals\"."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:31
msgid "**nsample**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:-1
msgid "int"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:30
msgid ""
"The number of items selected.  ``nsample`` must not be greater than "
"``sum(colors)``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:41
msgid "**size**"
msgstr "**size**"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:34
msgid ""
"The number of variates to generate, either an integer or a tuple holding the "
"shape of the array of variates.  If the given size is, e.g., ``(k, m)``, "
"then ``k * m`` variates are drawn, where one variate is a vector of length "
"``len(colors)``, and the return value has shape ``(k, m, len(colors))``.  If "
"`size` is an integer, the output has shape ``(size, len(colors))``.  Default "
"is None, in which case a single variate is returned as an array with shape "
"``(len(colors),)``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:46
msgid "**method**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:-1
msgid "string, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:44
msgid ""
"Specify the algorithm that is used to generate the variates. Must be 'count' "
"or 'marginals' (the default).  See the Notes for a description of the "
"methods."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:58
msgid "**variates**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:-1
msgid "ndarray"
msgstr "ndarray"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:51
msgid ""
"Array of variates drawn from the multivariate hypergeometric distribution."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:63
msgid ":obj:`hypergeometric`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:64
msgid "Draw samples from the (univariate) hypergeometric distribution."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:68
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:69
msgid "The two methods do not return the same sequence of variates."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:71
msgid ""
"The \"count\" algorithm is roughly equivalent to the following numpy code::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:74
msgid ""
"choices = np.repeat(np.arange(len(colors)), colors)\n"
"selection = np.random.choice(choices, nsample, replace=False)\n"
"variate = np.bincount(selection, minlength=len(colors))"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:78
msgid ""
"The \"count\" algorithm uses a temporary array of integers with length "
"``sum(colors)``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:81
msgid ""
"The \"marginals\" algorithm generates a variate by using repeated calls to "
"the univariate hypergeometric sampler.  It is roughly equivalent to::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:85
msgid ""
"variate = np.zeros(len(colors), dtype=np.int64)\n"
"# `remaining` is the cumulative sum of `colors` from the last\n"
"# element to the first; e.g. if `colors` is [3, 1, 5], then\n"
"# `remaining` is [9, 6, 5].\n"
"remaining = np.cumsum(colors[::-1])[::-1]\n"
"for i in range(len(colors)-1):\n"
"    if nsample < 1:\n"
"        break\n"
"    variate[i] = hypergeometric(colors[i], remaining[i+1],\n"
"                               nsample)\n"
"    nsample -= variate[i]\n"
"variate[-1] = nsample"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.multivariate_hypergeometric:98
msgid ""
"The default method is \"marginals\".  For some cases (e.g. when `colors` "
"contains relatively small integers), the \"count\" method can be "
"significantly faster than the \"marginals\" method.  If performance of the "
"algorithm is important, test the two methods with typical inputs to decide "
"which works best."
msgstr ""

