#: ../../../reference/random/generated/numpy.random.Generator.triangular.rst:4
msgid "numpy.random.Generator.triangular"
msgstr ""

#: ../../../reference/random/generated/numpy.random.Generator.triangular.rst:8
msgid "method"
msgstr "方法"

#: ../../../../docstring of numpy.random._generator.Generator.triangular:2
msgid ""
"Draw samples from the triangular distribution over the interval ``[left, "
"right]``."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.triangular:5
msgid ""
"The triangular distribution is a continuous probability distribution with "
"lower limit left, peak at mode, and upper limit right. Unlike the other "
"distributions, these parameters directly define the shape of the pdf."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.triangular:0
msgid "Parameters"
msgstr "參數"

#: ../../../../docstring of numpy.random._generator.Generator.triangular:13
msgid "**left**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.triangular:-1
msgid "float or array_like of floats"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.triangular:13
msgid "Lower limit."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.triangular:17
msgid "**mode**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.triangular:16
msgid ""
"The value where the peak of the distribution occurs. The value must fulfill "
"the condition ``left <= mode <= right``."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.triangular:20
msgid "**right**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.triangular:20
msgid "Upper limit, must be larger than `left`."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.triangular:29
msgid "**size**"
msgstr "**size**"

#: ../../../../docstring of numpy.random._generator.Generator.triangular:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.triangular:23
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn.  If size is ``None`` (default), a single value is "
"returned if ``left``, ``mode``, and ``right`` are all scalars.  Otherwise, "
"``np.broadcast(left, mode, right).size`` samples are drawn."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.triangular:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../docstring of numpy.random._generator.Generator.triangular:41
msgid "**out**"
msgstr "**out**"

#: ../../../../docstring of numpy.random._generator.Generator.triangular:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.triangular:34
msgid "Drawn samples from the parameterized triangular distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.triangular:44
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.triangular:45
msgid "The probability density function for the triangular distribution is"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.triangular:47
msgid ""
"P(x;l, m, r) = \\begin{cases}\n"
"\\frac{2(x-l)}{(r-l)(m-l)}& \\text{for $l \\leq x \\leq m$},\\\\\n"
"\\frac{2(r-x)}{(r-l)(r-m)}& \\text{for $m \\leq x \\leq r$},\\\\\n"
"0& \\text{otherwise}.\n"
"\\end{cases}\n"
"\n"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.triangular:53
msgid ""
"The triangular distribution is often used in ill-defined problems where the "
"underlying distribution is not known, but some knowledge of the limits and "
"mode exists. Often it is used in simulations."
msgstr ""

