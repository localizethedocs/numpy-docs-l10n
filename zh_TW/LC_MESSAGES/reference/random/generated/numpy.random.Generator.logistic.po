#: ../../../reference/random/generated/numpy.random.Generator.logistic.rst:4
msgid "numpy.random.Generator.logistic"
msgstr ""

#: ../../../reference/random/generated/numpy.random.Generator.logistic.rst:8
msgid "method"
msgstr "方法"

#: ../../../../docstring of numpy.random._generator.Generator.logistic:2
msgid "Draw samples from a logistic distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logistic:4
msgid ""
"Samples are drawn from a logistic distribution with specified parameters, "
"loc (location or mean, also median), and scale (>0)."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logistic:0
msgid "Parameters"
msgstr "參數"

#: ../../../../docstring of numpy.random._generator.Generator.logistic:10
msgid "**loc**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logistic:-1
msgid "float or array_like of floats, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logistic:10
msgid "Parameter of the distribution. Default is 0."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logistic:14
msgid "**scale**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logistic:13
msgid "Parameter of the distribution. Must be non-negative. Default is 1."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logistic:22
msgid "**size**"
msgstr "**size**"

#: ../../../../docstring of numpy.random._generator.Generator.logistic:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logistic:17
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn.  If size is ``None`` (default), a single value is "
"returned if ``loc`` and ``scale`` are both scalars. Otherwise, ``np."
"broadcast(loc, scale).size`` samples are drawn."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logistic:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../docstring of numpy.random._generator.Generator.logistic:33
msgid "**out**"
msgstr "**out**"

#: ../../../../docstring of numpy.random._generator.Generator.logistic:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logistic:27
msgid "Drawn samples from the parameterized logistic distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logistic:38
msgid ":obj:`scipy.stats.logistic`"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logistic:39
msgid ""
"probability density function, distribution or cumulative density function, "
"etc."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logistic:43
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logistic:44
msgid "The probability density for the Logistic distribution is"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logistic:46
msgid ""
"P(x) = \\frac{e^{-(x-\\mu)/s}}{s(1+e^{-(x-\\mu)/s})^2},\n"
"\n"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logistic:48
msgid "where :math:`\\mu` = location and :math:`s` = scale."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logistic:50
msgid ""
"The Logistic distribution is used in Extreme Value problems where it can act "
"as a mixture of Gumbel distributions, in Epidemiology, and by the World "
"Chess Federation (FIDE) where it is used in the Elo ranking system, assuming "
"the performance of each player is a logistically distributed random variable."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logistic:57
msgid "References"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logistic:58
msgid ""
"Reiss, R.-D. and Thomas M. (2001), \"Statistical Analysis of Extreme Values, "
"from Insurance, Finance, Hydrology and Other Fields,\" Birkhauser Verlag, "
"Basel, pp 132-133."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.logistic:61
msgid ""
