#: of numpy.random.Generator.wald:19
msgid "**scale**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.wald:19
msgid "Scale parameter, must be > 0."
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.wald:25
msgid "**size**"
msgstr "**size**"

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.wald:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.wald:22
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn.  If size is ``None`` (default), a single value is "
"returned if ``mean`` and ``scale`` are both scalars. Otherwise, ``np."
"broadcast(mean, scale).size`` samples are drawn."
msgstr ""

