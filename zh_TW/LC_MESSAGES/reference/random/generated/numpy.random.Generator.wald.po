msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.wald:-1
msgid "float or array_like of floats"
msgstr ""

#: ../../../../../../../.conda/lib/python3.10/site-packages/numpy/__init__.py:docstring
#: of numpy.random.Generator.wald:16
msgid "Distribution mean, must be > 0."
msgstr ""

