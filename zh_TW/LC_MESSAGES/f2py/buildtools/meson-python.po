#: ../../../f2py/buildtools/meson-python.rst:34
msgid "Minimal example"
msgstr ""

#: ../../../f2py/buildtools/meson-python.rst:36
msgid ""
"The project below wraps a Fortran ``fib`` subroutine into an importable "
"Python package called ``fib_wrapper``."
msgstr ""

#: ../../../f2py/buildtools/meson-python.rst:39
msgid "Project layout::"
msgstr ""

#: ../../../f2py/buildtools/meson-python.rst:41
msgid ""
"fib_wrapper/           # project root\n"
"├── fib.f90            # Fortran source\n"
"├── fib_wrapper/       # Python package directory\n"
"│   └── __init__.py\n"
"├── meson.build\n"
"└── pyproject.toml"
msgstr ""

#: ../../../f2py/buildtools/meson-python.rst:49
msgid "Fortran source"
msgstr ""

#: ../../../f2py/buildtools/meson-python.rst:51
msgid "Save the following as ``fib.f90``:"
msgstr ""

#: ../../../f2py/buildtools/meson-python.rst:53
msgid ""
"subroutine fib(a, n)\n"
"  use iso_c_binding\n"
"  integer(c_int), intent(in) :: n\n"
"  integer(c_int), intent(out) :: a(n)\n"
"  integer :: i\n"
"  do i = 1, n\n"
"     if (i == 1) then\n"
"        a(i) = 0\n"
"     else if (i == 2) then\n"
"        a(i) = 1\n"
"     else\n"
"        a(i) = a(i - 1) + a(i - 2)\n"
"     end if\n"
"  end do\n"
"end subroutine fib\n"
msgstr ""

#: ../../../f2py/buildtools/meson-python.rst:57
msgid "``pyproject.toml``"
msgstr ""

#: ../../../f2py/buildtools/meson-python.rst:59
msgid ""
"[build-system]\n"
"# numpy>=2.0 is required for dependency('numpy') support in meson.build\n"
"requires = [\"meson-python>=0.15.0\", \"numpy>=2.0\"]\n"
"build-backend = \"mesonpy\"\n"
"\n"
"[project]\n"
"name = \"fib_wrapper\"\n"
"version = \"0.1.0\"\n"
"requires-python = \">=3.10\"\n"
"dependencies = [\"numpy\"]\n"
msgstr ""

#: ../../../f2py/buildtools/meson-python.rst:62
msgid "Two entries matter here:"
msgstr ""

#: ../../../f2py/buildtools/meson-python.rst:64
msgid ""
"``build-backend = \"mesonpy\"`` tells build frontends to use ``meson-"
"python``."
msgstr ""

#: ../../../f2py/buildtools/meson-python.rst:65
msgid ""
"``requires`` lists build-time dependencies. ``numpy >= 2.0`` is required so "
"that ``f2py``, the NumPy headers, and ``dependency('numpy')`` support in "
"Meson are available during compilation."
msgstr ""

#: ../../../f2py/buildtools/meson-python.rst:70
msgid "``meson.build``"
msgstr "``meson.build``"

#: ../../../f2py/buildtools/meson-python.rst:72
msgid ""
"project('fib_wrapper', 'c',\n"
"  version : '0.1.0',\n"
"  meson_version: '>=1.1.0',\n"
"  default_options : ['warning_level=2'],\n"
")\n"
"\n"
"add_languages('fortran', native: false)\n"
"\n"
"py = import('python').find_installation(pure: false)\n"
"\n"
"# NumPy >=2.0 provides include dirs via dependency()\n"
"np_dep = dependency('numpy')\n"
"\n"
"incdir_f2py = run_command(py,\n"
"  ['-c', 'import numpy.f2py; print(numpy.f2py.get_include())'],\n"
"  check : true\n"
").stdout().strip()\n"
"\n"
"# f2py include dir (for fortranobject.h) is not in dependency('numpy'),\n"
"# so add it separately\n"
"f2py_dep = declare_dependency(\n"
"  include_directories : incdir_f2py,\n"
")\n"
"\n"
"# Generate the f2py wrappers\n"
"fib_source = custom_target('fibmodule.c',\n"
"  input : ['fib.f90'],\n"
"  output : ['fibmodule.c', 'fib-f2pywrappers.f'],\n"
"  command : [py, '-m', 'numpy.f2py', '@INPUT@', '-m', 'fib', '--lower']\n"
")\n"
"\n"
"py.extension_module('fib',\n"
"  ['fib.f90', fib_source, incdir_f2py / 'fortranobject.c'],\n"
"  dependencies : [np_dep, f2py_dep],\n"
"  subdir: 'fib_wrapper',\n"
"  install : true,\n"
")\n"
"\n"
"# Install the Python package files\n"
"py.install_sources(\n"
"  'fib_wrapper/__init__.py',\n"
"  subdir: 'fib_wrapper',\n"
")\n"
msgstr ""

#: ../../../f2py/buildtools/meson-python.rst:76
msgid ""
"The file is stored as ``meson_mesonpy.build`` in the documentation source "
"tree to avoid collisions with other examples. In your project, name it "
"``meson.build``."
msgstr ""

#: ../../../f2py/buildtools/meson-python.rst:80
msgid "The ``meson.build`` file does four things:"
msgstr ""

#: ../../../f2py/buildtools/meson-python.rst:82
msgid ""
"Uses ``dependency('numpy')`` to locate NumPy headers, and a "
"``declare_dependency`` to add the F2PY include directory (for "
"``fortranobject.h``)."
msgstr ""

#: ../../../f2py/buildtools/meson-python.rst:85
msgid "Runs ``f2py`` via ``custom_target`` to generate the C wrapper sources."
msgstr ""

#: ../../../f2py/buildtools/meson-python.rst:86
msgid ""
"Compiles the generated C code together with the Fortran source into a Python "
"extension module using ``py.extension_module``."
msgstr ""

#: ../../../f2py/buildtools/meson-python.rst:88
msgid ""
"Installs ``__init__.py`` into the package directory so the result is a "
"proper Python package."
msgstr ""

#: ../../../f2py/buildtools/meson-python.rst:91
msgid ""
"The ``subdir: 'fib_wrapper'`` argument on the extension module is required "
"so that the compiled ``fib`` shared library is installed inside the "
"``fib_wrapper/`` package directory, next to ``__init__.py``. Without it the "
"extension would be installed at the top level and ``import fib_wrapper`` "
"would not find the ``fib`` extension. The resulting installed layout is::"
msgstr ""

#: ../../../f2py/buildtools/meson-python.rst:97
msgid ""
"site-packages/\n"
"└── fib_wrapper/\n"
"    ├── __init__.py        # from .fib import fib\n"
"    └── fib.cpython-*.so   # compiled extension module"
msgstr ""

