#: ../../../release/1.23.3-notes.rst:5
msgid "NumPy 1.23.3 Release Notes"
msgstr "NumPy 1.23.3 發行備註"

#: ../../../release/1.23.3-notes.rst:6
msgid ""
"NumPy 1.23.3 is a maintenance release that fixes bugs discovered after the "
"1.23.2 release. There is no major theme for this release, the main "
"improvements are for some downstream builds and some annotation corner "
"cases. The Python versions supported for this release are 3.8-3.11."
msgstr ""

#: ../../../release/1.23.3-notes.rst:11
msgid ""
"Note that we will move to MacOS 11 for the NumPy 1.23.4 release, the 10.15 "
"version currently used will no longer be supported by our build "
"infrastructure at that point."
msgstr ""

