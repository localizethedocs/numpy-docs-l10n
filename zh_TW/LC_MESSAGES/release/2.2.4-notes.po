#: ../../../release/2.2.4-notes.rst:5
msgid "NumPy 2.2.4 Release Notes"
msgstr "NumPy 2.2.4 發行備註"

#: ../../../release/2.2.4-notes.rst:7
msgid ""
"NumPy 2.2.4 is a patch release that fixes bugs found after the 2.2.3 "
"release. There are a large number of typing improvements, the rest of the "
"changes are the usual mix of bug fixes and platform maintenance."
msgstr ""

#: ../../../release/2.2.4-notes.rst:11
msgid "This release supports Python versions 3.10-3.13."
msgstr ""

