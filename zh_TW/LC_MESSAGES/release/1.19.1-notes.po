#: ../../../release/1.19.1-notes.rst:5
msgid "NumPy 1.19.1 Release Notes"
msgstr "NumPy 1.19.1 發行備註"

#: ../../../release/1.19.1-notes.rst:7
msgid ""
"NumPy 1.19.1 fixes several bugs found in the 1.19.0 release, replaces "
"several functions deprecated in the upcoming Python-3.9 release, has "
"improved support for AIX, and has a number of development related updates to "
"keep CI working with recent upstream changes."
msgstr ""

#: ../../../release/1.19.1-notes.rst:12
msgid ""
"This release supports Python 3.6-3.8. Cython >= 0.29.21 needs to be used "
"when building with Python 3.9 for testing purposes."
msgstr ""

