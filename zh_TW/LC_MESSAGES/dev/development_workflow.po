msgid ""
"``36 - Build``: for pull requests changing build processes/configurations"
msgstr ""

#: ../../../dev/development_workflow.rst:255
msgid "``03 - Maintenance``: for pull requests upgrading dependencies"
msgstr ""

#: ../../../dev/development_workflow.rst:256
msgid "``14 - Release``: for pull requests preparing for a release"
msgstr ""

