#: ../../../release/2.1.3-notes.rst:5
msgid "NumPy 2.1.3 Release Notes"
msgstr "NumPy 2.1.3 發行備註"

#: ../../../release/2.1.3-notes.rst:7
msgid ""
"NumPy 2.1.3 is a maintenance release that fixes bugs and regressions "
"discovered after the 2.1.2 release."
msgstr ""

#: ../../../release/2.1.3-notes.rst:10
msgid "The Python versions supported by this release are 3.10-3.13."
msgstr ""

#: ../../../release/2.1.3-notes.rst:14
msgid "Improvements"
msgstr ""

#: ../../../release/2.1.3-notes.rst:16
msgid ""
"Fixed a number of issues around promotion for string ufuncs with StringDType "
"arguments. Mixing StringDType and the fixed-width DTypes using the string "
"ufuncs should now generate much more uniform results."
msgstr ""

#: ../../../release/2.1.3-notes.rst:20
msgid "(`gh-27636 <https://github.com/numpy/numpy/pull/27636>`__)"
msgstr ""

#: ../../../release/2.1.3-notes.rst:24
msgid "Changes"
msgstr ""

#: ../../../release/2.1.3-notes.rst:26
msgid ""
"`numpy.fix` now won't perform casting to a floating data-type for integer "
"and boolean data-type input arrays."
msgstr ""

#: ../../../release/2.1.3-notes.rst:29
msgid "(`gh-26766 <https://github.com/numpy/numpy/pull/26766>`__)"
msgstr ""

