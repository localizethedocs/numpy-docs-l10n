#: ../../../release/1.21.2-notes.rst:5
msgid "NumPy 1.21.2 Release Notes"
msgstr "NumPy 1.21.2 發行備註"

#: ../../../release/1.21.2-notes.rst:7
msgid ""
"The NumPy 1.21.2 is a maintenance release that fixes bugs discovered after "
"1.21.1. It also provides 64 bit manylinux Python 3.10.0rc1 wheels for "
"downstream testing. Note that Python 3.10 is not yet final. It also has "
"preliminary support for Windows on ARM64, but there is no OpenBLAS for that "
"platform and no wheels are available."
msgstr ""

#: ../../../release/1.21.2-notes.rst:13
msgid ""
"The Python versions supported for this release are 3.7-3.9. The 1.21.x "
"series is compatible with Python 3.10.0rc1 and Python 3.10 will be "
"officially supported after it is released. The previous problems with "
"gcc-11.1 have been fixed by gcc-11.2, check your version if you are using "
"gcc-11."
msgstr ""

