msgstr ""

#: ../../../release/2.3.2-notes.rst:48
msgid ""
"`#29416 <https://github.com/numpy/numpy/pull/29416>`__: TYP: Fix overloads "
"in ``np.char.array`` and ``np.char.asarray``..."
msgstr ""

#: ../../../release/2.3.2-notes.rst:49
msgid ""
"`#29417 <https://github.com/numpy/numpy/pull/29417>`__: BUG: Any dtype "
"should call ``square`` on ``arr \\*\\* 2`` (#29392)"
msgstr ""

#: ../../../release/2.3.2-notes.rst:50
msgid ""
"`#29424 <https://github.com/numpy/numpy/pull/29424>`__: MAINT: use a stable "
