msgid ""
"`#29287 <https://github.com/numpy/numpy/pull/29287>`__: BUG: handle case in "
"mapiter where descriptors might get replaced..."
msgstr ""

#: ../../../release/2.3.2-notes.rst:43
msgid ""
"`#29350 <https://github.com/numpy/numpy/pull/29350>`__: BUG: Fix shape error "
"path in array-interface"
msgstr ""

#: ../../../release/2.3.2-notes.rst:44
msgid ""
