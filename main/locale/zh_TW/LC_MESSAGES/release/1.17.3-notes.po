#: ../../../release/1.17.3-notes.rst:5
msgid "NumPy 1.17.3 Release Notes"
msgstr "NumPy 1.17.3 發行備註"

#: ../../../release/1.17.3-notes.rst:7
msgid ""
"This release contains fixes for bugs reported against NumPy 1.17.2 along "
"with a some documentation improvements. The Python versions supported in "
"this release are 3.5-3.8."
msgstr ""

#: ../../../release/1.17.3-notes.rst:11
msgid ""
"Downstream developers should use Cython >= 0.29.13 for Python 3.8 support "
"and OpenBLAS >= 3.7 to avoid errors on the Skylake architecture."
msgstr ""

