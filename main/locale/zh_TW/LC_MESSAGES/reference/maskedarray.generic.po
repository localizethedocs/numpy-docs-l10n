msgid ""
":py:obj:`masked_greater <numpy.ma.masked_greater>`\\ \\(x\\, value\\[\\, "
"copy\\]\\)"
msgstr ""

#: ../../../reference/maskedarray.generic.rst:152:<autosummary>:1
msgid "Mask an array where greater than a given value."
msgstr ""

#: ../../../reference/maskedarray.generic.rst:152:<autosummary>:1
msgid ""
":py:obj:`masked_greater_equal <numpy.ma.masked_greater_equal>`\\ \\(x\\, "
"value\\[\\, copy\\]\\)"
msgstr ""

