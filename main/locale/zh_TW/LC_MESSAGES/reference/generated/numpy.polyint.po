#: ../../../reference/generated/numpy.polyint.rst:4
msgid "numpy.polyint"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polyint:2
msgid "Return an antiderivative (indefinite integral) of a polynomial."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polyint:5
msgid ""
"This forms part of the old polynomial API. Since version 1.4, the new "
"polynomial API defined in `numpy.polynomial` is preferred. A summary of the "
"differences can be found in the :doc:`transition guide </reference/routines."
"polynomials>`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polyint:10
msgid ""
"The returned order `m` antiderivative `P` of polynomial `p` satisfies :math:"
"`\\frac{d^m}{dx^m}P(x) = p(x)` and is defined up to `m - 1` integration "
"constants `k`. The constants determine the low-order polynomial part"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polyint:15
msgid ""
"\\frac{k_{m-1}}{0!} x^0 + \\ldots + \\frac{k_0}{(m-1)!}x^{m-1}\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polyint:17
msgid "of `P` so that :math:`P^{(j)}(0) = k_{m-j-1}`."
msgstr ""

