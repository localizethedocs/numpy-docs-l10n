#: ../../../reference/generated/numpy.polynomial.polynomial.polyval3d.rst:4
msgid "numpy.polynomial.polynomial.polyval3d"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyval3d:2
msgid "Evaluate a 3-D polynomial at points (x, y, z)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyval3d:4
msgid "This function returns the values:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyval3d:6
msgid ""
"p(x,y,z) = \\sum_{i,j,k} c_{i,j,k} * x^i * y^j * z^k\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyval3d:8
msgid ""
"The parameters `x`, `y`, and `z` are converted to arrays only if they are "
"tuples or a lists, otherwise they are treated as a scalars and they must "
"have the same shape after conversion. In either case, either `x`, `y`, and "
"`z` or their elements must support multiplication and addition both with "
"themselves and with the elements of `c`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyval3d:14
msgid ""
"If `c` has fewer than 3 dimensions, ones are implicitly appended to its "
"shape to make it 3-D. The shape of the result will be c.shape[3:] + x.shape."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyval3d:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyval3d:25
msgid "**x, y, z**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyval3d:-1
msgid "array_like, compatible object"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyval3d:21
msgid ""
"The three dimensional series is evaluated at the points ``(x, y, z)``, where "
"`x`, `y`, and `z` must have the same shape.  If any of `x`, `y`, or `z` is a "
"list or tuple, it is first converted to an ndarray, otherwise it is left "
"unchanged and if it isn't an ndarray it is  treated as a scalar."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyval3d:33
msgid "**c**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyval3d:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyval3d:28
msgid ""
"Array of coefficients ordered so that the coefficient of the term of multi-"
"degree i,j,k is contained in ``c[i,j,k]``. If `c` has dimension greater than "
"3 the remaining indices enumerate multiple sets of coefficients."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyval3d:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyval3d:45
msgid "**values**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyval3d:-1
msgid "ndarray, compatible object"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyval3d:38
msgid ""
"The values of the multidimensional polynomial on points formed with triples "
"of corresponding values from `x`, `y`, and `z`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyval3d:50
msgid ":obj:`polyval`, :obj:`polyval2d`, :obj:`polygrid2d`, :obj:`polygrid3d`"
msgstr ""

