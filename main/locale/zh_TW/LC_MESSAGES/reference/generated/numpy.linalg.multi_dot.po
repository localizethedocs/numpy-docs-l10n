#: ../../../reference/generated/numpy.linalg.multi_dot.rst:4
msgid "numpy.linalg.multi\\_dot"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.multi_dot:2
msgid ""
"Compute the dot product of two or more arrays in a single function call, "
"while automatically selecting the fastest evaluation order."
msgstr "在一次函數呼叫中計算兩個或多個陣列的點積，同時自動選擇最快的計算順序。"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.multi_dot:5
msgid ""
"`multi_dot` chains `numpy.dot` and uses optimal parenthesization of the "
"matrices [R451bed364cc6-1]_ [R451bed364cc6-2]_. Depending on the shapes of "
"the matrices, this can speed up the multiplication a lot."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.multi_dot:9
msgid ""
"If the first argument is 1-D it is treated as a row vector. If the last "
"argument is 1-D it is treated as a column vector. The other arguments must "
"be 2-D."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.multi_dot:13
msgid "Think of `multi_dot` as::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.multi_dot:15
msgid "def multi_dot(arrays): return functools.reduce(np.dot, arrays)"
msgstr ""

