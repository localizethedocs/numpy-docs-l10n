#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.multi_dot:54
msgid ""
"The cost for a matrix multiplication can be calculated with the following "
"function::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.multi_dot:57
msgid ""
"def cost(A, B):\n"
"    return A.shape[0] * A.shape[1] * B.shape[1]"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.multi_dot:60
msgid ""
"Assume we have three matrices :math:`A_{10 \\times 100}, B_{100 \\times 5}, "
"C_{5 \\times 50}`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.multi_dot:63
msgid "The costs for the two different parenthesizations are as follows::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.multi_dot:65
msgid ""
"cost((AB)C) = 10*100*5 + 10*5*50   = 5000 + 2500   = 7500\n"
"cost(A(BC)) = 10*100*50 + 100*5*50 = 50000 + 25000 = 75000"
msgstr ""

