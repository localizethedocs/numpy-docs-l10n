#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.multi_dot:83
msgid "`multi_dot` allows you to write::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.multi_dot:85
msgid ""
">>> import numpy as np\n"
">>> from numpy.linalg import multi_dot\n"
">>> # Prepare some data\n"
">>> A = np.random.random((10000, 100))\n"
">>> B = np.random.random((100, 1000))\n"
">>> C = np.random.random((1000, 5))\n"
">>> D = np.random.random((5, 333))\n"
">>> # the actual dot multiplication\n"
">>> _ = multi_dot([A, B, C, D])"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.multi_dot:95
msgid "instead of::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.multi_dot:97
msgid ""
">>> _ = np.dot(np.dot(np.dot(A, B), C), D)\n"
">>> # or\n"
">>> _ = A.dot(B).dot(C).dot(D)"
msgstr ""
