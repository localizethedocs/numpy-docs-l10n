#: ../../../reference/generated/numpy.histogramdd.rst:4
msgid "numpy.histogramdd"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:2
msgid "Compute the multidimensional histogram of some data."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:17
msgid "**sample**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:-1
msgid "(N, D) array, or (N, D) array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:8
msgid "The data to be histogrammed."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:10
msgid "Note the unusual interpretation of sample when an array_like:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:12
msgid ""
"When an array, each row is a coordinate in a D-dimensional space - such as "
"``histogramdd(np.array([p1, p2, p3]))``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:14
msgid ""
"When an array_like, each element is the list of values for single coordinate "
"- such as ``histogramdd((X, Y, Z))``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:17
msgid "The first form should be preferred."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:25
msgid "**bins**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:-1
msgid "sequence or int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:20
msgid "The bin specification:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:22
msgid ""
"A sequence of arrays describing the monotonically increasing bin edges along "
"each dimension."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:24
msgid "The number of bins for each dimension (nx, ny, ... =bins)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:25
msgid "The number of bins for all dimensions (nx=ny=...=bins)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:33
msgid "**range**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:-1
msgid "sequence, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:28
msgid ""
"A sequence of length D, each an optional (lower, upper) tuple giving the "
"outer bin edges to be used if the edges are not given explicitly in `bins`. "
"An entry of None in the sequence results in the minimum and maximum values "
"being used for the corresponding dimension. The default, None, is equivalent "
"to passing a tuple of D None values."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:38
msgid "**density**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:36
msgid ""
"If False, the default, returns the number of samples in each bin. If True, "
"returns the probability *density* function at the bin, ``bin_count / "
"sample_count / bin_volume``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:46
msgid "**weights**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:-1
msgid "(N,) array_like, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:41
msgid ""
"An array of values `w_i` weighing each sample `(x_i, y_i, z_i, ...)`. "
"Weights are normalized to 1 if density is True. If density is False, the "
"values of the returned histogram are equal to the sum of the weights "
"belonging to the samples falling into each bin."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:52
msgid "**H**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:51
msgid ""
"The multidimensional histogram of sample x. See density and weights for the "
"different possible semantics."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:61
msgid "**edges**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:-1
msgid "tuple of ndarrays"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:55
msgid "A tuple of D arrays describing the bin edges for each dimension."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:66
msgid ":obj:`histogram`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:67
msgid "1-D histogram"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:68
msgid ":obj:`histogram2d`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.histogramdd:69
msgid "2-D histogram"
msgstr ""

