#: of numpy.std:14
msgid ""
"Axis or axes along which the standard deviation is computed. The default is "
"to compute the standard deviation of the flattened array. If this is a tuple "
"of ints, a standard deviation is performed over multiple axes, instead of a "
"single axis or all the axes as before."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
