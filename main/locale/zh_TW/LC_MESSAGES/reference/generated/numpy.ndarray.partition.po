#: ../../../reference/generated/numpy.ndarray.partition.rst:4
msgid "numpy.ndarray.partition"
msgstr ""

#: ../../../reference/generated/numpy.ndarray.partition.rst:8
msgid "method"
msgstr "方法"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ndarray.partition:2
msgid ""
"Partially sorts the elements in the array in such a way that the value of "
"the element in k-th position is in the position it would be in a sorted "
"array. In the output array, all elements smaller than the k-th element are "
"located to the left of this element and all equal or greater are located to "
"its right. The ordering of the elements in the two partitions on the either "
"side of the k-th element in the output array is undefined."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ndarray.partition:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ndarray.partition:21
msgid "**kth**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ndarray.partition:-1
msgid "int or sequence of ints"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ndarray.partition:13
msgid ""
"Element index to partition by. The kth element value will be in its final "
"sorted position and all smaller elements will be moved before it and all "
"equal or greater elements behind it. The order of all elements in the "
"partitions is undefined. If provided with a sequence of kth it will "
"partition all elements indexed by kth of them into their sorted position at "
"once."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ndarray.partition:20
msgid "Passing booleans as index is deprecated."
msgstr ""

