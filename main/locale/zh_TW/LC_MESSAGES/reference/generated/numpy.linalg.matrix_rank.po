#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.matrix_rank:4
msgid ""
"Rank of the array is the number of singular values of the array that are "
"greater than `tol`."
msgstr ""

