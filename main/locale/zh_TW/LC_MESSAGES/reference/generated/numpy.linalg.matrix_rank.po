msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.matrix_rank:13
msgid ""
"Threshold below which SVD values are considered zero. If `tol` is None, and "
"``S`` is an array with singular values for `M`, and ``eps`` is the epsilon "
"value for datatype of ``S``, then `tol` is set to ``S.max() * max(M, N) * "
"eps``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.matrix_rank:21
msgid "**hermitian**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.matrix_rank:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.matrix_rank:19
msgid ""
"If True, `A` is assumed to be Hermitian (symmetric if real-valued), enabling "
"a more efficient method for finding singular values. Defaults to False."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.matrix_rank:29
msgid "**rtol**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.matrix_rank:24
msgid ""
"Parameter for the relative tolerance component. Only ``tol`` or ``rtol`` can "
"be set at a time. Defaults to ``max(M, N) * eps``."
msgstr ""

