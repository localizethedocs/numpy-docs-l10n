msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.delete:15
msgid ""
"Boolean indices are now treated as a mask of elements to remove, rather than "
"being cast to the integers 0 and 1."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.delete:23
