#: of numpy.delete:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.delete:28
msgid ""
"A copy of `arr` with the elements specified by `obj` removed. Note that "
"`delete` does not occur in-place. If `axis` is None, `out` is a flattened "
"array."
msgstr ""

