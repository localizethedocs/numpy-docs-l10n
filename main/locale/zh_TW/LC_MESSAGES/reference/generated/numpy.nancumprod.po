#: ../../../reference/generated/numpy.nancumprod.rst:4
msgid "numpy.nancumprod"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nancumprod:2
msgid ""
"Return the cumulative product of array elements over a given axis treating "
"Not a Numbers (NaNs) as one.  The cumulative product does not change when "
"NaNs are encountered and leading NaNs are replaced by ones."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nancumprod:6
msgid "Ones are returned for slices that are all-NaN or empty."
msgstr ""

