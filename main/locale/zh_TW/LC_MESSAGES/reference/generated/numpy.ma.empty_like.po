#: ../../../reference/generated/numpy.ma.empty_like.rst:4
msgid "numpy.ma.empty\\_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:2
msgid "Return a new array with the same shape and type as a given array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:9
msgid "**prototype**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:8
msgid ""
"The shape and data-type of `prototype` define these same attributes of the "
"returned array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:12
msgid "**dtype**"
msgstr "**dtype**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:-1
msgid "data-type, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:12
msgid "Overrides the data type of the result."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:18
msgid "**order**"
msgstr "**命令**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:-1
msgid "{'C', 'F', 'A', or 'K'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:15
msgid ""
"Overrides the memory layout of the result. 'C' means C-order, 'F' means F-"
"order, 'A' means 'F' if `prototype` is Fortran contiguous, 'C' otherwise. "
"'K' means match the layout of `prototype` as closely as possible."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:23
msgid "**subok**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:-1
msgid "bool, optional."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:21
msgid ""
"If True, then the newly created array will use the sub-class type of "
"`prototype`, otherwise it will be a base-class array. Defaults to True."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:28
msgid "**shape**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:-1
msgid "int or sequence of ints, optional."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:26
msgid ""
"Overrides the shape of the result. If order='K' and the number of dimensions "
"is unchanged, will try to keep order, otherwise, order='C' is implied."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:36
msgid "**device**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:-1
msgid "str, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:31
msgid ""
"The device on which to place the created array. Default: None. For Array-API "
"interoperability only, so must be ``\"cpu\"`` if passed."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:48
msgid "**out**"
msgstr "**out**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:-1
msgid "MaskedArray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:41
msgid ""
"Array of uninitialized (arbitrary) data with the same shape and type as "
"`prototype`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:53
msgid ":obj:`ones_like`"
msgstr ":obj:`ones_like`"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:54
msgid "Return an array of ones with shape and type of input."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:55
msgid ":obj:`zeros_like`"
msgstr ":obj:`zeros_like`"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:56
msgid "Return an array of zeros with shape and type of input."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:57
msgid ":obj:`full_like`"
msgstr ":obj:`full_like`"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:58
msgid "Return a new array with shape of input filled with value."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:59
msgid ":obj:`empty`"
msgstr ":obj:`empty`"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:60
msgid "Return a new uninitialized array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:64
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty_like:65
msgid ""
"Unlike other array creation functions (e.g. `zeros_like`, `ones_like`, "
"`full_like`), `empty_like` does not initialize the values of the array, and "
"may therefore be marginally faster. However, the values stored in the newly "
"allocated array are arbitrary. For reproducible behavior, be sure to set "
"each element of the array before reading."
msgstr ""

