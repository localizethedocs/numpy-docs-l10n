msgid "numpy.polynomial.polynomial.polyder"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyder:2
msgid "Differentiate a polynomial."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyder:4
msgid ""
"Returns the polynomial coefficients `c` differentiated `m` times along "
"`axis`.  At each iteration the result is multiplied by `scl` (the scaling "
"factor is for use in a linear change of variable).  The argument `c` is an "
"array of coefficients from low to high degree along each axis, e.g., [1,2,3] "
"represents the polynomial ``1 + 2*x + 3*x**2`` while [[1,2],[1,2]] "
"represents ``1 + 1*x + 2*y + 2*x*y`` if axis=0 is ``x`` and axis=1 is ``y``."
msgstr ""

