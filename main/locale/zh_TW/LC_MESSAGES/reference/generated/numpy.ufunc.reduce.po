#: ../../../reference/generated/numpy.ufunc.reduce.rst:4
msgid "numpy.ufunc.reduce"
msgstr ""

#: ../../../reference/generated/numpy.ufunc.reduce.rst:8
msgid "method"
msgstr "方法"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:2
msgid "Reduces `array`'s dimension by one, by applying ufunc along one axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:4
msgid ""
"Let :math:`array.shape = (N_0, ..., N_i, ..., N_{M-1})`.  Then :math:`ufunc."
"reduce(array, axis=i)[k_0, ..,k_{i-1}, k_{i+1}, .., k_{M-1}]` = the result "
"of iterating `j` over :math:`range(N_i)`, cumulatively applying ufunc to "
"each :math:`array[k_0, ..,k_{i-1}, j, k_{i+1}, .., k_{M-1}]`. For a one-"
"dimensional array, reduce produces results equivalent to: ::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:11
msgid ""
"r = op.identity # op = ufunc\n"
"for i in range(len(A)):\n"
"  r = op(r, A[i])\n"
"return r"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:16
msgid "For example, add.reduce() is equivalent to sum()."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:21
msgid "**array**"
msgstr "**array**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:21
msgid "The array to act on."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:36
msgid "**axis**"
msgstr "**axis**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:-1
msgid "None or int or tuple of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:24
msgid ""
"Axis or axes along which a reduction is performed. The default (`axis` = 0) "
"is perform a reduction over the first dimension of the input array. `axis` "
"may be negative, in which case it counts from the last to the first axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:29
msgid ""
"If this is None, a reduction is performed over all the axes. If this is a "
"tuple of ints, a reduction is performed on multiple axes, instead of a "
"single axis or all the axes as before."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:33
msgid ""
"For operations which are either not commutative or not associative, doing a "
"reduction over multiple axes is not well-defined. The ufuncs do not "
"currently raise an exception in this case, but will likely do so in the "
"future."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:42
msgid "**dtype**"
msgstr "**dtype**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:-1
msgid "data-type code, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:39
msgid ""
"The data type used to perform the operation. Defaults to that of ``out`` if "
"given, and the data type of ``array`` otherwise (though upcast to conserve "
"precision for some cases, such as ``numpy.add.reduce`` for integer or "
"boolean input)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:53
msgid "**out**"
msgstr "**out**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:-1
msgid "ndarray, None, ..., or tuple of ndarray and None, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:45
msgid ""
"Location into which the result is stored. If not provided or None, a freshly-"
"allocated array is returned. If passed as a keyword argument, can be "
"Ellipses (``out=...``) to ensure an array is returned even if the result is "
"0-dimensional (which is useful especially for object dtype), or a 1-element "
"tuple (latter for consistency with ``ufunc.__call__``)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:52
msgid "Support for ``out=...`` was added."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:58
msgid "**keepdims**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:56
msgid ""
"If this is set to True, the axes which are reduced are left in the result as "
"dimensions with size one. With this option, the result will broadcast "
"correctly against the original `array`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:65
msgid "**initial**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:-1
msgid "scalar, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:61
msgid ""
"The value with which to start the reduction. If the ufunc has no identity or "
"the dtype is object, this defaults to None - otherwise it defaults to ufunc."
"identity. If ``None`` is given, the first element of the reduction is used, "
"and an error is thrown if the reduction is empty."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:73
msgid "**where**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:-1
msgid "array_like of bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:68
msgid ""
"A boolean array which is broadcasted to match the dimensions of `array`, and "
"selects elements to include in the reduction. Note that for ufuncs like "
"``minimum`` that do not have an identity defined, one has to pass in also "
"``initial``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:87
msgid "**r**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:78
msgid "The reduced array. If `out` was supplied, `r` is a reference to it."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:90
msgid "Examples"
msgstr "範例"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:99
msgid "A multi-dimensional array example:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:120
msgid ""
"You can use the ``initial`` keyword argument to initialize the reduction "
"with a different value, and ``where`` to select specific elements to include:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc.reduce:131
msgid ""
"Allows reductions of empty arrays where they would normally fail, i.e. for "
"ufuncs without an identity."
msgstr ""

