#: ../../../reference/generated/numpy.fft.fft2.rst:4
msgid "numpy.fft.fft2"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:2
msgid "Compute the 2-dimensional discrete Fourier Transform."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:4
msgid ""
"This function computes the *n*-dimensional discrete Fourier Transform over "
"any axes in an *M*-dimensional array by means of the Fast Fourier Transform "
"(FFT).  By default, the transform is computed over the last two axes of the "
"input array, i.e., a 2-dimensional FFT."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:12
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:12
msgid "Input array, can be complex"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:37
msgid "**s**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:-1
msgid "sequence of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:15
msgid ""
"Shape (length of each transformed axis) of the output (``s[0]`` refers to "
"axis 0, ``s[1]`` to axis 1, etc.). This corresponds to ``n`` for ``fft(x, "
"n)``. Along each axis, if the given shape is smaller than that of the input, "
"the input is cropped. If it is larger, the input is padded with zeros."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:23
msgid "If it is ``-1``, the whole input is used (no padding/trimming)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:25
msgid ""
"If `s` is not given, the shape of the input along the axes specified by "
"`axes` is used."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:30
msgid "If `s` is not ``None``, `axes` must not be ``None`` either."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:34
msgid ""
"`s` must contain only ``int`` s, not ``None`` values. ``None`` values "
"currently mean that the default value for ``n`` is used in the corresponding "
"1-D transform, but this behaviour is deprecated."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:48
msgid "**axes**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:40
msgid ""
"Axes over which to compute the FFT.  If not given, the last two axes are "
"used.  A repeated index in `axes` means the transform over that axis is "
"performed multiple times.  A one-element sequence means that a one-"
"dimensional FFT is performed. Default: ``(-2, -1)``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:47
msgid ""
"If `s` is specified, the corresponding `axes` to be transformed must not be "
"``None``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:57
msgid "**norm**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:-1
msgid "{\"backward\", \"ortho\", \"forward\"}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:51
msgid ""
"Normalization mode (see `numpy.fft`). Default is \"backward\". Indicates "
"which direction of the forward/backward pair of transforms is scaled and "
"with what normalization factor."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:57
msgid "The \"backward\", \"forward\" values were added."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:66 numpy.fft.fft2:75
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:-1
msgid "complex ndarray, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:60
msgid ""
"If provided, the result will be placed in this array. It should be of the "
"appropriate shape and dtype for all axes (and hence only the last axis can "
"have ``s`` not equal to the shape at that axis)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:-1
msgid "complex ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:71
msgid ""
"The truncated or zero-padded input, transformed along the axes indicated by "
"`axes`, or the last two axes if `axes` is not given."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:0
msgid "Raises"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:81
msgid "ValueError"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:80
msgid ""
"If `s` and `axes` have different length, or `axes` not given and ``len(s) != "
"2``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:86
msgid "IndexError"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:84
msgid "If an element of `axes` is larger than than the number of axes of `a`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:91
msgid ":obj:`numpy.fft`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:92
msgid ""
"Overall view of discrete Fourier transforms, with definitions and "
"conventions used."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:93
msgid ":obj:`ifft2`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:94
msgid "The inverse two-dimensional FFT."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:95
msgid ":obj:`fft`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:96
msgid "The one-dimensional FFT."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:97
msgid ":obj:`fftn`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:98
msgid "The *n*-dimensional FFT."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:99
msgid ":obj:`fftshift`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:100
msgid ""
"Shifts zero-frequency terms to the center of the array. For two-dimensional "
"input, swaps first and third quadrants, and second and fourth quadrants."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:104
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:105
msgid "`fft2` is just `fftn` with a different default for `axes`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:107
msgid ""
"The output, analogously to `fft`, contains the term for zero frequency in "
"the low-order corner of the transformed axes, the positive frequency terms "
"in the first half of these axes, the term for the Nyquist frequency in the "
"middle of the axes and the negative frequency terms in the second half of "
"the axes, in order of decreasingly negative frequency."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fft2:113
msgid ""
"See `fftn` for details and a plotting example, and `numpy.fft` for "
"definitions and conventions used."
msgstr ""

