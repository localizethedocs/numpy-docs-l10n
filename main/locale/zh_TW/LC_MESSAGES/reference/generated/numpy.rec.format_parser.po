msgid "dtype"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/rec/__init__.py:docstring
#: of numpy.rec.format_parser:39
msgid "The converted data-type."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/rec/__init__.py:docstring
#: of numpy.rec.format_parser:52
msgid ":obj:`numpy.dtype`, :obj:`numpy.typename`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/rec/__init__.py:docstring
#: of numpy.rec.format_parser:58
msgid "Examples"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/rec/__init__.py:docstring
#: of numpy.rec.format_parser:68
msgid ""
"`names` and/or `titles` can be empty lists. If `titles` is an empty list, "
"titles will simply not appear. If `names` is empty, default field names will "
"be used."
msgstr ""

