#: ../../../reference/generated/numpy.rec.format_parser.rst:2
msgid "numpy.rec.format\\_parser"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/rec/__init__.py:docstring
#: of numpy.rec.format_parser:2
msgid "Class to convert formats, names, titles description to a dtype."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/rec/__init__.py:docstring
#: of numpy.rec.format_parser:4
msgid ""
"After constructing the format_parser object, the dtype attribute is the "
"converted data-type: ``dtype = format_parser(formats, names, titles).dtype``"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/rec/__init__.py:docstring
#: of numpy.rec.format_parser:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/rec/__init__.py:docstring
#: of numpy.rec.format_parser:14
msgid "**formats**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/rec/__init__.py:docstring
#: of numpy.rec.format_parser:-1
msgid "str or list of str"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/rec/__init__.py:docstring
#: of numpy.rec.format_parser:11
msgid ""
"The format description, either specified as a string with comma-separated "
"format descriptions in the form ``'f8, i4, S5'``, or a list of format "
"description strings  in the form ``['f8', 'i4', 'S5']``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/rec/__init__.py:docstring
#: of numpy.rec.format_parser:21
msgid "**names**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/rec/__init__.py:docstring
#: of numpy.rec.format_parser:-1
msgid "str or list/tuple of str"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/rec/__init__.py:docstring
#: of numpy.rec.format_parser:17
msgid ""
"The field names, either specified as a comma-separated string in the form "
"``'col1, col2, col3'``, or as a list or tuple of strings in the form "
"``['col1', 'col2', 'col3']``. An empty list can be used, in that case "
"default field names ('f0', 'f1', ...) are used."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/rec/__init__.py:docstring
#: of numpy.rec.format_parser:25
msgid "**titles**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/rec/__init__.py:docstring
#: of numpy.rec.format_parser:-1
msgid "sequence"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/rec/__init__.py:docstring
#: of numpy.rec.format_parser:24
msgid ""
"Sequence of title strings. An empty list can be used to leave titles out."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/rec/__init__.py:docstring
#: of numpy.rec.format_parser:29
msgid "**aligned**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/rec/__init__.py:docstring
#: of numpy.rec.format_parser:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/rec/__init__.py:docstring
#: of numpy.rec.format_parser:28
msgid ""
"If True, align the fields by padding as the C-compiler would. Default is "
"False."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/rec/__init__.py:docstring
#: of numpy.rec.format_parser:34
msgid "**byteorder**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/rec/__init__.py:docstring
#: of numpy.rec.format_parser:-1
msgid "str, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/rec/__init__.py:docstring
#: of numpy.rec.format_parser:32
msgid ""
"If specified, all the fields will be changed to the provided byte-order.  "
"Otherwise, the default byte-order is used. For all available string "
"specifiers, see `dtype.newbyteorder`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/rec/__init__.py:docstring
#: of numpy.rec.format_parser:0
msgid "Attributes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/rec/__init__.py:docstring
