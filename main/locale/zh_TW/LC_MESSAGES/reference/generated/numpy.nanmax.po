#: ../../../reference/generated/numpy.nanmax.rst:4
msgid "numpy.nanmax"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmax:2
msgid ""
"Return the maximum of an array or maximum along an axis, ignoring any NaNs.  "
"When all-NaN slices are encountered a ``RuntimeWarning`` is raised and NaN "
"is returned for that slice."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmax:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmax:11
msgid "**a**"
msgstr "**a**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmax:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmax:10
msgid ""
"Array containing numbers whose maximum is desired. If `a` is not an array, a "
"conversion is attempted."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmax:15
msgid "**axis**"
msgstr "**axis**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmax:-1
msgid "{int, tuple of int, None}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmax:14
msgid ""
"Axis or axes along which the maximum is computed. The default is to compute "
"the maximum of the flattened array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmax:21
msgid "**out**"
msgstr "**out**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmax:-1
msgid "ndarray, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmax:18
msgid ""
"Alternate output array in which to place the result.  The default is "
"``None``; if provided, it must have the same shape as the expected output, "
"but the type will be cast if necessary. See :ref:`ufuncs-output-type` for "
"more details."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmax:30
msgid "**keepdims**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmax:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmax:24
msgid ""
"If this is set to True, the axes which are reduced are left in the result as "
"dimensions with size one. With this option, the result will broadcast "
"correctly against the original `a`. If the value is anything but the "
"default, then `keepdims` will be passed through to the `max` method of sub-"
"classes of `ndarray`.  If the sub-classes methods does not implement "
"`keepdims` any exceptions will be raised."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmax:36
msgid "**initial**"
msgstr "**initial**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmax:-1
msgid "scalar, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmax:33
msgid ""
"The minimum value of an output element. Must be present to allow computation "
"on empty slice. See `~numpy.ufunc.reduce` for details."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmax:44
msgid "**where**"
msgstr "**where**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmax:-1
msgid "array_like of bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanmax:39
msgid ""
"Elements to compare for the maximum. See `~numpy.ufunc.reduce` for details."
msgstr ""

