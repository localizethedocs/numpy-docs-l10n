#: ../../../reference/generated/numpy.savez.rst:4
msgid "numpy.savez"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:2
msgid "Save several arrays into a single file in uncompressed ``.npz`` format."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:4
msgid ""
"Provide arrays as keyword arguments to store them under the corresponding "
"name in the output file: ``savez(fn, x=x, y=y)``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:7
msgid ""
"If arrays are specified as positional arguments, i.e., ``savez(fn, x, y)``, "
"their names will be `arr_0`, `arr_1`, etc."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:16
msgid "**file**"
msgstr "**file**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:-1
msgid "file, str, or pathlib.Path"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:13
msgid ""
"Either the filename (string) or an open file (file-like object) where the "
"data will be saved. If file is a string or a Path, the ``.npz`` extension "
"will be appended to the filename if it is not already there."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:21
msgid "**args**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:-1
msgid "Arguments, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:19
msgid ""
"Arrays to save to the file. Please use keyword arguments (see `kwds` below) "
"to assign names to arrays.  Arrays specified as args will be named "
"\"arr_0\", \"arr_1\", and so on."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:30
msgid "**allow_pickle**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:24
msgid ""
"Allow saving object arrays using Python pickles. Reasons for disallowing "
"pickles include security (loading pickled data can execute arbitrary code) "
"and portability (pickled objects may not be loadable on different Python "
"installations, for example if the stored objects require libraries that are "
"not available, and not all pickled data is compatible between different "
"versions of Python). Default: True"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:36
msgid "**kwds**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:-1
msgid "Keyword arguments, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:33
msgid ""
"Arrays to save to the file. Each array will be saved to the output file with "
"its corresponding keyword name."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:47
msgid "None"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:52
msgid ":obj:`save`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:53
msgid "Save a single array to a binary file in NumPy format."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:54
msgid ":obj:`savetxt`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:55
msgid "Save an array to a file as plain text."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:56
msgid ":obj:`savez_compressed`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:57
msgid "Save several arrays into a compressed ``.npz`` archive"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:61
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:62
msgid ""
"The ``.npz`` file format is a zipped archive of files named after the "
"variables they contain.  The archive is not compressed and each file in the "
"archive contains one variable in ``.npy`` format. For a description of the "
"``.npy`` format, see :py:mod:`numpy.lib.format`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:67
msgid ""
"When opening the saved ``.npz`` file with `load` a `~lib.npyio.NpzFile` "
"object is returned. This is a dictionary-like object which can be queried "
"for its list of arrays (with the ``.files`` attribute), and for the arrays "
"themselves."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:72
msgid ""
"Keys passed in `kwds` are used as filenames inside the ZIP archive. "
"Therefore, keys should be valid filenames; e.g., avoid keys that begin with "
"``/`` or contain ``.``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:76
msgid ""
"When naming variables with keyword arguments, it is not possible to name a "
"variable ``file``, as this would cause the ``file`` argument to be defined "
"twice in the call to ``savez``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:82
msgid "Examples"
msgstr "範例"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:93
msgid "Using `savez` with \\*args, the arrays are saved with default names."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez:103
msgid ""
"Using `savez` with \\**kwds, the arrays are saved with the keyword names."
msgstr ""

