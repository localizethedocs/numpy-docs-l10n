#: ../../../reference/generated/numpy.dtype.subdtype.rst:4
msgid "numpy.dtype.subdtype"
msgstr ""

#: ../../../reference/generated/numpy.dtype.subdtype.rst:8
msgid "attribute"
msgstr ""

#: ../../../../docstring of numpy.dtype.subdtype:2
msgid ""
"Tuple ``(item_dtype, shape)`` if this `dtype` describes a sub-array, and "
"None otherwise."
msgstr ""

#: ../../../../docstring of numpy.dtype.subdtype:5
msgid ""
"The *shape* is the fixed shape of the sub-array described by this data type, "
"and *item_dtype* the data type of the array."
msgstr ""

#: ../../../../docstring of numpy.dtype.subdtype:8
msgid ""
"If a field whose dtype object has this attribute is retrieved, then the "
"extra dimensions implied by *shape* are tacked on to the end of the "
"retrieved array."
msgstr ""

