#: of numpy.ma.extras.compress_rowcols:16
msgid "**x**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.compress_rowcols:-1
msgid "array_like, MaskedArray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.compress_rowcols:14
msgid ""
"The array to operate on.  If not a MaskedArray instance (or if no array "
"elements are masked), `x` is interpreted as a MaskedArray with `mask` set to "
"`nomask`. Must be a 2D array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.compress_rowcols:21
msgid "**axis**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.compress_rowcols:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.compress_rowcols:19
msgid "Axis along which to perform the operation. Default is None."
msgstr ""

