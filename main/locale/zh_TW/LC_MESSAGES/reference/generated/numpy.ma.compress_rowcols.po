msgid "numpy.ma.compress\\_rowcols"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.compress_rowcols:2
msgid ""
"Suppress the rows and/or columns of a 2-D array that contain masked values."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.compress_rowcols:5
msgid "The suppression behavior is selected with the `axis` parameter."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.compress_rowcols:7
msgid "If axis is None, both rows and columns are suppressed."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.compress_rowcols:8
msgid "If axis is 0, only rows are suppressed."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.compress_rowcols:9
msgid "If axis is 1 or -1, only columns are suppressed."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.compress_rowcols:0
msgid "Parameters"
msgstr ""

