#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.extract:2
msgid "Return the elements of an array that satisfy some condition."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.extract:4
msgid ""
"This is equivalent to ``np.compress(ravel(condition), ravel(arr))``.  If "
"`condition` is boolean ``np.extract`` is equivalent to ``arr[condition]``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.extract:7
msgid "Note that `place` does the exact opposite of `extract`."
msgstr ""

