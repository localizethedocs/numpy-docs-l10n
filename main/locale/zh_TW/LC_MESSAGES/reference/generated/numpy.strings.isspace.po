#: ../../../reference/generated/numpy.strings.isspace.rst:4
msgid "numpy.strings.isspace"
msgstr ""

#: ../../../../docstring of numpy.strings.isspace:2
msgid ""
"Returns true for each element if there are only whitespace characters in the "
"string and there is at least one character, false otherwise."
msgstr ""

#: ../../../../docstring of numpy.strings.isspace:6
msgid ""
"For byte strings, whitespace characters are the ones in the sequence b' "
"\\t\\n\\r\\x0b\\f'. For Unicode strings, a character is whitespace, if, in "
"the Unicode character database, its general category is Zs (“Separator, "
"space”), or its bidirectional class is one of WS, B, or S."
msgstr ""

