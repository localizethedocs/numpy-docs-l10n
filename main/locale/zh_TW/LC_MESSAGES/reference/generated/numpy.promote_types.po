#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.promote_types:40
msgid ""
"Starting in NumPy 1.9, promote_types function now returns a valid string "
"length when given an integer or float dtype as one argument and a string "
"dtype as another argument. Previously it always returned the input string "
"dtype, even if it wasn't long enough to store the max integer/float value "
"converted to a string."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.promote_types:48
msgid ""
"NumPy now supports promotion for more structured dtypes.  It will now remove "
"unnecessary padding from a structure dtype and promote included fields "
"individually."
msgstr ""

