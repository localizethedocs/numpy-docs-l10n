#: ../../../reference/generated/numpy.isin.rst:4
msgid "numpy.isin"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isin:2
msgid ""
"Calculates ``element in test_elements``, broadcasting over `element` only. "
"Returns a boolean array of the same shape as `element` that is True where an "
"element of `element` is in `test_elements` and False otherwise."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isin:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isin:10
msgid "**element**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isin:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isin:10
msgid "Input array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isin:15
msgid "**test_elements**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isin:13
msgid ""
"The values against which to test each value of `element`. This argument is "
"flattened if it is an array or array_like. See notes for behavior with non-"
"array-like parameters."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isin:19
msgid "**assume_unique**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isin:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isin:18
msgid ""
"If True, the input arrays are both assumed to be unique, which can speed up "
"the calculation.  Default is False."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isin:25
msgid "**invert**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isin:22
msgid ""
"If True, the values in the returned array are inverted, as if calculating "
"`element not in test_elements`. Default is False. ``np.isin(a, b, "
"invert=True)`` is equivalent to (but faster than) ``np.invert(np.isin(a, "
"b))``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isin:48
msgid "**kind**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isin:-1
msgid "{None, 'sort', 'table'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isin:28
msgid ""
"The algorithm to use. This will not affect the final result, but will affect "
"the speed and memory use. The default, None, will select automatically based "
"on memory considerations."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isin:32
msgid ""
"If 'sort', will use a mergesort-based approach. This will have a memory "
"usage of roughly 6 times the sum of the sizes of `element` and "
"`test_elements`, not accounting for size of dtypes."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isin:35
msgid ""
"If 'table', will use a lookup table approach similar to a counting sort. "
"This is only available for boolean and integer arrays. This will have a "
"memory usage of the size of `element` plus the max-min value of "
"`test_elements`. `assume_unique` has no effect when the 'table' option is "
"used."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isin:40
msgid ""
"If None, will automatically choose 'table' if the required memory allocation "
"is less than or equal to 6 times the sum of the sizes of `element` and "
"`test_elements`, otherwise will use 'sort'. This is done to not use a large "
"amount of memory by default, even though 'table' may be faster in most "
"cases. If 'table' is chosen, `assume_unique` will have no effect."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isin:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isin:61
msgid "**isin**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isin:-1
msgid "ndarray, bool"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isin:53
msgid ""
"Has the same shape as `element`. The values `element[isin]` are in "
"`test_elements`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isin:64
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isin:65
msgid ""
"`isin` is an element-wise function version of the python keyword `in`. "
"``isin(a, b)`` is roughly equivalent to ``np.array([item in b for item in "
"a])`` if `a` and `b` are 1-D sequences."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isin:69
msgid ""
"`element` and `test_elements` are converted to arrays if they are not "
"already. If `test_elements` is a set (or other non-sequence collection) it "
"will be converted to an object array with one element, rather than an array "
"of the values contained in `test_elements`. This is a consequence of the "
"`array` constructor's way of handling non-sequence collections. Converting "
"the set to a list usually gives the desired behavior."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isin:76
msgid ""
"Using ``kind='table'`` tends to be faster than `kind='sort'` if the "
"following relationship is true: ``log10(len(test_elements)) > "
"(log10(max(test_elements)-min(test_elements)) - 2.27) / 0.927``, but may use "
"greater memory. The default value for `kind` will be automatically selected "
"based only on memory usage, so one may manually set ``kind='table'`` if "
"memory constraints can be relaxed."
msgstr ""

