msgid "ndarray, algebra_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermval:50
msgid "The shape of the return value is described above."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermval:61
msgid ""
":obj:`hermval2d`, :obj:`hermgrid2d`, :obj:`hermval3d`, :obj:`hermgrid3d`"
msgstr ""

