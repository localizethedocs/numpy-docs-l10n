#: ../../../reference/generated/numpy.polynomial.hermite.hermval.rst:4
msgid "numpy.polynomial.hermite.hermval"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermval:2
msgid "Evaluate a Hermite series at points x."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermval:4
msgid "If `c` is of length ``n + 1``, this function returns the value:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermval:6
msgid ""
"p(x) = c_0 * H_0(x) + c_1 * H_1(x) + ... + c_n * H_n(x)\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermval:8
msgid ""
"The parameter `x` is converted to an array only if it is a tuple or a list, "
"otherwise it is treated as a scalar. In either case, either `x` or its "
"elements must support multiplication and addition both with themselves and "
"with the elements of `c`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermval:13
msgid ""
"If `c` is a 1-D array, then ``p(x)`` will have the same shape as `x`.  If "
"`c` is multidimensional, then the shape of the result depends on the value "
"of `tensor`. If `tensor` is true the shape will be c.shape[1:] + x.shape. If "
"`tensor` is false the shape will be c.shape[1:]. Note that scalars have "
"shape (,)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermval:19
msgid ""
"Trailing zeros in the coefficients will be used in the evaluation, so they "
"should be avoided if efficiency is a concern."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermval:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermval:28
msgid "**x**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermval:-1
msgid "array_like, compatible object"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermval:25
msgid ""
"If `x` is a list or tuple, it is converted to an ndarray, otherwise it is "
"left unchanged and treated as a scalar. In either case, `x` or its elements "
"must support addition and multiplication with themselves and with the "
"elements of `c`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermval:35
msgid "**c**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermval:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermval:31
msgid ""
"Array of coefficients ordered so that the coefficients for terms of degree n "
"are contained in c[n]. If `c` is multidimensional the remaining indices "
"enumerate multiple polynomials. In the two dimensional case the coefficients "
"may be thought of as stored in the columns of `c`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermval:45
msgid "**tensor**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermval:-1
msgid "boolean, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermval:38
msgid ""
"If True, the shape of the coefficient array is extended with ones on the "
"right, one for each dimension of `x`. Scalars have dimension 0 for this "
"action. The result is that every column of coefficients in `c` is evaluated "
"for every element of `x`. If False, `x` is broadcast over the columns of `c` "
"for the evaluation.  This keyword is useful when `c` is multidimensional. "
"The default value is True."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermval:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermval:56
