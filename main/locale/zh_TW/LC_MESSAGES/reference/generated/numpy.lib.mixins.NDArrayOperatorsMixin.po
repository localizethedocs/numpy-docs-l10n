#: ../../../reference/generated/numpy.lib.mixins.NDArrayOperatorsMixin.rst:2
msgid "numpy.lib.mixins.NDArrayOperatorsMixin"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/mixins.py:docstring
#: of numpy.lib.mixins.NDArrayOperatorsMixin:2
msgid "Mixin defining all operator special methods using __array_ufunc__."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/mixins.py:docstring
#: of numpy.lib.mixins.NDArrayOperatorsMixin:4
msgid ""
"This class implements the special methods for almost all of Python's builtin "
"operators defined in the `operator` module, including comparisons (``==``, "
"``>``, etc.) and arithmetic (``+``, ``*``, ``-``, etc.), by deferring to the "
"``__array_ufunc__`` method, which subclasses must implement."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/mixins.py:docstring
#: of numpy.lib.mixins.NDArrayOperatorsMixin:10
msgid ""
"It is useful for writing classes that do not inherit from `numpy.ndarray`, "
"but that should support arithmetic and numpy universal functions like arrays "
"as described in :external+neps:doc:`nep-0013-ufunc-overrides`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/mixins.py:docstring
#: of numpy.lib.mixins.NDArrayOperatorsMixin:14
msgid ""
"As a trivial example, consider this implementation of an ``ArrayLike`` class "
"that simply wraps a NumPy array and ensures that the result of any "
"arithmetic operation is also an ``ArrayLike`` object:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/mixins.py:docstring
#: of numpy.lib.mixins.NDArrayOperatorsMixin:62
msgid ""
"In interactions between ``ArrayLike`` objects and numbers or numpy arrays, "
"the result is always another ``ArrayLike``:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/mixins.py:docstring
#: of numpy.lib.mixins.NDArrayOperatorsMixin:75
msgid ""
"Note that unlike ``numpy.ndarray``, ``ArrayLike`` does not allow operations "
"with arbitrary, unrecognized types. This ensures that interactions with "
"ArrayLike preserve a well-defined casting hierarchy."
msgstr ""
