#: ../../../reference/generated/numpy.divmod.rst:4
msgid "numpy.divmod"
msgstr ""

#: ../../../../docstring of numpy.divmod:2
msgid "Return element-wise quotient and remainder simultaneously."
msgstr ""

#: ../../../../docstring of numpy.divmod:4
msgid ""
"``np.divmod(x, y)`` is equivalent to ``(x // y, x % y)``, but faster because "
"it avoids redundant work. It is used to implement the Python built-in "
"function ``divmod`` on NumPy arrays."
msgstr ""

#: ../../../../docstring of numpy.divmod:0
msgid "Parameters"
msgstr "參數"

#: ../../../../docstring of numpy.divmod:11
msgid "**x1**"
msgstr ""

#: ../../../../docstring of numpy.divmod:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../docstring of numpy.divmod:11
msgid "Dividend array."
msgstr ""

#: ../../../../docstring of numpy.divmod:16
msgid "**x2**"
msgstr ""

#: ../../../../docstring of numpy.divmod:14
msgid ""
"Divisor array. If ``x1.shape != x2.shape``, they must be broadcastable to a "
"common shape (which becomes the shape of the output)."
msgstr ""

#: ../../../../docstring of numpy.divmod:22
msgid "**out**"
msgstr "**out**"

#: ../../../../docstring of numpy.divmod:-1
msgid "ndarray, None, or tuple of ndarray and None, optional"
msgstr ""

#: ../../../../docstring of numpy.divmod:19
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or None, a freshly-"
"allocated array is returned. A tuple (possible only as a keyword argument) "
"must have length equal to the number of outputs."
msgstr ""

#: ../../../../docstring of numpy.divmod:30
msgid "**where**"
msgstr ""

#: ../../../../docstring of numpy.divmod:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../docstring of numpy.divmod:25
msgid ""
"This condition is broadcast over the input. At locations where the condition "
"is True, the `out` array will be set to the ufunc result. Elsewhere, the "
"`out` array will retain its original value. Note that if an uninitialized "
"`out` array is created via the default ``out=None``, locations within it "
"where the condition is False will remain uninitialized."
msgstr ""

#: ../../../../docstring of numpy.divmod:36
msgid "**\\*\\*kwargs**"
msgstr ""

#: ../../../../docstring of numpy.divmod:33
msgid ""
"For other keyword-only arguments, see the :ref:`ufunc docs <ufuncs.kwargs>`."
msgstr ""

#: ../../../../docstring of numpy.divmod:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../docstring of numpy.divmod:42
msgid "**out1**"
msgstr ""

#: ../../../../docstring of numpy.divmod:-1
msgid "ndarray"
msgstr ""

#: ../../../../docstring of numpy.divmod:41
msgid ""
"Element-wise quotient resulting from floor division. This is a scalar if "
"both `x1` and `x2` are scalars."
msgstr ""

#: ../../../../docstring of numpy.divmod:52
msgid "**out2**"
msgstr ""

#: ../../../../docstring of numpy.divmod:45
msgid ""
"Element-wise remainder from floor division. This is a scalar if both `x1` "
"and `x2` are scalars."
msgstr ""

#: ../../../../docstring of numpy.divmod:57
msgid ":obj:`floor_divide`"
msgstr ""

#: ../../../../docstring of numpy.divmod:58
msgid "Equivalent to Python's ``//`` operator."
msgstr ""

#: ../../../../docstring of numpy.divmod:59
msgid ":obj:`remainder`"
msgstr ""

#: ../../../../docstring of numpy.divmod:60
msgid "Equivalent to Python's ``%`` operator."
msgstr ""

#: ../../../../docstring of numpy.divmod:61
msgid ":obj:`modf`"
msgstr ""

#: ../../../../docstring of numpy.divmod:62
msgid ""
"Equivalent to ``divmod(x, 1)`` for positive ``x`` with the return values "
"switched."
msgstr ""

#: ../../../../docstring of numpy.divmod:68
msgid "Examples"
msgstr "範例"

#: ../../../../docstring of numpy.divmod:77
msgid ""
"The `divmod` function can be used as a shorthand for ``np.divmod`` on "
"ndarrays."
msgstr ""

