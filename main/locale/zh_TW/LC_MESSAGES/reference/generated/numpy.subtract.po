#: ../../../reference/generated/numpy.subtract.rst:4
msgid "numpy.subtract"
msgstr ""

#: ../../../../docstring of numpy.subtract:2
msgid "Subtract arguments, element-wise."
msgstr ""

#: ../../../../docstring of numpy.subtract:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.subtract:10
msgid "**x1, x2**"
msgstr ""

#: ../../../../docstring of numpy.subtract:-1
msgid "array_like"
msgstr ""

#: ../../../../docstring of numpy.subtract:8
msgid ""
"The arrays to be subtracted from each other. If ``x1.shape != x2.shape``, "
"they must be broadcastable to a common shape (which becomes the shape of the "
"output)."
msgstr ""

#: ../../../../docstring of numpy.subtract:16
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.subtract:-1
msgid "ndarray, None, or tuple of ndarray and None, optional"
msgstr ""

#: ../../../../docstring of numpy.subtract:13
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or None, a freshly-"
"allocated array is returned. A tuple (possible only as a keyword argument) "
"must have length equal to the number of outputs."
msgstr ""

#: ../../../../docstring of numpy.subtract:24
msgid "**where**"
msgstr ""

#: ../../../../docstring of numpy.subtract:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../docstring of numpy.subtract:19
msgid ""
"This condition is broadcast over the input. At locations where the condition "
"is True, the `out` array will be set to the ufunc result. Elsewhere, the "
"`out` array will retain its original value. Note that if an uninitialized "
"`out` array is created via the default ``out=None``, locations within it "
"where the condition is False will remain uninitialized."
msgstr ""

#: ../../../../docstring of numpy.subtract:30
msgid "**\\*\\*kwargs**"
msgstr ""

#: ../../../../docstring of numpy.subtract:27
msgid ""
"For other keyword-only arguments, see the :ref:`ufunc docs <ufuncs.kwargs>`."
msgstr ""

#: ../../../../docstring of numpy.subtract:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.subtract:43
msgid "**y**"
msgstr ""

#: ../../../../docstring of numpy.subtract:-1
msgid "ndarray"
msgstr ""

#: ../../../../docstring of numpy.subtract:35
msgid ""
"The difference of `x1` and `x2`, element-wise. This is a scalar if both `x1` "
"and `x2` are scalars."
msgstr ""

#: ../../../../docstring of numpy.subtract:46
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.subtract:47
msgid "Equivalent to ``x1 - x2`` in terms of array broadcasting."
msgstr ""

#: ../../../../docstring of numpy.subtract:51
msgid "Examples"
msgstr ""

#: ../../../../docstring of numpy.subtract:67
msgid ""
"The ``-`` operator can be used as a shorthand for ``np.subtract`` on "
"ndarrays."
msgstr ""

