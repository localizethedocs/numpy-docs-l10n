#: ../../../reference/generated/numpy.polynomial.polynomial.polyint.rst:4
msgid "numpy.polynomial.polynomial.polyint"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyint:2
msgid "Integrate a polynomial."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyint:4
msgid ""
"Returns the polynomial coefficients `c` integrated `m` times from `lbnd` "
"along `axis`.  At each iteration the resulting series is **multiplied** by "
"`scl` and an integration constant, `k`, is added. The scaling factor is for "
"use in a linear change of variable.  (\"Buyer beware\": note that, depending "
"on what one is doing, one may want `scl` to be the reciprocal of what one "
"might expect; for more information, see the Notes section below.) The "
"argument `c` is an array of coefficients, from low to high degree along each "
"axis, e.g., [1,2,3] represents the polynomial ``1 + 2*x + 3*x**2`` while "
"[[1,2],[1,2]] represents ``1 + 1*x + 2*y + 2*x*y`` if axis=0 is ``x`` and "
"axis=1 is ``y``."
msgstr ""

