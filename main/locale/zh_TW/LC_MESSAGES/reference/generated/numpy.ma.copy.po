msgid "numpy.ma.copy"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.copy:2
msgid "Return a copy of the array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.copy:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.copy:22
msgid "**order**"
msgstr "**命令**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.copy:-1
msgid "{'C', 'F', 'A', 'K'}, optional"
msgstr "{'C', 'F', 'A', 'K'}，可選"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.copy:8
msgid ""
"Controls the memory layout of the copy. 'C' means C-order, 'F' means F-"
"order, 'A' means 'F' if `a` is Fortran contiguous, 'C' otherwise. 'K' means "
"match the layout of `a` as closely as possible. (Note that this function "
"and :func:`numpy.copy` are very similar but have different default values "
"for their order= arguments, and this function always passes sub-classes "
"through.)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.copy:27
msgid ":obj:`numpy.copy`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.copy:28
msgid "Similar function with different default behavior"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.copy:29
msgid ":obj:`numpy.copyto`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.copy:33
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.copy:34
msgid ""
"This function is the preferred method for creating an array copy.  The "
"function :func:`numpy.copy` is similar, but it defaults to using order 'K', "
"and will not pass sub-classes through by default."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.copy:40
msgid "Examples"
msgstr "範例"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.copy:63
msgid ""
"For arrays containing Python objects (e.g. dtype=np.object_), the copy is a "
"shallow one. The new array will contain the same object which may lead to "
"surprises if that object can be modified (is mutable):"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.copy:74
msgid ""
"To ensure all elements within an ``object`` array are copied, use `copy."
"deepcopy`:"
