msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.trim_zeros:-1
msgid "{\"fb\", \"f\", \"b\"}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.trim_zeros:11
msgid ""
"A string with 'f' representing trim from front and 'b' to trim from back. By "
"default, zeros are trimmed on both sides. Front and back refer to the edges "
"of a dimension, with \"front\" referring to the side with the lowest index "
"0, and \"back\" referring to the highest index (or index -1)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.trim_zeros:26
msgid "**axis**"
msgstr "**axis**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.trim_zeros:-1
msgid "int or sequence, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.trim_zeros:18
msgid ""
"If None, `filt` is cropped such that the smallest bounding box is returned "
"that still contains all values which are not zero. If an axis is specified, "
"`filt` will be sliced in that dimension only on the sides specified by "
"`trim`. The remaining area will be the smallest that still contains all "
"values which are not zero."
msgstr ""

