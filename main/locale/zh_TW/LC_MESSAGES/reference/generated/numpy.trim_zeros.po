msgid "ndarray or sequence"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.trim_zeros:31
msgid ""
"The result of trimming the input. The number of dimensions and the input "
"data type are preserved."
msgstr ""

