#: ../../../../docstring of numpy.ma.core.conjugate:2
msgid "Return the complex conjugate, element-wise."
msgstr ""

#: ../../../../docstring of numpy.ma.core.conjugate:4
msgid ""
"The complex conjugate of a complex number is obtained by changing the sign "
"of its imaginary part."
msgstr ""

