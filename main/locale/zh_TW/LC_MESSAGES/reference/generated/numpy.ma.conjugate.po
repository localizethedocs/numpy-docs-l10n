msgid "**y**"
msgstr ""

#: ../../../../docstring of numpy.ma.core.conjugate:-1
msgid "ndarray"
msgstr ""

#: ../../../../docstring of numpy.ma.core.conjugate:35
msgid ""
"The complex conjugate of `x`, with same dtype as `y`. This is a scalar if "
"`x` is a scalar."
