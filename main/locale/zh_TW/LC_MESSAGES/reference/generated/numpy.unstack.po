#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unstack:2
msgid "Split an array into a sequence of arrays along the given axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unstack:4
msgid ""
"The ``axis`` parameter specifies the dimension along which the array will be "
"split. For example, if ``axis=0`` (the default) it will be the first "
"dimension and if ``axis=-1`` it will be the last dimension."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unstack:8
msgid "The result is a tuple of arrays split along ``axis``."
