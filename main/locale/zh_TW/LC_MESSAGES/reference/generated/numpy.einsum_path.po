#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.einsum_path:59
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.einsum_path:60
msgid ""
"The resulting path indicates which terms of the input contraction should be "
"contracted first, the result of this contraction is then appended to the end "
"of the contraction list. This list can then be iterated over until all "
"intermediate contractions are complete."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.einsum_path:67
msgid "Examples"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.einsum_path:72
msgid ""
"We can begin with a chain dot example. In this case, it is optimal to "
"contract the ``b`` and ``c`` tensors first as represented by the first "
"element of the path ``(1, 2)``. The resulting tensor is added to the end of "
"the contraction and the remaining contraction ``(0, 1)`` is then completed."
msgstr ""

