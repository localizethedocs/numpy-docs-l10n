#: ../../../reference/generated/numpy.polynomial.laguerre.lagder.rst:4
msgid "numpy.polynomial.laguerre.lagder"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagder:2
msgid "Differentiate a Laguerre series."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagder:4
msgid ""
"Returns the Laguerre series coefficients `c` differentiated `m` times along "
"`axis`.  At each iteration the result is multiplied by `scl` (the scaling "
"factor is for use in a linear change of variable). The argument `c` is an "
"array of coefficients from low to high degree along each axis, e.g., [1,2,3] "
"represents the series ``1*L_0 + 2*L_1 + 3*L_2`` while [[1,2],[1,2]] "
"represents ``1*L_0(x)*L_0(y) + 1*L_1(x)*L_0(y) + 2*L_0(x)*L_1(y) + "
"2*L_1(x)*L_1(y)`` if axis=0 is ``x`` and axis=1 is ``y``."
msgstr ""

