#: ../../../reference/generated/numpy.count_nonzero.rst:4
msgid "numpy.count\\_nonzero"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.count_nonzero:2
msgid "Counts the number of non-zero values in the array ``a``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.count_nonzero:4
msgid ""
"A non-zero value is one that evaluates to truthful in a boolean context, "
"including any non-zero number and any string that is not empty. This "
"function recursively counts how many elements in ``a`` (and its sub-arrays) "
"are non-zero values."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.count_nonzero:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.count_nonzero:12
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.count_nonzero:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.count_nonzero:12
msgid "The array for which to count non-zeros."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.count_nonzero:17
msgid "**axis**"
msgstr "**axis**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.count_nonzero:-1
msgid "int or tuple, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.count_nonzero:15
msgid ""
"Axis or tuple of axes along which to count non-zeros. Default is None, "
"meaning that non-zeros will be counted along a flattened version of ``a``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.count_nonzero:24
msgid "**keepdims**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.count_nonzero:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.count_nonzero:20
msgid ""
"If this is set to True, the axes that are counted are left in the result as "
"dimensions with size one. With this option, the result will broadcast "
"correctly against the input array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.count_nonzero:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.count_nonzero:37
msgid "**count**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.count_nonzero:-1
msgid "int or array of int"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.count_nonzero:29
msgid ""
"Number of non-zero values in the array along a given axis. Otherwise, the "
"total number of non-zero values in the array is returned."
msgstr ""

