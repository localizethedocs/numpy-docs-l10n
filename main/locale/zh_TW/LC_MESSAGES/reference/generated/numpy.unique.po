msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:14
msgid ""
"Input array. Unless `axis` is specified, this will be flattened if it is not "
"already 1-D."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:19
msgid "**return_index**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:18
msgid ""
"If True, also return the indices of `ar` (along the specified axis, if "
"provided, or in the flattened array) that result in the unique array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:23
msgid "**return_inverse**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:22
msgid ""
"If True, also return the indices of the unique array (for the specified "
"axis, if provided) that can be used to reconstruct `ar`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:27
msgid "**return_counts**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:26
msgid ""
"If True, also return the number of times each unique item appears in `ar`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:35
msgid "**axis**"
msgstr "**axis**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:-1
msgid "int or None, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:30
msgid ""
"The axis to operate on. If None, `ar` will be flattened. If an integer, the "
"subarrays indexed by the given axis will be flattened and treated as the "
"elements of a 1-D array with the dimension of the given axis, see the notes "
"for more details.  Object arrays or structured arrays that contain objects "
"are not supported if the `axis` kwarg is used. The default is None."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:40
msgid "**equal_nan**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:38
msgid "If True, collapses multiple NaN values in the return array into one."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:49
msgid "**sorted**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:43
msgid ""
"If True, the unique elements are sorted. Elements may be sorted in practice "
"even if ``sorted=False``, but this could change without notice."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:54
msgid "**unique**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:54
msgid "The sorted unique values."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:58
msgid "**unique_indices**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:-1
msgid "ndarray, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:57
msgid ""
"The indices of the first occurrences of the unique values in the original "
"array. Only provided if `return_index` is True."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:62
msgid "**unique_inverse**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:61
msgid ""
"The indices to reconstruct the original array from the unique array. Only "
"provided if `return_inverse` is True."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:72
msgid "**unique_counts**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:65
msgid ""
"The number of times each of the unique values comes up in the original "
"array. Only provided if `return_counts` is True."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:77
msgid ":obj:`repeat`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:78
msgid "Repeat elements of an array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:79
msgid ":obj:`sort`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:80
msgid "Return a sorted copy of an array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:84
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:85
msgid ""
"When an axis is specified the subarrays indexed by the axis are sorted. This "
"is done by making the specified axis the first dimension of the array (move "
"the axis to the first dimension to keep the order of the other axes) and "
"then flattening the subarrays in C order. The flattened subarrays are then "
"viewed as a structured type with each element given a label, with the effect "
"that we end up with a 1-D array of structured types that can be treated in "
"the same way as any other 1-D array. The result is that the flattened "
"subarrays are sorted in lexicographic order starting with the first element."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:95
msgid ""
"Like np.sort, NaN will sort to the end of the values. For complex arrays all "
"NaN values are considered equivalent (no matter whether the NaN is in the "
"real or imaginary part). As the representant for the returned array the "
"smallest one in the lexicographical order is chosen - see np.sort for how "
"the lexicographical order is defined for complex arrays."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:103
msgid ""
"For multi-dimensional inputs, ``unique_inverse`` is reshaped such that the "
"input can be reconstructed using ``np.take(unique, unique_inverse, "
"axis=axis)``. The result is now not 1-dimensional when ``axis=None``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:109
msgid ""
"Note that in NumPy 2.0.0 a higher dimensional array was returned also when "
"``axis`` was not ``None``.  This was reverted, but ``inverse.reshape(-1)`` "
"can be used to ensure compatibility with both versions."
msgstr ""

