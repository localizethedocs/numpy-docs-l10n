msgid "Find the unique elements of an array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:4
msgid ""
"Returns the sorted unique elements of an array. There are three optional "
"outputs in addition to the unique elements:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:7
msgid "the indices of the input array that give the unique values"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:8
msgid "the indices of the unique array that reconstruct the input array"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.unique:9
msgid "the number of times each unique value comes up in the input array"
msgstr ""

