msgstr ""

#: ../../../../docstring of numpy.isfinite:2
msgid "Test element-wise for finiteness (not infinity and not Not a Number)."
msgstr ""

#: ../../../../docstring of numpy.isfinite:4
msgid "The result is returned as a boolean array."
msgstr ""

