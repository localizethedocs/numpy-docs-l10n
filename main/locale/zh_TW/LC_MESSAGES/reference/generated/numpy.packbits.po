#: ../../../reference/generated/numpy.packbits.rst:4
msgid "numpy.packbits"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.packbits:2
msgid "Packs the elements of a binary-valued array into bits in a uint8 array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.packbits:4
msgid "The result is padded to full bytes by inserting zero bits at the end."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.packbits:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.packbits:10
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.packbits:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.packbits:9
msgid ""
"An array of integers or booleans whose elements should be packed to bits."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.packbits:14
msgid "**axis**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.packbits:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.packbits:13
msgid ""
"The dimension over which bit-packing is done. ``None`` implies packing the "
"flattened array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.packbits:22
msgid "**bitorder**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.packbits:-1
msgid "{'big', 'little'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.packbits:17
msgid ""
"The order of the input bits. 'big' will mimic bin(val), ``[0, 0, 0, 0, 0, 0, "
"1, 1] => 3 = 0b00000011``, 'little' will reverse the order so ``[1, 1, 0, 0, "
"0, 0, 0, 0] => 3``. Defaults to 'big'."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.packbits:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.packbits:36
msgid "**packed**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.packbits:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.packbits:27
msgid ""
"Array of type uint8 whose elements represent bits corresponding to the "
"logical (0 or nonzero) value of the input elements. The shape of `packed` "
"has the same number of dimensions as the input (unless `axis` is None, in "
"which case the output is 1-D)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.packbits:41
msgid ":obj:`unpackbits`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.packbits:42
msgid "Unpacks elements of a uint8 array into a binary-valued output array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.packbits:48
msgid "Examples"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.packbits:65
msgid ""
"Note that in binary 160 = 1010 0000, 64 = 0100 0000, 192 = 1100 0000, and 32 "
"= 0010 0000."
msgstr ""

