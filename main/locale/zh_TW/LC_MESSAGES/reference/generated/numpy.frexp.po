#: ../../../reference/generated/numpy.frexp.rst:4
msgid "numpy.frexp"
msgstr ""

#: ../../../../docstring of numpy.frexp:2
msgid "Decompose the elements of x into mantissa and twos exponent."
msgstr ""

#: ../../../../docstring of numpy.frexp:4
msgid ""
"Returns (`mantissa`, `exponent`), where ``x = mantissa * 2**exponent``. The "
"mantissa lies in the open interval(-1, 1), while the twos exponent is a "
"signed integer."
msgstr ""

