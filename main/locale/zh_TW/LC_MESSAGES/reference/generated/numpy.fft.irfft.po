msgstr ":obj:`rfft`"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfft:74
msgid "The one-dimensional FFT of real input, of which `irfft` is inverse."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfft:75
