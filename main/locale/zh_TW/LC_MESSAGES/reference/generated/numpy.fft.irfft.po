#: ../../../reference/generated/numpy.fft.irfft.rst:4
msgid "numpy.fft.irfft"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfft:2
msgid "Computes the inverse of `rfft`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfft:4
msgid ""
"This function computes the inverse of the one-dimensional *n*-point discrete "
"Fourier Transform of real input computed by `rfft`. In other words, "
"``irfft(rfft(a), len(a)) == a`` to within numerical accuracy. (See Notes "
"below for why ``len(a)`` is necessary here.)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfft:9
msgid ""
"The input is expected to be in the form returned by `rfft`, i.e. the real "
"zero-frequency term followed by the complex positive frequency terms in "
"order of increasing frequency.  Since the discrete Fourier Transform of real "
"input is Hermitian-symmetric, the negative frequency terms are taken to be "
"the complex conjugates of the corresponding positive frequency terms."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfft:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfft:18
msgid "**a**"
msgstr "**a**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfft:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfft:18
msgid "The input array."
msgstr "輸入陣列。"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfft:26
msgid "**n**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfft:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfft:21
msgid ""
"Length of the transformed axis of the output. For `n` output points, "
"``n//2+1`` input points are necessary.  If the input is longer than this, it "
"is cropped.  If it is shorter than this, it is padded with zeros.  If `n` is "
"not given, it is taken to be ``2*(m-1)`` where ``m`` is the length of the "
"input along the axis specified by `axis`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfft:30
msgid "**axis**"
msgstr "**axis**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfft:29
msgid ""
"Axis over which to compute the inverse FFT. If not given, the last axis is "
"used."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfft:39
msgid "**norm**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfft:-1
msgid "{\"backward\", \"ortho\", \"forward\"}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfft:33
msgid ""
"Normalization mode (see `numpy.fft`). Default is \"backward\". Indicates "
"which direction of the forward/backward pair of transforms is scaled and "
"with what normalization factor."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfft:39
msgid "The \"backward\", \"forward\" values were added."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfft:47 numpy.fft.irfft:59
msgid "**out**"
msgstr "**out**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfft:-1
msgid "ndarray, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfft:42
msgid ""
"If provided, the result will be placed in this array. It should be of the "
"appropriate shape and dtype."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfft:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfft:-1
msgid "ndarray"
msgstr "ndarray"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfft:52
msgid ""
"The truncated or zero-padded input, transformed along the axis indicated by "
"`axis`, or the last one if `axis` is not specified. The length of the "
"transformed axis is `n`, or, if `n` is not given, ``2*(m-1)`` where ``m`` is "
"the length of the transformed axis of the input. To get an odd number of "
"output points, `n` must be specified."
msgstr ""

