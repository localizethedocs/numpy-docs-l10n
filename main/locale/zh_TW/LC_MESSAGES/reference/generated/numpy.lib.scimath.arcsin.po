#: ../../../reference/generated/numpy.lib.scimath.arcsin.rst:4
msgid "numpy.lib.scimath.arcsin"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arcsin:2
msgid "Compute the inverse sine of x."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arcsin:4
msgid ""
"Return the \"principal value\" (for a description of this, see `numpy."
"arcsin`) of the inverse sine of `x`. For real `x` such that `abs(x) <= 1`, "
"this is a real number in the closed interval :math:`[-\\pi/2, \\pi/2]`.  "
"Otherwise, the complex principle value is returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arcsin:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arcsin:15
msgid "**x**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arcsin:-1
msgid "array_like or scalar"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arcsin:13
msgid "The value(s) whose arcsin is (are) required."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arcsin:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arcsin:27
msgid "**out**"
msgstr "**out**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arcsin:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arcsin:20
msgid ""
"The inverse sine(s) of the `x` value(s). If `x` was a scalar, so is `out`, "
"otherwise an array object is returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arcsin:32
msgid ":obj:`numpy.arcsin`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arcsin:36
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arcsin:37
msgid ""
"For an arcsin() that returns ``NAN`` when real `x` is not in the interval "
"``[-1,1]``, use `numpy.arcsin`."
msgstr ""

