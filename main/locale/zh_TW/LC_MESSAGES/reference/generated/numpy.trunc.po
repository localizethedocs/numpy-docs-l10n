msgid "Returns"
msgstr "回傳值"

#: ../../../../docstring of numpy.trunc:43
msgid "**y**"
msgstr "**y**"

#: ../../../../docstring of numpy.trunc:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.trunc:36
msgid ""
"The truncated value of each element in `x`. This is a scalar if `x` is a "
"scalar."
msgstr ""

