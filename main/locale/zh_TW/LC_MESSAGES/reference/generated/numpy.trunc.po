#: ../../../reference/generated/numpy.trunc.rst:4
msgid "numpy.trunc"
msgstr ""

#: ../../../../docstring of numpy.trunc:2
msgid "Return the truncated value of the input, element-wise."
msgstr ""

#: ../../../../docstring of numpy.trunc:4
msgid ""
"The truncated value of the scalar `x` is the nearest integer `i` which is "
"closer to zero than `x` is. In short, the fractional part of the signed "
"number `x` is discarded."
msgstr ""

#: ../../../../docstring of numpy.trunc:0
msgid "Parameters"
msgstr "參數"

#: ../../../../docstring of numpy.trunc:11
msgid "**x**"
msgstr ""

#: ../../../../docstring of numpy.trunc:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../docstring of numpy.trunc:11
msgid "Input data."
msgstr "輸入資料。"

#: ../../../../docstring of numpy.trunc:17
msgid "**out**"
msgstr "**out**"

#: ../../../../docstring of numpy.trunc:-1
msgid "ndarray, None, or tuple of ndarray and None, optional"
msgstr ""

#: ../../../../docstring of numpy.trunc:14
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or None, a freshly-"
"allocated array is returned. A tuple (possible only as a keyword argument) "
"must have length equal to the number of outputs."
msgstr ""

#: ../../../../docstring of numpy.trunc:25
msgid "**where**"
msgstr "**where**"

#: ../../../../docstring of numpy.trunc:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../docstring of numpy.trunc:20
msgid ""
"This condition is broadcast over the input. At locations where the condition "
"is True, the `out` array will be set to the ufunc result. Elsewhere, the "
"`out` array will retain its original value. Note that if an uninitialized "
"`out` array is created via the default ``out=None``, locations within it "
"where the condition is False will remain uninitialized."
msgstr ""

#: ../../../../docstring of numpy.trunc:31
msgid "**\\*\\*kwargs**"
msgstr "**\\*\\*kwargs**"

#: ../../../../docstring of numpy.trunc:28
msgid ""
"For other keyword-only arguments, see the :ref:`ufunc docs <ufuncs.kwargs>`."
msgstr ""

