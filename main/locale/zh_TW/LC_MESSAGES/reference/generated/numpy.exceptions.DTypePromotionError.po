#: ../../../reference/generated/numpy.exceptions.DTypePromotionError.rst:4
msgid "numpy.exceptions.DTypePromotionError"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/exceptions.py:docstring
#: of numpy.exceptions.DTypePromotionError:2
msgid "Multiple DTypes could not be converted to a common one."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/exceptions.py:docstring
#: of numpy.exceptions.DTypePromotionError:4
msgid ""
"This exception derives from ``TypeError`` and is raised whenever dtypes "
"cannot be converted to a single common one.  This can be because they are of "
"a different category/class or incompatible instances of the same one (see "
"Examples)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/exceptions.py:docstring
#: of numpy.exceptions.DTypePromotionError:21
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/exceptions.py:docstring
#: of numpy.exceptions.DTypePromotionError:22
msgid ""
"Many functions will use promotion to find the correct result and "
"implementation.  For these functions the error will typically be chained "
"with a more specific error indicating that no implementation was found for "
"the input dtypes."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/exceptions.py:docstring
#: of numpy.exceptions.DTypePromotionError:27
msgid ""
"Typically promotion should be considered \"invalid\" between the dtypes of "
"two arrays when `arr1 == arr2` can safely return all ``False`` because the "
"dtypes are fundamentally different."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/exceptions.py:docstring
#: of numpy.exceptions.DTypePromotionError:33
msgid "Examples"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/exceptions.py:docstring
#: of numpy.exceptions.DTypePromotionError:38
msgid ""
"Datetimes and complex numbers are incompatible classes and cannot be "
"promoted:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/exceptions.py:docstring
#: of numpy.exceptions.DTypePromotionError:51
msgid ""
"For example for structured dtypes, the structure can mismatch and the same "
"``DTypePromotionError`` is given when two structured dtypes with a mismatch "
"in their number of fields is given:"
msgstr ""

