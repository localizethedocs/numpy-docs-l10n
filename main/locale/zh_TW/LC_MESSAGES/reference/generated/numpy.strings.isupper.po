#: ../../../reference/generated/numpy.strings.isupper.rst:4
msgid "numpy.strings.isupper"
msgstr ""

#: ../../../../docstring of numpy.strings.isupper:2
msgid ""
"Return true for each element if all cased characters in the string are "
"uppercase and there is at least one character, false otherwise."
msgstr ""

#: ../../../../docstring of numpy.strings.isupper:0
msgid "Parameters"
msgstr ""

