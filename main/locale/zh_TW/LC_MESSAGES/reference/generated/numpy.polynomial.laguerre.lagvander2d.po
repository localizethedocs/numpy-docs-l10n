#: ../../../reference/generated/numpy.polynomial.laguerre.lagvander2d.rst:4
msgid "numpy.polynomial.laguerre.lagvander2d"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagvander2d:2
msgid "Pseudo-Vandermonde matrix of given degrees."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagvander2d:4
msgid ""
"Returns the pseudo-Vandermonde matrix of degrees `deg` and sample points "
"``(x, y)``. The pseudo-Vandermonde matrix is defined by"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagvander2d:7
msgid ""
"V[..., (deg[1] + 1)*i + j] = L_i(x) * L_j(y),\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagvander2d:9
msgid ""
"where ``0 <= i <= deg[0]`` and ``0 <= j <= deg[1]``. The leading indices of "
"`V` index the points ``(x, y)`` and the last index encodes the degrees of "
"the Laguerre polynomials."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagvander2d:13
msgid ""
"If ``V = lagvander2d(x, y, [xdeg, ydeg])``, then the columns of `V` "
"correspond to the elements of a 2-D coefficient array `c` of shape (xdeg + "
"1, ydeg + 1) in the order"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagvander2d:17
msgid ""
"c_{00}, c_{01}, c_{02}, ... , c_{10}, c_{11}, c_{12}, ...\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagvander2d:19
msgid ""
"and ``np.dot(V, c.flat)`` and ``lagval2d(x, y, c)`` will be the same up to "
"roundoff. This equivalence is useful both for least squares fitting and for "
"the evaluation of a large number of 2-D Laguerre series of the same degrees "
"and sample points."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagvander2d:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagvander2d:30
msgid "**x, y**"
msgstr "**x, y**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagvander2d:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagvander2d:27
msgid ""
"Arrays of point coordinates, all of the same shape. The dtypes will be "
"converted to either float64 or complex128 depending on whether any of the "
"elements are complex. Scalars are converted to 1-D arrays."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagvander2d:35
msgid "**deg**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagvander2d:-1
msgid "list of ints"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagvander2d:33
msgid "List of maximum degrees of the form [x_deg, y_deg]."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagvander2d:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagvander2d:48
msgid "**vander2d**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagvander2d:-1
msgid "ndarray"
msgstr "ndarray"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagvander2d:40
msgid ""
"The shape of the returned matrix is ``x.shape + (order,)``, where :math:"
"`order = (deg[0]+1)*(deg[1]+1)`.  The dtype will be the same as the "
"converted `x` and `y`."
msgstr ""

