#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.poly1d:2
msgid "A one-dimensional polynomial class."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.poly1d:5
msgid ""
"This forms part of the old polynomial API. Since version 1.4, the new "
"polynomial API defined in `numpy.polynomial` is preferred. A summary of the "
"differences can be found in the :doc:`transition guide </reference/routines."
"polynomials>`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.poly1d:10
msgid ""
"A convenience class, used to encapsulate \"natural\" operations on "
"polynomials so that said operations may take on their customary form in code "
"(see Examples)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.poly1d:0
