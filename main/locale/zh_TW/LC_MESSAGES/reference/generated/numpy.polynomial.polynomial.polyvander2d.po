msgid ""
"The 2-D pseudo-Vandermonde matrix of degree ``[1, 2]`` and sample points ``x "
"= [-1, 2]`` and ``y = [1, 3]`` is as follows:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvander2d:79
msgid "We can verify the columns for any ``0 <= i <= m`` and ``0 <= j <= n``:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvander2d:85
msgid ""
"The (1D) Vandermonde matrix of sample points ``x`` and degree ``m`` is a "
"special case of the (2D) pseudo-Vandermonde matrix with ``y`` points all "
"zero and degree ``[m, 0]``."
msgstr ""

