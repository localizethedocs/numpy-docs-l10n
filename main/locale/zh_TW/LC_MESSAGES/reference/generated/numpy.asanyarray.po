msgid "numpy.asanyarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.asanyarray:2
msgid "Convert the input to an ndarray, but pass ndarray subclasses through."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.asanyarray:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.asanyarray:10
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.asanyarray:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.asanyarray:8
msgid ""
"Input data, in any form that can be converted to an array.  This includes "
"scalars, lists, lists of tuples, tuples, tuples of tuples, tuples of lists, "
"and ndarrays."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.asanyarray:13
msgid "**dtype**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.asanyarray:-1
msgid "data-type, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.asanyarray:13
msgid "By default, the data-type is inferred from the input data."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.asanyarray:23
msgid "**order**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.asanyarray:-1
msgid "{'C', 'F', 'A', 'K'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.asanyarray:16
msgid ""
"The memory layout of the output. 'C' gives a row-major layout (C-style), 'F' "
"gives a column-major layout (Fortran-style). 'C' and 'F' will copy if needed "
"to ensure the output format. 'A' (any) is equivalent to 'F' if input a is "
"non-contiguous or Fortran-contiguous, otherwise, it is equivalent to 'C'. "
"Unlike 'C' or 'F', 'A' does not ensure that the result is contiguous. "
"'K' (keep) preserves the input order for the output. 'C' is the default."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.asanyarray:29
msgid "**device**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.asanyarray:-1
msgid "str, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.asanyarray:26
msgid ""
"The device on which to place the created array. Default: ``None``. For Array-"
"API interoperability only, so must be ``\"cpu\"`` if passed."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.asanyarray:39
msgid "**copy**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.asanyarray:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.asanyarray:32
msgid ""
"If ``True``, then the object is copied. If ``None`` then the object is "
"copied only if needed, i.e. if ``__array__`` returns a copy, if obj is a "
"nested sequence, or if a copy is needed to satisfy any of the other "
"requirements (``dtype``, ``order``, etc.). For ``False`` it raises a "
"``ValueError`` if a copy cannot be avoided. Default: ``None``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.asanyarray:50
msgid "**like**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.asanyarray:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.asanyarray:42
msgid ""
"Reference object to allow the creation of arrays which are not NumPy arrays. "
"If an array-like passed in as ``like`` supports the ``__array_function__`` "
"protocol, the result will be defined by it. In this case, it ensures the "
"creation of an array object compatible with that passed in via this argument."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.asanyarray:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.asanyarray:62
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.asanyarray:-1
msgid "ndarray or an ndarray subclass"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.asanyarray:55
msgid ""
"Array interpretation of `a`.  If `a` is an ndarray or a subclass of ndarray, "
"it is returned as-is and no copy is performed."
msgstr ""

