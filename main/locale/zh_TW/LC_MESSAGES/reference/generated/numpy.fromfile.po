#: ../../../reference/generated/numpy.fromfile.rst:4
msgid "numpy.fromfile"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.fromfile:2
msgid "Construct an array from data in a text or binary file."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.fromfile:4
msgid ""
"A highly efficient way of reading binary data with a known data-type, as "
"well as parsing simply formatted text files.  Data written using the "
"`tofile` method can be read using this function."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.fromfile:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.fromfile:13
msgid "**file**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.fromfile:-1
msgid "file or str or Path"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.fromfile:11
msgid ""
"An open file object, a string containing the filename, or a Path object. "
"When reading from a file object it must support random access (i.e. it must "
"have tell and seek methods)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.fromfile:19
msgid "**dtype**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.fromfile:-1
msgid "data-type"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.fromfile:16
msgid ""
"Data type of the returned array. For binary files, it is used to determine "
"the size and byte-order of the items in the file. Most builtin numeric types "
"are supported and extension types may be supported."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.fromfile:23
msgid "**count**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.fromfile:-1
msgid "int"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.fromfile:22
msgid ""
"Number of items to read. ``-1`` means all items (i.e., the complete file)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.fromfile:30
msgid "**sep**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.fromfile:-1
msgid "str"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.fromfile:26
msgid ""
"Separator between items if file is a text file. Empty (\"\") separator means "
"the file should be treated as binary. Spaces (\" \") in the separator match "
"zero or more whitespace characters. A separator consisting only of spaces "
"must match at least one whitespace."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.fromfile:34
msgid "**offset**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.fromfile:33
msgid ""
"The offset (in bytes) from the file's current position. Defaults to 0. Only "
"permitted for binary files."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.fromfile:52
msgid "**like**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.fromfile:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.fromfile:37
msgid ""
"Reference object to allow the creation of arrays which are not NumPy arrays. "
"If an array-like passed in as ``like`` supports the ``__array_function__`` "
"protocol, the result will be defined by it. In this case, it ensures the "
"creation of an array object compatible with that passed in via this argument."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.fromfile:57
msgid ":obj:`load`, :obj:`save`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.fromfile:59
msgid ":obj:`ndarray.tofile`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.fromfile:61
msgid ":obj:`loadtxt`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.fromfile:62
msgid "More flexible way of loading data from a text file."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.fromfile:66
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.fromfile:67
msgid ""
"Do not rely on the combination of `tofile` and `fromfile` for data storage, "
"as the binary files generated are not platform independent.  In particular, "
"no byte-order or data-type information is saved.  Data can be stored in the "
"platform independent ``.npy`` format using `save` and `load` instead."
msgstr ""

