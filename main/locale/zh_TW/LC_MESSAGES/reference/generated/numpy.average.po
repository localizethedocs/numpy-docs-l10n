#: ../../../reference/generated/numpy.average.rst:4
msgid "numpy.average"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:2
msgid "Compute the weighted average along the specified axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:9
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:8
msgid ""
"Array containing data to be averaged. If `a` is not an array, a conversion "
"is attempted."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:17
msgid "**axis**"
msgstr "**axis**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:-1
msgid "None or int or tuple of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:12
msgid ""
"Axis or axes along which to average `a`.  The default, `axis=None`, will "
"average over all of the elements of the input array. If axis is negative it "
"counts from the last to the first axis. If axis is a tuple of ints, "
"averaging is performed on all of the axes specified in the tuple instead of "
"a single axis or all the axes as before."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:33
msgid "**weights**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:20
msgid ""
"An array of weights associated with the values in `a`. Each value in `a` "
"contributes to the average according to its associated weight. The array of "
"weights must be the same shape as `a` if no axis is specified, otherwise the "
"weights must have dimensions and shape consistent with `a` along the "
"specified axis. If `weights=None`, then all data in `a` are assumed to have "
"a weight equal to one. The calculation is::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:29
msgid "avg = sum(a * weights) / sum(weights)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:31
msgid ""
"where the sum is over all included elements. The only constraint on the "
"values of `weights` is that `sum(weights)` must not be 0."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:39
msgid "**returned**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:36
msgid ""
"Default is `False`. If `True`, the tuple (`average`, `sum_of_weights`) is "
"returned, otherwise only the average is returned. If `weights=None`, "
"`sum_of_weights` is equivalent to the number of elements over which the "
"average is taken."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:50
msgid "**keepdims**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:42
msgid ""
"If this is set to True, the axes which are reduced are left in the result as "
"dimensions with size one. With this option, the result will broadcast "
"correctly against the original `a`. *Note:* `keepdims` will not work with "
"instances of `numpy.matrix` or other classes whose methods do not support "
"`keepdims`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:67
msgid "**retval, [sum_of_weights]**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:-1
msgid "array_type or double"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:55
msgid ""
"Return the average along the specified axis. When `returned` is `True`, "
"return a tuple with the average as the first element and the sum of the "
"weights as the second element. `sum_of_weights` is of the same type as "
"`retval`. The result dtype follows a general pattern. If `weights` is None, "
"the result dtype will be that of `a` , or ``float64`` if `a` is integral. "
"Otherwise, if `weights` is not None and `a` is non- integral, the result "
"type will be the type of lowest precision capable of representing values of "
"both `a` and `weights`. If `a` happens to be integral, the previous rules "
"still applies but the result dtype will at least be ``float64``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:0
msgid "Raises"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:73
msgid "ZeroDivisionError"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:72
msgid ""
"When all weights along axis are zero. See `numpy.ma.average` for a version "
"robust to this type of error."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:76
msgid "TypeError"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:76
msgid "When `weights` does not have the same shape as `a`, and `axis=None`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:82
msgid "ValueError"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:79
msgid ""
"When `weights` does not have dimensions and shape consistent with `a` along "
"specified `axis`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:87
msgid ":obj:`mean`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:89
msgid ":obj:`ma.average`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:90
msgid ""
"average for masked arrays -- useful if your data contains \"missing\" values"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.average:91
msgid ":obj:`numpy.result_type`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
