#: ../../../reference/generated/numpy.linalg.norm.rst:4
msgid "numpy.linalg.norm"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.norm:2
msgid "Matrix or vector norm."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.norm:4
msgid ""
"This function is able to return one of eight different matrix norms, or one "
"of an infinite number of vector norms (described below), depending on the "
"value of the ``ord`` parameter."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.norm:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.norm:13
msgid "**x**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.norm:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.norm:11
msgid ""
"Input array.  If `axis` is None, `x` must be 1-D or 2-D, unless `ord` is "
"None. If both `axis` and `ord` are None, the 2-norm of ``x.ravel`` will be "
"returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.norm:18
msgid "**ord**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.norm:-1
msgid "{int, float, inf, -inf, 'fro', 'nuc'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.norm:16
msgid ""
"Order of the norm (see table under ``Notes`` for what values are supported "
"for matrices and vectors respectively). inf means numpy's `inf` object. The "
"default is None."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.norm:26
msgid "**axis**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.norm:-1
msgid "{None, int, 2-tuple of ints}, optional."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.norm:21
msgid ""
"If `axis` is an integer, it specifies the axis of `x` along which to compute "
"the vector norms.  If `axis` is a 2-tuple, it specifies the axes that hold 2-"
"D matrices, and the matrix norms of these matrices are computed.  If `axis` "
"is None then either a vector norm (when `x` is 1-D) or a matrix norm (when "
"`x` is 2-D) is returned. The default is None."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.norm:33
msgid "**keepdims**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.norm:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.norm:29
msgid ""
"If this is set to True, the axes which are normed over are left in the "
"result as dimensions with size one.  With this option the result will "
"broadcast correctly against the original `x`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.norm:0
msgid "Returns"
msgstr ""

