#: of numpy.clip:53
msgid "**clipped_array**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.clip:-1
msgid "ndarray"
msgstr "ndarray"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.clip:45
msgid ""
"An array with the elements of `a`, but where values < `a_min` are replaced "
"with `a_min`, and those > `a_max` with `a_max`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.clip:58
msgid ":ref:`ufuncs-output-type`"
msgstr ":ref:`ufuncs-output-type`"

