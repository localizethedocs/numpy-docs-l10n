#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ma.MaskedArray.__array__:2
msgid ""
"For ``dtype`` parameter it returns a new reference to self if ``dtype`` is "
"not given or it matches array's data type. A new array of provided data type "
"is returned if ``dtype`` is different from the current data type of the "
"array. For ``copy`` parameter it returns a new reference to self if "
"``copy=False`` or ``copy=None`` and copying isn't enforced by ``dtype`` "
"parameter. The method returns a new array for ``copy=True``, regardless of "
"``dtype`` parameter."
msgstr ""

