msgid "numpy.nanprod"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanprod:2
msgid ""
"Return the product of array elements over a given axis treating Not a "
"Numbers (NaNs) as ones."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanprod:5
msgid "One is returned for slices that are all-NaN or empty."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanprod:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanprod:11
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanprod:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanprod:10
msgid ""
"Array containing numbers whose product is desired. If `a` is not an array, a "
"conversion is attempted."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanprod:15
msgid "**axis**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanprod:-1
msgid "{int, tuple of int, None}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanprod:14
msgid ""
"Axis or axes along which the product is computed. The default is to compute "
"the product of the flattened array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanprod:23
msgid "**dtype**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanprod:-1
msgid "data-type, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanprod:18
msgid ""
"The type of the returned array and of the accumulator in which the elements "
"are summed.  By default, the dtype of `a` is used.  An exception is when `a` "
"has an integer type with less precision than the platform (u)intp. In that "
"case, the default will be either (u)int32 or (u)int64 depending on whether "
"the platform is 32 or 64 bits. For inexact inputs, dtype must be inexact."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanprod:30
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanprod:-1
msgid "ndarray, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanprod:26
msgid ""
"Alternate output array in which to place the result.  The default is "
"``None``. If provided, it must have the same shape as the expected output, "
"but the type will be cast if necessary. See :ref:`ufuncs-output-type` for "
"more details. The casting of NaN to integer can yield unexpected results."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanprod:35
msgid "**keepdims**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanprod:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanprod:33
msgid ""
"If True, the axes which are reduced are left in the result as dimensions "
"with size one. With this option, the result will broadcast correctly against "
"the original `arr`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanprod:41
msgid "**initial**"
msgstr ""

