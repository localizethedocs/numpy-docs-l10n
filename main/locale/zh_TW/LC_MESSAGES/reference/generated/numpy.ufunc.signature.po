#: ../../../reference/generated/numpy.ufunc.signature.rst:4
msgid "numpy.ufunc.signature"
msgstr ""

#: ../../../reference/generated/numpy.ufunc.signature.rst:8
msgid "attribute"
msgstr ""

#: ../../../../docstring of numpy.ufunc.signature:2
msgid "Definition of the core elements a generalized ufunc operates on."
msgstr ""

#: ../../../../docstring of numpy.ufunc.signature:4
msgid ""
"The signature determines how the dimensions of each input/output array are "
"split into core and loop dimensions:"
msgstr ""

#: ../../../../docstring of numpy.ufunc.signature:7
msgid ""
"Each dimension in the signature is matched to a dimension of the "
"corresponding passed-in array, starting from the end of the shape tuple."
msgstr ""

#: ../../../../docstring of numpy.ufunc.signature:9
msgid ""
"Core dimensions assigned to the same label in the signature must have "
"exactly matching sizes, no broadcasting is performed."
msgstr ""

#: ../../../../docstring of numpy.ufunc.signature:11
msgid ""
"The core dimensions are removed from all inputs and the remaining dimensions "
"are broadcast together, defining the loop dimensions."
msgstr ""

#: ../../../../docstring of numpy.ufunc.signature:26
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.ufunc.signature:27
msgid ""
"Generalized ufuncs are used internally in many linalg functions, and in the "
"testing suite; the examples below are taken from these. For ufuncs that "
"operate on scalars, the signature is None, which is equivalent to '()' for "
"every argument."
msgstr ""

