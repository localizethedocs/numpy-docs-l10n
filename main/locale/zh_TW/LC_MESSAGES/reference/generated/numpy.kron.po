#: ../../../reference/generated/numpy.kron.rst:4
msgid "numpy.kron"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.kron:2
msgid "Kronecker product of two arrays."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.kron:4
msgid ""
"Computes the Kronecker product, a composite array made of blocks of the "
"second array scaled by the first."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.kron:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.kron:12
msgid "**a, b**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.kron:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.kron:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.kron:23
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.kron:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.kron:28
msgid ":obj:`outer`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.kron:29
msgid "The outer product"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.kron:33
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.kron:34
msgid ""
"The function assumes that the number of dimensions of `a` and `b` are the "
"same, if necessary prepending the smallest with ones. If ``a.shape = (r0,"
"r1,...,rN)`` and ``b.shape = (s0,s1,...,sN)``, the Kronecker product has "
"shape ``(r0*s0, r1*s1, ..., rN*SN)``. The elements are products of elements "
"from `a` and `b`, organized explicitly by::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.kron:41
msgid "kron(a,b)[k0,k1,...,kN] = a[i0,i1,...,iN] * b[j0,j1,...,jN]"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.kron:43
msgid "where::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.kron:45
msgid "kt = it * st + jt,  t = 0,...,N"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.kron:47
msgid "In the common 2-D case (N=1), the block structure can be visualized::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.kron:49
msgid ""
"[[ a[0,0]*b,   a[0,1]*b,  ... , a[0,-1]*b  ],\n"
" [  ...                              ...   ],\n"
" [ a[-1,0]*b,  a[-1,1]*b, ... , a[-1,-1]*b ]]"
msgstr ""

