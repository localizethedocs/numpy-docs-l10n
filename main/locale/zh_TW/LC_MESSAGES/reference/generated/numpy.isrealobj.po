msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isrealobj:2
msgid "Return True if x is a not complex type or an array of complex numbers."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.isrealobj:4
msgid ""
"The type of the input is checked, not the value. So even if the input has an "
"imaginary part equal to zero, `isrealobj` evaluates to False if the data "
"type is complex."
msgstr ""

