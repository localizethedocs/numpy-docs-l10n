#: of numpy.real_if_close:2
msgid ""
"If input is complex with all imaginary parts close to zero, return real "
"parts."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.real_if_close:5
msgid ""
