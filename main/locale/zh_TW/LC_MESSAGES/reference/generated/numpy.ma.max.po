msgid "numpy.ma.max"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.max:2
msgid "Return the maximum along a given axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.max:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.max:11
msgid "**axis**"
msgstr "**axis**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.max:-1
msgid "None or int or tuple of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.max:8
msgid ""
"Axis along which to operate.  By default, ``axis`` is None and the flattened "
"input is used. If this is a tuple of ints, the maximum is selected over "
"multiple axes, instead of a single axis or all the axes as before."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.max:15
msgid "**out**"
msgstr "**out**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.max:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.max:14
msgid ""
"Alternative output array in which to place the result.  Must be of the same "
"shape and buffer length as the expected output."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.max:19
msgid "**fill_value**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.max:-1
msgid "scalar or None, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.max:18
msgid ""
"Value used to fill in the masked values. If None, use the output of "
"maximum_fill_value()."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.max:26
msgid "**keepdims**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.max:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.max:22
msgid ""
"If this is set to True, the axes which are reduced are left in the result as "
"dimensions with size one. With this option, the result will broadcast "
"correctly against the array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.max:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.max:38
msgid "**amax**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.max:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.max:31
msgid ""
"New array holding the result. If ``out`` was specified, ``out`` is returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.max:43
