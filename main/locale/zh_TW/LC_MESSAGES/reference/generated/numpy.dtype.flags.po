#: ../../../../docstring of numpy.dtype.flags:2
msgid "Bit-flags describing how this data type is to be interpreted."
msgstr ""

#: ../../../../docstring of numpy.dtype.flags:4
msgid ""
"Bit-masks are in ``numpy._core.multiarray`` as the constants "
"`ITEM_HASOBJECT`, `LIST_PICKLE`, `ITEM_IS_POINTER`, `NEEDS_INIT`, "
"`NEEDS_PYAPI`, `USE_GETITEM`, `USE_SETITEM`. A full explanation of these "
"flags is in C-API documentation; they are largely useful for user-defined "
"data-types."
msgstr ""

