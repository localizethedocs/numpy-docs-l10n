#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.asanyarray:2
msgid "Convert the input to a masked array, conserving subclasses."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.asanyarray:4
msgid ""
"If `a` is a subclass of `MaskedArray`, its class is conserved. No copy is "
"performed if the input is already an `ndarray`."
msgstr ""

