msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.asanyarray:23
msgid "**order**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.asanyarray:-1
msgid "{'C', 'F', 'A', 'K'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.asanyarray:16
msgid ""
"Memory layout.  'A' and 'K' depend on the order of input array ``a``. 'C' "
"row-major (C-style), 'F' column-major (Fortran-style) memory representation. "
"'A' (any) means 'F' if ``a`` is Fortran contiguous, 'C' otherwise 'K' (keep) "
"preserve input order Defaults to 'K'."
msgstr ""

