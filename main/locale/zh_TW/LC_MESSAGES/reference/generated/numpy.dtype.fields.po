#: ../../../reference/generated/numpy.dtype.fields.rst:4
msgid "numpy.dtype.fields"
msgstr ""

#: ../../../reference/generated/numpy.dtype.fields.rst:8
msgid "attribute"
msgstr ""

#: ../../../../docstring of numpy.dtype.fields:2
msgid "Dictionary of named fields defined for this data type, or ``None``."
msgstr ""

#: ../../../../docstring of numpy.dtype.fields:4
msgid ""
"The dictionary is indexed by keys that are the names of the fields. Each "
"entry in the dictionary is a tuple fully describing the field::"
msgstr ""

#: ../../../../docstring of numpy.dtype.fields:7
msgid "(dtype, offset[, title])"
msgstr ""

#: ../../../../docstring of numpy.dtype.fields:9
msgid ""
"Offset is limited to C int, which is signed and usually 32 bits. If present, "
"the optional title can be any object (if it is a string or unicode then it "
"will also be a key in the fields dictionary, otherwise it's meta-data). "
"Notice also that the first two elements of the tuple can be passed directly "
"as arguments to the ``ndarray.getfield`` and ``ndarray.setfield`` methods."
msgstr ""

#: ../../../../docstring of numpy.dtype.fields:29
msgid ":obj:`ndarray.getfield`, :obj:`ndarray.setfield`"
msgstr ""

