#: ../../../reference/generated/numpy.linspace.rst:4
msgid "numpy.linspace"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:2
msgid "Return evenly spaced numbers over a specified interval."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:4
msgid ""
"Returns `num` evenly spaced samples, calculated over the interval [`start`, "
"`stop`]."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:7
msgid "The endpoint of the interval can optionally be excluded."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:9
msgid ""
"Values are rounded towards ``-inf`` instead of ``0`` when an integer "
"``dtype`` is specified. The old behavior can still be obtained with ``np."
"linspace(start, stop, num).astype(np.int_)``"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:17
msgid "**start**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:17
msgid "The starting value of the sequence."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:23
msgid "**stop**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:20
msgid ""
"The end value of the sequence, unless `endpoint` is set to False. In that "
"case, the sequence consists of all but the last of ``num + 1`` evenly spaced "
"samples, so that `stop` is excluded.  Note that the step size changes when "
"`endpoint` is False."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:26
msgid "**num**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:26
msgid "Number of samples to generate. Default is 50. Must be non-negative."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:30
msgid "**endpoint**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:29
msgid ""
"If True, `stop` is the last sample. Otherwise, it is not included. Default "
"is True."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:34
msgid "**retstep**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:33
msgid ""
"If True, return (`samples`, `step`), where `step` is the spacing between "
"samples."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:40
msgid "**dtype**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:-1
msgid "dtype, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:37
msgid ""
"The type of the output array.  If `dtype` is not given, the data type is "
"inferred from `start` and `stop`. The inferred dtype will never be an "
"integer; `float` is chosen even if the arguments would produce an array of "
"integers."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:45
msgid "**axis**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:43
msgid ""
"The axis in the result to store the samples.  Relevant only if start or stop "
"are array-like.  By default (0), the samples will be along a new axis "
"inserted at the beginning. Use -1 to get an axis at the end."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:53
msgid "**device**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:-1
msgid "str, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:48
msgid ""
"The device on which to place the created array. Default: None. For Array-API "
"interoperability only, so must be ``\"cpu\"`` if passed."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:60
msgid "**samples**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:58
msgid ""
"There are `num` equally spaced samples in the closed interval ``[start, "
"stop]`` or the half-open interval ``[start, stop)`` (depending on whether "
"`endpoint` is True or False)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:71
msgid "**step**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:-1
msgid "float, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:63
msgid "Only returned if `retstep` is True"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:65
msgid "Size of spacing between samples."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:76
msgid ":obj:`arange`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:77
msgid ""
"Similar to `linspace`, but uses a step size (instead of the number of "
"samples)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:78
msgid ":obj:`geomspace`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:79
msgid ""
"Similar to `linspace`, but with numbers spaced evenly on a log scale (a "
"geometric progression)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:80
msgid ":obj:`logspace`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:81
msgid ""
"Similar to `geomspace`, but with the end points specified as logarithms."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.linspace:82
msgid ":ref:`how-to-partition`"
msgstr ""

