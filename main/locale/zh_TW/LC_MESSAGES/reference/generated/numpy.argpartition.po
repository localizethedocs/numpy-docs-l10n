#: ../../../reference/generated/numpy.argpartition.rst:4
msgid "numpy.argpartition"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:2
msgid ""
"Perform an indirect partition along the given axis using the algorithm "
"specified by the `kind` keyword. It returns an array of indices of the same "
"shape as `a` that index data along the given axis in partitioned order."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:11
msgid "**a**"
msgstr "**a**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:-1
msgid "array_like"
msgstr "array_like"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:11
msgid "Array to sort."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:22
msgid "**kth**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:-1
msgid "int or sequence of ints"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:14
msgid ""
"Element index to partition by. In the returned array, the k-th value of the "
"array will be in the position it would be in a sorted array, all elements "
"that are less than this element (or greater if `descending` is True) will be "
"moved before it, and all elements that are greater than or equal to this "
"element (or less than or equal if `descending` is True) will be moved after "
"it. The order of all elements within each partition is undefined. If "
"provided with a sequence of k-th it will partition all elements indexed by k-"
"th of them into their sorted position at once."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:26
msgid "**axis**"
msgstr "**axis**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:-1
msgid "int or None, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:25
msgid ""
"Axis along which to sort. The default is -1 (the last axis). If None, the "
"flattened array is used."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:31
msgid "**kind**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:-1
msgid "{'introselect'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:29
msgid ""
"NumPy currently offers only one selection algorithm, 'introselect', and this "
"parameter provides no additional functionality. Default is ``None``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:38
msgid "**order**"
msgstr "**命令**"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:-1
msgid "str or list of str, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:34
msgid ""
"When `a` is an array with fields defined, this argument specifies which "
"fields to compare first, second, etc. A single field can be specified as a "
"string, and not all fields need be specified, but unspecified fields will "
"still be used, in the order in which they come up in the dtype, to break "
"ties."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:48
msgid "**descending**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:41
msgid ""
"Sort order. If ``True``, the array will be partitioned in descending order. "
"If ``False`` or ``None``, the array will be partitioned in ascending order. "
"Values that are NaN are partitioned towards the end of the array regardless "
"of order. Default: ``None``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:62
msgid "**index_array**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:-1
msgid "ndarray, int"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:53
msgid ""
"Array of indices that partition `a` along the specified axis. If `a` is one-"
"dimensional, ``a[index_array]`` yields a partitioned `a`. More generally, "
"``np.take_along_axis(a, index_array, axis=axis)`` always yields the "
"partitioned `a`, irrespective of dimensionality."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:67
msgid ":obj:`partition`"
msgstr ":obj:`partition`"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:68
msgid "Describes partition algorithms used."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:69
msgid ":obj:`ndarray.partition`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:70
msgid "Inplace partition."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:71
msgid ":obj:`argsort`"
msgstr ":obj:`argsort`"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:72
msgid "Full indirect sort."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:73
msgid ":obj:`take_along_axis`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:74
msgid ""
"Apply ``index_array`` from argpartition to an array as if by calling "
"partition."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:78
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:79
msgid ""
"The returned indices are not guaranteed to be sorted according to the "
"values. Furthermore, the default selection algorithm ``introselect`` is "
"unstable, and hence the returned indices are not guaranteed to be the "
"earliest/latest occurrence of the element."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argpartition:84
msgid ""
"`argpartition` works for real/complex inputs with nan values, see "
"`partition` for notes on the enhanced sort order and different selection "
"algorithms."
msgstr ""

