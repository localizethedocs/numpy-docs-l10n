msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/strings/__init__.py:docstring
#: of numpy.strings.expandtabs:7
msgid ""
"Return a copy of each string element where all tab characters are replaced "
"by one or more spaces, depending on the current column and the given "
"`tabsize`. The column number is reset to zero after each newline occurring "
"in the string. This doesn't understand other non-printing characters or "
"escape sequences."
msgstr ""

