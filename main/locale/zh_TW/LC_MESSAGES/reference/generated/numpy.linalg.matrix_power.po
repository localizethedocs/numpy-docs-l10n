msgid "numpy.linalg.matrix\\_power"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.matrix_power:2
msgid "Raise a square matrix to the (integer) power `n`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.matrix_power:4
msgid ""
"For positive integers `n`, the power is computed by repeated matrix "
"squarings and matrix multiplications. If ``n == 0``, the identity matrix of "
"the same shape as M is returned. If ``n < 0``, the inverse is computed and "
"then raised to the ``abs(n)``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.matrix_power:9
msgid "Stacks of object matrices are not currently supported."
msgstr ""

