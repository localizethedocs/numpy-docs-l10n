msgid "**loc**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.gumbel:-1
msgid "float or array_like of floats, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.gumbel:11
msgid "The location of the mode of the distribution. Default is 0."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.gumbel:15
msgid "**scale**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.gumbel:14
msgid ""
"The scale parameter of the distribution. Default is 1. Must be non- negative."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.gumbel:23
msgid "**size**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.gumbel:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.gumbel:18
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn.  If size is ``None`` (default), a single value is "
"returned if ``loc`` and ``scale`` are both scalars. Otherwise, ``np."
"broadcast(loc, scale).size`` samples are drawn."
msgstr ""

