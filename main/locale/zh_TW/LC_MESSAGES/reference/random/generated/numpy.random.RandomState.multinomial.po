#: of numpy.random.RandomState.multinomial:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.multinomial:44
msgid ""
"The drawn samples, of shape *size*, if that was provided.  If not, the shape "
"is ``(N,)``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.multinomial:47
msgid ""
"In other words, each entry ``out[i,j,...,:]`` is an N-dimensional value "
"drawn from the distribution."
msgstr ""

