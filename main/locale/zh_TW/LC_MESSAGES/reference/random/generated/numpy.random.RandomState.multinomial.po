msgid "**pvals**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.multinomial:-1
msgid "sequence of floats, length p"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.multinomial:29
msgid ""
"Probabilities of each of the ``p`` different outcomes.  These must sum to 1 "
"(however, the last element is always assumed to account for the remaining "
"probability, as long as ``sum(pvals[:-1]) <= 1)``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.multinomial:39
msgid "**size**"
msgstr ""

