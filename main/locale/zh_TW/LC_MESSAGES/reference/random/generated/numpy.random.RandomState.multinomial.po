#: ../../../reference/random/generated/numpy.random.RandomState.multinomial.rst:4
msgid "numpy.random.RandomState.multinomial"
msgstr ""

#: ../../../reference/random/generated/numpy.random.RandomState.multinomial.rst:8
msgid "method"
msgstr "方法"

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.multinomial:2
msgid "Draw samples from a multinomial distribution."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.multinomial:4
msgid ""
"The multinomial distribution is a multivariate generalization of the "
"binomial distribution.  Take an experiment with one of ``p`` possible "
"outcomes.  An example of such an experiment is throwing a dice, where the "
"outcome can be 1 through 6.  Each sample drawn from the distribution "
"represents `n` such experiments.  Its values, ``X_i = [X_0, X_1, ..., "
"X_p]``, represent the number of times the outcome was ``i``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.multinomial:13
msgid ""
"New code should use the `~numpy.random.Generator.multinomial` method of a "
"`~numpy.random.Generator` instance instead; please see the :ref:`random-"
"quick-start`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.multinomial:18
msgid ""
"This function defaults to the C-long dtype, which is 32bit on windows and "
"otherwise 64bit on 64bit platforms (and 32bit on 32bit ones). Since NumPy "
"2.0, NumPy's default integer is 32bit on 32bit platforms and 64bit on 64bit "
"platforms."
msgstr ""

