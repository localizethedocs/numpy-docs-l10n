#: ../../../../docstring of numpy.random._generator.Generator.poisson:2
msgid "Draw samples from a Poisson distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.poisson:4
msgid ""
"The Poisson distribution is the limit of the binomial distribution for large "
"N."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.poisson:0
msgid "Parameters"
msgstr "參數"

#: ../../../../docstring of numpy.random._generator.Generator.poisson:12
msgid "**lam**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.poisson:-1
msgid "float or array_like of floats"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.poisson:10
msgid ""
"Expected number of events occurring in a fixed-time interval, must be >= 0. "
"A sequence must be broadcastable over the requested size."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.poisson:20
msgid "**size**"
msgstr "**size**"

#: ../../../../docstring of numpy.random._generator.Generator.poisson:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.poisson:15
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn.  If size is ``None`` (default), a single value is "
"returned if ``lam`` is a scalar. Otherwise, ``np.array(lam).size`` samples "
"are drawn."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.poisson:0
msgid "Returns"
msgstr "回傳值"

#: ../../../../docstring of numpy.random._generator.Generator.poisson:32
msgid "**out**"
msgstr "**out**"

#: ../../../../docstring of numpy.random._generator.Generator.poisson:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.poisson:25
msgid "Drawn samples from the parameterized Poisson distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.poisson:35
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.poisson:36
msgid "The probability mass function (PMF) of Poisson distribution is"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.poisson:38
msgid ""
"f(k; \\lambda)=\\frac{\\lambda^k e^{-\\lambda}}{k!}\n"
"\n"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.poisson:40
msgid ""
"For events with an expected separation :math:`\\lambda` the Poisson "
"distribution :math:`f(k; \\lambda)` describes the probability of :math:`k` "
"events occurring within the observed interval :math:`\\lambda`."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.poisson:45
msgid ""
"Because the output is limited to the range of the C int64 type, a ValueError "
"is raised when `lam` is within 10 sigma of the maximum representable value."
msgstr ""

