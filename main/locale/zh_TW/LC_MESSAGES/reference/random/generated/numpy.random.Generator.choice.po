#: ../../../reference/random/generated/numpy.random.Generator.choice.rst:4
msgid "numpy.random.Generator.choice"
msgstr ""

#: ../../../reference/random/generated/numpy.random.Generator.choice.rst:8
msgid "method"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:2
msgid "Generates a random sample from a given array"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:9
msgid "**a**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:-1
msgid "{array_like, int}"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:8
msgid ""
"If an ndarray, a random sample is generated from its elements. If an int, "
"the random sample is generated from np.arange(a)."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:17
msgid "**size**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:-1
msgid "{int, tuple[int]}, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:12
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn from the 1-d `a`. If `a` has more than one dimension, "
"the `size` shape will be inserted into the `axis` dimension, so the output "
"``ndim`` will be ``a.ndim - 1 + len(size)``. Default is None, in which case "
"a single value is returned."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:21
msgid "**replace**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:-1
msgid "bool, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:20
msgid ""
"Whether the sample is with or without replacement. Default is True, meaning "
"that a value of ``a`` can be selected multiple times."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:26
msgid "**p**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:-1
msgid "1-D array_like, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:24
msgid ""
"The probabilities associated with each entry in a. If not given, the sample "
"assumes a uniform distribution over all entries in ``a``."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:30
msgid "**axis**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:-1
msgid "int, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:29
msgid ""
"The axis along which the selection is performed. The default, 0, selects by "
"row."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:36
msgid "**shuffle**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:33
msgid ""
"Whether the sample is shuffled when sampling without replacement. Default is "
"True, False provides a speedup."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:44
msgid "**samples**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:-1
msgid "single item or ndarray"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:41
msgid "The generated random samples"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:0
msgid "Raises"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:55
msgid "ValueError"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:49
msgid ""
"If a is an int and less than zero, if p is not 1-dimensional, if a is array-"
"like with a size 0, if p is not a vector of probabilities, if a and p have "
"different lengths, or if replace=False and the sample size is greater than "
"the population size."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:60
msgid ":obj:`integers`, :obj:`shuffle`, :obj:`permutation`"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:64
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:65
msgid ""
"Setting user-specified probabilities through ``p`` uses a more general but "
"less efficient sampler than the default. The general sampler produces a "
"different sample than the optimized sampler even if each element of ``p`` is "
"1 / len(a)."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:69
msgid ""
"``p`` must sum to 1 when cast to ``float64``. To ensure this, you may wish "
"to normalize using ``p = p / np.sum(p, dtype=np.float64)``."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:72
msgid ""
"When passing ``a`` as an integer type and ``size`` is not specified, the "
"return type is a native Python ``int``."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:77
msgid "Examples"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:82
msgid "Generate a uniform random sample from np.arange(5) of size 3:"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:89
msgid "Generate a non-uniform random sample from np.arange(5) of size 3:"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:94
msgid ""
"Generate a uniform random sample from np.arange(5) of size 3 without "
"replacement:"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:101
msgid ""
"Generate a uniform random sample from a 2-D array along the first axis (the "
"default), without replacement:"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:108
msgid ""
"Generate a non-uniform random sample from np.arange(5) of size 3 without "
"replacement:"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.choice:114
msgid ""
"Any of the above can be repeated with an arbitrary array-like instead of "
"just integers. For instance:"
