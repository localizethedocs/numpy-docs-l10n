#: ../../../reference/random/generated/numpy.random.Generator.gamma.rst:4
msgid "numpy.random.Generator.gamma"
msgstr ""

#: ../../../reference/random/generated/numpy.random.Generator.gamma.rst:8
msgid "method"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.gamma:2
msgid "Draw samples from a Gamma distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.gamma:4
msgid ""
"Samples are drawn from a Gamma distribution with specified parameters, "
"`shape` (sometimes designated \"k\") and `scale` (sometimes designated "
"\"theta\"), where both parameters are > 0."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.gamma:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.gamma:11
msgid "**shape**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.gamma:-1
msgid "float or array_like of floats"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.gamma:11
msgid "The shape of the gamma distribution. Must be non-negative."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.gamma:15
msgid "**scale**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.gamma:-1
msgid "float or array_like of floats, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.gamma:14
msgid ""
"The scale of the gamma distribution. Must be non-negative. Default is equal "
"to 1."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.gamma:23
msgid "**size**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.gamma:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.gamma:18
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn.  If size is ``None`` (default), a single value is "
"returned if ``shape`` and ``scale`` are both scalars. Otherwise, ``np."
"broadcast(shape, scale).size`` samples are drawn."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.gamma:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.gamma:34
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.gamma:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.gamma:28
msgid "Drawn samples from the parameterized gamma distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.gamma:39
msgid ":obj:`scipy.stats.gamma`"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.gamma:40
msgid ""
"probability density function, distribution or cumulative density function, "
"etc."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.gamma:44
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.gamma:45
msgid "The probability density for the Gamma distribution is"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.gamma:47
msgid ""
"p(x) = x^{k-1}\\frac{e^{-x/\\theta}}{\\theta^k\\Gamma(k)},\n"
"\n"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.gamma:49
msgid ""
"where :math:`k` is the shape and :math:`\\theta` the scale, and :math:"
"`\\Gamma` is the Gamma function."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.gamma:52
msgid ""
"The Gamma distribution is often used to model the times to failure of "
"electronic components, and arises naturally in processes for which the "
"waiting times between Poisson distributed events are relevant."
msgstr ""

