#: ../../../reference/random/generated/numpy.random.zipf.rst:4
msgid "numpy.random.zipf"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.zipf:2
msgid "Draw samples from a Zipf distribution."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.zipf:4
msgid ""
"Samples are drawn from a Zipf distribution with specified parameter `a` > 1."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.zipf:7
msgid ""
"The Zipf distribution (also known as the zeta distribution) is a discrete "
"probability distribution that satisfies Zipf's law: the frequency of an item "
"is inversely proportional to its rank in a frequency table."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.zipf:13
msgid ""
"New code should use the `~numpy.random.Generator.zipf` method of a `~numpy."
"random.Generator` instance instead; please see the :ref:`random-quick-start`."
msgstr ""

