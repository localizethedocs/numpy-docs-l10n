msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.zipf:52
msgid "The probability mass function (PMF) for the Zipf distribution is"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.zipf:54
msgid ""
"p(k) = \\frac{k^{-a}}{\\zeta(a)},\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.zipf:56
msgid ""
"for integers :math:`k \\geq 1`, where :math:`\\zeta` is the Riemann Zeta "
"function."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.zipf:59
msgid ""
"It is named for the American linguist George Kingsley Zipf, who noted that "
"the frequency of any word in a sample of a language is inversely "
"proportional to its rank in the frequency table."
msgstr ""

