#: ../../../../docstring of numpy.random._generator.Generator.pareto:43
msgid "The probability density for the Pareto II distribution is"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.pareto:45
msgid ""
"p(x) = \\frac{a}{(x+1)^{a+1}} , x \\ge 0\n"
"\n"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.pareto:47
msgid "where :math:`a > 0` is the shape."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.pareto:49
msgid ""
"The Pareto II distribution is a shifted and scaled version of the Pareto I "
"distribution, which can be found in `scipy.stats.pareto`."
msgstr ""

