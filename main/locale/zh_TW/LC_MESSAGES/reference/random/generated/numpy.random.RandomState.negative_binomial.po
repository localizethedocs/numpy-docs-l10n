msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.negative_binomial:4
msgid ""
"Samples are drawn from a negative binomial distribution with specified "
"parameters, `n` successes and `p` probability of success where `n` is > 0 "
"and `p` is in the interval [0, 1]."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.negative_binomial:9
msgid ""
"New code should use the `~numpy.random.Generator.negative_binomial` method "
"of a `~numpy.random.Generator` instance instead; please see the :ref:`random-"
"quick-start`."
msgstr ""

