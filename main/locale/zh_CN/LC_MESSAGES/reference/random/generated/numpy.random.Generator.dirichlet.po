#: ../../../reference/random/generated/numpy.random.Generator.dirichlet.rst:4
msgid "numpy.random.Generator.dirichlet"
msgstr ""

#: ../../../reference/random/generated/numpy.random.Generator.dirichlet.rst:8
msgid "method"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.dirichlet:2
msgid "Draw samples from the Dirichlet distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.dirichlet:4
msgid ""
"Draw `size` samples of dimension k from a Dirichlet distribution. A "
"Dirichlet-distributed random variable can be seen as a multivariate "
"generalization of a Beta distribution. The Dirichlet distribution is a "
"conjugate prior of a multinomial distribution in Bayesian inference."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.dirichlet:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.dirichlet:14
msgid "**alpha**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.dirichlet:-1
msgid "sequence of floats, length k"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.dirichlet:13
msgid ""
"Parameter of the distribution (length ``k`` for sample of length ``k``)."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.dirichlet:21
msgid "**size**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.dirichlet:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.dirichlet:17
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n)``, then ``m * n * k`` "
"samples are drawn.  Default is None, in which case a vector of length ``k`` "
"is returned."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.dirichlet:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.dirichlet:29
msgid "**samples**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.dirichlet:-1
msgid "ndarray,"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.dirichlet:26
msgid "The drawn samples, of shape ``(size, k)``."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.dirichlet:0
msgid "Raises"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.dirichlet:37
msgid "ValueError"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.dirichlet:34
msgid "If any value in ``alpha`` is less than zero"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.dirichlet:40
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.dirichlet:41
msgid ""
"The Dirichlet distribution is a distribution over vectors :math:`x` that "
"fulfil the conditions :math:`x_i>0` and :math:`\\sum_{i=1}^k x_i = 1`."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.dirichlet:45
msgid ""
"The probability density function :math:`p` of a Dirichlet-distributed random "
"vector :math:`X` is proportional to"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.dirichlet:49
msgid ""
"p(x) \\propto \\prod_{i=1}^{k}{x^{\\alpha_i-1}_i},\n"
"\n"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.dirichlet:51
msgid ""
"where :math:`\\alpha` is a vector containing the positive concentration "
"parameters."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.dirichlet:54
msgid ""
"The method uses the following property for computation: let :math:`Y` be a "
"random vector which has components that follow a standard gamma "
"distribution, then :math:`X = \\frac{1}{\\sum_{i=1}^k{Y_i}} Y` is Dirichlet-"
"distributed"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.dirichlet:60
msgid "References"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.dirichlet:61
msgid ""
"David McKay, \"Information Theory, Inference and Learning Algorithms,\" "
"chapter 23, https://www.inference.org.uk/mackay/itila/"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.dirichlet:64
msgid ""
"Wikipedia, \"Dirichlet distribution\", https://en.wikipedia.org/wiki/"
"Dirichlet_distribution"
msgstr ""

