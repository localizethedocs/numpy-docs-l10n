#: ../../../reference/random/generated/numpy.random.Generator.lognormal.rst:4
msgid "numpy.random.Generator.lognormal"
msgstr ""

#: ../../../reference/random/generated/numpy.random.Generator.lognormal.rst:8
msgid "method"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.lognormal:2
msgid "Draw samples from a log-normal distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.lognormal:4
msgid ""
"Draw samples from a log-normal distribution with specified mean, standard "
"deviation, and array shape.  Note that the mean and standard deviation are "
"not the values for the distribution itself, but of the underlying normal "
"distribution it is derived from."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.lognormal:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.lognormal:12
msgid "**mean**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.lognormal:-1
msgid "float or array_like of floats, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.lognormal:12
msgid "Mean value of the underlying normal distribution. Default is 0."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.lognormal:16
msgid "**sigma**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.lognormal:15
msgid ""
"Standard deviation of the underlying normal distribution. Must be non-"
"negative. Default is 1."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.lognormal:24
msgid "**size**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.lognormal:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.lognormal:19
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn.  If size is ``None`` (default), a single value is "
"returned if ``mean`` and ``sigma`` are both scalars. Otherwise, ``np."
"broadcast(mean, sigma).size`` samples are drawn."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.lognormal:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.lognormal:35
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.lognormal:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.lognormal:29
msgid "Drawn samples from the parameterized log-normal distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.lognormal:40
msgid ":obj:`scipy.stats.lognorm`"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.lognormal:41
msgid ""
"probability density function, distribution, cumulative density function, etc."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.lognormal:45
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.lognormal:46
msgid ""
"A variable `x` has a log-normal distribution if `log(x)` is normally "
"distributed.  The probability density function for the log-normal "
"distribution is:"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.lognormal:50
msgid ""
"p(x) = \\frac{1}{\\sigma x \\sqrt{2\\pi}}\n"
"e^{(-\\frac{(ln(x)-\\mu)^2}{2\\sigma^2})}\n"
"\n"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.lognormal:53
msgid ""
"where :math:`\\mu` is the mean and :math:`\\sigma` is the standard deviation "
"of the normally distributed logarithm of the variable. A log-normal "
"distribution results if a random variable is the *product* of a large number "
"of independent, identically-distributed variables in the same way that a "
"normal distribution results if the variable is the *sum* of a large number "
"of independent, identically-distributed variables."
msgstr ""

