#: ../../../reference/random/generated/numpy.random.Generator.uniform.rst:4
msgid "numpy.random.Generator.uniform"
msgstr ""

#: ../../../reference/random/generated/numpy.random.Generator.uniform.rst:8
msgid "method"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.uniform:2
msgid "Draw samples from a uniform distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.uniform:4
msgid ""
"Samples are uniformly distributed over the half-open interval ``[low, "
"high)`` (includes low, but excludes high).  In other words, any value within "
"the given interval is equally likely to be drawn by `uniform`."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.uniform:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.uniform:13
msgid "**low**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.uniform:-1
msgid "float or array_like of floats, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.uniform:12
msgid ""
"Lower boundary of the output interval.  All values generated will be greater "
"than or equal to low.  The default value is 0."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.uniform:20
msgid "**high**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.uniform:-1
msgid "float or array_like of floats"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.uniform:16
msgid ""
"Upper boundary of the output interval.  All values generated will be less "
"than high.  The high limit may be included in the returned array of floats "
"due to floating-point rounding in the equation ``low + (high-low) * "
"random_sample()``.  high - low must be non-negative.  The default value is "
"1.0."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.uniform:28
msgid "**size**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.uniform:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.uniform:23
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn.  If size is ``None`` (default), a single value is "
"returned if ``low`` and ``high`` are both scalars. Otherwise, ``np."
"broadcast(low, high).size`` samples are drawn."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.uniform:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.uniform:39
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.uniform:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.uniform:33
msgid "Drawn samples from the parameterized uniform distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.uniform:44
msgid ":obj:`integers`"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.uniform:45
msgid "Discrete uniform distribution, yielding integers."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.uniform:46
msgid ":obj:`random`"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.uniform:47
msgid "Floats uniformly distributed over ``[0, 1)``."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.uniform:51
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.uniform:52
msgid "The probability density function of the uniform distribution is"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.uniform:54
msgid ""
"p(x) = \\frac{1}{b - a}\n"
"\n"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.uniform:56
msgid "anywhere within the interval ``[a, b)``, and zero elsewhere."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.uniform:58
msgid "When ``high`` == ``low``, values of ``low`` will be returned."
msgstr ""

