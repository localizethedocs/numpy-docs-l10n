#: ../../../reference/random/generated/numpy.random.Generator.wald.rst:4
msgid "numpy.random.Generator.wald"
msgstr ""

#: ../../../reference/random/generated/numpy.random.Generator.wald.rst:8
msgid "method"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.wald:2
msgid "Draw samples from a Wald, or inverse Gaussian, distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.wald:4
msgid ""
"As the scale approaches infinity, the distribution becomes more like a "
"Gaussian. Some references claim that the Wald is an inverse Gaussian with "
"mean equal to 1, but this is by no means universal."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.wald:8
msgid ""
"The inverse Gaussian distribution was first studied in relationship to "
"Brownian motion. In 1956 M.C.K. Tweedie used the name inverse Gaussian "
"because there is an inverse relationship between the time to cover a unit "
"distance and distance covered in unit time."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.wald:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.wald:16
msgid "**mean**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.wald:-1
msgid "float or array_like of floats"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.wald:16
msgid "Distribution mean, must be > 0."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.wald:19
msgid "**scale**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.wald:19
msgid "Scale parameter, must be > 0."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.wald:27
msgid "**size**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.wald:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.wald:22
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn.  If size is ``None`` (default), a single value is "
"returned if ``mean`` and ``scale`` are both scalars. Otherwise, ``np."
"broadcast(mean, scale).size`` samples are drawn."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.wald:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.wald:39
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.wald:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.wald:32
msgid "Drawn samples from the parameterized Wald distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.wald:42
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.wald:43
msgid "The probability density function for the Wald distribution is"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.wald:45
msgid ""
"P(x;mean,scale) = \\sqrt{\\frac{scale}{2\\pi x^3}}e^\n"
"\\frac{-scale(x-mean)^2}{2\\cdotp mean^2x}\n"
"\n"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.wald:48
msgid ""
"As noted above the inverse Gaussian distribution first arise from attempts "
"to model Brownian motion. It is also a competitor to the Weibull for use in "
"reliability modeling and modeling stock returns and interest rate processes."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.wald:54
msgid "References"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.wald:55
msgid ""
"Brighton Webs Ltd., Wald Distribution, https://web.archive.org/"
"web/20090423014010/http://www.brighton-webs.co.uk:80/distributions/wald.asp"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.wald:57
msgid ""
"Chhikara, Raj S., and Folks, J. Leroy, \"The Inverse Gaussian Distribution: "
"Theory : Methodology, and Applications\", CRC Press, 1988."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.wald:60
msgid ""
"Wikipedia, \"Inverse Gaussian distribution\" https://en.wikipedia.org/wiki/"
"Inverse_Gaussian_distribution"
msgstr ""

