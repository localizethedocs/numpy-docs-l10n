#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.set_state:2
msgid "Set the internal state of the generator from a tuple."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.set_state:4
msgid ""
"For use if one has reason to manually (re-)set the internal state of the bit "
"generator used by the RandomState instance. By default, RandomState uses the "
"\"Mersenne Twister\"[Rd62dfb5ffa26-1]_ pseudo-random number generating "
"algorithm."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.set_state:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.set_state:23
msgid "**state**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.set_state:-1
msgid "{tuple(str, ndarray of 624 uints, int, int, float), dict}"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.set_state:12
msgid "The `state` tuple has the following items:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.set_state:14
msgid "the string 'MT19937', specifying the Mersenne Twister algorithm."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.set_state:15
msgid "a 1-D array of 624 unsigned integers ``keys``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.set_state:16
msgid "an integer ``pos``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.set_state:17
msgid "an integer ``has_gauss``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.set_state:18
msgid "a float ``cached_gaussian``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.set_state:20
msgid ""
"If state is a dictionary, it is directly set using the BitGenerators `state` "
"property."
msgstr ""

