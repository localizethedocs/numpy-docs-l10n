#: ../../../reference/random/generated/numpy.random.multivariate_normal.rst:4
msgid "numpy.random.multivariate\\_normal"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.multivariate_normal:2
msgid "Draw random samples from a multivariate normal distribution."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.multivariate_normal:4
msgid ""
"The multivariate normal, multinormal or Gaussian distribution is a "
"generalization of the one-dimensional normal distribution to higher "
"dimensions.  Such a distribution is specified by its mean and covariance "
"matrix.  These parameters are analogous to the mean (average or \"center\") "
"and variance (standard deviation, or \"width,\" squared) of the one-"
"dimensional normal distribution."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.multivariate_normal:12
msgid ""
"New code should use the `~numpy.random.Generator.multivariate_normal` method "
"of a `~numpy.random.Generator` instance instead; please see the :ref:`random-"
"quick-start`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.multivariate_normal:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.multivariate_normal:20
msgid "**mean**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.multivariate_normal:-1
msgid "1-D array_like, of length N"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.multivariate_normal:20
msgid "Mean of the N-dimensional distribution."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.multivariate_normal:24
msgid "**cov**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.multivariate_normal:-1
msgid "2-D array_like, of shape (N, N)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.multivariate_normal:23
msgid ""
"Covariance matrix of the distribution. It must be symmetric and positive-"
"semidefinite for proper sampling."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.multivariate_normal:30
msgid "**size**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.multivariate_normal:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.multivariate_normal:27
msgid ""
"Given a shape of, for example, ``(m,n,k)``, ``m*n*k`` samples are generated, "
"and packed in an `m`-by-`n`-by-`k` arrangement.  Because each sample is `N`-"
"dimensional, the output shape is ``(m,n,k,N)``. If no shape is specified, a "
"single (`N`-D) sample is returned."
msgstr ""

