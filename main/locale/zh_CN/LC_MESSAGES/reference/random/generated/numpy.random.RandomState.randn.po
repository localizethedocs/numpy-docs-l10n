msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.randn:-1
msgid "ndarray or float"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.randn:33
msgid ""
"A ``(d0, d1, ..., dn)``-shaped array of floating-point samples from the "
"standard normal distribution, or a single such float if no parameters were "
"supplied."
msgstr ""

