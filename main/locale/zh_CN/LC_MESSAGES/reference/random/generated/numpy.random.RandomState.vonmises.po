#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.vonmises:2
msgid "Draw samples from a von Mises distribution."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.vonmises:4
msgid ""
"Samples are drawn from a von Mises distribution with specified mode (mu) and "
"concentration (kappa), on the interval [-pi, pi]."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.vonmises:7
msgid ""
"The von Mises distribution (also known as the circular normal distribution) "
"is a continuous probability distribution on the unit circle.  It may be "
"thought of as the circular analogue of the normal distribution."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.vonmises:13
msgid ""
"New code should use the `~numpy.random.Generator.vonmises` method of a "
"`~numpy.random.Generator` instance instead; please see the :ref:`random-"
"quick-start`."
msgstr ""

