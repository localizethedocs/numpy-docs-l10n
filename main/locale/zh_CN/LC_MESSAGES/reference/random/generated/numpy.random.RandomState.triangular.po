#: ../../../reference/random/generated/numpy.random.RandomState.triangular.rst:4
msgid "numpy.random.RandomState.triangular"
msgstr ""

#: ../../../reference/random/generated/numpy.random.RandomState.triangular.rst:8
msgid "method"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.triangular:2
msgid ""
"Draw samples from the triangular distribution over the interval ``[left, "
"right]``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.triangular:5
msgid ""
"The triangular distribution is a continuous probability distribution with "
"lower limit left, peak at mode, and upper limit right. Unlike the other "
"distributions, these parameters directly define the shape of the pdf."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.triangular:11
msgid ""
"New code should use the `~numpy.random.Generator.triangular` method of a "
"`~numpy.random.Generator` instance instead; please see the :ref:`random-"
"quick-start`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.triangular:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.triangular:18
msgid "**left**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.triangular:-1
msgid "float or array_like of floats"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.triangular:18
msgid "Lower limit."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.triangular:22
msgid "**mode**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.triangular:21
msgid ""
"The value where the peak of the distribution occurs. The value must fulfill "
"the condition ``left <= mode <= right``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.triangular:25
msgid "**right**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.triangular:25
msgid "Upper limit, must be larger than `left`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.triangular:34
msgid "**size**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.triangular:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.triangular:28
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn.  If size is ``None`` (default), a single value is "
"returned if ``left``, ``mode``, and ``right`` are all scalars.  Otherwise, "
"``np.broadcast(left, mode, right).size`` samples are drawn."
msgstr ""

