#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc:27
msgid ""
"Location(s) into which the result(s) are stored. If not provided or None, "
"new array(s) are created by the ufunc. If passed as a keyword argument, can "
"be Ellipses (``out=...``) to ensure an array is returned even if the result "
"is 0-dimensional, or a tuple with length equal to the number of outputs "
"(where None can be used for allocation by the ufunc)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ufunc:34
msgid "Support for ``out=...`` was added."
msgstr ""

