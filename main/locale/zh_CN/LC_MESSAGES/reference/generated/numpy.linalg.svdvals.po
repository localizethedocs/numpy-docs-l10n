msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.svdvals:14
msgid ""
"Input array having shape (..., M, N) and whose last two dimensions form "
"matrices on which to perform singular value decomposition. Should have a "
"floating-point data type."
msgstr ""

