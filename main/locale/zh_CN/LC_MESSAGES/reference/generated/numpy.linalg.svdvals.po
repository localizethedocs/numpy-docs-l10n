#: ../../../reference/generated/numpy.linalg.svdvals.rst:4
msgid "numpy.linalg.svdvals"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.svdvals:2
msgid ""
"Returns the singular values of a matrix (or a stack of matrices) ``x``. When "
"x is a stack of matrices, the function will compute the singular values for "
"each matrix in the stack."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.svdvals:6
msgid "This function is Array API compatible."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.svdvals:8
msgid ""
"Calling ``np.svdvals(x)`` to get singular values is the same as ``np.svd(x, "
"compute_uv=False, hermitian=False)``."
msgstr ""

