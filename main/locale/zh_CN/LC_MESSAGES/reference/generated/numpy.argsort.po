msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:70
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:71
msgid "See `sort` for notes on the different sorting algorithms."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:73
msgid ""
"As of NumPy 1.4.0 `argsort` works with real/complex arrays containing nan "
"values. The enhanced sort order is documented in `sort`."
msgstr ""

