#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legpow:4
msgid ""
"Returns the Legendre series `c` raised to the power `pow`. The argument `c` "
"is a sequence of coefficients ordered from low to high. i.e., [1,2,3] is the "
"series  ``P_0 + 2*P_1 + 3*P_2.``"
msgstr ""

