#: ../../../reference/generated/numpy.polynomial.hermite.hermvander2d.rst:4
msgid "numpy.polynomial.hermite.hermvander2d"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander2d:2
msgid "Pseudo-Vandermonde matrix of given degrees."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander2d:4
msgid ""
"Returns the pseudo-Vandermonde matrix of degrees `deg` and sample points "
"``(x, y)``. The pseudo-Vandermonde matrix is defined by"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander2d:7
msgid ""
"V[..., (deg[1] + 1)*i + j] = H_i(x) * H_j(y),\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander2d:9
msgid ""
"where ``0 <= i <= deg[0]`` and ``0 <= j <= deg[1]``. The leading indices of "
"`V` index the points ``(x, y)`` and the last index encodes the degrees of "
"the Hermite polynomials."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander2d:13
msgid ""
"If ``V = hermvander2d(x, y, [xdeg, ydeg])``, then the columns of `V` "
"correspond to the elements of a 2-D coefficient array `c` of shape (xdeg + "
"1, ydeg + 1) in the order"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander2d:17
msgid ""
"c_{00}, c_{01}, c_{02}, ... , c_{10}, c_{11}, c_{12}, ...\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander2d:19
msgid ""
"and ``np.dot(V, c.flat)`` and ``hermval2d(x, y, c)`` will be the same up to "
"roundoff. This equivalence is useful both for least squares fitting and for "
"the evaluation of a large number of 2-D Hermite series of the same degrees "
"and sample points."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander2d:0
msgid "Parameters"
msgstr ""

