#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busday_count:2
msgid ""
"Counts the number of valid days between `begindates` and `enddates`, not "
"including the day of `enddates`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busday_count:5
msgid ""
"If ``enddates`` specifies a date value that is earlier than the "
"corresponding ``begindates`` date value, the count will be negative."
msgstr ""

