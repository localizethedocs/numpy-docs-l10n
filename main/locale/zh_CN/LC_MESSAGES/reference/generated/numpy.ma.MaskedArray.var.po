msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.var:71
msgid ""
"If ``out=None``, returns a new array containing the variance; otherwise, a "
"reference to the output array is returned."
msgstr ""

