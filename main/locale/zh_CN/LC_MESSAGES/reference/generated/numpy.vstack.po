#: of numpy.vstack:-1
msgid "sequence of ndarrays"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.vstack:16
msgid ""
"The arrays must have the same shape along all but the first axis. 1-D arrays "
"must have the same length. In the case of a single array_like input, it will "
"be treated as a sequence of arrays; i.e., each element along the zeroth axis "
"is treated as a separate array."
msgstr ""

