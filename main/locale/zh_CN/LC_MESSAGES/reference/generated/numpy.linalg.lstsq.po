#: of numpy.linalg.lstsq:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.lstsq:16
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.lstsq:-1
msgid "(M, N) array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.lstsq:16
msgid "\"Coefficient\" matrix."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.lstsq:21
msgid "**b**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.lstsq:-1
msgid "{(M,), (M, K)} array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.lstsq:19
msgid ""
"Ordinate or \"dependent variable\" values. If `b` is two-dimensional, the "
"least-squares solution is calculated for each of the `K` columns of `b`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.lstsq:35
msgid "**rcond**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.lstsq:-1
msgid "float, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.lstsq:24
msgid ""
"Cut-off ratio for small singular values of `a`. For the purposes of rank "
"determination, singular values are treated as zero if they are smaller than "
"`rcond` times the largest singular value of `a`. The default uses the "
"machine precision times ``max(M, N)``.  Passing ``-1`` will use machine "
"precision."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.lstsq:31
msgid ""
"Previously, the default was ``-1``, but a warning was given that this would "
"change."
msgstr ""

