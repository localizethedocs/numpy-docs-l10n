#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.lstsq:44
msgid ""
"Sums of squared residuals: Squared Euclidean 2-norm for each column in ``b - "
"a @ x``. If the rank of `a` is < N or M <= N, this is an empty array. If `b` "
"is 1-dimensional, this is a (1,) shape array. Otherwise the shape is (K,)."
msgstr ""

