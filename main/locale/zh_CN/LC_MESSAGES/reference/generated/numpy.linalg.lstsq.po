msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.lstsq:40
msgid ""
"Least-squares solution. If `b` is two-dimensional, the solutions are in the "
"`K` columns of `x`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.lstsq:48
msgid "**residuals**"
msgstr ""

