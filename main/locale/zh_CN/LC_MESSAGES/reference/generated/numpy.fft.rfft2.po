msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfft2:-1
msgid "complex ndarray, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfft2:46
msgid ""
"If provided, the result will be placed in this array. It should be of the "
"appropriate shape and dtype for the last inverse transform. incompatible "
"with passing in all but the trivial ``s``)."
msgstr ""

