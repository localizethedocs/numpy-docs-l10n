msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.multiply:43
msgid "**y**"
msgstr ""

#: ../../../../docstring of numpy.multiply:-1
msgid "ndarray"
msgstr ""

#: ../../../../docstring of numpy.multiply:35
msgid ""
"The product of `x1` and `x2`, element-wise. This is a scalar if both `x1` "
"and `x2` are scalars."
msgstr ""

#: ../../../../docstring of numpy.multiply:46
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.multiply:47
msgid "Equivalent to `x1` * `x2` in terms of array broadcasting."
msgstr ""

