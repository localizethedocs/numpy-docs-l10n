#: ../../../reference/generated/numpy.polynomial.polynomial.polyfit.rst:4
msgid "numpy.polynomial.polynomial.polyfit"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:2
msgid "Least-squares fit of a polynomial to data."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:4
msgid ""
"Return the coefficients of a polynomial of degree `deg` that is the least "
"squares fit to the data values `y` given at points `x`. If `y` is 1-D the "
"returned coefficients will also be 1-D. If `y` is 2-D multiple fits are "
"done, one for each column of `y`, and the resulting coefficients are stored "
"in the corresponding columns of a 2-D return. The fitted polynomial(s) are "
"in the form"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:11
msgid ""
"p(x) = c_0 + c_1 * x + ... + c_n * x^n,\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:13
msgid "where `n` is `deg`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:18
msgid "**x** : array_like, shape (`M`,)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:-1
msgid "array_like, shape ("
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:18
msgid "x-coordinates of the `M` sample (data) points ``(x[i], y[i])``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:24
msgid "**y** : array_like, shape (`M`,) or (`M`, `K`)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:21
msgid ""
"y-coordinates of the sample points.  Several sets of sample points sharing "
"the same x-coordinates can be (independently) fit with one call to `polyfit` "
"by passing in for `y` a 2-D array that contains one data set per column."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:30
msgid "**deg**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:-1
msgid "int or 1-D array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:27
msgid ""
"Degree(s) of the fitting polynomials. If `deg` is a single integer all terms "
"up to and including the `deg`'th term are included in the fit. For NumPy "
"versions >= 1.11.0 a list of integers specifying the degrees of the terms to "
"include may be used instead."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:37
msgid "**rcond**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:-1
msgid "float, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:33
msgid ""
"Relative condition number of the fit.  Singular values smaller than `rcond`, "
"relative to the largest singular value, will be ignored.  The default value "
"is ``len(x)*eps``, where `eps` is the relative precision of the platform's "
"float type, about 2e-16 in most cases."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:43
msgid "**full**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:40
msgid ""
"Switch determining the nature of the return value.  When ``False`` (the "
"default) just the coefficients are returned; when ``True``, diagnostic "
"information from the singular value decomposition (used to solve the fit's "
"matrix equation) is also returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:52
msgid "**w** : array_like, shape (`M`,), optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:46
msgid ""
"Weights. If not None, the weight ``w[i]`` applies to the unsquared residual "
"``y[i] - y_hat[i]`` at ``x[i]``. Ideally the weights are chosen so that the "
"errors of the products ``w[i]*y[i]`` all have the same variance.  When using "
"inverse-variance weighting, use ``w[i] = 1/sigma(y[i])``.  The default value "
"is None."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:59
msgid "**coef** : ndarray, shape (`deg` + 1,) or (`deg` + 1, `K`)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:-1
msgid "ndarray, shape ("
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:57
msgid ""
"Polynomial coefficients ordered from low to high.  If `y` was 2-D, the "
"coefficients in column `k` of `coef` represent the polynomial fit to the "
"data in `y`'s `k`-th column."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:72
msgid "**[residuals, rank, singular_values, rcond]**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:-1
msgid "list"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:62
msgid "These values are only returned if ``full == True``"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:64
msgid "residuals -- sum of squared residuals of the least squares fit"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:65
msgid "rank -- the numerical rank of the scaled Vandermonde matrix"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:66
msgid "singular_values -- singular values of the scaled Vandermonde matrix"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:67
msgid "rcond -- value of `rcond`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:69
msgid "For more details, see `numpy.linalg.lstsq`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfit:0
msgid "Raises"
msgstr ""

