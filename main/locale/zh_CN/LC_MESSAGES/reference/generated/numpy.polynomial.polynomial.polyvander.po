msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvander:26
msgid "Degree of the resulting matrix."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvander:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvander:41
msgid "**vander**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvander:-1
msgid "ndarray."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvander:33
msgid ""
"The Vandermonde matrix. The shape of the returned matrix is ``x.shape + (deg "
"+ 1,)``, where the last index is the power of `x`. The dtype will be the "
"same as the converted `x`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvander:46
msgid ":obj:`polyvander2d`, :obj:`polyvander3d`"
msgstr ""

