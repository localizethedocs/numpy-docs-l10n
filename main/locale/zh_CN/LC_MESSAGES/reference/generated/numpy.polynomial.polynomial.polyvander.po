#: ../../../reference/generated/numpy.polynomial.polynomial.polyvander.rst:4
msgid "numpy.polynomial.polynomial.polyvander"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvander:2
msgid "Vandermonde matrix of given degree."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvander:4
msgid ""
"Returns the Vandermonde matrix of degree `deg` and sample points `x`. The "
"Vandermonde matrix is defined by"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvander:7
msgid ""
"V[..., i] = x^i,\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvander:9
msgid ""
"where ``0 <= i <= deg``. The leading indices of `V` index the elements of "
"`x` and the last index is the power of `x`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvander:12
msgid ""
"If `c` is a 1-D array of coefficients of length ``n + 1`` and `V` is the "
"matrix ``V = polyvander(x, n)``, then ``np.dot(V, c)`` and ``polyval(x, c)`` "
"are the same up to roundoff. This equivalence is useful both for least "
"squares fitting and for the evaluation of a large number of polynomials of "
"the same degree and sample points."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
