#: of numpy.testing._private.utils.decorate_methods:2
msgid ""
"Apply a decorator to all methods in a class matching a regular expression."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.decorate_methods:4
msgid ""
"The given decorator is applied to all public methods of `cls` that are "
"matched by the regular expression `testmatch` (``testmatch."
"search(methodname)``). Methods that are private, i.e. start with an "
"underscore, are ignored."
msgstr ""

