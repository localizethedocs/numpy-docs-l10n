#: of numpy.ma.extras.median:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.median:39
msgid ""
"A new array holding the result is returned unless out is specified, in which "
"case a reference to out is returned. Return data-type is `float64` for "
"integers and floats smaller than `float64`, or the input data-type, "
"otherwise."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.median:53
msgid ":obj:`mean`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.median:57
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.median:58
msgid ""
"Given a vector ``V`` with ``N`` non masked values, the median of ``V`` is "
"the middle value of a sorted copy of ``V`` (``Vs``) - i.e. ``Vs[(N-1)/2]``, "
"when ``N`` is odd, or ``{Vs[N/2 - 1] + Vs[N/2]}/2`` when ``N`` is even."
msgstr ""

