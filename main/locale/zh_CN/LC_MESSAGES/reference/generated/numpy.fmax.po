#: ../../../reference/generated/numpy.fmax.rst:4
msgid "numpy.fmax"
msgstr ""

#: ../../../../docstring of numpy.fmax:2
msgid "Element-wise maximum of array elements."
msgstr ""

#: ../../../../docstring of numpy.fmax:4
msgid ""
"Compare two arrays and return a new array containing the element-wise "
"maxima. If one of the elements being compared is a NaN, then the non-nan "
"element is returned. If both elements are NaNs then the first is returned.  "
"The latter distinction is important for complex NaNs, which are defined as "
"at least one of the real or imaginary parts being a NaN. The net effect is "
"that NaNs are ignored when possible."
msgstr ""

#: ../../../../docstring of numpy.fmax:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.fmax:16
msgid "**x1, x2**"
msgstr ""

#: ../../../../docstring of numpy.fmax:-1
msgid "array_like"
msgstr ""

#: ../../../../docstring of numpy.fmax:14
msgid ""
"The arrays holding the elements to be compared. If ``x1.shape != x2.shape``, "
"they must be broadcastable to a common shape (which becomes the shape of the "
"output)."
msgstr ""

#: ../../../../docstring of numpy.fmax:22
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.fmax:-1
msgid "ndarray, None, or tuple of ndarray and None, optional"
msgstr ""

#: ../../../../docstring of numpy.fmax:19
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or None, a freshly-"
"allocated array is returned. A tuple (possible only as a keyword argument) "
"must have length equal to the number of outputs."
msgstr ""

#: ../../../../docstring of numpy.fmax:30
msgid "**where**"
msgstr ""

#: ../../../../docstring of numpy.fmax:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../docstring of numpy.fmax:25
msgid ""
"This condition is broadcast over the input. At locations where the condition "
"is True, the `out` array will be set to the ufunc result. Elsewhere, the "
"`out` array will retain its original value. Note that if an uninitialized "
"`out` array is created via the default ``out=None``, locations within it "
"where the condition is False will remain uninitialized."
msgstr ""

#: ../../../../docstring of numpy.fmax:36
msgid "**\\*\\*kwargs**"
msgstr ""

#: ../../../../docstring of numpy.fmax:33
msgid ""
"For other keyword-only arguments, see the :ref:`ufunc docs <ufuncs.kwargs>`."
msgstr ""

#: ../../../../docstring of numpy.fmax:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.fmax:48
msgid "**y**"
msgstr ""

#: ../../../../docstring of numpy.fmax:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.fmax:41
msgid ""
"The maximum of `x1` and `x2`, element-wise. This is a scalar if both `x1` "
"and `x2` are scalars."
msgstr ""

#: ../../../../docstring of numpy.fmax:53
msgid ":obj:`fmin`"
msgstr ""

#: ../../../../docstring of numpy.fmax:54
msgid "Element-wise minimum of two arrays, ignores NaNs."
msgstr ""

#: ../../../../docstring of numpy.fmax:55
msgid ":obj:`maximum`"
msgstr ""

#: ../../../../docstring of numpy.fmax:56
msgid "Element-wise maximum of two arrays, propagates NaNs."
msgstr ""

#: ../../../../docstring of numpy.fmax:57
msgid ":obj:`amax`"
msgstr ""

#: ../../../../docstring of numpy.fmax:58
msgid "The maximum value of an array along a given axis, propagates NaNs."
msgstr ""

#: ../../../../docstring of numpy.fmax:59
msgid ":obj:`nanmax`"
msgstr ""

#: ../../../../docstring of numpy.fmax:60
msgid "The maximum value of an array along a given axis, ignores NaNs."
msgstr ""

#: ../../../../docstring of numpy.fmax:61
msgid ":obj:`minimum`, :obj:`amin`, :obj:`nanmin`"
msgstr ""

#: ../../../../docstring of numpy.fmax:65
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.fmax:66
msgid ""
"The fmax is equivalent to ``np.where(x1 >= x2, x1, x2)`` when neither x1 nor "
"x2 are NaNs, but it is faster and does proper broadcasting."
msgstr ""

