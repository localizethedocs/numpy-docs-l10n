#: ../../../reference/generated/numpy.testing.assert_array_less.rst:4
msgid "numpy.testing.assert\\_array\\_less"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.assert_array_less:2
msgid ""
"Raises an AssertionError if two array_like objects are not ordered by less "
"than."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.assert_array_less:5
msgid ""
"Given two array_like objects `x` and `y`, check that the shape is equal and "
"all elements of `x` are strictly less than the corresponding elements of `y` "
"(but see the Notes for the special handling of a scalar). An exception is "
"raised at shape mismatch or values that are not correctly ordered. In "
"contrast to the  standard usage in NumPy, no assertion is raised if both "
"objects have NaNs in the same positions."
msgstr ""

