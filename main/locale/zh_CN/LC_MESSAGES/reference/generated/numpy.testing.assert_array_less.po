msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.assert_array_less:27
msgid ""
"If True, raise an AssertionError when either the shape or the data type of "
"the array_like objects does not match. The special handling for scalars "
"mentioned in the Notes section is disabled."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.assert_array_less:0
