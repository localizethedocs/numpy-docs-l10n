#: of numpy.testing._private.utils.assert_array_less:42
msgid "If x is not strictly smaller than y, element-wise."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.assert_array_less:49
msgid ":obj:`assert_array_equal`"
msgstr ""

