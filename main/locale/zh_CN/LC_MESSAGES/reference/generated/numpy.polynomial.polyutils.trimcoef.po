#: of numpy.polynomial.polyutils.trimcoef:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polyutils.py:docstring
#: of numpy.polynomial.polyutils.trimcoef:23
msgid ""
"1-d array with trailing zeros removed.  If the resulting series would be "
"empty, a series containing a single zero is returned."
