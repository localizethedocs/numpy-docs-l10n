#: ../../../reference/generated/numpy.polynomial.laguerre.lagvander.rst:4
msgid "numpy.polynomial.laguerre.lagvander"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagvander:2
msgid "Pseudo-Vandermonde matrix of given degree."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagvander:4
msgid ""
"Returns the pseudo-Vandermonde matrix of degree `deg` and sample points `x`. "
"The pseudo-Vandermonde matrix is defined by"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagvander:7
msgid ""
"V[..., i] = L_i(x)\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagvander:9
msgid ""
"where ``0 <= i <= deg``. The leading indices of `V` index the elements of "
"`x` and the last index is the degree of the Laguerre polynomial."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagvander:12
msgid ""
"If `c` is a 1-D array of coefficients of length ``n + 1`` and `V` is the "
"array ``V = lagvander(x, n)``, then ``np.dot(V, c)`` and ``lagval(x, c)`` "
"are the same up to roundoff. This equivalence is useful both for least "
"squares fitting and for the evaluation of a large number of Laguerre series "
"of the same degree and sample points."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.lagvander:0
msgid "Parameters"
msgstr ""

