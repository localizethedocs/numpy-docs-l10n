#: of numpy.tri:-1
msgid "ndarray of shape (N, M)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.tri:36
msgid ""
"Array with its lower triangle filled with ones and zero elsewhere; in other "
"words ``T[i,j] == 1`` for ``j <= i + k``, 0 otherwise."
msgstr ""

