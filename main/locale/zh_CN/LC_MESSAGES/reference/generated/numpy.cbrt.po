#: ../../../reference/generated/numpy.cbrt.rst:4
msgid "numpy.cbrt"
msgstr ""

#: ../../../../docstring of numpy.cbrt:2
msgid "Return the cube-root of an array, element-wise."
msgstr ""

#: ../../../../docstring of numpy.cbrt:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.cbrt:8
msgid "**x**"
msgstr ""

#: ../../../../docstring of numpy.cbrt:-1
msgid "array_like"
msgstr ""

#: ../../../../docstring of numpy.cbrt:8
msgid "The values whose cube-roots are required."
msgstr ""

#: ../../../../docstring of numpy.cbrt:14
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.cbrt:-1
msgid "ndarray, None, or tuple of ndarray and None, optional"
msgstr ""

#: ../../../../docstring of numpy.cbrt:11
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or None, a freshly-"
"allocated array is returned. A tuple (possible only as a keyword argument) "
"must have length equal to the number of outputs."
msgstr ""

#: ../../../../docstring of numpy.cbrt:22
msgid "**where**"
msgstr ""

#: ../../../../docstring of numpy.cbrt:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../docstring of numpy.cbrt:17
msgid ""
"This condition is broadcast over the input. At locations where the condition "
"is True, the `out` array will be set to the ufunc result. Elsewhere, the "
"`out` array will retain its original value. Note that if an uninitialized "
"`out` array is created via the default ``out=None``, locations within it "
"where the condition is False will remain uninitialized."
msgstr ""

#: ../../../../docstring of numpy.cbrt:28
msgid "**\\*\\*kwargs**"
msgstr ""

#: ../../../../docstring of numpy.cbrt:25
msgid ""
"For other keyword-only arguments, see the :ref:`ufunc docs <ufuncs.kwargs>`."
msgstr ""

#: ../../../../docstring of numpy.cbrt:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.cbrt:45
msgid "**y**"
msgstr ""

#: ../../../../docstring of numpy.cbrt:-1
msgid "ndarray"
msgstr ""

#: ../../../../docstring of numpy.cbrt:33
msgid ""
"An array of the same shape as `x`, containing the cube root of each element "
"in `x`. If `out` was provided, `y` is a reference to it. This is a scalar if "
"`x` is a scalar."
msgstr ""

