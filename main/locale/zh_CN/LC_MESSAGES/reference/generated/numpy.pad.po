#: of numpy.pad:46
msgid "'reflect'"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.pad:45
msgid ""
"Pads with the reflection of the vector mirrored on the first and last values "
