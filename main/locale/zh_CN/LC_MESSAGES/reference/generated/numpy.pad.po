#: of numpy.pad:74
msgid "**stat_length**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.pad:-1
msgid "sequence or int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.pad:62
msgid ""
"Used in 'maximum', 'mean', 'median', and 'minimum'.  Number of values at "
"edge of each axis used to calculate the statistic value."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.pad:65
msgid ""
"``((before_1, after_1), ... (before_N, after_N))`` unique statistic lengths "
"for each axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.pad:68
msgid ""
"``(before, after)`` or ``((before, after),)`` yields same before and after "
"statistic lengths for each axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.pad:71
msgid ""
"``(stat_length,)`` or ``int`` is a shortcut for ``before = after = "
"statistic`` length for all axes."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.pad:74
msgid "Default is ``None``, to use the entire axis."
msgstr ""

