#: of numpy.pad:89
msgid "**constant_values**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.pad:-1
msgid "sequence or scalar, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.pad:77
msgid "Used in 'constant'.  The values to set the padded values for each axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.pad:80
msgid ""
"``((before_1, after_1), ... (before_N, after_N))`` unique pad constants for "
"each axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.pad:83
msgid ""
"``(before, after)`` or ``((before, after),)`` yields same before and after "
"constants for each axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.pad:86 numpy.pad:101
msgid ""
"``(constant,)`` or ``constant`` is a shortcut for ``before = after = "
"constant`` for all axes."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.pad:89 numpy.pad:104
msgid "Default is 0."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.pad:104
msgid "**end_values**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.pad:92
msgid ""
"Used in 'linear_ramp'.  The values used for the ending value of the "
"linear_ramp and that will form the edge of the padded array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.pad:95
msgid ""
"``((before_1, after_1), ... (before_N, after_N))`` unique end values for "
"each axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.pad:98
msgid ""
"``(before, after)`` or ``((before, after),)`` yields same before and after "
"end values for each axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.pad:112
msgid "**reflect_type**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.pad:-1
msgid "{'even', 'odd'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.pad:107
msgid ""
"Used in 'reflect', and 'symmetric'.  The 'even' style is the default with an "
"unaltered reflection around the edge value.  For the 'odd' style, the "
"extended part of the array is created by subtracting the reflected values "
"from two times the edge value."
msgstr ""

