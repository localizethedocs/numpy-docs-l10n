msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/matrixlib/defmatrix.py:docstring
#: of numpy.matrixlib.defmatrix.matrix.flatten:9
msgid ""
"'C' means to flatten in row-major (C-style) order. 'F' means to flatten in "
"column-major (Fortran-style) order. 'A' means to flatten in column-major "
"order if `m` is Fortran *contiguous* in memory, row-major order otherwise. "
"'K' means to flatten `m` in the order the elements occur in memory. The "
"default is 'C'."
msgstr ""

