msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.trapezoid:55
msgid ""
"Image [R1ffe72fc1dc5-2]_ illustrates trapezoidal rule -- y-axis locations of "
"points will be taken from `y` array, by default x-axis distances between "
"points will be 1.0, alternatively they can be provided with `x` array or "
"with `dx` scalar.  Return value will be equal to combined area under the red "
"lines."
msgstr ""

