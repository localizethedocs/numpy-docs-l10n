#: of numpy.tril:11
msgid "Input array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.tril:17
msgid "**k**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.tril:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.tril:14
msgid ""
"Diagonal above which to zero elements.  `k = 0` (the default) is the main "
"diagonal, `k < 0` is below it and `k > 0` is above."
msgstr ""

