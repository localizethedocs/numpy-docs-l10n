#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty:2
msgid ""
"Return a new array of given shape and type, without initializing entries."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty:0
msgid "Parameters"
msgstr ""

