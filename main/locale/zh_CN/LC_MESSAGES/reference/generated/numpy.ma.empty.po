msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty:11
msgid ""
"Desired output data-type for the array, e.g, `numpy.int8`. Default is `numpy."
"float64`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty:16
msgid "**order**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty:-1
msgid "{'C', 'F'}, optional, default: 'C'"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty:15
msgid ""
"Whether to store multi-dimensional data in row-major (C-style) or column-"
"major (Fortran-style) order in memory."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty:22
msgid "**device**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty:-1
msgid "str, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty:19
msgid ""
"The device on which to place the created array. Default: ``None``. For Array-"
"API interoperability only, so must be ``\"cpu\"`` if passed."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty:33
msgid "**like**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.empty:25
msgid ""
"Reference object to allow the creation of arrays which are not NumPy arrays. "
"If an array-like passed in as ``like`` supports the ``__array_function__`` "
"protocol, the result will be defined by it. In this case, it ensures the "
"creation of an array object compatible with that passed in via this argument."
msgstr ""

