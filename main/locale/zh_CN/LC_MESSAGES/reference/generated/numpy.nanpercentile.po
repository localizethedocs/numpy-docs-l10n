msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanpercentile:117
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanpercentile:118
msgid ""
"The behavior of `numpy.nanpercentile` with percentage `q` is that of `numpy."
"quantile` with argument ``q/100`` (ignoring nan values). For more "
"information, please see `numpy.quantile`."
msgstr ""

