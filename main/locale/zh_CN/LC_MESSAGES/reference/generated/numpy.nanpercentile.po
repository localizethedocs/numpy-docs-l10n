#: of numpy.nanpercentile:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanpercentile:28
msgid ""
"If True, then allow the input array `a` to be modified by intermediate "
"calculations, to save memory. In this case, the contents of the input `a` "
"after this function completes is undefined."
msgstr ""

