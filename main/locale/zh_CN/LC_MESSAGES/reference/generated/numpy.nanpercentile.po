msgid "numpy.nanpercentile"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanpercentile:2
msgid ""
"Compute the qth percentile of the data along the specified axis, while "
"ignoring nan values."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanpercentile:5
msgid "Returns the qth percentile(s) of the array elements."
msgstr ""

