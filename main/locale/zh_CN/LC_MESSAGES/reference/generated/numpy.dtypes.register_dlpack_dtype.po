#: ../../../reference/generated/numpy.dtypes.register_dlpack_dtype.rst:4
msgid "numpy.dtypes.register\\_dlpack\\_dtype"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/dtypes.py:docstring
#: of numpy.dtypes.register_dlpack_dtype:2
msgid ""
"Register a NumPy dtype for a DLPack ``(code, bits)`` pair so that `numpy."
"from_dlpack` can import it and ``ndarray.__dlpack__`` can export it.  Built-"
"in dtype mappings take priority on import."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/dtypes.py:docstring
#: of numpy.dtypes.register_dlpack_dtype:6
msgid ""
"If you think a conflict is possible but unproblematic you may wrap this into "
"a try/except block as NumPy will raise an error if another DType is already "
"registered for the same (code, bits) pair. While an error is raised, the "
"export is registered even on error."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/dtypes.py:docstring
#: of numpy.dtypes.register_dlpack_dtype:11
msgid ""
"Registering an identical (not equal) dtype multiple times is allowed but "
"normally registration should happen at import time."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/dtypes.py:docstring
#: of numpy.dtypes.register_dlpack_dtype:15
msgid ""
"It is the responsibility of the registering user to ensure that the mapping "
"is valid."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/dtypes.py:docstring
#: of numpy.dtypes.register_dlpack_dtype:19
msgid ""
"This function was added primarily for ``ml_dtypes`` and may be replaced with "
"a different mechanism in the future.  It is intended to be used by authors "
"of user-defined dtypes and not end-users."
msgstr ""

