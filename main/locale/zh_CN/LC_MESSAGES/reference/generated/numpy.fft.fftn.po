msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fftn:105
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.fftn:106
msgid ""
"The output, analogously to `fft`, contains the term for zero frequency in "
"the low-order corner of all axes, the positive frequency terms in the first "
"half of all axes, the term for the Nyquist frequency in the middle of all "
"axes and the negative frequency terms in the second half of all axes, in "
"order of decreasingly negative frequency."
msgstr ""

