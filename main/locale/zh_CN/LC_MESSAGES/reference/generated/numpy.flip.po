#: ../../../reference/generated/numpy.flip.rst:4
msgid "numpy.flip"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.flip:2
msgid "Reverse the order of elements in an array along the given axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.flip:4
msgid "The shape of the array is preserved, but the elements are reordered."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.flip:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.flip:9
msgid "**m**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.flip:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.flip:9
msgid "Input array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.flip:19
msgid "**axis**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.flip:-1
msgid "None or int or tuple of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.flip:12
msgid ""
"Axis or axes along which to flip over. The default, axis=None, will flip "
"over all of the axes of the input array. If axis is negative it counts from "
"the last to the first axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.flip:16
msgid ""
"If axis is a tuple of ints, flipping is performed on all of the axes "
"specified in the tuple."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.flip:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.flip:31
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.flip:24
msgid ""
"A view of `m` with the entries of axis reversed.  Since a view is returned, "
"this operation is done in constant time."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.flip:36
msgid ":obj:`flipud`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.flip:37
msgid "Flip an array vertically (axis=0)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.flip:38
msgid ":obj:`fliplr`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.flip:39
msgid "Flip an array horizontally (axis=1)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.flip:43
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.flip:44
msgid "flip(m, 0) is equivalent to flipud(m)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.flip:46
msgid "flip(m, 1) is equivalent to fliplr(m)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.flip:48
msgid ""
"flip(m, n) corresponds to ``m[...,::-1,...]`` with ``::-1`` at position n."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.flip:50
msgid ""
"flip(m) corresponds to ``m[::-1,::-1,...,::-1]`` with ``::-1`` at all "
"positions."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.flip:53
msgid ""
"flip(m, (0, 1)) corresponds to ``m[::-1,::-1,...]`` with ``::-1`` at "
"position 0 and position 1."
msgstr ""

