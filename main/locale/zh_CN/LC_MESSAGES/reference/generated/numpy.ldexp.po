#: ../../../reference/generated/numpy.ldexp.rst:4
msgid "numpy.ldexp"
msgstr ""

#: ../../../../docstring of numpy.ldexp:2
msgid "Returns x1 * 2**x2, element-wise."
msgstr ""

#: ../../../../docstring of numpy.ldexp:4
msgid ""
"The mantissas `x1` and twos exponents `x2` are used to construct floating "
"point numbers ``x1 * 2**x2``."
msgstr ""

#: ../../../../docstring of numpy.ldexp:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.ldexp:10
msgid "**x1**"
msgstr ""

#: ../../../../docstring of numpy.ldexp:-1
msgid "array_like"
msgstr ""

#: ../../../../docstring of numpy.ldexp:10
msgid "Array of multipliers."
msgstr ""

#: ../../../../docstring of numpy.ldexp:15
msgid "**x2**"
msgstr ""

#: ../../../../docstring of numpy.ldexp:-1
msgid "array_like, int"
msgstr ""

#: ../../../../docstring of numpy.ldexp:13
msgid ""
"Array of twos exponents. If ``x1.shape != x2.shape``, they must be "
"broadcastable to a common shape (which becomes the shape of the output)."
msgstr ""

#: ../../../../docstring of numpy.ldexp:21
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.ldexp:-1
msgid "ndarray, None, or tuple of ndarray and None, optional"
msgstr ""

#: ../../../../docstring of numpy.ldexp:18
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or None, a freshly-"
"allocated array is returned. A tuple (possible only as a keyword argument) "
"must have length equal to the number of outputs."
msgstr ""

#: ../../../../docstring of numpy.ldexp:29
msgid "**where**"
msgstr ""

#: ../../../../docstring of numpy.ldexp:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../docstring of numpy.ldexp:24
msgid ""
"This condition is broadcast over the input. At locations where the condition "
"is True, the `out` array will be set to the ufunc result. Elsewhere, the "
"`out` array will retain its original value. Note that if an uninitialized "
"`out` array is created via the default ``out=None``, locations within it "
"where the condition is False will remain uninitialized."
msgstr ""

#: ../../../../docstring of numpy.ldexp:35
msgid "**\\*\\*kwargs**"
msgstr ""

#: ../../../../docstring of numpy.ldexp:32
msgid ""
"For other keyword-only arguments, see the :ref:`ufunc docs <ufuncs.kwargs>`."
msgstr ""

#: ../../../../docstring of numpy.ldexp:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.ldexp:47
msgid "**y**"
msgstr ""

#: ../../../../docstring of numpy.ldexp:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.ldexp:40
msgid ""
"The result of ``x1 * 2**x2``. This is a scalar if both `x1` and `x2` are "
"scalars."
msgstr ""

#: ../../../../docstring of numpy.ldexp:52
msgid ":obj:`frexp`"
msgstr ""

#: ../../../../docstring of numpy.ldexp:53
msgid "Return (y1, y2) from ``x = y1 * 2**y2``, inverse to `ldexp`."
msgstr ""

#: ../../../../docstring of numpy.ldexp:57
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.ldexp:58
msgid "Complex dtypes are not supported, they will raise a TypeError."
msgstr ""

#: ../../../../docstring of numpy.ldexp:60
msgid ""
"`ldexp` is useful as the inverse of `frexp`, if used by itself it is more "
"clear to simply use the expression ``x1 * 2**x2``."
msgstr ""

