#: ../../../reference/generated/numpy.ma.apply_along_axis.rst:4
msgid "numpy.ma.apply\\_along\\_axis"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.apply_along_axis:2
msgid "Apply a function to 1-D slices along the given axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.apply_along_axis:4
msgid ""
"Execute `func1d(a, *args, **kwargs)` where `func1d` operates on 1-D arrays "
"and `a` is a 1-D slice of `arr` along `axis`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.apply_along_axis:7
msgid ""
"This is equivalent to (but faster than) the following use of `ndindex` and "
"`s_`, which sets each of ``ii``, ``jj``, and ``kk`` to a tuple of indices::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.apply_along_axis:10
msgid ""
"Ni, Nk = a.shape[:axis], a.shape[axis+1:]\n"
"for ii in ndindex(Ni):\n"
"    for kk in ndindex(Nk):\n"
"        f = func1d(arr[ii + s_[:,] + kk])\n"
"        Nj = f.shape\n"
"        for jj in ndindex(Nj):\n"
"            out[ii + jj + kk] = f[jj]"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.apply_along_axis:18
msgid "Equivalently, eliminating the inner loop, this can be expressed as::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.apply_along_axis:20
msgid ""
"Ni, Nk = a.shape[:axis], a.shape[axis+1:]\n"
"for ii in ndindex(Ni):\n"
"    for kk in ndindex(Nk):\n"
"        out[ii + s_[...,] + kk] = func1d(arr[ii + s_[:,] + kk])"
msgstr ""

