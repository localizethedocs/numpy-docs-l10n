msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.place:32
msgid "**vals**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.place:-1
msgid "1-D sequence"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.place:20
msgid ""
"Values to put into `arr`. Only the first N elements are used, where N is the "
"number of True values in `mask`. If `vals` is smaller than N, it will be "
"repeated, and if elements of `arr` are to be masked, this sequence must be "
"non-empty."
msgstr ""

