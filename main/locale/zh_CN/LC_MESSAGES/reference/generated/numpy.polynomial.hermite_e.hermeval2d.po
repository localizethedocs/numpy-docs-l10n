#: ../../../reference/generated/numpy.polynomial.hermite_e.hermeval2d.rst:4
msgid "numpy.polynomial.hermite\\_e.hermeval2d"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite_e.py:docstring
#: of numpy.polynomial.hermite_e.hermeval2d:2
msgid "Evaluate a 2-D HermiteE series at points (x, y)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite_e.py:docstring
#: of numpy.polynomial.hermite_e.hermeval2d:4
msgid "This function returns the values:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite_e.py:docstring
#: of numpy.polynomial.hermite_e.hermeval2d:6
msgid ""
"p(x,y) = \\sum_{i,j} c_{i,j} * He_i(x) * He_j(y)\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite_e.py:docstring
#: of numpy.polynomial.hermite_e.hermeval2d:8
msgid ""
"The parameters `x` and `y` are converted to arrays only if they are tuples "
"or a lists, otherwise they are treated as a scalars and they must have the "
"same shape after conversion. In either case, either `x` and `y` or their "
"elements must support multiplication and addition both with themselves and "
"with the elements of `c`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite_e.py:docstring
#: of numpy.polynomial.hermite_e.hermeval2d:14
msgid ""
"If `c` is a 1-D array a one is implicitly appended to its shape to make it 2-"
"D. The shape of the result will be c.shape[2:] + x.shape."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite_e.py:docstring
#: of numpy.polynomial.hermite_e.hermeval2d:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite_e.py:docstring
#: of numpy.polynomial.hermite_e.hermeval2d:23
msgid "**x, y**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite_e.py:docstring
#: of numpy.polynomial.hermite_e.hermeval2d:-1
msgid "array_like, compatible objects"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite_e.py:docstring
#: of numpy.polynomial.hermite_e.hermeval2d:20
msgid ""
"The two dimensional series is evaluated at the points ``(x, y)``, where `x` "
"and `y` must have the same shape. If `x` or `y` is a list or tuple, it is "
"first converted to an ndarray, otherwise it is left unchanged and if it "
"isn't an ndarray it is treated as a scalar."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite_e.py:docstring
#: of numpy.polynomial.hermite_e.hermeval2d:31
msgid "**c**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite_e.py:docstring
#: of numpy.polynomial.hermite_e.hermeval2d:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite_e.py:docstring
#: of numpy.polynomial.hermite_e.hermeval2d:26
msgid ""
"Array of coefficients ordered so that the coefficient of the term of multi-"
"degree i,j is contained in ``c[i,j]``. If `c` has dimension greater than two "
"the remaining indices enumerate multiple sets of coefficients."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite_e.py:docstring
#: of numpy.polynomial.hermite_e.hermeval2d:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite_e.py:docstring
#: of numpy.polynomial.hermite_e.hermeval2d:43
msgid "**values**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite_e.py:docstring
#: of numpy.polynomial.hermite_e.hermeval2d:-1
msgid "ndarray, compatible object"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite_e.py:docstring
#: of numpy.polynomial.hermite_e.hermeval2d:36
msgid ""
"The values of the two dimensional polynomial at points formed with pairs of "
"corresponding values from `x` and `y`."
msgstr ""

