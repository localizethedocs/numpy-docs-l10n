msgid "Mask an array inside a given interval."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.masked_inside:4
msgid ""
"Shortcut to ``masked_where``, where `condition` is True for `x` inside the "
"interval [v1,v2] (v1 <= x <= v2).  The boundaries `v1` and `v2` can be given "
"in either order."
msgstr ""

