msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take_along_axis:46
msgid "Take along an axis, using the same indices for every 1d slice"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take_along_axis:47
msgid ":obj:`put_along_axis`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take_along_axis:48
msgid ""
"Put values into the destination array by matching 1d index and data slices"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take_along_axis:52
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take_along_axis:53
msgid ""
"This is equivalent to (but faster than) the following use of `ndindex` and "
"`s_`, which sets each of ``ii`` and ``kk`` to a tuple of indices::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take_along_axis:56
msgid ""
"Ni, M, Nk = a.shape[:axis], a.shape[axis], a.shape[axis+1:]\n"
"J = indices.shape[axis]  # Need not equal M\n"
"out = np.empty(Ni + (J,) + Nk)\n"
"\n"
"for ii in ndindex(Ni):\n"
"    for kk in ndindex(Nk):\n"
"        a_1d       = a      [ii + s_[:,] + kk]\n"
"        indices_1d = indices[ii + s_[:,] + kk]\n"
"        out_1d     = out    [ii + s_[:,] + kk]\n"
"        for j in range(J):\n"
"            out_1d[j] = a_1d[indices_1d[j]]"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take_along_axis:68
msgid "Equivalently, eliminating the inner loop, the last two lines would be::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take_along_axis:70
msgid "out_1d[:] = a_1d[indices_1d]"
msgstr ""

