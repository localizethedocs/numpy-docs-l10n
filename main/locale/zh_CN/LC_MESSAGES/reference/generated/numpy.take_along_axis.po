msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take_along_axis:17
msgid ""
"Indices to take along each 1d slice of ``arr``. This must match the "
"dimension of ``arr``, but dimensions Ni and Nj only need to broadcast "
"against ``arr``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take_along_axis:29
