msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take_along_axis:22
msgid ""
"The axis to take 1d slices along. If axis is None, the input array is "
"treated as if it had first been flattened to 1d, for consistency with `sort` "
"and `argsort`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.take_along_axis:26
msgid "The default value is now ``-1``."
msgstr ""

