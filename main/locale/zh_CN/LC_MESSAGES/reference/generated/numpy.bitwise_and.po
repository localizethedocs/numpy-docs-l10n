#: ../../../reference/generated/numpy.bitwise_and.rst:4
msgid "numpy.bitwise\\_and"
msgstr ""

#: ../../../../docstring of numpy.bitwise_and:2
msgid "Compute the bit-wise AND of two arrays element-wise."
msgstr ""

#: ../../../../docstring of numpy.bitwise_and:4
msgid ""
"Computes the bit-wise AND of the underlying binary representation of the "
"integers in the input arrays. This ufunc implements the C/Python operator "
"``&``."
msgstr ""

#: ../../../../docstring of numpy.bitwise_and:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.bitwise_and:13
msgid "**x1, x2**"
msgstr ""

#: ../../../../docstring of numpy.bitwise_and:-1
msgid "array_like"
msgstr ""

#: ../../../../docstring of numpy.bitwise_and:11
msgid ""
"Only integer and boolean types are handled. If ``x1.shape != x2.shape``, "
"they must be broadcastable to a common shape (which becomes the shape of the "
"output)."
msgstr ""

#: ../../../../docstring of numpy.bitwise_and:19 numpy.bitwise_and:45
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.bitwise_and:-1
msgid "ndarray, None, or tuple of ndarray and None, optional"
msgstr ""

#: ../../../../docstring of numpy.bitwise_and:16
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or None, a freshly-"
"allocated array is returned. A tuple (possible only as a keyword argument) "
"must have length equal to the number of outputs."
msgstr ""

#: ../../../../docstring of numpy.bitwise_and:27
msgid "**where**"
msgstr ""

#: ../../../../docstring of numpy.bitwise_and:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../docstring of numpy.bitwise_and:22
msgid ""
"This condition is broadcast over the input. At locations where the condition "
"is True, the `out` array will be set to the ufunc result. Elsewhere, the "
"`out` array will retain its original value. Note that if an uninitialized "
"`out` array is created via the default ``out=None``, locations within it "
"where the condition is False will remain uninitialized."
msgstr ""

#: ../../../../docstring of numpy.bitwise_and:33
msgid "**\\*\\*kwargs**"
msgstr ""

#: ../../../../docstring of numpy.bitwise_and:30
msgid ""
"For other keyword-only arguments, see the :ref:`ufunc docs <ufuncs.kwargs>`."
msgstr ""

#: ../../../../docstring of numpy.bitwise_and:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.bitwise_and:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.bitwise_and:38
msgid "Result. This is a scalar if both `x1` and `x2` are scalars."
msgstr ""

#: ../../../../docstring of numpy.bitwise_and:50
msgid ":obj:`logical_and`"
msgstr ""

#: ../../../../docstring of numpy.bitwise_and:52
msgid ":obj:`bitwise_or`"
msgstr ""

#: ../../../../docstring of numpy.bitwise_and:54
msgid ":obj:`bitwise_xor`"
msgstr ""

#: ../../../../docstring of numpy.bitwise_and:56
msgid ":obj:`binary_repr`"
msgstr ""

#: ../../../../docstring of numpy.bitwise_and:57
msgid "Return the binary representation of the input number as a string."
msgstr ""

#: ../../../../docstring of numpy.bitwise_and:63
msgid "Examples"
msgstr ""

#: ../../../../docstring of numpy.bitwise_and:70
msgid ""
"The number 13 is represented by ``00001101``.  Likewise, 17 is represented "
"by ``00010001``.  The bit-wise AND of 13 and 17 is therefore ``000000001``, "
"or 1:"
msgstr ""

#: ../../../../docstring of numpy.bitwise_and:91
msgid ""
"The ``&`` operator can be used as a shorthand for ``np.bitwise_and`` on "
"ndarrays."
msgstr ""

