#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.reshape:2
msgid "Give a new shape to the array without changing its data."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.reshape:4
msgid ""
"Returns a masked array containing the same data, but with a new shape. The "
"result is a view on the original array; if this is not possible, a "
"ValueError is raised."
msgstr ""

