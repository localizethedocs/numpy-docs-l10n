msgid "Examples"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:102
msgid ""
"``p[4]`` is 2;  all elements in ``p[:4]`` are less than or equal to "
"``p[4]``, and all elements in ``p[5:]`` are greater than or equal to "
"``p[4]``.  The partition is::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:106
msgid "[0, 1, 2, 1], [2], [5, 2, 3, 3, 6, 7, 7, 7, 7]"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:108
msgid "The next example shows the use of multiple values passed to `kth`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:114
msgid ""
"``p2[4]`` is 2  and ``p2[8]`` is 5.  All elements in ``p2[:4]`` are less "
"than or equal to ``p2[4]``, all elements in ``p2[5:8]`` are greater than or "
"equal to ``p2[4]`` and less than or equal to ``p2[8]``, and all elements in "
"``p2[9:]`` are greater than or equal to ``p2[8]``.  The partition is::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:120
msgid "[0, 1, 2, 1], [2], [3, 3, 2], [5], [6, 7, 7, 7, 7]"
msgstr ""

