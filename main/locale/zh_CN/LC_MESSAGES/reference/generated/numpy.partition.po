#: ../../../reference/generated/numpy.partition.rst:4
msgid "numpy.partition"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:2
msgid "Return a partitioned copy of an array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:4
msgid ""
"Creates a copy of the array and partially sorts it in such a way that the "
"value of the element in k-th position is in the position it would be in a "
"sorted array. In the output array, all elements smaller than the k-th "
"element are located to the left of this element and all equal or greater are "
"located to its right. The ordering of the elements in the two partitions on "
"the either side of the k-th element in the output array is undefined."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:15
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:15
msgid "Array to be sorted."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:23
msgid "**kth**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:-1
msgid "int or sequence of ints"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:18
msgid ""
"Element index to partition by. The k-th value of the element will be in its "
"final sorted position and all smaller elements will be moved before it and "
"all equal or greater elements behind it. The order of all elements in the "
"partitions is undefined. If provided with a sequence of k-th it will "
"partition all elements indexed by k-th  of them into their sorted position "
"at once."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:27
msgid "**axis**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:-1
msgid "int or None, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:26
msgid ""
"Axis along which to sort. If None, the array is flattened before sorting. "
"The default is -1, which sorts along the last axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:30
msgid "**kind**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:-1
msgid "{'introselect'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:30
msgid "Selection algorithm. Default is 'introselect'."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:39
msgid "**order**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:-1
msgid "str or list of str, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.partition:33
msgid ""
"When `a` is an array with fields defined, this argument specifies which "
"fields to compare first, second, etc.  A single field can be specified as a "
"string.  Not all fields need be specified, but unspecified fields will still "
"be used, in the order in which they come up in the dtype, to break ties."
msgstr ""

