#: ../../../reference/generated/numpy.fft.irfftn.rst:4
msgid "numpy.fft.irfftn"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfftn:2
msgid "Computes the inverse of `rfftn`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfftn:4
msgid ""
"This function computes the inverse of the N-dimensional discrete Fourier "
"Transform for real input over any number of axes in an M-dimensional array "
"by means of the Fast Fourier Transform (FFT).  In other words, "
"``irfftn(rfftn(a), a.shape) == a`` to within numerical accuracy. (The ``a."
"shape`` is necessary like ``len(a)`` is for `irfft`, and for the same "
"reason.)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfftn:11
msgid ""
"The input should be ordered in the same way as is returned by `rfftn`, i.e. "
"as for `irfft` for the final transformation axis, and as for `ifftn` along "
"all the other axes."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfftn:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfftn:18
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfftn:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfftn:18
msgid "Input array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfftn:46
msgid "**s**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfftn:-1
msgid "sequence of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfftn:21
msgid ""
"Shape (length of each transformed axis) of the output (``s[0]`` refers to "
"axis 0, ``s[1]`` to axis 1, etc.). `s` is also the number of input points "
"used along this axis, except for the last axis, where ``s[-1]//2+1`` points "
"of the input are used. Along any axis, if the shape indicated by `s` is "
"smaller than that of the input, the input is cropped.  If it is larger, the "
"input is padded with zeros."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfftn:31
msgid "If it is ``-1``, the whole input is used (no padding/trimming)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfftn:33
msgid ""
"If `s` is not given, the shape of the input along the axes specified by axes "
"is used. Except for the last axis which is taken to be ``2*(m-1)`` where "
"``m`` is the length of the input along that axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfftn:39
msgid "If `s` is not ``None``, `axes` must not be ``None`` either."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfftn:43
msgid ""
"`s` must contain only ``int`` s, not ``None`` values. ``None`` values "
"currently mean that the default value for ``n`` is used in the corresponding "
"1-D transform, but this behaviour is deprecated."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfftn:57
msgid "**axes**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfftn:49
msgid ""
"Axes over which to compute the inverse FFT. If not given, the last `len(s)` "
"axes are used, or all axes if `s` is also not specified. Repeated indices in "
"`axes` means that the inverse transform over that axis is performed multiple "
"times."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfftn:56
msgid ""
"If `s` is specified, the corresponding `axes` to be transformed must be "
"explicitly specified too."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfftn:66
msgid "**norm**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfftn:-1
msgid "{\"backward\", \"ortho\", \"forward\"}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfftn:60
msgid ""
"Normalization mode (see `numpy.fft`). Default is \"backward\". Indicates "
"which direction of the forward/backward pair of transforms is scaled and "
"with what normalization factor."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfftn:66
msgid "The \"backward\", \"forward\" values were added."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfftn:74 numpy.fft.irfftn:90
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfftn:-1
msgid "ndarray, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfftn:69
msgid ""
"If provided, the result will be placed in this array. It should be of the "
"appropriate shape and dtype for the last transformation."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfftn:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfftn:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.irfftn:79
msgid ""
"The truncated or zero-padded input, transformed along the axes indicated by "
"`axes`, or by a combination of `s` or `a`, as explained in the parameters "
"section above. The length of each transformed axis is as given by the "
"corresponding element of `s`, or the length of the input in every axis "
"except for the last one if `s` is not given.  In the final transformed axis "
"the length of the output when `s` is not given is ``2*(m-1)`` where ``m`` is "
"the length of the final transformed axis of the input.  To get an odd number "
"of output points in the final axis, `s` must be specified."
msgstr ""

