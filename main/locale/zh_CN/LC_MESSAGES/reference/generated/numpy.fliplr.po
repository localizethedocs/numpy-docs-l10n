msgid "numpy.fliplr"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.fliplr:2
msgid "Reverse the order of elements along axis 1 (left/right)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.fliplr:4
msgid ""
"For a 2-D array, this flips the entries in each row in the left/right "
"direction. Columns are preserved, but appear in a different order than "
"before."
msgstr ""

