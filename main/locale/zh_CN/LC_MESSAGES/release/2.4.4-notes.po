#: ../../../release/2.4.4-notes.rst:5
msgid "NumPy 2.4.4 Release Notes"
msgstr ""

#: ../../../release/2.4.4-notes.rst:7
msgid ""
"The NumPy 2.4.4 is a patch release that fixes bugs discovered after the "
"2.4.3 release. It should finally close issue #30816, the OpenBLAS threading "
"problem on ARM."
msgstr ""

#: ../../../release/2.4.4-notes.rst:11
msgid "This release supports Python versions 3.11-3.14"
msgstr ""

