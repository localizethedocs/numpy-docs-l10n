msgid "NumPy 1.14.5 Release Notes"
msgstr ""

#: ../../../release/1.14.5-notes.rst:5
msgid ""
"This is a bugfix release for bugs reported following the 1.14.4 release. The "
"most significant fixes are:"
msgstr ""

#: ../../../release/1.14.5-notes.rst:8
msgid "fixes for compilation errors on alpine and NetBSD"
msgstr ""

#: ../../../release/1.14.5-notes.rst:10
msgid ""
"The Python versions supported in this release are 2.7 and 3.4 - 3.6. The "
"Python 3.6 wheels available from PIP are built with Python 3.6.2 and should "
"be compatible with all previous versions of Python 3.6. The source releases "
"were cythonized with Cython 0.28.2 and should work for the upcoming Python "
"3.7."
msgstr ""

