#: ../../../release/2.4.3-notes.rst:5
msgid "NumPy 2.4.3 Release Notes"
msgstr ""

#: ../../../release/2.4.3-notes.rst:7
msgid ""
"The NumPy 2.4.3 is a patch release that fixes bugs discovered after the "
"2.4.2 release. The most user visible fix may be a threading fix for OpenBLAS "
"on ARM, closing issue #30816."
msgstr ""

#: ../../../release/2.4.3-notes.rst:11
msgid "This release supports Python versions 3.11-3.14"
msgstr ""

