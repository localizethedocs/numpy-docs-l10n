msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/recfunctions.py:docstring
#: of numpy.lib.recfunctions.repack_fields:-1
msgid "boolean"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/recfunctions.py:docstring
#: of numpy.lib.recfunctions.repack_fields:27
msgid ""
