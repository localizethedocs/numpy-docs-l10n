#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/recfunctions.py:docstring
#: of numpy.lib.recfunctions.unstructured_to_structured:2
msgid "Converts an n-D unstructured array into an (n-1)-D structured array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/recfunctions.py:docstring
#: of numpy.lib.recfunctions.unstructured_to_structured:4
msgid ""
"The last dimension of the input array is converted into a structure, with "
"number of field-elements equal to the size of the last dimension of the "
"input array. By default all output fields have the input array's dtype, but "
"an output structured dtype with an equal number of fields-elements can be "
"supplied instead."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/recfunctions.py:docstring
#: of numpy.lib.recfunctions.unstructured_to_structured:10
msgid ""
"Nested fields, as well as each element of any subarray fields, all count "
"towards the number of field-elements."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/recfunctions.py:docstring
#: of numpy.lib.recfunctions.unstructured_to_structured:16
msgid "Unstructured array or dtype to convert."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/recfunctions.py:docstring
#: of numpy.lib.recfunctions.unstructured_to_structured:19
msgid "The structured dtype of the output array"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/recfunctions.py:docstring
#: of numpy.lib.recfunctions.unstructured_to_structured:-1
msgid "list of strings, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/recfunctions.py:docstring
#: of numpy.lib.recfunctions.unstructured_to_structured:22
msgid ""
"If dtype is not supplied, this specifies the field names for the output "
"dtype, in order. The field dtypes will be the same as the input array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/recfunctions.py:docstring
