#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/recfunctions.py:docstring
#: of numpy.lib.recfunctions.repack_fields:2
msgid "Re-pack the fields of a structured array or dtype in memory."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/recfunctions.py:docstring
#: of numpy.lib.recfunctions.repack_fields:4
msgid ""
"The memory layout of structured datatypes allows fields at arbitrary byte "
"offsets. This means the fields can be separated by padding bytes, their "
"offsets can be non-monotonically increasing, and they can overlap."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/recfunctions.py:docstring
#: of numpy.lib.recfunctions.repack_fields:8
msgid ""
"This method removes any overlaps and reorders the fields in memory so they "
"have increasing byte offsets, and adds or removes padding bytes depending on "
"the `align` option, which behaves like the `align` option to `numpy.dtype`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/recfunctions.py:docstring
#: of numpy.lib.recfunctions.repack_fields:13
msgid ""
"If `align=False`, this method produces a \"packed\" memory layout in which "
"each field starts at the byte the previous field ended, and any padding "
"bytes are removed."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/recfunctions.py:docstring
#: of numpy.lib.recfunctions.repack_fields:17
msgid ""
"If `align=True`, this methods produces an \"aligned\" memory layout in which "
"each field's offset is a multiple of its alignment, and the total itemsize "
"is a multiple of the largest alignment, by adding padding bytes as needed."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/recfunctions.py:docstring
#: of numpy.lib.recfunctions.repack_fields:-1
msgid "ndarray or dtype"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/recfunctions.py:docstring
#: of numpy.lib.recfunctions.repack_fields:24
msgid "array or dtype for which to repack the fields."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/recfunctions.py:docstring
#: of numpy.lib.recfunctions.repack_fields:27
#: numpy.lib.recfunctions.unstructured_to_structured:26
