#: ../../../release/1.17.5-notes.rst:5
msgid "NumPy 1.17.5 Release Notes"
msgstr ""

#: ../../../release/1.17.5-notes.rst:7
msgid ""
"This release contains fixes for bugs reported against NumPy 1.17.4 along "
"with some build improvements. The Python versions supported in this release "
"are 3.5-3.8."
msgstr ""

#: ../../../release/1.17.5-notes.rst:11
msgid ""
"Downstream developers should use Cython >= 0.29.14 for Python 3.8 support "
"and OpenBLAS >= 3.7 to avoid errors on the Skylake architecture."
msgstr ""

#: ../../../release/1.17.5-notes.rst:14
msgid ""
"It is recommended that developers interested in the new random bit "
"generators upgrade to the NumPy 1.18.x series, as it has updated "
"documentation and many small improvements."
msgstr ""

