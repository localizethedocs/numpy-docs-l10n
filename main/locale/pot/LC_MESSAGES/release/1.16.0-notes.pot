#: ../../../release/1.16.0-notes.rst:3
msgid "NumPy 1.16.0 Release Notes"
msgstr ""

#: ../../../release/1.16.0-notes.rst:5
msgid ""
"This NumPy release is the last one to support Python 2.7 and will be "
"maintained as a long term release with bug fixes until 2020.  Support for "
"Python 3.4 been dropped, the supported Python versions are 2.7 and 3.5-3.7. "
"The wheels on PyPI are linked with OpenBLAS v0.3.4+,  which should fix the "
"known threading issues found in previous OpenBLAS versions."
msgstr ""

#: ../../../release/1.16.0-notes.rst:11
msgid ""
"Downstream developers building this release should use Cython >= 0.29 and, "
"if using OpenBLAS, OpenBLAS > v0.3.4."
msgstr ""

#: ../../../release/1.16.0-notes.rst:14
msgid ""
"This release has seen a lot of refactoring and features many bug fixes, "
"improved code organization, and better cross platform compatibility. Not all "
"of these improvements will be visible to users, but they should help make "
"maintenance easier going forward."
msgstr ""

#: ../../../release/1.16.0-notes.rst:21
msgid "Highlights"
msgstr ""

#: ../../../release/1.16.0-notes.rst:23
msgid ""
"Experimental (opt-in only) support for overriding numpy functions, see "
"``__array_function__`` below."
msgstr ""

#: ../../../release/1.16.0-notes.rst:26
msgid ""
"The ``matmul`` function is now a ufunc. This provides better performance and "
"allows overriding with ``__array_ufunc__``."
msgstr ""

#: ../../../release/1.16.0-notes.rst:29
msgid "Improved support for the ARM and POWER architectures."
msgstr ""

#: ../../../release/1.16.0-notes.rst:31
msgid "Improved support for AIX and PyPy."
msgstr ""

#: ../../../release/1.16.0-notes.rst:33
msgid "Improved interop with ctypes."
msgstr ""

#: ../../../release/1.16.0-notes.rst:35
msgid "Improved support for PEP 3118."
msgstr ""

#: ../../../release/1.16.0-notes.rst:40
msgid "New functions"
msgstr ""

