msgid "NumPy 1.24.2 Release Notes"
msgstr ""

#: ../../../release/1.24.2-notes.rst:6
msgid ""
"NumPy 1.24.2 is a maintenance release that fixes bugs and regressions "
"discovered after the 1.24.1 release. The Python versions supported by this "
"release are 3.8-3.11."
msgstr ""

