#: ../../../release/1.22.2-notes.rst:5
msgid "NumPy 1.22.2 Release Notes"
msgstr ""

#: ../../../release/1.22.2-notes.rst:7
msgid ""
"The NumPy 1.22.2 is maintenance release that fixes bugs discovered after the "
"1.22.1 release. Notable fixes are:"
msgstr ""

#: ../../../release/1.22.2-notes.rst:10
msgid ""
"Several build related fixes for downstream projects and other platforms."
msgstr ""

#: ../../../release/1.22.2-notes.rst:11
msgid "Various Annotation fixes/additions."
msgstr ""

#: ../../../release/1.22.2-notes.rst:12
msgid ""
"Numpy wheels for Windows will use the 1.41 tool chain, fixing downstream "
"link problems for projects using NumPy provided libraries on Windows."
msgstr ""

#: ../../../release/1.22.2-notes.rst:14
msgid "Deal with CVE-2021-41495 complaint."
msgstr ""

#: ../../../release/1.22.2-notes.rst:16
msgid "The Python versions supported for this release are 3.8-3.10."
msgstr ""

