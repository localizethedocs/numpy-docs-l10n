msgid "Returns"
msgstr ""

#: ../../../../docstring of
#: numpy.random._generator.Generator.standard_normal:-1
msgid "float or ndarray"
msgstr ""

#: ../../../../docstring of
#: numpy.random._generator.Generator.standard_normal:26
msgid ""
"A floating-point array of shape ``size`` of drawn samples, or a single "
"sample if ``size`` was not specified."
msgstr ""

