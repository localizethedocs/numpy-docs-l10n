#: ../../../reference/random/generated/numpy.random.Generator.integers.rst:4
msgid "numpy.random.Generator.integers"
msgstr ""

#: ../../../reference/random/generated/numpy.random.Generator.integers.rst:8
msgid "method"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.integers:2
msgid ""
"Return random integers from `low` (inclusive) to `high` (exclusive), or if "
"endpoint=True, `low` (inclusive) to `high` (inclusive). Replaces "
"`RandomState.randint` (with endpoint=False) and `RandomState."
"random_integers` (with endpoint=True)"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.integers:7
msgid ""
"Return random integers from the \"discrete uniform\" distribution of the "
"specified dtype. If `high` is None (the default), then results are from 0 to "
"`low`."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.integers:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.integers:16
msgid "**low**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.integers:-1
msgid "int or array-like of ints"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.integers:14
msgid ""
"Lowest (signed) integers to be drawn from the distribution (unless "
"``high=None``, in which case this parameter is 0 and this value is used for "
"`high`)."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.integers:21
msgid "**high**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.integers:-1
msgid "int or array-like of ints, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.integers:19
msgid ""
"If provided, one above the largest (signed) integer to be drawn from the "
"distribution (see above for behavior if ``high=None``). If array-like, must "
"contain integer values"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.integers:26
msgid "**size**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.integers:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.integers:24
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn.  Default is None, in which case a single value is "
"returned."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.integers:30
msgid "**dtype**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.integers:-1
msgid "dtype, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.integers:29
msgid ""
"Desired dtype of the result. Byteorder must be native. The default value is "
"np.int64."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.integers:37
msgid "**endpoint**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.integers:-1
msgid "bool, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.integers:33
msgid ""
"If true, sample from the interval [low, high] instead of the default [low, "
"high) Defaults to False"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.integers:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.integers:50
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.integers:-1
msgid "int or ndarray of ints"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.integers:42
msgid ""
"`size`-shaped array of random integers from the appropriate distribution, or "
"a single such random int if `size` not provided."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.integers:53
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.integers:54
msgid ""
"When using broadcasting with uint64 dtypes, the maximum value (2**64) cannot "
"be represented as a standard integer type. The high array (or low if high is "
"None) must have object dtype, e.g., array([2**64])."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.integers:59
msgid "References"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.integers:60
msgid ""
"Daniel Lemire., \"Fast Random Integer Generation in an Interval\", ACM "
"Transactions on Modeling and Computer Simulation 29 (1), 2019, https://arxiv."
"org/abs/1805.10941."
msgstr ""

