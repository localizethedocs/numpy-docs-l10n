msgid "which should be used for new code."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.chisquare:51
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.chisquare:52
msgid ""
"The variable obtained by summing the squares of `df` independent, standard "
"normally distributed random variables:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.chisquare:55
msgid ""
"Q = \\sum_{i=1}^{\\mathtt{df}} X^2_i\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.chisquare:57
msgid "is chi-square distributed, denoted"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.chisquare:59
msgid ""
"Q \\sim \\chi^2_k.\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.chisquare:61
msgid "The probability density function of the chi-squared distribution is"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.chisquare:63
msgid ""
"p(x) = \\frac{(1/2)^{k/2}}{\\Gamma(k/2)}\n"
"x^{k/2 - 1} e^{-x/2},\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.chisquare:66
msgid "where :math:`\\Gamma` is the gamma function,"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.chisquare:68
msgid ""
"\\Gamma(x) = \\int_0^{-\\infty} t^{x - 1} e^{-t} dt.\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.chisquare:71
msgid "References"
msgstr ""

