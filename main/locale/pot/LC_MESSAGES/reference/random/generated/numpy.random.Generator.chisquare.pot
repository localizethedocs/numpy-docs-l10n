#: ../../../reference/random/generated/numpy.random.Generator.chisquare.rst:4
msgid "numpy.random.Generator.chisquare"
msgstr ""

#: ../../../reference/random/generated/numpy.random.Generator.chisquare.rst:8
msgid "method"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.chisquare:2
msgid "Draw samples from a chi-square distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.chisquare:4
msgid ""
"When `df` independent random variables, each with standard normal "
"distributions (mean 0, variance 1), are squared and summed, the resulting "
"distribution is chi-square (see Notes).  This distribution is often used in "
"hypothesis testing."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.chisquare:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.chisquare:12
msgid "**df**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.chisquare:-1
msgid "float or array_like of floats"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.chisquare:12
msgid "Number of degrees of freedom, must be > 0."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.chisquare:20
msgid "**size**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.chisquare:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.chisquare:15
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn.  If size is ``None`` (default), a single value is "
"returned if ``df`` is a scalar.  Otherwise, ``np.array(df).size`` samples "
"are drawn."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.chisquare:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.chisquare:28
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.chisquare:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.chisquare:25
msgid "Drawn samples from the parameterized chi-square distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.chisquare:0
msgid "Raises"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.chisquare:37
msgid "ValueError"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.chisquare:33
msgid ""
"When `df` <= 0 or when an inappropriate `size` (e.g. ``size=-1``) is given."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.chisquare:40
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.chisquare:41
msgid ""
"The variable obtained by summing the squares of `df` independent, standard "
"normally distributed random variables:"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.chisquare:44
msgid ""
"Q = \\sum_{i=1}^{\\mathtt{df}} X^2_i\n"
"\n"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.chisquare:46
msgid "is chi-square distributed, denoted"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.chisquare:48
msgid ""
"Q \\sim \\chi^2_k.\n"
"\n"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.chisquare:50
msgid "The probability density function of the chi-squared distribution is"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.chisquare:52
msgid ""
"p(x) = \\frac{(1/2)^{k/2}}{\\Gamma(k/2)}\n"
"x^{k/2 - 1} e^{-x/2},\n"
"\n"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.chisquare:55
msgid "where :math:`\\Gamma` is the gamma function,"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.chisquare:57
msgid ""
"\\Gamma(x) = \\int_0^{-\\infty} t^{x - 1} e^{-t} dt.\n"
"\n"
msgstr ""

