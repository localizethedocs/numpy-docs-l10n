#: of numpy.random.RandomState.wald:53
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.wald:54
msgid "The probability density function for the Wald distribution is"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.wald:56
msgid ""
"P(x;mean,scale) = \\sqrt{\\frac{scale}{2\\pi x^3}}e^\n"
"\\frac{-scale(x-mean)^2}{2\\cdotp mean^2x}\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.wald:59
msgid ""
"As noted above the inverse Gaussian distribution first arise from attempts "
"to model Brownian motion. It is also a competitor to the Weibull for use in "
"reliability modeling and modeling stock returns and interest rate processes."
msgstr ""

