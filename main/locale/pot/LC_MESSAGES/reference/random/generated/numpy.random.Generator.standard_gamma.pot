#: ../../../reference/random/generated/numpy.random.Generator.standard_gamma.rst:4
msgid "numpy.random.Generator.standard\\_gamma"
msgstr ""

#: ../../../reference/random/generated/numpy.random.Generator.standard_gamma.rst:8
msgid "method"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.standard_gamma:2
msgid "Draw samples from a standard Gamma distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.standard_gamma:4
msgid ""
"Samples are drawn from a Gamma distribution with specified parameters, shape "
"(sometimes designated \"k\") and scale=1."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.standard_gamma:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.standard_gamma:10
msgid "**shape**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.standard_gamma:-1
msgid "float or array_like of floats"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.standard_gamma:10
msgid "Parameter, must be non-negative."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.standard_gamma:16
msgid "**size**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.standard_gamma:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.standard_gamma:13
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn.  If size is ``None`` (default), a single value is "
"returned if ``shape`` is a scalar.  Otherwise, ``np.array(shape).size`` "
"samples are drawn."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.standard_gamma:20
msgid "**dtype**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.standard_gamma:-1
msgid "dtype, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.standard_gamma:19
msgid ""
"Desired dtype of the result, only `float64` and `float32` are supported. "
"Byteorder must be native. The default value is np.float64."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.standard_gamma:27
#: numpy.random._generator.Generator.standard_gamma:38
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.standard_gamma:-1
msgid "ndarray, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.standard_gamma:23
msgid ""
"Alternative output array in which to place the result. If size is not None, "
"it must have the same shape as the provided size and must match the type of "
"the output values."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.standard_gamma:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.standard_gamma:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.standard_gamma:32
msgid "Drawn samples from the parameterized standard gamma distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.standard_gamma:43
msgid ":obj:`scipy.stats.gamma`"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.standard_gamma:44
msgid ""
"probability density function, distribution or cumulative density function, "
"etc."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.standard_gamma:48
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.standard_gamma:49
msgid "The probability density for the Gamma distribution is"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.standard_gamma:51
msgid ""
"p(x) = x^{k-1}\\frac{e^{-x/\\theta}}{\\theta^k\\Gamma(k)},\n"
"\n"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.standard_gamma:53
msgid ""
"where :math:`k` is the shape and :math:`\\theta` the scale, and :math:"
"`\\Gamma` is the Gamma function."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.standard_gamma:56
msgid ""
"The Gamma distribution is often used to model the times to failure of "
"electronic components, and arises naturally in processes for which the "
"waiting times between Poisson distributed events are relevant."
msgstr ""

