#: of numpy.random.RandomState.choice:66
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.choice:67
msgid ""
"Setting user-specified probabilities through ``p`` uses a more general but "
"less efficient sampler than the default. The general sampler produces a "
"different sample than the optimized sampler even if each element of ``p`` is "
"1 / len(a)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.choice:71
msgid ""
"Sampling random rows from a 2-D array is not possible with this function, "
"but is possible with `Generator.choice` through its ``axis`` keyword."
msgstr ""

