#: ../../../reference/random/generated/numpy.random.Generator.exponential.rst:4
msgid "numpy.random.Generator.exponential"
msgstr ""

#: ../../../reference/random/generated/numpy.random.Generator.exponential.rst:8
msgid "method"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.exponential:2
msgid "Draw samples from an exponential distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.exponential:4
msgid "Its probability density function is"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.exponential:6
msgid ""
"f(x; \\frac{1}{\\beta}) = \\frac{1}{\\beta} \\exp(-\\frac{x}{\\beta}),\n"
"\n"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.exponential:8
msgid ""
"for ``x > 0`` and 0 elsewhere. :math:`\\beta` is the scale parameter, which "
"is the inverse of the rate parameter :math:`\\lambda = 1/\\beta`. The rate "
"parameter is an alternative, widely used parameterization of the exponential "
"distribution [R0dbb9b01ef9c-3]_."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.exponential:13
msgid ""
"The exponential distribution is a continuous analogue of the geometric "
"distribution.  It describes many common situations, such as the size of "
"raindrops measured over many rainstorms [R0dbb9b01ef9c-1]_, or the time "
"between page requests to Wikipedia [R0dbb9b01ef9c-2]_."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.exponential:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.exponential:22
msgid "**scale**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.exponential:-1
msgid "float or array_like of floats"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.exponential:21
msgid "The scale parameter, :math:`\\beta = 1/\\lambda`. Must be non-negative."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.exponential:30
msgid "**size**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.exponential:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.exponential:25
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn.  If size is ``None`` (default), a single value is "
"returned if ``scale`` is a scalar.  Otherwise, ``np.array(scale).size`` "
"samples are drawn."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.exponential:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.exponential:43
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.exponential:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.exponential:35
msgid "Drawn samples from the parameterized exponential distribution."
msgstr ""

