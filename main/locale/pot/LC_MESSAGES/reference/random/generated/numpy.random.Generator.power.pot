#: ../../../reference/random/generated/numpy.random.Generator.power.rst:4
msgid "numpy.random.Generator.power"
msgstr ""

#: ../../../reference/random/generated/numpy.random.Generator.power.rst:8
msgid "method"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.power:2
msgid ""
"Draws samples in [0, 1] from a power distribution with positive exponent a - "
"1."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.power:5
msgid "Also known as the power function distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.power:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.power:10
msgid "**a**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.power:-1
msgid "float or array_like of floats"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.power:10
msgid "Parameter of the distribution. Must be non-negative."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.power:18
msgid "**size**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.power:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.power:13
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn.  If size is ``None`` (default), a single value is "
"returned if ``a`` is a scalar.  Otherwise, ``np.array(a).size`` samples are "
"drawn."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.power:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.power:26
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.power:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.power:23
msgid "Drawn samples from the parameterized power distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.power:0
msgid "Raises"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.power:34
msgid "ValueError"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.power:31
msgid "If a <= 0."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.power:37
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.power:38
msgid "The probability density function is"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.power:40
msgid ""
"P(x; a) = ax^{a-1}, 0 \\le x \\le 1, a>0.\n"
"\n"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.power:42
msgid ""
"The power function distribution is just the inverse of the Pareto "
"distribution. It may also be seen as a special case of the Beta distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.power:46
msgid ""
"It is used, for example, in modeling the over-reporting of insurance claims."
msgstr ""

