#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.gamma:45
msgid ""
"probability density function, distribution or cumulative density function, "
"etc."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.gamma:46
msgid ":obj:`random.Generator.gamma`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.gamma:47
msgid "which should be used for new code."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.gamma:51
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.gamma:52
msgid "The probability density for the Gamma distribution is"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.gamma:54
msgid ""
"p(x) = x^{k-1}\\frac{e^{-x/\\theta}}{\\theta^k\\Gamma(k)},\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.gamma:56
msgid ""
"where :math:`k` is the shape and :math:`\\theta` the scale, and :math:"
"`\\Gamma` is the Gamma function."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.gamma:59
msgid ""
"The Gamma distribution is often used to model the times to failure of "
"electronic components, and arises naturally in processes for which the "
"waiting times between Poisson distributed events are relevant."
msgstr ""

