#: ../../../reference/random/generated/numpy.random.gamma.rst:4
msgid "numpy.random.gamma"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.gamma:2
msgid "Draw samples from a Gamma distribution."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.gamma:4
msgid ""
"Samples are drawn from a Gamma distribution with specified parameters, "
"`shape` (sometimes designated \"k\") and `scale` (sometimes designated "
"\"theta\"), where both parameters are > 0."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.gamma:9
msgid ""
"New code should use the `~numpy.random.Generator.gamma` method of a `~numpy."
"random.Generator` instance instead; please see the :ref:`random-quick-start`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.gamma:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.gamma:16
msgid "**shape**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.gamma:-1
msgid "float or array_like of floats"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.gamma:16
msgid "The shape of the gamma distribution. Must be non-negative."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.gamma:20
msgid "**scale**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.gamma:-1
msgid "float or array_like of floats, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.gamma:19
msgid ""
"The scale of the gamma distribution. Must be non-negative. Default is equal "
"to 1."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.gamma:28
msgid "**size**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.gamma:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.gamma:23
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn.  If size is ``None`` (default), a single value is "
"returned if ``shape`` and ``scale`` are both scalars. Otherwise, ``np."
"broadcast(shape, scale).size`` samples are drawn."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.gamma:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.gamma:39
