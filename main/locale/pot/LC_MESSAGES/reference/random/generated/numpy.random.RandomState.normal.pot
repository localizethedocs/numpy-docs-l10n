#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.normal:58
msgid "The probability density for the Gaussian distribution is"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.normal:60
msgid ""
"p(x) = \\frac{1}{\\sqrt{ 2 \\pi \\sigma^2 }}\n"
"e^{ - \\frac{ (x - \\mu)^2 } {2 \\sigma^2} },\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.normal:63
msgid ""
"where :math:`\\mu` is the mean and :math:`\\sigma` the standard deviation. "
"The square of the standard deviation, :math:`\\sigma^2`, is called the "
"variance."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.normal:67
msgid ""
"The function has its peak at the mean, and its \"spread\" increases with the "
"standard deviation (the function reaches 0.607 times its maximum at :math:`x "
"+ \\sigma` and :math:`x - \\sigma` [Ra2e838c5ea87-2]_).  This implies that "
"normal is more likely to return samples lying close to the mean, rather than "
"those far away."
msgstr ""

