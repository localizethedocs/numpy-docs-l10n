#: ../../../reference/random/generated/numpy.random.random_integers.rst:4
msgid "numpy.random.random\\_integers"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.random_integers:2
msgid ""
"Random integers of type `numpy.int_` between `low` and `high`, inclusive."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.random_integers:4
msgid ""
"Return random integers of type `numpy.int_` from the \"discrete uniform\" "
"distribution in the closed interval [`low`, `high`].  If `high` is None (the "
"default), then results are from [1, `low`]. The `numpy.int_` type translates "
"to the C long integer type and its precision is platform dependent."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.random_integers:10
msgid "This function has been deprecated. Use randint instead."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.random_integers:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.random_integers:19
msgid "**low**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.random_integers:-1
msgid "int"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.random_integers:17
msgid ""
"Lowest (signed) integer to be drawn from the distribution (unless "
"``high=None``, in which case this parameter is the *highest* such integer)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.random_integers:23
msgid "**high**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.random_integers:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.random_integers:22
msgid ""
"If provided, the largest (signed) integer to be drawn from the distribution "
"(see above for behavior if ``high=None``)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.random_integers:30
msgid "**size**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.random_integers:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.random_integers:26
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn.  Default is None, in which case a single value is "
"returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.random_integers:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.random_integers:42
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.random_integers:-1
msgid "int or ndarray of ints"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.random_integers:35
msgid ""
"`size`-shaped array of random integers from the appropriate distribution, or "
"a single such random int if `size` not provided."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.random_integers:47
msgid ":obj:`randint`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.random_integers:48
msgid ""
"Similar to `random_integers`, only for the half-open interval [`low`, "
"`high`), and 0 is the lowest value if `high` is omitted."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.random_integers:52
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.random_integers:53
msgid ""
"To sample from N evenly spaced floating-point numbers between a and b, use::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/random/__init__.py:docstring
#: of numpy.random.RandomState.random_integers:56
msgid "a + (b - a) * (np.random.random_integers(N) - 1) / (N - 1.)"
msgstr ""

