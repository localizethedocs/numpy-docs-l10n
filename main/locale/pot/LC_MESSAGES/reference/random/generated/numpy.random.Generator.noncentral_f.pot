#: ../../../../docstring of numpy.random._generator.Generator.noncentral_f:63
msgid "Examples"
msgstr ""

#: ../../../reference/random/generated/numpy.random.Generator.noncentral_f.rst:3
msgid ""
"In a study, testing for a specific alternative to the null hypothesis "
"requires use of the Noncentral F distribution. We need to calculate the area "
"in the tail of the distribution that exceeds the value of the F distribution "
"for the null hypothesis.  We'll plot the two probability distributions for "
"comparison."
msgstr ""

