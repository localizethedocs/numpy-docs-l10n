#: ../../../reference/random/generated/numpy.random.Generator.noncentral_f.rst:4
msgid "numpy.random.Generator.noncentral\\_f"
msgstr ""

#: ../../../reference/random/generated/numpy.random.Generator.noncentral_f.rst:8
msgid "method"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.noncentral_f:2
msgid "Draw samples from the noncentral F distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.noncentral_f:4
msgid ""
"Samples are drawn from an F distribution with specified parameters, `dfnum` "
"(degrees of freedom in numerator) and `dfden` (degrees of freedom in "
"denominator), where both parameters > 1. `nonc` is the non-centrality "
"parameter."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.noncentral_f:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.noncentral_f:12
msgid "**dfnum**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.noncentral_f:-1
msgid "float or array_like of floats"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.noncentral_f:12
msgid "Numerator degrees of freedom, must be > 0."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.noncentral_f:15
msgid "**dfden**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.noncentral_f:15
msgid "Denominator degrees of freedom, must be > 0."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.noncentral_f:19
msgid "**nonc**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.noncentral_f:18
msgid ""
"Non-centrality parameter, the sum of the squares of the numerator means, "
"must be >= 0."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.noncentral_f:28
msgid "**size**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.noncentral_f:-1
msgid "int or tuple of ints, optional"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.noncentral_f:22
msgid ""
"Output shape.  If the given shape is, e.g., ``(m, n, k)``, then ``m * n * "
"k`` samples are drawn.  If size is ``None`` (default), a single value is "
"returned if ``dfnum``, ``dfden``, and ``nonc`` are all scalars.  Otherwise, "
"``np.broadcast(dfnum, dfden, nonc).size`` samples are drawn."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.noncentral_f:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.noncentral_f:40
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.noncentral_f:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.noncentral_f:33
msgid "Drawn samples from the parameterized noncentral Fisher distribution."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.noncentral_f:43
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.noncentral_f:44
msgid ""
"When calculating the power of an experiment (power = probability of "
"rejecting the null hypothesis when a specific alternative is true) the non-"
"central F statistic becomes important.  When the null hypothesis is true, "
"the F statistic follows a central F distribution. When the null hypothesis "
"is not true, then it follows a non-central F statistic."
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.noncentral_f:51
msgid "References"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.noncentral_f:52
msgid ""
"Weisstein, Eric W. \"Noncentral F-Distribution.\" From MathWorld--A Wolfram "
"Web Resource. https://mathworld.wolfram.com/NoncentralF-Distribution.html"
msgstr ""

#: ../../../../docstring of numpy.random._generator.Generator.noncentral_f:55
msgid ""
"Wikipedia, \"Noncentral F-distribution\", https://en.wikipedia.org/wiki/"
"Noncentral_F-distribution"
msgstr ""

