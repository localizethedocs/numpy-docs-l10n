msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ctypeslib/__init__.py:docstring
#: of numpy.ctypeslib.ndpointer:4
msgid ""
"An ndpointer instance is used to describe an ndarray in restypes and "
"argtypes specifications.  This approach is more flexible than using, for "
"example, ``POINTER(c_double)``, since several restrictions can be specified, "
"which are verified upon calling the ctypes function. These include data "
"type, number of dimensions, shape and flags.  If a given array does not "
"satisfy the specified restrictions, a ``TypeError`` is raised."
msgstr ""

