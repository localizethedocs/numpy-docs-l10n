#: ../../../reference/arrays.ndarray.rst:625
msgid "Structural pattern matching"
msgstr ""

#: ../../../reference/arrays.ndarray.rst:627
msgid ""
"Arrays support :pep:`structural pattern matching <634>`. The array is "
"matched as a sequence, so you can unpack arrays along the first dimension in "
"``match``/``case`` statements::"
msgstr ""

#: ../../../reference/arrays.ndarray.rst:631
msgid ""
">>> arr = np.array([[1, 2], [3, 4]])\n"
">>> match arr:\n"
"...     case [row1, row2]:\n"
"...         print(f\"row1={row1}, row2={row2}\")\n"
"row1=[1 2], row2=[3 4]"
msgstr ""

#: ../../../reference/arrays.ndarray.rst:637
msgid "Nested patterns work too, matching inner dimensions::"
msgstr ""

#: ../../../reference/arrays.ndarray.rst:639
msgid ""
">>> match arr:\n"
"...     case [[a, b], [c, d]]:\n"
"...         print(f\"a={a}, b={b}, c={c}, d={d}\")\n"
"a=1, b=2, c=3, d=4"
msgstr ""

#: ../../../reference/arrays.ndarray.rst:644
msgid "All ndarray subclasses inherit this behavior."
msgstr ""

