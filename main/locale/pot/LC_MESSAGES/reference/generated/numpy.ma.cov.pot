#: ../../../reference/generated/numpy.ma.cov.rst:4
msgid "numpy.ma.cov"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.cov:2
msgid "Estimate the covariance matrix."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.cov:4
msgid ""
"Except for the handling of missing data this function does the same as "
"`numpy.cov`. For more details and examples, see `numpy.cov`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.cov:7
msgid ""
"By default, masked values are recognized as such. If `x` and `y` have the "
"same shape, a common mask is allocated: if ``x[i,j]`` is masked, then ``y[i,"
"j]`` will also be masked. Setting `allow_masked` to False will raise an "
"exception if values are missing in either of the input arrays."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.cov:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.cov:18
msgid "**x**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.cov:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.cov:16
msgid ""
"A 1-D or 2-D array containing multiple variables and observations. Each row "
"of `x` represents a variable, and each column a single observation of all "
"those variables. Also see `rowvar` below."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.cov:22
msgid "**y**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.cov:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.cov:21
msgid ""
"An additional set of variables and observations. `y` has the same shape as "
"`x`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.cov:28
msgid "**rowvar**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.cov:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.cov:25
msgid ""
"If `rowvar` is True (default), then each row represents a variable, with "
"observations in the columns. Otherwise, the relationship is transposed: each "
"column represents a variable, while the rows contain observations."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.cov:34
msgid "**bias**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.cov:31
msgid ""
"Default normalization (False) is by ``(N-1)``, where ``N`` is the number of "
"observations given (unbiased estimate). If `bias` is True, then "
"normalization is by ``N``. This keyword can be overridden by the keyword "
"``ddof`` in numpy versions >= 1.5."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.cov:39
msgid "**allow_masked**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.cov:37
msgid ""
"If True, masked values are propagated pair-wise: if a value is masked in "
"`x`, the corresponding value is masked in `y`. If False, raises a "
"`ValueError` exception when some values are missing."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.cov:50
msgid "**ddof**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.cov:-1
msgid "{None, int}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.cov:42
msgid ""
"If not ``None`` normalization is by ``(N - ddof)``, where ``N`` is the "
"number of observations; this overrides the value implied by ``bias``. The "
"default value is ``None``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.cov:0
msgid "Raises"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.cov:57
msgid "ValueError"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.cov:55
msgid "Raised if some values are missing and `allow_masked` is False."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.cov:62
msgid ":obj:`numpy.cov`"
msgstr ""

