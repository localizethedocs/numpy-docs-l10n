msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.suppress_warnings:48
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.suppress_warnings:49
msgid ""
"Filters added inside the context manager will be discarded again when "
"leaving it. Upon entering all filters defined outside a context will be "
"applied automatically."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.suppress_warnings:53
msgid ""
"When a recording filter is added, matching warnings are stored in the "
"``log`` attribute as well as in the list returned by ``record``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.suppress_warnings:56
msgid ""
"If filters are added and the ``module`` keyword is given, the warning "
"registry of this module will additionally be cleared when applying it, "
"entering the context, or exiting it. This could cause warnings to appear a "
"second time after leaving the context if they were configured to be printed "
"once (default) and were already printed before the context was entered."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.suppress_warnings:63
msgid ""
"Nesting this context manager will work as expected when the forwarding rule "
"is \"always\" (default). Unfiltered and unrecorded warnings will be passed "
"out and be matched by the outer level. On the outmost level they will be "
"printed (or caught by another warnings context). The forwarding rule "
"argument can modify this behaviour."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.suppress_warnings:70
msgid "Like ``catch_warnings`` this context manager is not threadsafe."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.suppress_warnings:74
msgid "Examples"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.suppress_warnings:79
msgid "With a context manager::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.suppress_warnings:81
msgid ""
"with np.testing.suppress_warnings() as sup:\n"
"    sup.filter(DeprecationWarning, \"Some text\")\n"
"    sup.filter(module=np.ma.core)\n"
"    log = sup.record(FutureWarning, \"Does this occur?\")\n"
"    command_giving_warnings()\n"
"    # The FutureWarning was given once, the filtered warnings were\n"
"    # ignored. All other warnings abide outside settings (may be\n"
"    # printed/error)\n"
"    assert_(len(log) == 1)\n"
"    assert_(len(sup.log) == 1)  # also stored in log attribute"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.suppress_warnings:92
msgid "Or as a decorator::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.suppress_warnings:94
msgid ""
"sup = np.testing.suppress_warnings()\n"
"sup.filter(module=np.ma.core)  # module must match exactly\n"
"@sup\n"
"def some_function():\n"
"    # do something which causes a warning in np.ma.core\n"
"    pass"
msgstr ""

