#: ../../../reference/generated/numpy.digitize.rst:4
msgid "numpy.digitize"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:2
msgid ""
"Return the indices of the bins to which each value in input array belongs."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:5
msgid "`right`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:5
msgid "order of bins"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:5
msgid "returned index `i` satisfies"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:7 numpy.digitize:9
msgid "``False``"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:7 numpy.digitize:8
msgid "increasing"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:7
msgid "``bins[i-1] <= x < bins[i]``"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:8 numpy.digitize:10
msgid "``True``"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:8
msgid "``bins[i-1] < x <= bins[i]``"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:9 numpy.digitize:10
msgid "decreasing"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:9
msgid "``bins[i-1] > x >= bins[i]``"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:10
msgid "``bins[i-1] >= x > bins[i]``"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:13
msgid ""
"If values in `x` are beyond the bounds of `bins`, 0 or ``len(bins)`` is "
"returned as appropriate."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:20
msgid "**x**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:19
msgid ""
"Input array to be binned. Prior to NumPy 1.10.0, this array had to be 1-"
"dimensional, but can now have any shape."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:23
msgid "**bins**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:23
msgid "Array of bins. It has to be 1-dimensional and monotonic."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:32
msgid "**right**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:26
msgid ""
"Indicating whether the intervals include the right or the left bin edge. "
"Default behavior is (right==False) indicating that the interval does not "
"include the right edge. The left bin end is open in this case, i.e., "
"bins[i-1] <= x < bins[i] is the default behavior for monotonically "
"increasing bins."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:40
msgid "**indices**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:-1
msgid "ndarray of ints"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:37
msgid "Output array of indices, of same shape as `x`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:0
msgid "Raises"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:45
msgid "ValueError"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:45
msgid "If `bins` is not monotonic."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:50
msgid "TypeError"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:48
msgid "If the type of the input is complex."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:55
msgid ":obj:`bincount`, :obj:`histogram`, :obj:`unique`, :obj:`searchsorted`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:59
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:60
msgid ""
"If values in `x` are such that they fall outside the bin range, attempting "
"to index `bins` with the indices that `digitize` returns will result in an "
"IndexError."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:66
msgid ""
"`numpy.digitize` is  implemented in terms of `numpy.searchsorted`. This "
"means that a binary search is used to bin the values, which scales much "
"better for larger number of bins than the previous linear search. It also "
"removes the requirement for the input array to be 1-dimensional."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:71
msgid "For monotonically *increasing* `bins`, the following are equivalent::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:73
msgid ""
"np.digitize(x, bins, right=True)\n"
"np.searchsorted(bins, x, side='left')"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.digitize:76
msgid ""
"Note that as the order of the arguments are reversed, the side must be too. "
"The `searchsorted` call is marginally faster, as it does not do any "
"monotonicity checks. Perhaps more importantly, it supports all dtypes."
msgstr ""

