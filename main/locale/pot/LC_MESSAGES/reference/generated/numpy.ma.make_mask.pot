msgid "numpy.ma.make\\_mask"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.make_mask:2
msgid "Create a boolean mask from an array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.make_mask:4
msgid ""
"Return `m` as a boolean mask, creating a copy if necessary or requested. The "
"function can accept any sequence that is convertible to integers, or "
"``nomask``.  Does not require that contents must be 0s and 1s, values of 0 "
"are interpreted as False, everything else as True."
msgstr ""

