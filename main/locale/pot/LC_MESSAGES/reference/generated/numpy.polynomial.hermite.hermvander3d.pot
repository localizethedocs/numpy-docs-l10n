msgid "**x, y, z**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander3d:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander3d:28
msgid ""
"Arrays of point coordinates, all of the same shape. The dtypes will be "
"converted to either float64 or complex128 depending on whether any of the "
"elements are complex. Scalars are converted to 1-D arrays."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander3d:36
msgid "**deg**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
