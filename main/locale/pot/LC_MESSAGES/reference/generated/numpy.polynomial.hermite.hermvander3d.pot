#: ../../../reference/generated/numpy.polynomial.hermite.hermvander3d.rst:4
msgid "numpy.polynomial.hermite.hermvander3d"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander3d:2
msgid "Pseudo-Vandermonde matrix of given degrees."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander3d:4
msgid ""
"Returns the pseudo-Vandermonde matrix of degrees `deg` and sample points "
"``(x, y, z)``. If `l`, `m`, `n` are the given degrees in `x`, `y`, `z`, then "
"The pseudo-Vandermonde matrix is defined by"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander3d:8
msgid ""
"V[..., (m+1)(n+1)i + (n+1)j + k] = H_i(x)*H_j(y)*H_k(z),\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander3d:10
msgid ""
"where ``0 <= i <= l``, ``0 <= j <= m``, and ``0 <= j <= n``.  The leading "
"indices of `V` index the points ``(x, y, z)`` and the last index encodes the "
"degrees of the Hermite polynomials."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander3d:14
msgid ""
"If ``V = hermvander3d(x, y, z, [xdeg, ydeg, zdeg])``, then the columns of "
"`V` correspond to the elements of a 3-D coefficient array `c` of shape (xdeg "
"+ 1, ydeg + 1, zdeg + 1) in the order"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander3d:18
msgid ""
"c_{000}, c_{001}, c_{002},... , c_{010}, c_{011}, c_{012},...\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander3d:20
msgid ""
"and  ``np.dot(V, c.flat)`` and ``hermval3d(x, y, z, c)`` will be the same up "
"to roundoff. This equivalence is useful both for least squares fitting and "
"for the evaluation of a large number of 3-D Hermite series of the same "
"degrees and sample points."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
