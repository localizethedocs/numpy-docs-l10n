msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander3d:34
msgid "List of maximum degrees of the form [x_deg, y_deg, z_deg]."
msgstr ""

