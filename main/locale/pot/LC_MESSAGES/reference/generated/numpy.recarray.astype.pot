msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.astype:-1
msgid "str or dtype"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.astype:8
msgid "Typecode or data-type to which the array is cast."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.astype:16
msgid "**order**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.astype:-1
msgid "{'C', 'F', 'A', 'K'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.astype:11
msgid ""
"Controls the memory layout order of the result. 'C' means C order, 'F' means "
"Fortran order, 'A' means 'F' order if all the arrays are Fortran contiguous, "
"'C' order otherwise, and 'K' means as close to the order the array elements "
"appear in memory as possible. Default is 'K'."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.astype:32
msgid "**casting**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.astype:-1
msgid "{'no', 'equiv', 'safe', 'same_kind', 'same_value', 'unsafe'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.astype:19
msgid ""
"Controls what kind of data casting may occur. Defaults to 'unsafe' for "
"backwards compatibility."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.astype:22
msgid "'no' means the data types should not be cast at all."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.astype:23
msgid "'equiv' means only byte-order changes are allowed."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.astype:24
msgid "'safe' means only casts which can preserve values are allowed."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.astype:25
msgid ""
"'same_kind' means only safe casts or casts within a kind, like float64 to "
"float32, are allowed."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.astype:27
msgid "'unsafe' means any data conversions may be done."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.astype:28
msgid ""
"'same_value' means any data conversions may be done, but the values must not "
"change, including rounding of floats or overflow of ints"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.astype:31
msgid "Support for ``'same_value'`` was added."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.astype:36
msgid "**subok**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.astype:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.astype:35
msgid ""
"If True, then sub-classes will be passed-through (default), otherwise the "
"returned array will be forced to be a base-class array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.astype:44
msgid "**copy**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.astype:39
msgid ""
"By default, astype always returns a newly allocated array. If this is set to "
"false, and the `dtype`, `order`, and `subok` requirements are satisfied, the "
"input array is returned instead of a copy."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.astype:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.astype:55
msgid "**arr_t**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.astype:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.astype:49
msgid ""
"Unless `copy` is False and the other conditions for returning the input "
"array are satisfied (see description for `copy` input parameter), `arr_t` is "
"a new array of the same shape as the input array, with dtype, order given by "
"`dtype`, `order`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.astype:0
msgid "Raises"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.astype:61
msgid "ComplexWarning"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.astype:60
msgid ""
"When casting from complex to float or int. To avoid this, one should use ``a."
"real.astype(t)``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.astype:70
msgid "ValueError"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.astype:64
msgid ""
"When casting using ``'same_value'`` and the values change or would overflow"
msgstr ""

