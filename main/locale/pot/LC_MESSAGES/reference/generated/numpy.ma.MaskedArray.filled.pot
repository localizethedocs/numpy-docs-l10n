#: ../../../reference/generated/numpy.ma.MaskedArray.filled.rst:4
msgid "numpy.ma.MaskedArray.filled"
msgstr ""

#: ../../../reference/generated/numpy.ma.MaskedArray.filled.rst:8
msgid "method"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.filled:2
msgid ""
"Return a copy of self, with masked values filled with a given value. "
"**However**, if there are no masked values to fill, self will be returned "
"instead as an ndarray."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.filled:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.filled:15
msgid "**fill_value**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.filled:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.filled:10
msgid ""
"The value to use for invalid entries. Can be scalar or non-scalar. If non-"
"scalar, the resulting ndarray must be broadcastable over input array. "
"Default is None, in which case, the `fill_value` attribute of the array is "
"used instead."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.filled:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.filled:30
msgid "**filled_array**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.filled:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.filled:20
msgid ""
"A copy of ``self`` with invalid entries replaced by *fill_value* (be it the "
"function argument or the attribute of ``self``), or ``self`` itself as an "
"ndarray if there are no invalid entries to be replaced."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.filled:33
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.filled:34
msgid "The result is **not** a MaskedArray!"
msgstr ""

