msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/npyio.py:docstring
#: of numpy.lib.npyio.DataSource:36
msgid ""
"URLs require a scheme string (``http://``) to be used, without it they will "
"fail::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/npyio.py:docstring
#: of numpy.lib.npyio.DataSource:39
msgid ""
">>> repos = np.lib.npyio.DataSource()\n"
">>> repos.exists('www.google.com/index.html')\n"
"False\n"
">>> repos.exists('http://www.google.com/index.html')\n"
"True"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/npyio.py:docstring
#: of numpy.lib.npyio.DataSource:45
msgid "Temporary directories are deleted when the DataSource is deleted."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/npyio.py:docstring
#: of numpy.lib.npyio.DataSource:49
msgid "Examples"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/npyio.py:docstring
#: of numpy.lib.npyio.DataSource:56
msgid ""
">>> ds = np.lib.npyio.DataSource('/home/guido')\n"
">>> urlname = 'http://www.google.com/'\n"
">>> gfile = ds.open('http://www.google.com/')\n"
">>> ds.abspath(urlname)\n"
"'/home/guido/www.google.com/index.html'\n"
"\n"
">>> ds = np.lib.npyio.DataSource(None)  # use with temporary file\n"
">>> ds.open('/home/guido/foobar.txt')\n"
"<open file '/home/guido.foobar.txt', mode 'r' at 0x91d4430>\n"
">>> ds.abspath('/home/guido/foobar.txt')\n"
"'/tmp/.../home/guido/foobar.txt'"
msgstr ""

