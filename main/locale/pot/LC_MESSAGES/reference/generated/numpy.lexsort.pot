#: ../../../reference/generated/numpy.lexsort.rst:4
msgid "numpy.lexsort"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.lexsort:2
msgid "Perform an indirect stable sort using a sequence of keys."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.lexsort:4
msgid ""
"Given multiple sorting keys, lexsort returns an array of integer indices "
"that describes the sort order by multiple keys. The last key in the sequence "
"is used for the primary sort order, ties are broken by the second-to-last "
"key, and so on."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.lexsort:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.lexsort:15
msgid "**keys**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.lexsort:-1
msgid "(k, m, n, ...) array-like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.lexsort:12
msgid ""
"The `k` keys to be sorted. The *last* key (e.g, the last row if `keys` is a "
"2D array) is the primary sort key. Each element of `keys` along the zeroth "
"axis must be an array-like object of the same shape."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.lexsort:22
msgid "**axis**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.lexsort:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.lexsort:18
msgid ""
"Axis to be indirectly sorted. By default, sort over the last axis of each "
"sequence. Separate slices along `axis` sorted over independently; see last "
"example."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.lexsort:0
msgid "Returns"
msgstr ""

