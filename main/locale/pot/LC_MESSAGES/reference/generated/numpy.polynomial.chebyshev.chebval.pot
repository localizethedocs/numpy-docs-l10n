#: of numpy.polynomial.chebyshev.chebval:-1
msgid "ndarray, algebra_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/chebyshev.py:docstring
#: of numpy.polynomial.chebyshev.chebval:50
msgid "The shape of the return value is described above."
msgstr ""

