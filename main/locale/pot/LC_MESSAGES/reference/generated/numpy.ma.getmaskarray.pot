#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.getmaskarray:2
msgid "Return the mask of a masked array, or full boolean array of False."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.getmaskarray:4
msgid ""
"Return the mask of `arr` as an ndarray if `arr` is a `MaskedArray` and the "
"mask is not `nomask`, else return a full boolean array of False of the same "
"shape as `arr`."
msgstr ""

