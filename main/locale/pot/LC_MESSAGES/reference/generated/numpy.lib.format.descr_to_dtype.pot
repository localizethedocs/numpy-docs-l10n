msgid "Returns a dtype based off the given description."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.descr_to_dtype:4
msgid ""
"This is essentially the reverse of `~lib.format.dtype_to_descr`. It will "
"remove the valueless padding fields created by, i.e. simple fields like "
"dtype('float32'), and then convert the description to its corresponding "
"dtype."
msgstr ""

