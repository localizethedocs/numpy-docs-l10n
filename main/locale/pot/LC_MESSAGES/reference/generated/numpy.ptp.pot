msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.ptp:47
msgid ""
"The range of a given array - `scalar` if array is one-dimensional or a new "
"array holding the result along the given axis"
msgstr ""

