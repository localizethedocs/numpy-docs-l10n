#: ../../../reference/generated/numpy.linalg.tensorinv.rst:4
msgid "numpy.linalg.tensorinv"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorinv:2
msgid "Compute the 'inverse' of an N-dimensional array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorinv:4
msgid ""
"The result is an inverse for `a` relative to the tensordot operation "
"``tensordot(a, b, ind)``, i. e., up to floating-point accuracy, "
"``tensordot(tensorinv(a), a, ind)`` is the \"identity\" tensor for the "
"tensordot operation."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorinv:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorinv:13
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorinv:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorinv:12
msgid ""
"Tensor to 'invert'. Its shape must be 'square', i. e., ``prod(a.shape[:ind]) "
"== prod(a.shape[ind:])``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorinv:19
msgid "**ind**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorinv:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorinv:16
msgid ""
"Number of first indices that are involved in the inverse sum. Must be a "
"positive integer, default is 2."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorinv:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorinv:27
msgid "**b**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorinv:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/linalg/__init__.py:docstring
#: of numpy.linalg.tensorinv:24
msgid "`a`'s tensordot inverse, shape ``a.shape[ind:] + a.shape[:ind]``."
msgstr ""

