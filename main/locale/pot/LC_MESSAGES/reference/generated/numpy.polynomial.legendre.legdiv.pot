msgid "Divide one Legendre series by another."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legdiv:4
msgid ""
"Returns the quotient-with-remainder of two Legendre series `c1` / `c2`.  The "
"arguments are sequences of coefficients from lowest order \"term\" to "
"highest, e.g., [1,2,3] represents the series ``P_0 + 2*P_1 + 3*P_2``."
msgstr ""

