msgid "Suppress whole columns of a 2-D array that contain masked values."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.compress_cols:4
msgid ""
