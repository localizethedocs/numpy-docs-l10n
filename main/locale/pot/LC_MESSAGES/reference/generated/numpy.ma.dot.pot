#: ../../../reference/generated/numpy.ma.dot.rst:4
msgid "numpy.ma.dot"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.dot:2
msgid "Return the dot product of two arrays."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.dot:4
msgid ""
"This function is the equivalent of `numpy.dot` that takes masked values into "
"account. Note that `strict` and `out` are in different position than in the "
"method version. In order to maintain compatibility with the corresponding "
"method, it is recommended that the optional arguments be treated as keyword "
"only.  At some point that may be mandatory."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.dot:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.dot:13
msgid "**a, b**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.dot:-1
msgid "masked_array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.dot:13
msgid "Inputs arrays."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.dot:19
msgid "**strict**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.dot:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.dot:16
msgid ""
"Whether masked data are propagated (True) or set to 0 (False) for the "
"computation. Default is False.  Propagating the mask means that if a masked "
"value appears in a row or column, the whole row or column is considered "
"masked."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.dot:36
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.dot:-1
msgid "masked_array, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.dot:22
msgid ""
"Output argument. This must have the exact kind that would be returned if it "
"was not used. In particular, it must have the right type, must be C-"
"contiguous, and its dtype must be the dtype that would be returned for "
"`dot(a,b)`. This is a performance feature. Therefore, if these conditions "
"are not met, an exception is raised, instead of attempting to be flexible."
msgstr ""

