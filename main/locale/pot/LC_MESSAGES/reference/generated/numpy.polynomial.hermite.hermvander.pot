#: ../../../reference/generated/numpy.polynomial.hermite.hermvander.rst:4
msgid "numpy.polynomial.hermite.hermvander"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander:2
msgid "Pseudo-Vandermonde matrix of given degree."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander:4
msgid ""
"Returns the pseudo-Vandermonde matrix of degree `deg` and sample points `x`. "
"The pseudo-Vandermonde matrix is defined by"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander:7
msgid ""
"V[..., i] = H_i(x),\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander:9
msgid ""
"where ``0 <= i <= deg``. The leading indices of `V` index the elements of "
"`x` and the last index is the degree of the Hermite polynomial."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander:12
msgid ""
"If `c` is a 1-D array of coefficients of length ``n + 1`` and `V` is the "
"array ``V = hermvander(x, n)``, then ``np.dot(V, c)`` and ``hermval(x, c)`` "
"are the same up to roundoff. This equivalence is useful both for least "
"squares fitting and for the evaluation of a large number of Hermite series "
"of the same degree and sample points."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander:23
msgid "**x**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander:21
msgid ""
"Array of points. The dtype is converted to float64 or complex128 depending "
"on whether any of the elements are complex. If `x` is scalar it is converted "
"to a 1-D array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander:28
msgid "**deg**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander:-1
msgid "int"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander:26
msgid "Degree of the resulting matrix."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander:45
msgid "**vander**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/hermite.py:docstring
#: of numpy.polynomial.hermite.hermvander:33
msgid ""
"The pseudo-Vandermonde matrix. The shape of the returned matrix is ``x.shape "
"+ (deg + 1,)``, where The last index is the degree of the corresponding "
"Hermite polynomial.  The dtype will be the same as the converted `x`."
msgstr ""

