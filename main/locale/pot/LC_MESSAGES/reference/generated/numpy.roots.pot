#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.roots:2
msgid "Return the roots of a polynomial with coefficients given in p."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.roots:5
msgid ""
"This forms part of the old polynomial API. Since version 1.4, the new "
"polynomial API defined in `numpy.polynomial` is preferred. A summary of the "
"differences can be found in the :doc:`transition guide </reference/routines."
"polynomials>`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.roots:10
msgid ""
"The values in the rank-1 array `p` are coefficients of a polynomial. If the "
"length of `p` is n+1 then the polynomial is described by::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.roots:13
msgid "p[0] * x**n + p[1] * x**(n-1) + ... + p[n-1]*x + p[n]"
msgstr ""

