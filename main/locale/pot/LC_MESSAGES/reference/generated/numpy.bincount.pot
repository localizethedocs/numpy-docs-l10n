#: ../../../reference/generated/numpy.bincount.rst:4
msgid "numpy.bincount"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.bincount:2
msgid ""
"Count number of occurrences of each value in array of non-negative ints."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.bincount:4
msgid ""
"The number of bins (of size 1) is one larger than the largest value in `x`. "
"If `minlength` is specified, there will be at least this number of bins in "
"the output array (though it will be longer if necessary, depending on the "
"contents of `x`). Each bin gives the number of occurrences of its index "
"value in `x`. If `weights` is specified the input array is weighted by it, i."
"e. if a value ``n`` is found at position ``i``, ``out[n] += weight[i]`` "
"instead of ``out[n] += 1``."
msgstr ""

