#: ../../../reference/generated/numpy.busdaycalendar.rst:2
msgid "numpy.busdaycalendar"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busdaycalendar:2
msgid ""
"A business day calendar object that efficiently stores information defining "
"valid days for the busday family of functions."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busdaycalendar:5
msgid ""
"The default valid days are Monday through Friday (\"business days\"). A "
"busdaycalendar object can be specified with any set of weekly valid days, "
"plus an optional \"holiday\" dates that always will be invalid."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busdaycalendar:9
msgid ""
"Once a busdaycalendar object is created, the weekmask and holidays cannot be "
"modified."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busdaycalendar:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busdaycalendar:20
msgid "**weekmask**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busdaycalendar:-1
msgid "str or array_like of bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busdaycalendar:15
msgid ""
"A seven-element array indicating which of Monday through Sunday are valid "
"days. May be specified as a length-seven list or array, like "
"[1,1,1,1,1,0,0]; a length-seven string, like '1111100'; or a string like "
"\"Mon Tue Wed Thu Fri\", made up of 3-character abbreviations for weekdays, "
"optionally separated by white space. Valid abbreviations are: Mon Tue Wed "
"Thu Fri Sat Sun"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busdaycalendar:27
msgid "**holidays**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busdaycalendar:-1
msgid "array_like of datetime64[D], optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.busdaycalendar:23
msgid ""
"An array of dates to consider as invalid dates, no matter which weekday they "
"fall upon.  Holiday dates may be specified in any order, and NaT (not-a-"
"time) dates are ignored.  This list is saved in a normalized form that is "
"suited for fast calculations of valid days."
msgstr ""

