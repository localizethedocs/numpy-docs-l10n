#: ../../../reference/generated/numpy.savez_compressed.rst:4
msgid "numpy.savez\\_compressed"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:2
msgid "Save several arrays into a single file in compressed ``.npz`` format."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:4
msgid ""
"Provide arrays as keyword arguments to store them under the corresponding "
"name in the output file: ``savez_compressed(fn, x=x, y=y)``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:7
msgid ""
"If arrays are specified as positional arguments, i.e., "
"``savez_compressed(fn, x, y)``, their names will be `arr_0`, `arr_1`, etc."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:16
msgid "**file**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:-1
msgid "file, str, or pathlib.Path"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:13
msgid ""
"Either the filename (string) or an open file (file-like object) where the "
"data will be saved. If file is a string or a Path, the ``.npz`` extension "
"will be appended to the filename if it is not already there."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:21
msgid "**args**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:-1
msgid "Arguments, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:19
msgid ""
"Arrays to save to the file. Please use keyword arguments (see `kwds` below) "
"to assign names to arrays.  Arrays specified as args will be named "
"\"arr_0\", \"arr_1\", and so on."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:30
msgid "**allow_pickle**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:24
msgid ""
"Allow saving object arrays using Python pickles. Reasons for disallowing "
"pickles include security (loading pickled data can execute arbitrary code) "
"and portability (pickled objects may not be loadable on different Python "
"installations, for example if the stored objects require libraries that are "
"not available, and not all pickled data is compatible between different "
"versions of Python). Default: True"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:36
msgid "**kwds**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:-1
msgid "Keyword arguments, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:33
msgid ""
"Arrays to save to the file. Each array will be saved to the output file with "
"its corresponding keyword name."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:47
msgid "None"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:52
msgid ":obj:`numpy.save`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:53
msgid "Save a single array to a binary file in NumPy format."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:54
msgid ":obj:`numpy.savetxt`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:55
msgid "Save an array to a file as plain text."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:56
msgid ":obj:`numpy.savez`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:57
msgid "Save several arrays into an uncompressed ``.npz`` file format"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:58
msgid ":obj:`numpy.load`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:59
msgid "Load the files created by savez_compressed."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:63
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:64
msgid ""
"The ``.npz`` file format is a zipped archive of files named after the "
"variables they contain.  The archive is compressed with ``zipfile."
"ZIP_DEFLATED`` and each file in the archive contains one variable in ``."
"npy`` format. For a description of the ``.npy`` format, see :py:mod:`numpy."
"lib.format`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.savez_compressed:70
msgid ""
"When opening the saved ``.npz`` file with `load` a `~lib.npyio.NpzFile` "
"object is returned. This is a dictionary-like object which can be queried "
"for its list of arrays (with the ``.files`` attribute), and for the arrays "
"themselves."
msgstr ""

