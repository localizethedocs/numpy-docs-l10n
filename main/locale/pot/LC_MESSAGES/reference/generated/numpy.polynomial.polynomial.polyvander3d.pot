#: ../../../reference/generated/numpy.polynomial.polynomial.polyvander3d.rst:4
msgid "numpy.polynomial.polynomial.polyvander3d"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvander3d:2
msgid "Pseudo-Vandermonde matrix of given degrees."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvander3d:4
msgid ""
"Returns the pseudo-Vandermonde matrix of degrees `deg` and sample points "
"``(x, y, z)``. If `l`, `m`, `n` are the given degrees in `x`, `y`, `z`, then "
"The pseudo-Vandermonde matrix is defined by"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvander3d:8
msgid ""
"V[..., (m+1)(n+1)i + (n+1)j + k] = x^i * y^j * z^k,\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvander3d:10
msgid ""
"where ``0 <= i <= l``, ``0 <= j <= m``, and ``0 <= j <= n``.  The leading "
"indices of `V` index the points ``(x, y, z)`` and the last index encodes the "
"powers of `x`, `y`, and `z`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvander3d:14
msgid ""
"If ``V = polyvander3d(x, y, z, [xdeg, ydeg, zdeg])``, then the columns of "
"`V` correspond to the elements of a 3-D coefficient array `c` of shape (xdeg "
"+ 1, ydeg + 1, zdeg + 1) in the order"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvander3d:18
msgid ""
"c_{000}, c_{001}, c_{002},... , c_{010}, c_{011}, c_{012},...\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvander3d:20
msgid ""
"and  ``np.dot(V, c.flat)`` and ``polyval3d(x, y, z, c)`` will be the same up "
"to roundoff. This equivalence is useful both for least squares fitting and "
"for the evaluation of a large number of 3-D polynomials of the same degrees "
"and sample points."
msgstr ""

