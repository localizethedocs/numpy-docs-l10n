msgid "Subtract one Chebyshev series from another."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/chebyshev.py:docstring
#: of numpy.polynomial.chebyshev.chebsub:4
msgid ""
"Returns the difference of two Chebyshev series `c1` - `c2`.  The sequences "
"of coefficients are from lowest order term to highest, i.e., [1,2,3] "
"represents the series ``T_0 + 2*T_1 + 3*T_2``."
msgstr ""

