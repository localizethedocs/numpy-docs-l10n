msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/extras.py:docstring
#: of numpy.ma.extras.vander:21
msgid ""
"Order of the powers of the columns.  If True, the powers increase from left "
"to right, if False (the default) they are reversed."
msgstr ""

