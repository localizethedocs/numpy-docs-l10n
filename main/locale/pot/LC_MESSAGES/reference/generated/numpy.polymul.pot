#: of numpy.polymul:-1
msgid "ndarray or poly1d object"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.polymul:24
msgid ""
"The polynomial resulting from the multiplication of the inputs. If either "
"inputs is a poly1d object, then the output is also a poly1d object. "
"Otherwise, it is a 1D array of polynomial coefficients from highest to "
"lowest degree."
msgstr ""

