#: ../../../reference/generated/numpy.compress.rst:4
msgid "numpy.compress"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.compress:2
msgid "Return selected slices of an array along given axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.compress:4
msgid ""
"When working along a given axis, a slice along that axis is returned in "
"`output` for each index where `condition` evaluates to True. When working on "
"a 1-D array, `compress` is equivalent to `extract`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.compress:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.compress:13
msgid "**condition**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.compress:-1
msgid "1-D array of bools"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.compress:11
msgid ""
"Array that selects which entries to return. If len(condition) is less than "
"the size of `a` along the given axis, then output is truncated to the length "
"of the condition array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.compress:16
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.compress:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.compress:16
msgid "Array from which to extract a part."
msgstr ""

