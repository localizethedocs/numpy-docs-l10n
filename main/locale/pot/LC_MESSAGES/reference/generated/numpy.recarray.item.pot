msgid "**z**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.item:-1
msgid "Standard Python scalar object"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.item:24
msgid ""
"A copy of the specified element of the array as a suitable Python scalar"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.item:35
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.item:36
msgid ""
"When the data type of `a` is longdouble or clongdouble, item() returns a "
"scalar array object because there is no available Python scalar that would "
"not lose information. Void arrays return a buffer object for item(), unless "
"fields are defined, in which case a tuple is returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.recarray.item:41
msgid ""
"`item` is very similar to a[args], except, instead of an array scalar, a "
"standard Python scalar is returned. This can be useful for speeding up "
"access to elements of the array and doing arithmetic on elements of the "
"array using Python's optimized math."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
