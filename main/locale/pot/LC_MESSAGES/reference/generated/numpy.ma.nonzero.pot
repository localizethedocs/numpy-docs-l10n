#: of numpy.ma.core.nonzero:8
msgid "a[a.nonzero()]"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.nonzero:10
msgid "To group the indices by element, rather than dimension, use instead::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.nonzero:13
msgid "np.transpose(a.nonzero())"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.nonzero:15
