#: of numpy.fft.rfft:11
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfft:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfft:11
msgid "Input array"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfft:17
msgid "**n**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfft:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfft:14
msgid ""
"Number of points along transformation axis in the input to use. If `n` is "
"smaller than the length of the input, the input is cropped. If it is larger, "
"the input is padded with zeros. If `n` is not given, the length of the input "
"along the axis specified by `axis` is used."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfft:21
msgid "**axis**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfft:20
msgid ""
"Axis over which to compute the FFT. If not given, the last axis is used."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfft:30
msgid "**norm**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfft:-1
msgid "{\"backward\", \"ortho\", \"forward\"}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfft:24
msgid ""
"Normalization mode (see `numpy.fft`). Default is \"backward\". Indicates "
"which direction of the forward/backward pair of transforms is scaled and "
"with what normalization factor."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfft:30
msgid "The \"backward\", \"forward\" values were added."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfft:38 numpy.fft.rfft:49
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfft:-1
msgid "complex ndarray, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfft:33
msgid ""
"If provided, the result will be placed in this array. It should be of the "
"appropriate shape and dtype."
msgstr ""

