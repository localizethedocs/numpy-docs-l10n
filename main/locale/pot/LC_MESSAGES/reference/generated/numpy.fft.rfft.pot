#: of numpy.fft.rfft:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfft:-1
msgid "complex ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/fft/__init__.py:docstring
#: of numpy.fft.rfft:43
msgid ""
"The truncated or zero-padded input, transformed along the axis indicated by "
"`axis`, or the last one if `axis` is not specified. If `n` is even, the "
"length of the transformed axis is ``(n/2)+1``. If `n` is odd, the length is "
"``(n+1)/2``."
msgstr ""

