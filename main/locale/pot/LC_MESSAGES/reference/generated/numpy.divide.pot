msgid "numpy.divide"
msgstr ""

#: ../../../../docstring of numpy.divide:2
msgid "Divide arguments element-wise."
msgstr ""

#: ../../../../docstring of numpy.divide:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.divide:8
msgid "**x1**"
msgstr ""

#: ../../../../docstring of numpy.divide:-1
msgid "array_like"
msgstr ""

#: ../../../../docstring of numpy.divide:8
msgid "Dividend array."
msgstr ""

#: ../../../../docstring of numpy.divide:13
msgid "**x2**"
msgstr ""

#: ../../../../docstring of numpy.divide:11
msgid ""
"Divisor array. If ``x1.shape != x2.shape``, they must be broadcastable to a "
"common shape (which becomes the shape of the output)."
msgstr ""

#: ../../../../docstring of numpy.divide:19
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.divide:-1
msgid "ndarray, None, or tuple of ndarray and None, optional"
msgstr ""

#: ../../../../docstring of numpy.divide:16
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or None, a freshly-"
"allocated array is returned. A tuple (possible only as a keyword argument) "
"must have length equal to the number of outputs."
msgstr ""

#: ../../../../docstring of numpy.divide:27
msgid "**where**"
msgstr ""

#: ../../../../docstring of numpy.divide:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../docstring of numpy.divide:22
msgid ""
"This condition is broadcast over the input. At locations where the condition "
"is True, the `out` array will be set to the ufunc result. Elsewhere, the "
"`out` array will retain its original value. Note that if an uninitialized "
"`out` array is created via the default ``out=None``, locations within it "
"where the condition is False will remain uninitialized."
msgstr ""

#: ../../../../docstring of numpy.divide:33
msgid "**\\*\\*kwargs**"
msgstr ""

#: ../../../../docstring of numpy.divide:30
msgid ""
"For other keyword-only arguments, see the :ref:`ufunc docs <ufuncs.kwargs>`."
msgstr ""

#: ../../../../docstring of numpy.divide:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.divide:45
msgid "**y**"
msgstr ""

#: ../../../../docstring of numpy.divide:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.divide:38
msgid ""
"The quotient ``x1/x2``, element-wise. This is a scalar if both `x1` and `x2` "
"are scalars."
msgstr ""

#: ../../../../docstring of numpy.divide:50
msgid ":obj:`seterr`"
msgstr ""

#: ../../../../docstring of numpy.divide:51
msgid ""
"Set whether to raise or warn on overflow, underflow and division by zero."
msgstr ""

#: ../../../../docstring of numpy.divide:55
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.divide:56
msgid "Equivalent to ``x1`` / ``x2`` in terms of array-broadcasting."
msgstr ""

#: ../../../../docstring of numpy.divide:58
msgid ""
"The ``true_divide(x1, x2)`` function is an alias for ``divide(x1, x2)``."
msgstr ""

