#: ../../../reference/generated/numpy.nonzero.rst:4
msgid "numpy.nonzero"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nonzero:2
msgid "Return the indices of the elements that are non-zero."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nonzero:4
msgid ""
"Returns a tuple of arrays, one for each dimension of `a`, containing the "
"indices of the non-zero elements in that dimension. The values in `a` are "
"always tested and returned in row-major, C-style order."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nonzero:9
msgid ""
"To group the indices by element, rather than dimension, use `argwhere`, "
"which returns a row for each non-zero element."
msgstr ""

