#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.assert_almost_equal:2
msgid ""
"Raises an AssertionError if two items are not equal up to desired precision."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.assert_almost_equal:5
msgid ""
"It is recommended to use one of `assert_allclose`, "
"`assert_array_almost_equal_nulp` or `assert_array_max_ulp` instead of this "
"function for more consistent floating point comparisons."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.assert_almost_equal:10
msgid "The test verifies that the elements of `actual` and `desired` satisfy::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.assert_almost_equal:12
msgid "abs(desired-actual) < float64(1.5 * 10**(-decimal))"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/testing/_private/utils.py:docstring
#: of numpy.testing._private.utils.assert_almost_equal:14
msgid ""
"That is a looser test than originally documented, but agrees with what the "
"actual implementation in `assert_array_almost_equal` did up to rounding "
"vagaries. An exception is raised at conflicting values. For ndarrays this "
"delegates to assert_array_almost_equal"
msgstr ""

