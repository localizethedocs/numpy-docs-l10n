#: ../../../reference/generated/numpy.fmin.rst:4
msgid "numpy.fmin"
msgstr ""

#: ../../../../docstring of numpy.fmin:2
msgid "Element-wise minimum of array elements."
msgstr ""

#: ../../../../docstring of numpy.fmin:4
msgid ""
"Compare two arrays and return a new array containing the element-wise "
"minima. If one of the elements being compared is a NaN, then the non-nan "
"element is returned. If both elements are NaNs then the first is returned.  "
"The latter distinction is important for complex NaNs, which are defined as "
"at least one of the real or imaginary parts being a NaN. The net effect is "
"that NaNs are ignored when possible."
msgstr ""

#: ../../../../docstring of numpy.fmin:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.fmin:16
msgid "**x1, x2**"
msgstr ""

#: ../../../../docstring of numpy.fmin:-1
msgid "array_like"
msgstr ""

#: ../../../../docstring of numpy.fmin:14
msgid ""
"The arrays holding the elements to be compared. If ``x1.shape != x2.shape``, "
"they must be broadcastable to a common shape (which becomes the shape of the "
"output)."
msgstr ""

#: ../../../../docstring of numpy.fmin:22
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.fmin:-1
msgid "ndarray, None, or tuple of ndarray and None, optional"
msgstr ""

#: ../../../../docstring of numpy.fmin:19
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or None, a freshly-"
"allocated array is returned. A tuple (possible only as a keyword argument) "
"must have length equal to the number of outputs."
msgstr ""

#: ../../../../docstring of numpy.fmin:30
msgid "**where**"
msgstr ""

#: ../../../../docstring of numpy.fmin:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../docstring of numpy.fmin:25
msgid ""
"This condition is broadcast over the input. At locations where the condition "
"is True, the `out` array will be set to the ufunc result. Elsewhere, the "
"`out` array will retain its original value. Note that if an uninitialized "
"`out` array is created via the default ``out=None``, locations within it "
"where the condition is False will remain uninitialized."
msgstr ""

#: ../../../../docstring of numpy.fmin:36
msgid "**\\*\\*kwargs**"
msgstr ""

#: ../../../../docstring of numpy.fmin:33
msgid ""
"For other keyword-only arguments, see the :ref:`ufunc docs <ufuncs.kwargs>`."
msgstr ""

#: ../../../../docstring of numpy.fmin:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.fmin:48
msgid "**y**"
msgstr ""

#: ../../../../docstring of numpy.fmin:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.fmin:41
msgid ""
"The minimum of `x1` and `x2`, element-wise. This is a scalar if both `x1` "
"and `x2` are scalars."
msgstr ""

#: ../../../../docstring of numpy.fmin:53
msgid ":obj:`fmax`"
msgstr ""

#: ../../../../docstring of numpy.fmin:54
msgid "Element-wise maximum of two arrays, ignores NaNs."
msgstr ""

#: ../../../../docstring of numpy.fmin:55
msgid ":obj:`minimum`"
msgstr ""

#: ../../../../docstring of numpy.fmin:56
msgid "Element-wise minimum of two arrays, propagates NaNs."
msgstr ""

#: ../../../../docstring of numpy.fmin:57
msgid ":obj:`amin`"
msgstr ""

#: ../../../../docstring of numpy.fmin:58
msgid "The minimum value of an array along a given axis, propagates NaNs."
msgstr ""

#: ../../../../docstring of numpy.fmin:59
msgid ":obj:`nanmin`"
msgstr ""

#: ../../../../docstring of numpy.fmin:60
msgid "The minimum value of an array along a given axis, ignores NaNs."
msgstr ""

#: ../../../../docstring of numpy.fmin:61
msgid ":obj:`maximum`, :obj:`amax`, :obj:`nanmax`"
msgstr ""

#: ../../../../docstring of numpy.fmin:65
msgid "Notes"
msgstr ""

#: ../../../../docstring of numpy.fmin:66
msgid ""
"The fmin is equivalent to ``np.where(x1 <= x2, x1, x2)`` when neither x1 nor "
"x2 are NaNs, but it is faster and does proper broadcasting."
msgstr ""

