#: ../../../reference/generated/numpy.nancumsum.rst:4
msgid "numpy.nancumsum"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nancumsum:2
msgid ""
"Return the cumulative sum of array elements over a given axis treating Not a "
"Numbers (NaNs) as zero.  The cumulative sum does not change when NaNs are "
"encountered and leading NaNs are replaced by zeros."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nancumsum:6
msgid "Zeros are returned for slices that are all-NaN or empty."
msgstr ""

