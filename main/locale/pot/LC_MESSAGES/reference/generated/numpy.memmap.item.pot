#: of numpy.memmap.item:2
msgid "Copy an element of an array to a standard Python scalar and return it."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.memmap.item:0
msgid "Parameters"
msgstr ""

