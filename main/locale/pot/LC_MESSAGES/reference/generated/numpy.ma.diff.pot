#: ../../../reference/generated/numpy.ma.diff.rst:4
msgid "numpy.ma.diff"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.diff:2
msgid ""
"Calculate the n-th discrete difference along the given axis. The first "
"difference is given by ``out[i] = a[i+1] - a[i]`` along the given axis, "
"higher differences are calculated by using `diff` recursively. Preserves the "
"input mask."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.diff:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.diff:12
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.diff:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.diff:12
msgid "Input array"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.diff:16
msgid "**n**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.diff:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.diff:15
msgid ""
"The number of times values are differenced. If zero, the input is returned "
"as-is."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.diff:20
msgid "**axis**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.diff:19
msgid "The axis along which the difference is taken, default is the last axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.diff:29
msgid "**prepend, append**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.diff:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.diff:23
msgid ""
"Values to prepend or append to `a` along axis prior to performing the "
"difference.  Scalar values are expanded to arrays with length 1 in the "
"direction of axis and the shape of the input array in along all other axes.  "
"Otherwise the dimension and shape must match `a` except along axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.diff:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.diff:45
msgid "**diff**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.diff:-1
msgid "MaskedArray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.diff:34
msgid ""
"The n-th differences. The shape of the output is the same as `a` except "
"along `axis` where the dimension is smaller by `n`. The type of the output "
"is the same as the type of the difference between any two elements of `a`. "
"This is the same as the type of `a` in most cases. A notable exception is "
"`datetime64`, which results in a `timedelta64` output array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.diff:50
msgid ":obj:`numpy.diff`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.diff:51
msgid "Equivalent function in the top-level NumPy module."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.diff:55
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.diff:56
msgid ""
"Type is preserved for boolean arrays, so the result will contain `False` "
"when consecutive elements are the same and `True` when they differ."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.diff:60
msgid ""
"For unsigned integer arrays, the results will also be unsigned. This should "
"not be surprising, as the result is consistent with calculating the "
"difference directly:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.diff:73
msgid ""
"If this is not desirable, then the array should be cast to a larger integer "
"type first:"
msgstr ""

