#: ../../../reference/generated/numpy.polynomial.legendre.legint.rst:4
msgid "numpy.polynomial.legendre.legint"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legint:2
msgid "Integrate a Legendre series."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legint:4
msgid ""
"Returns the Legendre series coefficients `c` integrated `m` times from "
"`lbnd` along `axis`. At each iteration the resulting series is "
"**multiplied** by `scl` and an integration constant, `k`, is added. The "
"scaling factor is for use in a linear change of variable.  (\"Buyer "
"beware\": note that, depending on what one is doing, one may want `scl` to "
"be the reciprocal of what one might expect; for more information, see the "
"Notes section below.)  The argument `c` is an array of coefficients from low "
"to high degree along each axis, e.g., [1,2,3] represents the series ``L_0 + "
"2*L_1 + 3*L_2`` while [[1,2],[1,2]] represents ``1*L_0(x)*L_0(y) + "
"1*L_1(x)*L_0(y) + 2*L_0(x)*L_1(y) + 2*L_1(x)*L_1(y)`` if axis=0 is ``x`` and "
"axis=1 is ``y``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legint:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legint:21
msgid "**c**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legint:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legint:19
msgid ""
"Array of Legendre series coefficients. If c is multidimensional the "
"different axis correspond to different variables with the degree in each "
"axis given by the corresponding index."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legint:24
msgid "**m**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legint:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legint:24
msgid "Order of integration, must be positive. (Default: 1)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legint:31
msgid "**k**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legint:-1
msgid "{[], list, scalar}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legint:27
msgid ""
"Integration constant(s).  The value of the first integral at ``lbnd`` is the "
"first value in the list, the value of the second integral at ``lbnd`` is the "
"second value, etc.  If ``k == []`` (the default), all constants are set to "
"zero.  If ``m == 1``, a single scalar can be given instead of a list."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legint:34
msgid "**lbnd**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legint:-1
msgid "scalar, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legint:34
msgid "The lower bound of the integral. (Default: 0)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legint:38
msgid "**scl**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legint:37
msgid ""
"Following each integration the result is *multiplied* by `scl` before the "
"integration constant is added. (Default: 1)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legint:43
msgid "**axis**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legint:41
msgid "Axis over which the integral is taken. (Default: 0)."
msgstr ""

