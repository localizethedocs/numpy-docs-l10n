#: ../../../reference/generated/numpy.argsort.rst:4
msgid "numpy.argsort"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:2
msgid "Returns the indices that would sort an array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:4
msgid ""
"Perform an indirect sort along the given axis using the algorithm specified "
"by the `kind` keyword. It returns an array of indices of the same shape as "
"`a` that index data along the given axis in sorted order."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:11
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:11
msgid "Array to sort."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:15
msgid "**axis**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:-1
msgid "int or None, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:14
msgid ""
"Axis along which to sort.  The default is -1 (the last axis). If None, the "
"flattened array is used."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:21
msgid "**kind**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:-1
msgid "{'quicksort', 'mergesort', 'heapsort', 'stable'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:18
msgid ""
"Sorting algorithm. The default is 'quicksort'. Note that both 'stable' and "
"'mergesort' use timsort under the covers and, in general, the actual "
"implementation will vary with data type. The 'mergesort' option is retained "
"for backwards compatibility."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:28
msgid "**order**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:-1
msgid "str or list of str, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:24
msgid ""
"When `a` is an array with fields defined, this argument specifies which "
"fields to compare first, second, etc.  A single field can be specified as a "
"string, and not all fields need be specified, but unspecified fields will "
"still be used, in the order in which they come up in the dtype, to break "
"ties."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:36
msgid "**stable**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:31
msgid ""
"Sort stability. If ``True``, the returned array will maintain the relative "
"order of ``a`` values which compare as equal. If ``False`` or ``None``, this "
"is not guaranteed. Internally, this option selects ``kind='stable'``. "
"Default: ``None``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:46
msgid "**descending**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:39
msgid ""
"Sort order. If ``True``, the returned array will be sorted in descending "
"order. If ``False`` or ``None``, the returned array will be sorted in "
"ascending order. Values that are NaN are sorted to the end for both orders. "
"Default: ``None``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:60
msgid "**index_array**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:-1
msgid "ndarray, int"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:51
msgid ""
"Array of indices that sort `a` along the specified `axis`. If `a` is one-"
"dimensional, ``a[index_array]`` yields a sorted `a`. More generally, ``np."
"take_along_axis(a, index_array, axis=axis)`` always yields the sorted `a`, "
"irrespective of dimensionality."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:65
msgid ":obj:`sort`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:66
msgid "Describes sorting algorithms used."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:67
msgid ":obj:`lexsort`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:68
msgid "Indirect stable sort with multiple keys."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:69
msgid ":obj:`ndarray.sort`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:70
msgid "Inplace sort."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:71
msgid ":obj:`argpartition`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:72
msgid "Indirect partial sort."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:73
msgid ":obj:`take_along_axis`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:74
msgid "Apply ``index_array`` from argsort to an array as if by calling sort."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:78
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:79
msgid "See `sort` for notes on the different sorting algorithms."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argsort:81
msgid ""
"As of NumPy 1.4.0 `argsort` works with real/complex arrays containing nan "
"values. The enhanced sort order is documented in `sort`."
msgstr ""

