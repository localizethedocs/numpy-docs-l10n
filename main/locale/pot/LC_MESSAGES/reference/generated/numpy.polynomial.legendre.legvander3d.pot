#: of numpy.polynomial.legendre.legvander3d:49
msgid "**vander3d**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legvander3d:-1
msgid "ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/legendre.py:docstring
#: of numpy.polynomial.legendre.legvander3d:41
msgid ""
"The shape of the returned matrix is ``x.shape + (order,)``, where :math:"
"`order = (deg[0]+1)*(deg[1]+1)*(deg[2]+1)`.  The dtype will be the same as "
"the converted `x`, `y`, and `z`."
msgstr ""

