msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.poly:58
msgid ""
"Specifying the roots of a polynomial still leaves one degree of freedom, "
"typically represented by an undetermined leading coefficient. "
"[R6c2ffae921d1-1]_ In the case of this function, that coefficient - the "
"first one in the returned array - is always taken as one. (If for some "
"reason you have one other point, the only automatic way presently to "
"leverage that information is to use ``polyfit``.)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.poly:65
msgid ""
"The characteristic polynomial, :math:`p_a(t)`, of an `n`-by-`n` matrix **A** "
"is given by"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.poly:68
msgid ":math:`p_a(t) = \\mathrm{det}(t\\, \\mathbf{I} - \\mathbf{A})`,"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.poly:70
msgid "where **I** is the `n`-by-`n` identity matrix. [R6c2ffae921d1-2]_"
msgstr ""

