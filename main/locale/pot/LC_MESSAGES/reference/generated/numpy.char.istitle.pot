#: ../../../reference/generated/numpy.char.istitle.rst:4
msgid "numpy.char.istitle"
msgstr ""

#: ../../../../docstring of numpy.strings.istitle:2
msgid ""
"Returns true for each element if the element is a titlecased string and "
"there is at least one character, false otherwise."
msgstr ""

#: ../../../../docstring of numpy.strings.istitle:0
msgid "Parameters"
msgstr ""

