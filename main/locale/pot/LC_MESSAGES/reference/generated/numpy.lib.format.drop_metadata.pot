#: ../../../reference/generated/numpy.lib.format.drop_metadata.rst:4
msgid "numpy.lib.format.drop\\_metadata"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.drop_metadata:2
msgid ""
"Returns the dtype unchanged if it contained no metadata or a copy of the "
"dtype if it (or any of its structure dtypes) contained metadata."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.drop_metadata:5
msgid ""
"This utility is used by `np.save` and `np.savez` to drop metadata before "
"saving."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.drop_metadata:10
msgid ""
"Due to its limitation this function may move to a more appropriate home or "
"change in the future and is considered semi-public API only."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/format.py:docstring
#: of numpy.lib.format.drop_metadata:15
msgid ""
"This function does not preserve more strange things like record dtypes and "
"user dtypes may simply return the wrong thing.  If you need to be sure about "
"the latter, check the result with: ``np.can_cast(new_dtype, dtype, "
"casting=\"no\")``."
msgstr ""
