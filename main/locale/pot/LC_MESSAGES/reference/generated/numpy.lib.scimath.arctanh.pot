#: ../../../reference/generated/numpy.lib.scimath.arctanh.rst:4
msgid "numpy.lib.scimath.arctanh"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arctanh:2
msgid "Compute the inverse hyperbolic tangent of `x`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arctanh:4
msgid ""
"Return the \"principal value\" (for a description of this, see `numpy."
"arctanh`) of ``arctanh(x)``. For real `x` such that ``abs(x) < 1``, this is "
"a real number.  If `abs(x) > 1`, or if `x` is complex, the result is "
"complex. Finally, `x = 1` returns``inf`` and ``x=-1`` returns ``-inf``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arctanh:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arctanh:15
msgid "**x**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arctanh:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arctanh:13
msgid "The value(s) whose arctanh is (are) required."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arctanh:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arctanh:27
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arctanh:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arctanh:20
msgid ""
"The inverse hyperbolic tangent(s) of the `x` value(s). If `x` was a scalar "
"so is `out`, otherwise an array is returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arctanh:32
msgid ":obj:`numpy.arctanh`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arctanh:36
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.arctanh:37
msgid ""
"For an arctanh() that returns ``NAN`` when real `x` is not in the interval "
"``(-1,1)``, use `numpy.arctanh` (this latter, however, does return +/-inf "
"for ``x = +/-1``)."
msgstr ""

