msgid "numpy.not\\_equal"
msgstr ""

#: ../../../../docstring of numpy.not_equal:2
msgid "Return (x1 != x2) element-wise."
msgstr ""

#: ../../../../docstring of numpy.not_equal:0
msgid "Parameters"
msgstr ""

#: ../../../../docstring of numpy.not_equal:10
msgid "**x1, x2**"
msgstr ""

#: ../../../../docstring of numpy.not_equal:-1
msgid "array_like"
msgstr ""

#: ../../../../docstring of numpy.not_equal:8
msgid ""
"Input arrays. If ``x1.shape != x2.shape``, they must be broadcastable to a "
"common shape (which becomes the shape of the output)."
msgstr ""

#: ../../../../docstring of numpy.not_equal:16 numpy.not_equal:43
msgid "**out**"
msgstr ""

#: ../../../../docstring of numpy.not_equal:-1
msgid "ndarray, None, or tuple of ndarray and None, optional"
msgstr ""

#: ../../../../docstring of numpy.not_equal:13
msgid ""
"A location into which the result is stored. If provided, it must have a "
"shape that the inputs broadcast to. If not provided or None, a freshly-"
"allocated array is returned. A tuple (possible only as a keyword argument) "
"must have length equal to the number of outputs."
msgstr ""

#: ../../../../docstring of numpy.not_equal:24
msgid "**where**"
msgstr ""

#: ../../../../docstring of numpy.not_equal:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../docstring of numpy.not_equal:19
msgid ""
"This condition is broadcast over the input. At locations where the condition "
"is True, the `out` array will be set to the ufunc result. Elsewhere, the "
"`out` array will retain its original value. Note that if an uninitialized "
"`out` array is created via the default ``out=None``, locations within it "
"where the condition is False will remain uninitialized."
msgstr ""

#: ../../../../docstring of numpy.not_equal:30
msgid "**\\*\\*kwargs**"
msgstr ""

#: ../../../../docstring of numpy.not_equal:27
msgid ""
"For other keyword-only arguments, see the :ref:`ufunc docs <ufuncs.kwargs>`."
msgstr ""

#: ../../../../docstring of numpy.not_equal:0
msgid "Returns"
msgstr ""

#: ../../../../docstring of numpy.not_equal:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../docstring of numpy.not_equal:35
msgid ""
"Output array, element-wise comparison of `x1` and `x2`. Typically of type "
"bool, unless ``dtype=np.object_`` is passed. This is a scalar if both `x1` "
"and `x2` are scalars."
msgstr ""

#: ../../../../docstring of numpy.not_equal:48
msgid ""
":obj:`equal`, :obj:`greater`, :obj:`greater_equal`, :obj:`less`, :obj:"
"`less_equal`"
msgstr ""

#: ../../../../docstring of numpy.not_equal:54
msgid "Examples"
msgstr ""

#: ../../../../docstring of numpy.not_equal:66
msgid ""
"The ``!=`` operator can be used as a shorthand for ``np.not_equal`` on "
"ndarrays."
msgstr ""

