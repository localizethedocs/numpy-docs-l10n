msgid "Replaces specified elements of an array with given values."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.put:4
msgid ""
"The indexing works on the flattened target array. `put` is roughly "
"equivalent to:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.put:9
msgid "a.flat[ind] = v"
msgstr ""

