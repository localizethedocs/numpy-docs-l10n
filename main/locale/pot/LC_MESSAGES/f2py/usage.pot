#: ../../../f2py/usage.rst:265
msgid "Building with Meson (Examples)"
msgstr ""

#: ../../../f2py/usage.rst:268
msgid "Using f2py with Meson"
msgstr ""

#: ../../../f2py/usage.rst:270
msgid ""
"Meson is a modern build system recommended for building Python extension "
"modules, especially starting with Python 3.12 and NumPy 2.x. Meson provides "
"a robust and maintainable way to build Fortran extensions with f2py."
msgstr ""

#: ../../../f2py/usage.rst:274
msgid ""
"To build a Fortran extension using f2py and Meson, you can use Meson's "
"``custom_target`` to invoke f2py and generate the extension module. The "
"following minimal example demonstrates how to do this:"
msgstr ""

#: ../../../f2py/usage.rst:278
msgid ""
"This example shows how to build the ``add`` extension from the ``add.f`` and "
"``add.pyf`` files described in the :ref:`f2py-examples` (note that you do "
"not always need a ``.pyf`` file: in many cases ``f2py`` can figure out the "
"annotations by itself)."
msgstr ""

#: ../../../f2py/usage.rst:282
msgid "Project layout::"
msgstr ""

#: ../../../f2py/usage.rst:284
msgid ""
"f2py_examples/\n"
"  meson.build\n"
"  add.f\n"
"  add.pyf (optional)\n"
"  __init__.py  (can be empty)"
msgstr ""

#: ../../../f2py/usage.rst:290
msgid "Example ``meson.build``:"
msgstr ""

#: ../../../f2py/usage.rst:292
msgid ""
"project('f2py_examples', 'fortran')\n"
"\n"
"py = import('python').find_installation()\n"
"\n"
"# List your Fortran source files\n"
"sources = files('add.pyf', 'add.f')\n"
"\n"
"# Build the extension by invoking f2py via a custom target\n"
"add_mod = custom_target(\n"
"  'add_extension',\n"
"  input: sources,\n"
"  output: ['add' + py.extension_suffix()],\n"
"  command: [\n"
"    py.full_path(), '-m', 'numpy.f2py',\n"
"    '-c', 'add.pyf', 'add.f',\n"
"    '-m', 'add'\n"
"  ],\n"
"  build_by_default: true\n"
")\n"
"\n"
"# Install into site-packages under the f2py_examples package\n"
"install_subdir('.', install_dir: join_paths(py.site_packages_dir(), "
"'f2py_examples'),\n"
"               strip_directory: false,\n"
"               exclude_files: ['meson.build'])\n"
"\n"
"# Also install the built extension (place it beside __init__.py)\n"
"install_data(add_mod, install_dir: join_paths(py.site_packages_dir(), "
"'f2py_examples'))"
msgstr ""

#: ../../../f2py/usage.rst:322
msgid ""
"For more details and advanced usage, see the Meson build guide in the user "
"documentation or refer to SciPy's Meson build files for real-world examples: "
"https://github.com/scipy/scipy/tree/main/meson.build"
msgstr ""
