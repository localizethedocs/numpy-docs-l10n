#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.asarray:2
msgid "Convert the input to a masked array of the given data-type."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.asarray:4
msgid ""
"No copy is performed if the input is already an `ndarray`. If `a` is a "
"subclass of `MaskedArray`, a base class `MaskedArray` is returned."
msgstr ""

