#: of numpy.array2string:32
msgid ""
"The length of the prefix and suffix strings are used to respectively align "
"and wrap the output. An array is typically printed as::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array2string:35
