msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array2string:37
msgid ""
"The output is left-padded by the length of the prefix string, and wrapping "
"is forced at the column ``max_line_width - len(suffix)``. It should be noted "
"that the content of prefix and suffix strings are not included in the output."
msgstr ""

