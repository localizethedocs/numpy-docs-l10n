msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array2string:87
msgid "**sign**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array2string:-1
msgid "string, either '-', '+', or ' ', optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array2string:79
msgid ""
"Controls printing of the sign of floating-point types. If '+', always print "
"the sign of positive values. If ' ', always prints a space (whitespace "
"character) in the sign position of positive values.  If '-', omit the sign "
"character of positive values. Defaults to ``numpy.get_printoptions()"
"['sign']``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array2string:85
msgid ""
"The sign parameter can now be an integer type, previously types were "
"floating-point types."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array2string:108
msgid "**floatmode**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array2string:90
msgid ""
"Controls the interpretation of the `precision` option for floating-point "
"types. Defaults to ``numpy.get_printoptions()['floatmode']``. Can take the "
"following values:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array2string:95
msgid ""
"'fixed': Always print exactly `precision` fractional digits, even if this "
"would print more or fewer digits than necessary to specify the value "
"uniquely."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array2string:98
msgid ""
"'unique': Print the minimum number of fractional digits necessary to "
"represent each value uniquely. Different elements may have a different "
"number of digits.  The value of the `precision` option is ignored."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array2string:102
msgid ""
"'maxprec': Print at most `precision` fractional digits, but if an element "
"can be uniquely represented with fewer digits only print it with that many."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array2string:105
msgid ""
"'maxprec_equal': Print at most `precision` fractional digits, but if every "
"element in the array can be uniquely represented with an equal number of "
"fewer digits, use that many digits for all elements."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array2string:117
msgid "**legacy** : string or `False`, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array2string:-1
msgid "string or"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.array2string:111
msgid ""
"If set to the string ``'1.13'`` enables 1.13 legacy printing mode. This "
"approximates numpy 1.13 print output by including a space in the sign "
"position of floats and different behavior for 0d arrays. If set to `False`, "
"disables legacy mode. Unrecognized strings will be ignored with a warning "
"for forward compatibility."
msgstr ""

