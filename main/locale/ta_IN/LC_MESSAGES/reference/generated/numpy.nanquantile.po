#: ../../../reference/generated/numpy.nanquantile.rst:4
msgid "numpy.nanquantile"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:2
msgid ""
"Compute the qth quantile of the data along the specified axis, while "
"ignoring nan values. Returns the qth quantile(s) of the array elements."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:11
msgid "**a**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:10
msgid ""
"Input array or object that can be converted to an array, containing nan "
"values to be ignored"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:15
msgid "**q**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:-1
msgid "array_like of float"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:14
msgid ""
"Probability or sequence of probabilities for the quantiles to compute. "
"Values must be between 0 and 1 inclusive."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:20
msgid "**axis**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:-1
msgid "{int, tuple of int, None}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:18
msgid ""
"Axis or axes along which the quantiles are computed. The default is to "
"compute the quantile(s) along a flattened version of the array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:25
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:-1
msgid "ndarray, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:23
msgid ""
"Alternative output array in which to place the result. It must have the same "
"shape and buffer length as the expected output, but the type (of the output) "
"will be cast if necessary."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:30
msgid "**overwrite_input**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:28
msgid ""
"If True, then allow the input array `a` to be modified by intermediate "
"calculations, to save memory. In this case, the contents of the input `a` "
"after this function completes is undefined."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:58
msgid "**method**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:-1
msgid "str, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:33
msgid ""
"This parameter specifies the method to use for estimating the quantile.  "
"There are many different methods, some unique to NumPy. See the notes for "
"explanation.  The options sorted by their R type as summarized in the H&F "
"paper [R02de30f409d2-1]_ are:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:38
msgid "'inverted_cdf'"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:39
msgid "'averaged_inverted_cdf'"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:40
msgid "'closest_observation'"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:41
msgid "'interpolated_inverted_cdf'"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:42
msgid "'hazen'"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:43
msgid "'weibull'"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:44
msgid "'linear'  (default)"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:45
msgid "'median_unbiased'"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:46
msgid "'normal_unbiased'"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:48
msgid ""
"The first three methods are discontinuous.  NumPy further defines the "
"following discontinuous variations of the default 'linear' (7.) option:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:51
msgid "'lower'"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:52
msgid "'higher',"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:53
msgid "'midpoint'"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:54
msgid "'nearest'"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:56
msgid ""
"This argument was previously called \"interpolation\" and only offered the "
"\"linear\" default and last four options."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:69
msgid "**keepdims**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:61
msgid ""
"If this is set to True, the axes which are reduced are left in the result as "
"dimensions with size one. With this option, the result will broadcast "
"correctly against the original array `a`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:65
msgid ""
"If this is anything but the default value it will be passed through (in the "
"special case of an empty array) to the `mean` function of the underlying "
"array.  If the array is a sub-class and `mean` does not have the kwarg "
"`keepdims` this will raise a RuntimeError."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:82
msgid "**weights**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:-1
msgid "array_like, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:72
msgid ""
"An array of weights associated with the values in `a`. Each value in `a` "
"contributes to the quantile according to its associated weight. The weights "
"array can either be 1-D (in which case its length must be the size of `a` "
"along the given axis) or of the same shape as `a`. If `weights=None`, then "
"all data in `a` are assumed to have a weight equal to one. Only "
"`method=\"inverted_cdf\"` supports weights."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:100
msgid "**quantile**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:-1
msgid "scalar or ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:87
msgid ""
"If `q` is a single probability and `axis=None`, then the result is a scalar. "
"If multiple probability levels are given, first axis of the result "
"corresponds to the quantiles. The other axes are the axes that remain after "
"the reduction of `a`. If the input contains integers or floats smaller than "
"``float64``, the output data-type is ``float64``. Otherwise, the output data-"
"type is the same as that of the input. If `out` is specified, that array is "
"returned instead."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:105
msgid ":obj:`quantile`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:107
msgid ":obj:`nanmean`, :obj:`nanmedian`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:109
msgid ":obj:`nanmedian`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:110
msgid "equivalent to ``nanquantile(..., 0.5)``"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:111
msgid ":obj:`nanpercentile`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:112
msgid "same as nanquantile, but with q in the range [0, 100]."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:116
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nanquantile:117
msgid ""
"The behavior of `numpy.nanquantile` is the same as that of `numpy.quantile` "
"(ignoring nan values). For more information, please see `numpy.quantile`."
msgstr ""

