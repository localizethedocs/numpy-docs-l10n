msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/laguerre.py:docstring
#: of numpy.polynomial.laguerre.laggauss:4
msgid ""
"Computes the sample points and weights for Gauss-Laguerre quadrature. These "
"sample points and weights will correctly integrate polynomials of degree :"
"math:`2*deg - 1` or less over the interval :math:`[0, \\inf]` with the "
"weight function :math:`f(x) = \\exp(-x)`."
msgstr ""

