#: of numpy.ma.core.MaskedArray.partition:26
msgid ""
"Axis along which to sort. Default is -1, which means sort along the last "
"axis."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.partition:32
msgid "**kind**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.partition:-1
msgid "{'introselect'}, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.partition:30
msgid ""
"NumPy currently offers only one selection algorithm, 'introselect', and this "
"parameter provides no additional functionality. Default is ``None``."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.partition:39
msgid "**order**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.partition:-1
msgid "str or list of str, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.partition:35
msgid ""
"When `a` is an array with fields defined, this argument specifies which "
"fields to compare first, second, etc. A single field can be specified as a "
"string, and not all fields need to be specified, but unspecified fields will "
"still be used, in the order in which they come up in the dtype, to break "
"ties."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.partition:56
msgid "**descending**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.partition:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/ma/core.py:docstring
#: of numpy.ma.core.MaskedArray.partition:42
msgid ""
"Sort order. If ``True``, the array will be partitioned in descending order. "
"If ``False`` or ``None``, the array will be partitioned in ascending order. "
"Values that are NaN are partitioned towards the end of the array regardless "
"of order. Default: ``None``."
msgstr ""

