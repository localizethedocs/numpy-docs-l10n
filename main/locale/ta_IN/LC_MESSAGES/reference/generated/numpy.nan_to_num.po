msgid "Input data."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nan_to_num:27
msgid "**copy**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nan_to_num:-1
msgid "bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nan_to_num:24
msgid ""
"Whether to create a copy of `x` (True) or to replace values in-place "
"(False). The in-place operation only occurs if casting to an array does not "
"require a copy. Default is True."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nan_to_num:31
msgid "**nan**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nan_to_num:-1
msgid "int, float, or bool or array_like of int, float, or bool, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nan_to_num:30
msgid ""
"Values to be used to fill NaN values. If no values are passed then NaN "
"values will be replaced with 0.0."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nan_to_num:36
msgid "**posinf**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nan_to_num:34
msgid ""
"Values to be used to fill positive infinity values. If no values are passed "
"then positive infinity values will be replaced with a very large number."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nan_to_num:43
msgid "**neginf**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.nan_to_num:39
msgid ""
"Values to be used to fill negative infinity values. If no values are passed "
"then negative infinity values will be replaced with a very small (or "
"negative) number."
msgstr ""

