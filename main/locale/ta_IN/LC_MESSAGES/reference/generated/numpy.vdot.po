#: ../../../reference/generated/numpy.vdot.rst:4
msgid "numpy.vdot"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.vdot:2
msgid "Return the dot product of two vectors."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.vdot:4
msgid ""
"The `vdot` function handles complex numbers differently than `dot`: if the "
"first argument is complex, it is replaced by its complex conjugate in the "
"dot product calculation. `vdot` also handles multidimensional arrays "
"differently than `dot`: it does not perform a matrix product, but flattens "
"the arguments to 1-D arrays before taking a vector dot product."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.vdot:10
msgid ""
"Consequently, when the arguments are 2-D arrays of the same shape, this "
"function effectively returns their `Frobenius inner product <https://en."
"wikipedia.org/wiki/Frobenius_inner_product>`_ (also known as the *trace "
"inner product* or the *standard inner product* on a vector space of "
"matrices)."
msgstr ""

