msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.roll:20
msgid ""
"Axis or axes along which elements are shifted.  By default, the array is "
"flattened before shifting, after which the original shape is restored."
msgstr ""

