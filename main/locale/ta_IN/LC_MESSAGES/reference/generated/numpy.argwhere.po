#: of numpy.argwhere:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argwhere:8
msgid "Input data."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argwhere:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argwhere:23
msgid "**index_array**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argwhere:-1
msgid "(N, a.ndim) ndarray"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argwhere:15
msgid ""
"Indices of elements that are non-zero. Indices are grouped by element. This "
"array will have shape ``(N, a.ndim)`` where ``N`` is the number of non-zero "
"items."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argwhere:28
msgid ":obj:`where`, :obj:`nonzero`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argwhere:32
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argwhere:33
msgid ""
"``np.argwhere(a)`` is almost the same as ``np.transpose(np.nonzero(a))``, "
"but produces a result of the correct shape for a 0D array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.argwhere:36
msgid ""
"The output of ``argwhere`` is not suitable for indexing arrays. For this "
"purpose use ``nonzero(a)`` instead."
msgstr ""

