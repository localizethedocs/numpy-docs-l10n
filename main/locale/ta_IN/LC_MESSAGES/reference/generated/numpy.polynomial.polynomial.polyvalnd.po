#: ../../../reference/generated/numpy.polynomial.polynomial.polyvalnd.rst:4
msgid "numpy.polynomial.polynomial.polyvalnd"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalnd:2
msgid "Evaluate an N-D polynomial at points."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalnd:4
msgid "This function returns the values:"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalnd:6
msgid ""
"p(pts, c) = \\sum_{i_1, i_2, \\dots, i_n}\n"
"c_{i_1, i_2, \\dots, i_n} * x_1^{i_1} * x_2^{i_2} \\dots x_n^{i_n}\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalnd:10
msgid ""
"where :math:`x_1, x_2, \\dots, x_n = pts`. Note that `pts` may also be an "
"`(n, m)` array."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalnd:13
msgid ""
"The parameters in `pts` are converted to arrays only if they are tuples or "
"lists, otherwise they are treated as scalars and they must have the same "
"shape after conversion. In either case, either the elements of `pts` or "
"their elements must support multiplication and addition both with themselves "
"and with the elements of `c`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalnd:19
msgid ""
"If `c` has fewer than N dimensions, ones are implicitly appended to its "
"shape to make it N-D. The shape of the result will be c.shape[N:] + pts[0]."
"shape."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalnd:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalnd:30
msgid "**pts**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalnd:-1
msgid "tuple or list of array_like, compatible objects"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalnd:26
msgid ""
"The N-dimensional series is evaluated at the points ``(x_1, x_2, ..., x_n)`` "
"provided in the `pts` iterable, where all elements must have the same shape. "
"If any element is a list or tuple, it is first converted to an ndarray, "
"otherwise it is left unchanged and if it isn't an ndarray it is treated as a "
"scalar."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalnd:38
msgid "**c**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalnd:-1
msgid "array_like"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalnd:33
msgid ""
"Array of coefficients ordered so that the coefficient of the term of multi-"
"degree i,j,k,... is contained in ``c[i,j,k,...]``. If `c` has dimension "
"greater than N, the remaining indices enumerate multiple sets of "
"coefficients."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalnd:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalnd:50
msgid "**values**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalnd:-1
msgid "ndarray, compatible object"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalnd:43
msgid ""
"The values of the multidimensional polynomial on points formed with N-tuples "
"of corresponding values from `pts`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyvalnd:55
msgid ":obj:`polyval`, :obj:`polyval2d`, :obj:`polyval3d`"
