#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.flipud:2
msgid "Reverse the order of elements along axis 0 (up/down)."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.flipud:4
msgid ""
"For a 2-D array, this flips the entries in each column in the up/down "
"direction. Rows are preserved, but appear in a different order than before."
msgstr ""

