#: ../../../reference/generated/numpy.get_include.rst:4
msgid "numpy.get\\_include"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.get_include:2
msgid "Return the directory that contains the NumPy \\*.h header files."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.get_include:4
msgid ""
"Extension modules that need to compile against NumPy may need to use this "
"function to locate the appropriate include directory."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.get_include:19
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.get_include:20
msgid "When using ``setuptools``, for example in ``setup.py``::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.get_include:22
msgid ""
"import numpy as np\n"
"...\n"
"Extension('extension_name', ...\n"
"          include_dirs=[np.get_include()])\n"
"..."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.get_include:28
msgid ""
"Note that a CLI tool ``numpy-config`` was introduced in NumPy 2.0, using "
"that is likely preferred for build systems other than ``setuptools``::"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.get_include:31
msgid ""
"$ numpy-config --cflags\n"
"-I/path/to/site-packages/numpy/_core/include\n"
"\n"
"# Or rely on pkg-config:\n"
"$ export PKG_CONFIG_PATH=$(numpy-config --pkgconfigdir)\n"
"$ pkg-config --cflags\n"
"-I/path/to/site-packages/numpy/_core/include"
msgstr ""

