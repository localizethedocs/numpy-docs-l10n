#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfromroots:57
msgid ""
"The coefficients are determined by multiplying together linear factors of "
"the form ``(x - r_i)``, i.e."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfromroots:60
msgid ""
"p(x) = (x - r_0) (x - r_1) ... (x - r_n)\n"
"\n"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/polynomial/polynomial.py:docstring
#: of numpy.polynomial.polynomial.polyfromroots:62
msgid ""
"where ``n == len(roots) - 1``; note that this implies that ``1`` is always "
"returned for :math:`a_n`."
