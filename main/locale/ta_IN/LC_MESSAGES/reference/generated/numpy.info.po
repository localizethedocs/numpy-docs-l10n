#: ../../../reference/generated/numpy.info.rst:4
msgid "numpy.info"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.info:2
msgid "Get help information for an array, function, class, or module."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.info:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.info:12
msgid "**object**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.info:-1
msgid "object or str, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.info:8
msgid ""
"Input object or name to get information about. If `object` is an `ndarray` "
"instance, information about the array is printed. If `object` is a numpy "
"object, its docstring is given. If it is a string, available modules are "
"searched for matching objects. If None, information about `info` itself is "
"returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.info:15
msgid "**maxwidth**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.info:-1
msgid "int, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.info:15
msgid "Printing width."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.info:20
msgid "**output**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.info:-1
msgid "file like object, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.info:18
msgid ""
"File like object that the output is written to, default is ``None``, in "
"which case ``sys.stdout`` will be used. The object has to be opened in 'w' "
"or 'a' mode."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.info:33
msgid "**toplevel**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.info:-1
msgid "str, optional"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.info:23
msgid "Start search at this level."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.info:36
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.info:37
msgid ""
"When used interactively with an object, ``np.info(obj)`` is equivalent to "
"``help(obj)`` on the Python prompt or ``obj?`` on the IPython prompt."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.info:43
msgid "Examples"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.info:53
msgid ""
"When using a string for `object` it is possible to get multiple results."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/__init__.py:docstring
#: of numpy.info:65
msgid "When the argument is an array, information about the array is printed."
msgstr ""

