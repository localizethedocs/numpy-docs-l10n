#: ../../../reference/generated/numpy.emath.log10.rst:4
msgid "numpy.emath.log10"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log10:2
msgid "Compute the logarithm base 10 of `x`."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log10:4
msgid ""
"Return the \"principal value\" (for a description of this, see `numpy."
"log10`) of :math:`log_{10}(x)`. For real `x > 0`, this is a real number "
"(``log10(0)`` returns ``-inf`` and ``log10(np.inf)`` returns ``inf``). "
"Otherwise, the complex principle value is returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log10:0
msgid "Parameters"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log10:14
msgid "**x**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log10:-1
msgid "array_like or scalar"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log10:12
msgid "The value(s) whose log base 10 is (are) required."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log10:0
msgid "Returns"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log10:26
msgid "**out**"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log10:-1
msgid "ndarray or scalar"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log10:19
msgid ""
"The log base 10 of the `x` value(s). If `x` was a scalar, so is `out`, "
"otherwise an array object is returned."
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log10:31
msgid ":obj:`numpy.log10`"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log10:35
msgid "Notes"
msgstr ""

#: ../../../../../../../.conda/lib/python3.13/site-packages/numpy/lib/scimath.py:docstring
#: of numpy.lib.scimath.log10:36
msgid ""
"For a log10() that returns ``NAN`` when real `x < 0`, use `numpy.log10` "
"(note, however, that otherwise `numpy.log10` and this `log10` are identical, "
"i.e., both return ``-inf`` for `x = 0`, ``inf`` for `x = inf`, and, notably, "
"the complex principle value if ``x.imag != 0``)."
msgstr ""

