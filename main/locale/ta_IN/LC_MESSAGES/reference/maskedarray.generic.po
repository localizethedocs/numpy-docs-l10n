msgid "As an illustration, let's consider the following dataset:"
msgstr ""

#: ../../../reference/maskedarray.generic.rst:46
msgid ""
"We wish to mark the fourth entry as invalid. The easiest is to create a "
"masked array::"
msgstr ""

#: ../../../reference/maskedarray.generic.rst:49
msgid ">>> mx = ma.masked_array(x, mask=[0, 0, 0, 1, 0])"
msgstr ""

#: ../../../reference/maskedarray.generic.rst:51
msgid ""
