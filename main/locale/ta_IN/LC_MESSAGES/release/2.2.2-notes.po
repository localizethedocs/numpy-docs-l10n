#: ../../../release/2.2.2-notes.rst:33
msgid ""
"`#28050 <https://github.com/numpy/numpy/pull/28050>`__: MAINT: Prepare 2.2.x "
"for further development"
msgstr ""

#: ../../../release/2.2.2-notes.rst:34
msgid ""
"`#28055 <https://github.com/numpy/numpy/pull/28055>`__: TYP: fix ``void`` "
"arrays not accepting ``str`` keys in ``__setitem__``"
msgstr ""

#: ../../../release/2.2.2-notes.rst:35
msgid ""
"`#28066 <https://github.com/numpy/numpy/pull/28066>`__: TYP: fix "
"unnecessarily broad ``integer`` binop return types (#28065)"
msgstr ""

#: ../../../release/2.2.2-notes.rst:36
msgid ""
"`#28112 <https://github.com/numpy/numpy/pull/28112>`__: TYP: Better "
"``ndarray`` binop return types for ``float64`` &..."
msgstr ""

#: ../../../release/2.2.2-notes.rst:37
msgid ""
"`#28113 <https://github.com/numpy/numpy/pull/28113>`__: TYP: Return the "
"correct ``bool`` from ``issubdtype``"
msgstr ""

#: ../../../release/2.2.2-notes.rst:38
msgid ""
"`#28114 <https://github.com/numpy/numpy/pull/28114>`__: TYP: Always accept "
"``date[time]`` in the ``datetime64`` constructor"
msgstr ""

#: ../../../release/2.2.2-notes.rst:39
msgid ""
"`#28120 <https://github.com/numpy/numpy/pull/28120>`__: BUG: Fix auxdata "
"initialization in ufunc slow path"
msgstr ""

#: ../../../release/2.2.2-notes.rst:40
msgid ""
"`#28131 <https://github.com/numpy/numpy/pull/28131>`__: BUG: move reduction "
"initialization to ufunc initialization"
msgstr ""

#: ../../../release/2.2.2-notes.rst:41
msgid ""
"`#28132 <https://github.com/numpy/numpy/pull/28132>`__: TYP: Fix ``interp`` "
"to accept and return scalars"
msgstr ""

#: ../../../release/2.2.2-notes.rst:42
msgid ""
"`#28137 <https://github.com/numpy/numpy/pull/28137>`__: BUG: call "
"PyType_Ready in f2py to avoid data races"
msgstr ""

#: ../../../release/2.2.2-notes.rst:43
msgid ""
"`#28145 <https://github.com/numpy/numpy/pull/28145>`__: BUG: remove "
"unnecessary call to PyArray_UpdateFlags"
msgstr ""

#: ../../../release/2.2.2-notes.rst:44
msgid ""
"`#28160 <https://github.com/numpy/numpy/pull/28160>`__: BUG: Avoid data race "
"in PyArray_CheckFromAny_int"
msgstr ""

#: ../../../release/2.2.2-notes.rst:45
msgid ""
"`#28175 <https://github.com/numpy/numpy/pull/28175>`__: BUG: Fix f2py "
"directives and --lower casing"
msgstr ""

#: ../../../release/2.2.2-notes.rst:46
msgid ""
"`#28176 <https://github.com/numpy/numpy/pull/28176>`__: TYP: Fix overlapping "
"overloads issue in 2->1 ufuncs"
msgstr ""

#: ../../../release/2.2.2-notes.rst:47
msgid ""
"`#28177 <https://github.com/numpy/numpy/pull/28177>`__: TYP: preserve shape-"
"type in ndarray.astype()"
msgstr ""

#: ../../../release/2.2.2-notes.rst:48
msgid ""
"`#28178 <https://github.com/numpy/numpy/pull/28178>`__: TYP: Fix missing and "
"spurious top-level exports"
msgstr ""
